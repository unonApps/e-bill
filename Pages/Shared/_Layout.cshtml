<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TAB System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TAB.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
    <!-- Top Navigation -->
    <header class="top-header">
        <div class="header-content">
            <button id="sidebarToggle" class="mobile-menu-btn d-md-none">
                <i class="bi bi-list"></i>
            </button>
            <div class="header-left">
                <img src="~/images/unlogo.png" alt="UN Logo" class="un-logo" />
                <div class="header-text d-none d-md-block">
                    <h1>UNITED NATIONS</h1>
                    <h2>OFFICE NAIROBI</h2>
                    <p>UN HEADQUARTERS IN AFRICA</p>
                </div>
            </div>
            <div class="header-center d-none d-md-block">
                <h2 class="app-title">E-Billing</h2>
            </div>
            <div class="header-right">
                <partial name="_LoginPartial" />
            </div>
        </div>
    </header>

    <div class="wrapper">
        <!-- Mobile sidebar overlay -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>
        
        <!-- Sidebar -->
        <nav id="sidebar">
            <!-- Home Button -->
            <ul class="list-unstyled menu-sections mt-1">
                <li>
                    <a asp-page="/Index" class="menu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Index" ? "active" : "")">
                        <i class="menu-icon bi bi-house-door"></i>
                        <span>Home</span>
                    </a>
                </li>
            </ul>

            <!-- Services section -->
            <div class="sidebar-section-header mt-0">
                Services
            </div>
            <ul class="list-unstyled menu-sections">
                <li>
                    <a asp-page="/Modules/SimManagement/Requests/Index" class="menu-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.StartsWith("/Modules/SimManagement/Requests") == true ? "active" : "")">
                        <i class="menu-icon bi bi-phone"></i>
                        <span>SIM Card Request</span>
                        <span class="pending-badge" id="sim-badge" style="display: none;">0</span>
                    </a>
                </li>
                <li>
                    <a asp-page="/Modules/RefundManagement/Requests/Index" class="menu-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.StartsWith("/Modules/RefundManagement/Requests") == true ? "active" : "")">
                        <i class="menu-icon bi bi-cash-coin"></i>
                        <span>Refund Request</span>
                        <span class="pending-badge" id="refund-badge" style="display: none;">0</span>
                    </a>
                </li>
                <li>
                    <a asp-page="/Modules/EBillManagement/CallRecords/MyCallLogs" class="menu-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.StartsWith("/Modules/EBillManagement/CallRecords") == true ? "active" : "")">
                        <i class="menu-icon bi bi-envelope"></i>
                        <span>E-Bill</span>
                        <span class="pending-badge" id="ebill-badge" style="display: none;">0</span>
                    </a>
                </li>
            </ul>

            <!-- My Reports section -->
            @{
                var supervisorName = User.Identity?.IsAuthenticated == true ? $"{User.FindFirst("FirstName")?.Value} {User.FindFirst("LastName")?.Value}" : "";
            }
            @if (User.Identity?.IsAuthenticated == true)
            {
            <div class="sidebar-section-header">
                My Reports
            </div>
            <ul class="list-unstyled menu-sections">
                <li>
                    <a asp-page="/Staff/MyRecoveryReport" class="menu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Staff/MyRecoveryReport" ? "active" : "")">
                        <i class="menu-icon bi bi-file-earmark-bar-graph"></i>
                        <span>My Recovery Report</span>
                    </a>
                </li>
            </ul>
            }

            <!-- Approval Dashboard section -->
            @if (User.Identity?.IsAuthenticated == true)
            {
            <div class="sidebar-section-header">
                Approval Dashboard
            </div>
            <ul class="list-unstyled menu-sections">
                <li>
                    <a asp-page="/Dashboard/Approver/Index" class="menu-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.StartsWith("/Dashboard/Approver") == true || ViewContext.RouteData.Values["Page"]?.ToString()?.Contains("/Approvals/") == true ? "active" : "")">
                        <i class="menu-icon bi bi-person-badge"></i>
                        <span>Approver Dashboard</span>
                        <span class="pending-badge" id="approver-badge" style="display: none;">0</span>
                    </a>
                </li>
            </ul>
            }

            <!-- Management section -->
            @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
            {
            <div class="sidebar-section-header">
                Management
            </div>
            }

            @if (User.IsInRole("Admin"))
            {
            <ul class="list-unstyled menu-sections">
                <li class="has-nested-submenu">
                    <a href="#" class="menu-item @(ViewContext.RouteData.Values["Page"]?.ToString()?.StartsWith("/Admin/") == true ? "active" : "")">
                        <i class="menu-icon bi bi-gear-fill"></i>
                        <span>Administration</span>
                        <span class="submenu-icon"><i class="bi bi-chevron-right"></i></span>
                    </a>
                    <ul class="nested-submenu list-unstyled">
                        <!-- User & Organization Setup Section -->
                        <li class="nested-section-header">
                            <span>USER & ORGANIZATION SETUP</span>
                        </li>
                        <li>
                            <a asp-page="/Admin/UserManagement" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/UserManagement" ? "active" : "")">
                                <i class="menu-icon bi bi-people"></i>
                                <span>User Management</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/Organizations" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/Organizations" ? "active" : "")">
                                <i class="menu-icon bi bi-building"></i>
                                <span>Organizations</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/Offices" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/Offices" ? "active" : "")">
                                <i class="menu-icon bi bi-door-open"></i>
                                <span>Offices</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/EbillUsers" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/EbillUsers" ? "active" : "")">
                                <i class="menu-icon bi bi-person-lines-fill"></i>
                                <span>Ebill Users</span>
                            </a>
                        </li>

                        <!-- Telecom Configuration Section -->
                        <li class="menu-divider"></li>
                        <li class="nested-section-header">
                            <span>TELECOM CONFIGURATION</span>
                        </li>
                        <li>
                            <a asp-page="/Admin/ClassOfService" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/ClassOfService" ? "active" : "")">
                                <i class="menu-icon bi bi-telephone"></i>
                                <span>Class of Service</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/ServiceProvider" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/ServiceProvider" ? "active" : "")">
                                <i class="menu-icon bi bi-broadcast"></i>
                                <span>Service Provider</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/UserPhones" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/UserPhones" ? "active" : "")">
                                <i class="menu-icon bi bi-telephone-plus"></i>
                                <span>User Phones</span>
                            </a>
                        </li>

                        <!-- Call Log Management Section -->
                        <li class="menu-divider"></li>
                        <li class="nested-section-header">
                            <span>CALL LOG MANAGEMENT</span>
                        </li>
                        <li>
                            <a asp-page="/Admin/CallLogs" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/CallLogs" ? "active" : "")">
                                <i class="menu-icon bi bi-telephone-fill"></i>
                                <span>Call Logs</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/CallLogStaging" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/CallLogStaging" ? "active" : "")">
                                <i class="menu-icon bi bi-clipboard-check"></i>
                                <span>Call Logs Reviews</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/ImportAudits" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/ImportAudits" ? "active" : "")">
                                <i class="menu-icon bi bi-file-earmark-check"></i>
                                <span>Import Audit Trail</span>
                            </a>
                        </li>

                        <!-- System Configuration Section -->
                        <li class="menu-divider"></li>
                        <li class="nested-section-header">
                            <span>SYSTEM CONFIGURATION</span>
                        </li>
                        <li>
                            <a asp-page="/Admin/ExchangeRates" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/ExchangeRates" ? "active" : "")">
                                <i class="menu-icon bi bi-currency-exchange"></i>
                                <span>Exchange Rates</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/AuditLogs" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/AuditLogs" ? "active" : "")">
                                <i class="menu-icon bi bi-journal-text"></i>
                                <span>Audit Logs</span>
                            </a>
                        </li>

                        <!-- Email Management Section -->
                        <li class="menu-divider"></li>
                        <li class="nested-section-header">
                            <span>EMAIL MANAGEMENT</span>
                        </li>
                        <li>
                            <a asp-page="/Admin/EmailConfiguration" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/EmailConfiguration" ? "active" : "")">
                                <i class="menu-icon bi bi-gear-fill"></i>
                                <span>Email Configuration</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/EmailTemplates" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/EmailTemplates" ? "active" : "")">
                                <i class="menu-icon bi bi-file-text"></i>
                                <span>Email Templates</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/SendEmail" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/SendEmail" ? "active" : "")">
                                <i class="menu-icon bi bi-send"></i>
                                <span>Send Email</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/EmailLogs" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/EmailLogs" ? "active" : "")">
                                <i class="menu-icon bi bi-clock-history"></i>
                                <span>Email History & Logs</span>
                            </a>
                        </li>

                        <!-- Recovery Management Section -->
                        <li class="menu-divider"></li>
                        <li class="nested-section-header">
                            <span>RECOVERY MANAGEMENT</span>
                        </li>
                        <li>
                            <a asp-page="/Admin/RecoveryDashboard" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/RecoveryDashboard" ? "active" : "")">
                                <i class="menu-icon bi bi-speedometer2"></i>
                                <span>Recovery Dashboard</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/EOSRecovery" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/EOSRecovery" ? "active" : "")">
                                <i class="menu-icon bi bi-person-dash"></i>
                                <span>EOS Recovery</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/RecoveryReports" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/RecoveryReports" ? "active" : "")">
                                <i class="menu-icon bi bi-file-earmark-bar-graph"></i>
                                <span>Recovery Reports</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/RecoveryJobStatus" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/RecoveryJobStatus" ? "active" : "")">
                                <i class="menu-icon bi bi-clock-history"></i>
                                <span>Job Execution History</span>
                            </a>
                        </li>
                        <li>
                            <a asp-page="/Admin/RecoverySettings" class="nested-submenu-item @(ViewContext.RouteData.Values["Page"]?.ToString() == "/Admin/RecoverySettings" ? "active" : "")">
                                <i class="menu-icon bi bi-sliders"></i>
                                <span>Recovery Settings</span>
                            </a>
                        </li>
                    </ul>
                </li>
            </ul>
            }
        </nav>

        <!-- Page Content -->
        <div id="content">
            <div class="container-fluid">
                <main role="main" class="py-3">
                    @RenderBody()
                </main>
            </div>
            
            <!-- UNON Footer -->
            <footer>
        <!-- Rainbow color bar -->
        <div class="d-flex" style="height: 5px;">
            <div style="flex-grow: 1; background-color: #E5243B;"></div>
            <div style="flex-grow: 1; background-color: #DDA63A;"></div>
            <div style="flex-grow: 1; background-color: #4C9F38;"></div>
            <div style="flex-grow: 1; background-color: #C5192D;"></div>
            <div style="flex-grow: 1; background-color: #FF3A21;"></div>
            <div style="flex-grow: 1; background-color: #26BDE2;"></div>
            <div style="flex-grow: 1; background-color: #FCC30B;"></div>
            <div style="flex-grow: 1; background-color: #A21942;"></div>
            <div style="flex-grow: 1; background-color: #FD6925;"></div>
            <div style="flex-grow: 1; background-color: #DD1367;"></div>
            <div style="flex-grow: 1; background-color: #FD9D24;"></div>
            <div style="flex-grow: 1; background-color: #BF8B2E;"></div>
            <div style="flex-grow: 1; background-color: #3F7E44;"></div>
            <div style="flex-grow: 1; background-color: #0A97D9;"></div>
            <div style="flex-grow: 1; background-color: #56C02B;"></div>
            <div style="flex-grow: 1; background-color: #00689D;"></div>
            <div style="flex-grow: 1; background-color: #19486A;"></div>
    </div>

        <div class="container-fluid py-2">
            <div class="text-center small">
                <span>If you have any questions contact UNON ICTS Service Desk <a href="mailto:ICTS.Servicedesk@un.org">ICTS.Servicedesk@un.org</a></span>
                <span>| +2542076 (2 1111) | Monday - Friday 8:00am - 6:00pm</span>
                <span class="d-block fw-bold">Powered By UNON © 2025</span>
                <span>DAS | ICTS | Innovation Business Unit</span>
            </div>
        </div>
    </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Load pending request counts *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        @await Component.InvokeAsync("PendingRequestCounts")

        <script>
            // Update badges with counts when page loads
            $(document).ready(function() {
                if (window.pendingRequestCounts) {
                    var counts = window.pendingRequestCounts;

                    // Update SIM Card badge
                    if (counts.simCount > 0) {
                        $('#sim-badge').text(counts.simCount).show();
                    }

                    // Update Refund badge
                    if (counts.refundCount > 0) {
                        $('#refund-badge').text(counts.refundCount).show();
                    }

                    // Update E-Bill badge
                    if (counts.ebillCount > 0) {
                        $('#ebill-badge').text(counts.ebillCount).show();
                    }

                    // Update Approver Dashboard badge
                    if (counts.totalCount > 0) {
                        $('#approver-badge').text(counts.totalCount).show();
                    }
                }
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>