@using Microsoft.AspNetCore.Identity
@using TAB.Web.Models
@using TAB.Web.Services
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject INotificationService NotificationService

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    if (user != null)
    {
        var roles = await UserManager.GetRolesAsync(user);
        var unreadCount = await NotificationService.GetUnreadCountAsync(user.Id);
        var recentNotifications = await NotificationService.GetUnreadNotificationsAsync(user.Id, 5);

        <div class="user-info">
            <div class="user-details">
                <span class="user-name">@user.FirstName @user.LastName</span>
                <span class="user-meta">@(roles.FirstOrDefault() ?? "User") • @user.Email</span>
            </div>
        </div>

        <div class="notification-bell-container">
            <div class="dropdown">
                <button class="notification-bell-btn" type="button" id="notificationDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                    <i class="bi bi-bell"></i>
                    @if (unreadCount > 0)
                    {
                        <span class="notification-badge">@(unreadCount > 99 ? "99+" : unreadCount.ToString())</span>
                    }
                </button>
                <div class="dropdown-menu dropdown-menu-end notification-dropdown" aria-labelledby="notificationDropdown">
                    <div class="notification-header">
                        <h6 class="mb-0">Notifications</h6>
                        @if (unreadCount > 0)
                        {
                            <form method="post" asp-page-handler="MarkAllAsRead" class="d-inline">
                                <button type="submit" class="btn btn-link btn-sm p-0" title="Mark all as read">
                                    <i class="bi bi-check-all"></i>
                                </button>
                            </form>
                        }
                    </div>
                    <div class="notification-list">
                        @if (recentNotifications.Any())
                        {
                            @foreach (var notification in recentNotifications)
                            {
                                <a href="@(notification.Link ?? "#")" class="notification-item @(!notification.IsRead ? "unread" : "")" data-notification-id="@notification.Id">
                                    <div class="notification-icon notification-@notification.Type.ToLower()">
                                        <i class="@(notification.Icon ?? "bi-info-circle")"></i>
                                    </div>
                                    <div class="notification-content">
                                        <div class="notification-title">@notification.Title</div>
                                        <div class="notification-message">@notification.Message</div>
                                        <div class="notification-time">
                                            <i class="bi bi-clock"></i>
                                            @GetTimeAgo(notification.CreatedDate)
                                        </div>
                                    </div>
                                </a>
                            }
                            <div class="notification-footer">
                                <a href="/Notifications" class="btn btn-sm btn-link">View All Notifications</a>
                            </div>
                        }
                        else
                        {
                            <div class="notification-empty">
                                <i class="bi bi-bell-slash"></i>
                                <p>No new notifications</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="user-info">
            <span class="user-type">Guest User</span>
            <span class="user-role">Unknown</span>
            <span class="user-department">No Email</span>
        </div>
    }
    <div class="user-actions">
        <a href="#" class="btn btn-job-aid" title="View Job Aid and Training Materials" onclick="alert('Job Aid link coming soon!')">
            <i class="bi bi-book"></i> 
            <span class="btn-text">Job Aid</span>
        </a>
        <form class="form-inline" asp-page="/Account/Logout" method="post">
            <button type="submit" class="btn btn-logout" title="Sign out of your account">
                <i class="bi bi-box-arrow-right"></i>
                <span class="btn-text">Log Out</span>
            </button>
        </form>
    </div>
}
else
{
    <div class="login-buttons">
        <a class="btn btn-primary" asp-page="/Account/Login">
            <i class="bi bi-box-arrow-in-right"></i> Login
        </a>
    </div>
}

@functions {
    private string GetTimeAgo(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;

        if (timeSpan.TotalMinutes < 1)
            return "Just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes}m ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours}h ago";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays}d ago";
        if (timeSpan.TotalDays < 30)
            return $"{(int)(timeSpan.TotalDays / 7)}w ago";

        return dateTime.ToString("MMM dd");
    }
}
