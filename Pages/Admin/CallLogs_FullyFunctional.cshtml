        // View telecom record details (PSTN, PrivateWire, Safaricom, Airtel)
        async function viewTelecomDetails(type, id) {
            // For CallLog type, use the existing function
            if (type === 'CallLog') {
                return viewCallLogDetails(id);
            }

            // Show a simple details modal for other types
            const modal = new bootstrap.Modal(document.getElementById('detailsModal'));
            document.getElementById('callLogDetailsContent').innerHTML = `
                <div class="detail-section">
                    <h6 class="section-title">
