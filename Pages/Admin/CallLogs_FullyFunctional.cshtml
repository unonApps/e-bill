        // Link telecom record to user
        let currentLinkingRecord = null;
        let selectedUserId = null;

        function linkTelecomToUser(type, id, accountNo) {
            currentLinkingRecord = { type, id, accountNo };
            selectedUserId = null;

            // Update modal info
            document.getElementById('linkRecordInfo').textContent = `${type} Record #${id} - Account: ${accountNo}`;
            document.getElementById('userSearchInput').value = '';
            document.getElementById('userSearchResults').innerHTML = '';
            document.getElementById('selectedUserPreview').classList.add('d-none');
            document.getElementById('confirmLinkButton').disabled = true;

            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('linkUserModal'));
            modal.show();

            // Search for the account number automatically
            searchUsersForLinking(accountNo);
        }

        // Search users for linking
        async function searchUsersForLinking(searchTerm) {
            const resultsDiv = document.getElementById('userSearchResults');

            // Show loading
            resultsDiv.innerHTML = `
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Searching...</span>
                    </div>
                    <p class="mt-2 mb-0">Searching for users...</p>
                </div>
            `;

            try {
                const response = await fetch(`/Admin/CallLogs?handler=SearchUsers&searchTerm=${encodeURIComponent(searchTerm || '')}&accountNo=${encodeURIComponent(currentLinkingRecord?.accountNo || '')}`);
                const data = await response.json();

                if (data.users && data.users.length > 0) {
                    if (data.exactMatch && data.users.length === 1) {
                        // Auto-select exact match
                        resultsDiv.innerHTML = `
                            <div class="alert alert-success">
                                <i class="bi bi-check-circle me-2"></i>
                                <strong>Exact match found!</strong> Account number matched with user below.
                            </div>
                        `;
                    } else {
                        resultsDiv.innerHTML = '';
                    }

                    // Display users
                    const usersHtml = data.users.map(user => `
                        <div class="border rounded p-3 mb-2 user-select-card" style="cursor: pointer;"
                             onclick="selectUserForLinking(${user.id}, '${user.firstName}', '${user.lastName}', '${user.indexNumber}', '${user.email || 'N/A'}', '${user.phoneNumber || 'N/A'}', '${user.organizationName}', '${user.officeName}')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">
                                        <i class="bi bi-person-circle me-2 text-primary"></i>
                                        ${user.firstName} ${user.lastName}
                                    </h6>
                                    <div class="small text-muted">
                                        <div><i class="bi bi-hash me-1"></i>Index: ${user.indexNumber}</div>
                                        <div><i class="bi bi-envelope me-1"></i>Email: ${user.email || 'N/A'}</div>
                                        <div><i class="bi bi-telephone me-1"></i>Phone: ${user.phoneNumber || 'N/A'}</div>
                                        <div><i class="bi bi-building me-1"></i>Org: ${user.organizationName} - ${user.officeName}</div>
                                    </div>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-primary">
                                        Select
                                    </button>
                                </div>
                            </div>
                        </div>
                    `).join('');

                    resultsDiv.innerHTML += usersHtml;

                    // Auto-select if exact match
                    if (data.exactMatch && data.users.length === 1) {
                        const user = data.users[0];
                        selectUserForLinking(user.id, user.firstName, user.lastName, user.indexNumber,
                                           user.email || 'N/A', user.phoneNumber || 'N/A',
                                           user.organizationName, user.officeName);
                    }
                } else {
                    resultsDiv.innerHTML = `
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            No users found matching "${searchTerm || currentLinkingRecord?.accountNo}".
                            Try searching with a different term.
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error searching users:', error);
                resultsDiv.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-x-circle me-2"></i>
                        Error searching for users. Please try again.
                    </div>
                `;
            }
        }

        // Select user for linking
        function selectUserForLinking(userId, firstName, lastName, indexNumber, email, phone, org, office) {
            selectedUserId = userId;

            // Update UI
            document.querySelectorAll('.user-select-card').forEach(card => {
                card.classList.remove('border-primary', 'bg-light');
            });
            event.currentTarget.classList.add('border-primary', 'bg-light');

            // Show preview
            const previewDiv = document.getElementById('selectedUserPreview');
            const detailsDiv = document.getElementById('selectedUserDetails');

            detailsDiv.innerHTML = `
                <div class="row">
                    <div class="col-md-6">
                        <strong>${firstName} ${lastName}</strong><br>
                        <span class="text-muted">Index: ${indexNumber}</span>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted">
                            Email: ${email}<br>
                            Phone: ${phone}<br>
                            ${org} - ${office}
                        </small>
                    </div>
                </div>
            `;

            previewDiv.classList.remove('d-none');
            document.getElementById('confirmLinkButton').disabled = false;
        }

        // Initialize search input
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('userSearchInput');
            if (searchInput) {
                let searchTimeout;
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        searchUsersForLinking(this.value);
                    }, 500);
                });
            }

            // Confirm link button
            const confirmButton = document.getElementById('confirmLinkButton');
            if (confirmButton) {
                confirmButton.addEventListener('click', async function() {
                    if (!selectedUserId || !currentLinkingRecord) return;

                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Linking...';

                    try {
                        const formData = new FormData();
                        formData.append('type', currentLinkingRecord.type);
                        formData.append('id', currentLinkingRecord.id);
                        formData.append('userId', selectedUserId);

                        const response = await fetch('/Admin/CallLogs?handler=LinkTelecom', {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: formData
                        });

                        const result = await response.json();

                        if (result.success) {
                            // Close modal
                            bootstrap.Modal.getInstance(document.getElementById('linkUserModal')).hide();

                            // Show success message
                            alert(`Success! Record linked to ${result.userName}`);

                            // Reload page to show updated data
                            window.location.reload();
                        } else {
                            alert(`Error: ${result.message}`);
                            this.disabled = false;
                            this.innerHTML = '<i class="bi bi-link-45deg me-1"></i>Link User';
                        }
                    } catch (error) {
                        console.error('Error linking record:', error);
                        alert('An error occurred while linking the record.');
                        this.disabled = false;
                        this.innerHTML = '<i class="bi bi-link-45deg me-1"></i>Link User';
                    }
                });
            }
        });

        // Delete telecom record
        let currentDeletingRecord = null;

        async function deleteTelecomRecord(type, id) {
            currentDeletingRecord = { type, id };

            // First check if the record can be deleted
            const checkResponse = await fetch(`/Admin/CallLogs?handler=CheckDeletePermission&type=${encodeURIComponent(type)}&id=${id}`);
            const checkResult = await checkResponse.json();

            const modalContent = document.getElementById('deleteConfirmContent');
            const confirmButton = document.getElementById('confirmDeleteButton');

            if (!checkResult.canDelete) {
                // Show warning that record cannot be deleted
                modalContent.innerHTML = `
                    <div class="alert alert-warning mb-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Cannot Delete This Record</strong>
                    </div>
                    <p class="mb-3">
                        This <strong>${type}</strong> record (#${id}) is part of an import batch and cannot be deleted individually.
                    </p>
                    <div class="bg-light rounded p-3">
                        <p class="mb-2"><strong>Reason:</strong></p>
                        <p class="mb-0">${checkResult.message}</p>
                    </div>
                    <div class="mt-3 text-muted">
                        <small>
                            <i class="bi bi-info-circle me-1"></i>
                            To remove this record, you must delete the entire import batch from the Import Audits page.
                        </small>
                    </div>
                `;
                confirmButton.style.display = 'none';
            } else {
                // Show normal deletion confirmation
                modalContent.innerHTML = `
                    <div class="text-center mb-4">
                        <div class="bg-danger bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                            <i class="bi bi-trash text-danger" style="font-size: 32px;"></i>
                        </div>
                    </div>
                    <h6 class="text-center mb-3">Are you sure you want to delete this record?</h6>
                    <div class="bg-light rounded p-3 mb-3">
                        <div class="row">
                            <div class="col-6">
                                <strong>Type:</strong> ${type}
                            </div>
                            <div class="col-6">
                                <strong>Record ID:</strong> #${id}
                            </div>
                        </div>
                    </div>
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Warning:</strong> This action cannot be undone!
                    </div>
                `;
                confirmButton.style.display = 'block';
            }

            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
            modal.show();
        }

        // Initialize delete confirmation button
        document.addEventListener('DOMContentLoaded', function() {
            const confirmDeleteBtn = document.getElementById('confirmDeleteButton');
            if (confirmDeleteBtn) {
                confirmDeleteBtn.addEventListener('click', async function() {
                    if (!currentDeletingRecord) return;

                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Deleting...';

                    try {
                        const formData = new FormData();
                        formData.append('type', currentDeletingRecord.type);
                        formData.append('id', currentDeletingRecord.id);

                        const response = await fetch('/Admin/CallLogs?handler=DeleteTelecom', {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: formData
                        });

                        const result = await response.json();

                        if (result.success) {
                            // Close modal
                            bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal')).hide();

                            // Show success message
                            alert(`Success! ${result.message}`);

                            // Reload page to show updated data
                            window.location.reload();
                        } else {
                            // Show error in modal
                            const modalContent = document.getElementById('deleteConfirmContent');
                            if (result.hasImportAudit) {
                                modalContent.innerHTML = `
                                    <div class="alert alert-danger">
                                        <i class="bi bi-x-circle me-2"></i>
                                        ${result.message}
                                    </div>
                                `;
                                this.style.display = 'none';
                            } else {
                                alert(`Error: ${result.message}`);
                                this.disabled = false;
                                this.innerHTML = '<i class="bi bi-trash me-1"></i>Delete Record';
                            }
                        }
                    } catch (error) {
                        console.error('Error deleting record:', error);
                        alert('An error occurred while deleting the record.');
                        this.disabled = false;
                        this.innerHTML = '<i class="bi bi-trash me-1"></i>Delete Record';
                    }
                });
            }
        });

        // View call log details
        async function viewCallLogDetails(id) {
            // Show loading spinner
            document.getElementById('callLogDetailsContent').innerHTML = `
                <div class="text-center py-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Loading details...</p>
                </div>
            `;
            
            var modal = new bootstrap.Modal(document.getElementById('detailsModal'));
            modal.show();
            
            try {
                // Fetch call log details
                const response = await fetch(`/Admin/CallLogs?handler=CallLogDetails&id=${id}`, {
                    method: 'GET',
                    headers: {
                        'Accept': 'text/html'
                    }
                });
                
                if (response.ok) {
                    const html = await response.text();
                    document.getElementById('callLogDetailsContent').innerHTML = html;
                } else {
                    document.getElementById('callLogDetailsContent').innerHTML = `
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Failed to load call log details. Please try again.
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error loading call log details:', error);
                document.getElementById('callLogDetailsContent').innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        An error occurred while loading the details.
                    </div>
                `;
            }
        }
        
        // Link call log to user
        function linkToUser(callLogId, msisdn) {
            if (confirm(`Do you want to find and link a user for phone number ${msisdn}?`)) {
                // This would typically redirect to a user selection page or open a modal
                window.location.href = `/Admin/CallLogs?handler=LinkUser&id=${callLogId}`;
            }
        }
        
        // Show import result if there are results
        @if (TempData["ImportResults"] != null && TempData["ImportAuditId"] != null)
        {
            <text>
            // Parse the results
            var importResults = @Html.Raw(TempData["ImportResults"]);
            var auditId = @TempData["ImportAuditId"];
            var statusMessage = '@Html.Raw(Model.StatusMessage?.Replace("'", "\\'"))';
            
            // Extract counts from status message
            var successMatch = statusMessage.match(/(\d+) new call logs created/);
            var updateMatch = statusMessage.match(/(\d+) existing call logs updated/);
            var skipMatch = statusMessage.match(/(\d+) (?:duplicates|unmatched phone numbers) skipped/);
            var errorMatch = statusMessage.match(/(\d+) errors/);
            
            var successCount = successMatch ? parseInt(successMatch[1]) : 0;
            var updateCount = updateMatch ? parseInt(updateMatch[1]) : 0;
            var skipCount = skipMatch ? parseInt(skipMatch[1]) : 0;
            var errorCount = errorMatch ? parseInt(errorMatch[1]) : 0;
            
            // Build results details HTML
            var detailsHtml = '<div class="row text-center mb-3">';
            
            if (successCount > 0) {
                detailsHtml += `
                    <div class="col-md-3 mb-2">
                        <div class="bg-success bg-opacity-10 rounded p-3">
                            <h3 class="text-success mb-1">${successCount}</h3>
                            <small class="text-muted">Successfully Imported</small>
                        </div>
                    </div>`;
            }
            
            if (updateCount > 0) {
                detailsHtml += `
                    <div class="col-md-3 mb-2">
                        <div class="bg-info bg-opacity-10 rounded p-3">
                            <h3 class="text-info mb-1">${updateCount}</h3>
                            <small class="text-muted">Records Updated</small>
                        </div>
                    </div>`;
            }
            
            if (skipCount > 0) {
                detailsHtml += `
                    <div class="col-md-3 mb-2">
                        <div class="bg-warning bg-opacity-10 rounded p-3">
                            <h3 class="text-warning mb-1">${skipCount}</h3>
                            <small class="text-muted">Records Skipped</small>
                        </div>
                    </div>`;
            }
            
            if (errorCount > 0) {
                detailsHtml += `
                    <div class="col-md-3 mb-2">
                        <div class="bg-danger bg-opacity-10 rounded p-3">
                            <h3 class="text-danger mb-1">${errorCount}</h3>
                            <small class="text-muted">Errors Encountered</small>
                        </div>
                    </div>`;
            }
            
            detailsHtml += '</div>';
            
            // Add detailed messages if any
            if (importResults && importResults.length > 0) {
                detailsHtml += '<div class="border rounded p-3" style="background-color: #f8f9fa; max-height: 200px; overflow-y: auto;">';
                detailsHtml += '<small class="text-muted d-block mb-2">Detailed Messages (showing first 100):</small>';
                detailsHtml += '<pre class="mb-0" style="font-size: 12px; white-space: pre-wrap;">' + importResults.join('\n') + '</pre>';
                detailsHtml += '</div>';
            }
            
            document.getElementById('importResultsDetails').innerHTML = detailsHtml;
            
            // Add download buttons
            var buttonsHtml = '';
            
            if (errorCount > 0) {
                buttonsHtml += `<a href="/Admin/CallLogs?handler=DownloadImportResults&auditId=${auditId}&type=errors" 
                                   class="btn btn-outline-danger btn-sm">
                                   <i class="bi bi-download me-1"></i>Download Errors
                                </a>`;
            }
            
            if (skipCount > 0) {
                buttonsHtml += `<a href="/Admin/CallLogs?handler=DownloadImportResults&auditId=${auditId}&type=skipped" 
                                   class="btn btn-outline-warning btn-sm">
                                   <i class="bi bi-download me-1"></i>Download Skipped
                                </a>`;
            }
            
            buttonsHtml += `<a href="/Admin/CallLogs?handler=DownloadImportResults&auditId=${auditId}&type=all" 
                               class="btn btn-outline-primary btn-sm">
                               <i class="bi bi-download me-1"></i>Download All Results
                            </a>`;
            
            document.getElementById('downloadButtons').innerHTML = buttonsHtml;
            
            // Show the modal
            var importModal = new bootstrap.Modal(document.getElementById('importResultsModal'));
            importModal.show();
            </text>
        }
    </script>
}