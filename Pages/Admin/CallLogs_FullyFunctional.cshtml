@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Toggle between regular, PSTN, Private Wire, Safaricom, and Airtel format tables
        document.addEventListener('DOMContentLoaded', function() {
            const regularRadio = document.getElementById('typeRegular');
            const pstnRadio = document.getElementById('typePSTN');
            const privateWireRadio = document.getElementById('typePrivateWire');
            const safaricomRadio = document.getElementById('typeSafaricom');
            const airtelRadio = document.getElementById('typeAirtel');
            const regularTable = document.getElementById('regularFormatTable');
            const pstnTable = document.getElementById('pstnFormatTable');
            const privateWireTable = document.getElementById('privateWireFormatTable');
            const safaricomTable = document.getElementById('safaricomFormatTable');
            const airtelTable = document.getElementById('airtelFormatTable');
            const helpText = document.getElementById('fileUploadHelpText');
            const typeDesc = document.getElementById('typeDescription');

            function toggleFormatTable() {
                // Hide all tables first
                if (regularTable) regularTable.style.display = 'none';
                if (pstnTable) pstnTable.style.display = 'none';
                if (privateWireTable) privateWireTable.style.display = 'none';
                if (safaricomTable) safaricomTable.style.display = 'none';
                if (airtelTable) airtelTable.style.display = 'none';

                if (pstnRadio && pstnRadio.checked) {
                    if (pstnTable) pstnTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing PSTN call log data with extended fields.';
                    if (typeDesc) typeDesc.textContent = 'PSTN - Public Switched Telephone Network logs for traditional phone systems.';
                } else if (privateWireRadio && privateWireRadio.checked) {
                    if (privateWireTable) privateWireTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing Private Wire telecommunications service records.';
                    if (typeDesc) typeDesc.textContent = 'Private Wire - Dedicated telecommunications circuits with USD billing.';
                } else if (safaricomRadio && safaricomRadio.checked) {
                    if (safaricomTable) safaricomTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing Safaricom call records exported from their billing system.';
                    if (typeDesc) typeDesc.textContent = 'Safaricom - Leading telecommunications service provider in Kenya.';
                } else if (airtelRadio && airtelRadio.checked) {
                    if (airtelTable) airtelTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing Airtel call records exported from their billing system.';
                    if (typeDesc) typeDesc.textContent = 'Airtel - Major telecommunications service provider operating in Kenya and Africa.';
                } else {
                    if (regularTable) regularTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing call log data. Phone numbers will be matched with E-bill users.';
                    if (typeDesc) typeDesc.textContent = 'Regular - Standard mobile/telephone billing records.';
                }
            }

            if (regularRadio) {
                regularRadio.addEventListener('change', toggleFormatTable);
            }
            if (pstnRadio) {
                pstnRadio.addEventListener('change', toggleFormatTable);
            }
            if (privateWireRadio) {
                privateWireRadio.addEventListener('change', toggleFormatTable);
            }
            if (safaricomRadio) {
                safaricomRadio.addEventListener('change', toggleFormatTable);
            }
            if (airtelRadio) {
                airtelRadio.addEventListener('change', toggleFormatTable);
            }

            // Initialize on page load
            toggleFormatTable();
        });

        // Preview CSV function
        function previewCSV() {
            const fileInput = document.getElementById('callLogFile');
            const file = fileInput.files[0];

            if (!file) {
                alert('Please select a CSV file first.');
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                const text = e.target.result;
                const lines = text.split('\n').filter(line => line.trim());

                if (lines.length < 2) {
                    alert('The CSV file appears to be empty or has no data rows.');
                    return;
                }

                // Parse CSV
                const headers = parseCSVLine(lines[0]);
                const dataRows = lines.slice(1, Math.min(11, lines.length)) // Show first 10 data rows
                    .map(line => parseCSVLine(line));

                // Update preview summary
                const totalRows = lines.length - 1;
                document.getElementById('previewSummary').textContent =
                    `Found ${totalRows} row${totalRows !== 1 ? 's' : ''} in the CSV file. Showing first ${Math.min(10, totalRows)} rows.`;
                document.getElementById('totalRowsCount').textContent = totalRows;
                document.getElementById('validRowsCount').textContent = totalRows; // Will be updated after validation

                // Build preview table headers
                const headerRow = document.getElementById('previewHeaders');
                headerRow.innerHTML = '';
                headers.forEach(header => {
                    const th = document.createElement('th');
                    th.textContent = header;
                    th.className = 'text-nowrap';
                    headerRow.appendChild(th);
                });

                // Build preview table body
                const tbody = document.getElementById('previewBody');
                tbody.innerHTML = '';
                dataRows.forEach((row, index) => {
                    const tr = document.createElement('tr');
                    headers.forEach((header, colIndex) => {
                        const td = document.createElement('td');
                        td.textContent = row[colIndex] || '';
                        td.className = 'text-nowrap';
                        tr.appendChild(td);
                    });
                    tbody.appendChild(tr);
                });

                // Switch to preview step
                showPreviewStep();
            };

            reader.readAsText(file);
        }

        // Parse CSV line (handles quoted values)
        function parseCSVLine(line) {
            const result = [];
            let current = '';
            let inQuotes = false;

            for (let i = 0; i < line.length; i++) {
                const char = line[i];
                const nextChar = line[i + 1];

                if (char === '"') {
                    if (inQuotes && nextChar === '"') {
                        current += '"';
                        i++; // Skip next quote
                    } else {
                        inQuotes = !inQuotes;
                    }
                } else if (char === ',' && !inQuotes) {
                    result.push(current.trim());
                    current = '';
                } else {
                    current += char;
                }
            }

            result.push(current.trim());
            return result;
        }

        // Show preview step
        function showPreviewStep() {
            // Update step indicators
            document.getElementById('step1Indicator').classList.remove('active');
            document.getElementById('step1Indicator').classList.add('completed');
            document.getElementById('step2Indicator').classList.add('active');

            // Hide upload content, show preview
            document.getElementById('uploadStep').style.display = 'none';
            document.getElementById('previewStep').style.display = 'block';

            // Update buttons
            document.getElementById('previewButton').style.display = 'none';
            document.getElementById('backButton').style.display = 'inline-block';
            document.getElementById('importButton').style.display = 'inline-block';
        }

        // Go back to upload step
        function goBackToUpload() {
            // Update step indicators
            document.getElementById('step1Indicator').classList.add('active');
            document.getElementById('step1Indicator').classList.remove('completed');
            document.getElementById('step2Indicator').classList.remove('active');

            // Show upload content, hide preview
            document.getElementById('uploadStep').style.display = 'block';
            document.getElementById('previewStep').style.display = 'none';

            // Update buttons
            document.getElementById('previewButton').style.display = 'inline-block';
            document.getElementById('backButton').style.display = 'none';
            document.getElementById('importButton').style.display = 'none';
        }

        // Function to download sample Call Log CSV
        function downloadCallLogSampleCSV() {
            // Check which type is selected
