    }
</style>

@section Scripts {
    <script>
        function viewEmail(id) {
            var modal = new bootstrap.Modal(document.getElementById('emailModal'));
            modal.show();

            fetch('/Admin/EmailLogs?handler=EmailDetails&id=' + id)
                .then(response => response.text())
                .then(html => {
                    document.getElementById('emailContent').innerHTML = html;
                })
                .catch(error => {
                    document.getElementById('emailContent').innerHTML = '<p class="text-danger">Error loading email details.</p>';
                });
        }
    </script>
}
