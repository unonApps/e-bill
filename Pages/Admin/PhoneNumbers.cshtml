@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function() {
            // Helper function to count digits in a phone number
            function countDigits(phoneNumber) {
                return (phoneNumber.match(/\d/g) || []).length;
            }

            // Helper function to toggle fields based on phone type
            function toggleFieldsForPhoneType(prefix, phoneType) {
                var isFixed = (phoneType === 'Fixed');

                // Line Type field
                var lineTypeSelect = $('#' + prefix + '_LineType');
                var lineTypeGroup = $('#' + prefix + '_lineTypeGroup');
                var lineTypeNotAvailable = $('#' + prefix + '_lineTypeNotAvailable');

                if (isFixed) {
                    lineTypeSelect.prop('disabled', true).css('background-color', '#e9ecef');
                    lineTypeNotAvailable.show();
                } else {
                    lineTypeSelect.prop('disabled', false).css('background-color', '');
                    lineTypeNotAvailable.hide();
                }

                // Class of Service field
                var cosSelect = $('#' + prefix + '_ClassOfServiceId');
                var cosNotAvailable = $('#' + prefix + '_cosNotAvailable');

                if (isFixed) {
                    cosSelect.prop('disabled', true).val('').css('background-color', '#e9ecef');
                    cosNotAvailable.show();
                } else {
                    cosSelect.prop('disabled', false).css('background-color', '');
                    cosNotAvailable.hide();
                }
            }

            // Helper function to auto-detect phone type based on number length
            function autoDetectPhoneType(prefix) {
                var phoneNumber = $('#' + prefix + '_PhoneNumber').val();
                var digitCount = countDigits(phoneNumber);
                var phoneTypeSelect = $('#' + prefix + '_PhoneType');
                var currentType = phoneTypeSelect.val();

                // If less than 9 digits and currently set to Mobile, switch to Fixed
                if (digitCount > 0 && digitCount < 9 && currentType === 'Mobile') {
                    phoneTypeSelect.val('Fixed');
                    toggleFieldsForPhoneType(prefix, 'Fixed');
                    return false; // Indicate auto-correction happened
                }
                return true;
            }

            // Initialize Select2 for user dropdown in Add Modal
            $('#Input_IndexNumber').select2({
                theme: 'bootstrap-5',
                placeholder: 'Search for a user...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('#addPhoneModal')
            });

            // Initialize Select2 for user dropdown in Edit Modal
            $('#edit_IndexNumber').select2({
                theme: 'bootstrap-5',
                placeholder: 'Search for a user...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('#editPhoneModal')
            });

            // Initialize Select2 for user dropdown in Reassign Modal
            $('#reassign_IndexNumber').select2({
                theme: 'bootstrap-5',
                placeholder: 'Search for a user...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('#reassignPhoneModal')
            });

            // ===== ADD MODAL: Phone Type Logic =====

            // Phone number input change - auto-detect type
            $('#Input_PhoneNumber').on('input blur', function() {
                var digitCount = countDigits($(this).val());
                var phoneTypeSelect = $('#Input_PhoneType');

                // Update hint based on digit count
                if (digitCount > 0 && digitCount < 9) {
                    $('#add_phoneTypeHint').html('<i class="bi bi-exclamation-circle text-warning"></i> ' + digitCount + ' digits detected - will be treated as Fixed Line');
                    // Auto-switch to Fixed if currently Mobile
                    if (phoneTypeSelect.val() === 'Mobile') {
                        phoneTypeSelect.val('Fixed').trigger('change');
                    }
                } else if (digitCount >= 9) {
                    $('#add_phoneTypeHint').html('<i class="bi bi-check-circle text-success"></i> ' + digitCount + ' digits - valid for Mobile');
                } else {
                    $('#add_phoneTypeHint').html('<i class="bi bi-info-circle"></i> Mobile requires 9+ digits');
                }
            });

            // Phone type change
            $('#Input_PhoneType').on('change', function() {
                var phoneType = $(this).val();
                var digitCount = countDigits($('#Input_PhoneNumber').val());

                // Prevent selecting Mobile if less than 9 digits
                if (phoneType === 'Mobile' && digitCount > 0 && digitCount < 9) {
                    alert('Mobile phone numbers must have at least 9 digits. This number has only ' + digitCount + ' digits.');
                    $(this).val('Fixed');
                    phoneType = 'Fixed';
                }

                toggleFieldsForPhoneType('Input', phoneType);
            });

            // Show/hide purpose field based on ownership type in Add Modal
            $('#Input_OwnershipType').on('change', function() {
                if (this.value === '1') { // Personal
                    $('#add_purposeField').hide();
                } else {
                    $('#add_purposeField').show();
                }
            });

            // ===== EDIT MODAL: Phone Type Logic =====

            // Phone type change in Edit modal
            $('#edit_PhoneType').on('change', function() {
                var phoneType = $(this).val();
                var digitCount = countDigits($('#edit_PhoneNumber').val());

                // Prevent selecting Mobile if less than 9 digits
                if (phoneType === 'Mobile' && digitCount > 0 && digitCount < 9) {
                    alert('Mobile phone numbers must have at least 9 digits. This number has only ' + digitCount + ' digits.');
                    $(this).val('Fixed');
                    phoneType = 'Fixed';
                }

                toggleFieldsForPhoneType('edit', phoneType);
            });

            // Show/hide purpose field based on ownership type in Edit Modal
            $('#edit_OwnershipType').on('change', function() {
                if (this.value === '1') { // Personal
                    $('#edit_purposeField').hide();
                } else {
                    $('#edit_purposeField').show();
                }
            });

            // Reset Add modal when closed
            $('#addPhoneModal').on('hidden.bs.modal', function() {
                $(this).find('form')[0].reset();
                $('#Input_IndexNumber').val(null).trigger('change');
                $('#add_purposeField').hide();
                // Reset field states
                toggleFieldsForPhoneType('Input', 'Mobile');
                $('#add_phoneTypeHint').html('<i class="bi bi-info-circle"></i> Mobile requires 9+ digits');
            });

            // Form validation on Add submit
            $('#addPhoneModal form').on('submit', function(e) {
                var phoneType = $('#Input_PhoneType').val();
                var digitCount = countDigits($('#Input_PhoneNumber').val());

                if (phoneType === 'Mobile' && digitCount < 9) {
                    e.preventDefault();
                    alert('Mobile phone numbers must have at least 9 digits. Please enter a valid mobile number or select Fixed Line.');
                    return false;
                }
            });

            // Form validation on Edit submit
            $('#editPhoneModal form').on('submit', function(e) {
                var phoneType = $('#edit_PhoneType').val();
                var digitCount = countDigits($('#edit_PhoneNumber').val());

                if (phoneType === 'Mobile' && digitCount < 9) {
                    e.preventDefault();
                    alert('Mobile phone numbers must have at least 9 digits. Please enter a valid mobile number or select Fixed Line.');
                    return false;
                }
            });

            // Populate Edit Phone Modal when shown
            $('#editPhoneModal').on('show.bs.modal', function(e) {
                var button = $(e.relatedTarget);

                // Set all field values and also set the value attribute for proper form submission
                $('#edit_PhoneId').val(button.data('phone-id')).attr('value', button.data('phone-id'));
                $('#edit_PhoneNumber').val(button.data('phone-number')).attr('value', button.data('phone-number'));

                // Map old phone types to new ones (Desk/Extension -> Fixed)
                var phoneType = button.data('phone-type');
                if (phoneType === 'Desk' || phoneType === 'Extension') {
                    phoneType = 'Fixed';
                }
                $('#edit_PhoneType').val(phoneType);

                $('#edit_LineType').val(button.data('phone-linetype'));
                $('#edit_Location').val(button.data('phone-location')).attr('value', button.data('phone-location') || '');
                $('#edit_Notes').val(button.data('phone-notes'));
                $('#edit_ClassOfServiceId').val(button.data('phone-classofservice') || '');
                $('#edit_Status').val(button.data('phone-status'));
                $('#edit_OwnershipType').val(button.data('phone-ownershiptype'));
                $('#edit_Purpose').val(button.data('phone-purpose')).attr('value', button.data('phone-purpose') || '');
                $('#edit_IndexNumber').val(button.data('phone-indexnumber') || '').trigger('change');

                // Show/hide purpose field
                if (button.data('phone-ownershiptype') === 1) {
                    $('#edit_purposeField').hide();
                } else {
                    $('#edit_purposeField').show();
                }

                // Apply phone type field toggling
                toggleFieldsForPhoneType('edit', phoneType);

                // Update hint for phone number
                var digitCount = countDigits(button.data('phone-number') || '');
                if (phoneType === 'Fixed' || digitCount < 9) {
                    $('#edit_phoneTypeHint').html('<i class="bi bi-info-circle"></i> Fixed Line - Line Type and Class of Service disabled');
                } else {
                    $('#edit_phoneTypeHint').html('<i class="bi bi-check-circle text-success"></i> ' + digitCount + ' digits - valid for Mobile');
                }
            });

            // Don't auto-reset Edit modal - let values persist for debugging

            // Checkbox Selection Logic
            var selectedPhones = [];

            function updateBulkActionsBar() {
                var count = selectedPhones.length;
                if (count > 0) {
                    $('#bulkActionsBar').show();
                    $('#selectedCount').text(count + ' phone' + (count > 1 ? 's' : '') + ' selected');
                } else {
                    $('#bulkActionsBar').hide();
                }
            }

            // Select All Phones checkbox
            $('#selectAllPhones').on('change', function() {
                var isChecked = $(this).is(':checked');
                $('.phone-checkbox').prop('checked', isChecked);

                selectedPhones = [];
                if (isChecked) {
                    $('.phone-checkbox').each(function() {
                        selectedPhones.push({
                            id: $(this).data('phone-id'),
                            number: $(this).data('phone-number')
                        });
                    });
                }
                updateBulkActionsBar();
            });

            // Individual phone checkbox
            $('.phone-checkbox').on('change', function() {
                var phoneId = $(this).data('phone-id');
                var phoneNumber = $(this).data('phone-number');

                if ($(this).is(':checked')) {
                    selectedPhones.push({ id: phoneId, number: phoneNumber });
                } else {
                    selectedPhones = selectedPhones.filter(p => p.id !== phoneId);
                    $('#selectAllPhones').prop('checked', false);
                }

                updateBulkActionsBar();
            });

            // Reassign Selected Button click
            $('#reassignSelectedBtn').on('click', function() {
                if (selectedPhones.length === 0) {
                    alert('Please select at least one phone number to reassign.');
                    return;
                }

                // Populate selected phones list in modal
                var phonesList = selectedPhones.map(p =>
                    '<div class="mb-2"><i class="bi bi-telephone me-2"></i>' + p.number + '</div>'
                ).join('');
                $('#reassign_selectedPhones').html(phonesList);

                // Set phone IDs as comma-separated string
                $('#reassign_phoneIds').val(selectedPhones.map(p => p.id).join(','));

                // Reset user selection
                $('#reassign_IndexNumber').val(null).trigger('change');

                // Show modal
                $('#reassignPhoneModal').modal('show');
            });

            // Reset Reassign modal when closed
            $('#reassignPhoneModal').on('hidden.bs.modal', function() {
                $(this).find('form')[0].reset();
                $('#reassign_IndexNumber').val(null).trigger('change');
                $('#reassign_selectedPhones').html('');
            });
        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}
