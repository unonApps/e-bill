                                        @i
                                    </a>
                                </li>
                            }
                            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                                <a class="page-link" href="?PageNumber=@(Model.PageNumber + 1)&SearchTerm=@Model.SearchTerm&FilterOwnershipType=@Model.FilterOwnershipType&FilterLineType=@Model.FilterLineType&FilterStatus=@Model.FilterStatus&FilterAssigned=@Model.FilterAssigned&PageSize=@Model.PageSize">
