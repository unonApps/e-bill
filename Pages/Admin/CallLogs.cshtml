        // Function to view import details
        async function viewImportDetails(importId) {
            try {
                const response = await fetch(`/Admin/CallLogs?handler=ImportDetails&id=${importId}`, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (response.ok) {
                    const data = await response.json();
                    showImportDetailsModal(data);
                } else {
                    alert('Failed to load import details');
                }
            } catch (error) {
                console.error('Error loading import details:', error);
                alert('Error loading import details');
            }
        }

        // Function to show import details modal
        function showImportDetailsModal(data) {
            const modal = document.getElementById('importDetailsModal');
            if (!modal) {
                // Create modal if it doesn't exist
                const modalHtml = `
                    <div class="modal fade" id="importDetailsModal" tabindex="-1">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Import Details</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body" id="importDetailsBody">
                                    <!-- Content will be inserted here -->
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                document.body.insertAdjacentHTML('beforeend', modalHtml);
            }

            // Populate modal content
            const body = document.getElementById('importDetailsBody');
            body.innerHTML = `
                <div class="mb-3">
                    <h6>Import Summary</h6>
                    <table class="table table-sm">
                        <tr><td>Type:</td><td>${data.importType}</td></tr>
                        <tr><td>File:</td><td>${data.fileName}</td></tr>
                        <tr><td>Date:</td><td>${new Date(data.importDate).toLocaleString()}</td></tr>
                        <tr><td>Imported By:</td><td>${data.importedBy}</td></tr>
                        <tr><td>Total Records:</td><td>${data.totalRecords}</td></tr>
                        <tr><td>Success:</td><td class="text-success">${data.successCount}</td></tr>
                        <tr><td>Failed:</td><td class="text-danger">${data.errorCount}</td></tr>
                        <tr><td>Skipped:</td><td class="text-warning">${data.skippedCount}</td></tr>
                    </table>
                </div>
                ${data.summaryMessage ? `<div class="alert alert-info">${data.summaryMessage}</div>` : ''}
                ${data.errors && data.errors.length > 0 ? `
                    <div class="mb-3">
                        <h6 class="text-danger">Errors (${data.errors.length})</h6>
                        <div class="table-responsive" style="max-height: 200px; overflow-y: auto;">
                            <table class="table table-sm">
                                <thead>
                                    <tr><th>Line</th><th>Error</th></tr>
                                </thead>
                                <tbody>
                                    ${data.errors.map(e => `
                                        <tr>
                                            <td>${e.lineNumber}</td>
                                            <td>${e.errorMessage}</td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    </div>
                ` : ''}
            `;

            // Show modal
            const modalInstance = new bootstrap.Modal(document.getElementById('importDetailsModal'));
            modalInstance.show();
        }

