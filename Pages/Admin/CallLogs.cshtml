        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);">
            <div class="modal-header border-0 pb-0" style="padding: 2rem 2rem 1rem 2rem;">
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                         style="width: 48px; height: 48px;">
                        <i class="bi bi-exclamation-triangle text-warning" style="font-size: 24px;"></i>
                    </div>
