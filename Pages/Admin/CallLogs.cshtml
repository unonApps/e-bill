@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Bulk Selection Functions
        function toggleSelectAll(checkbox) {
            const checkboxes = document.querySelectorAll('.record-checkbox');
            checkboxes.forEach(cb => {
                cb.checked = checkbox.checked;
            });
            updateBulkActionsBar();
        }

        function updateBulkActionsBar() {
            const checkboxes = document.querySelectorAll('.record-checkbox:checked');
            const bulkActionsBar = document.getElementById('bulkActionsBar');
            const selectedCount = document.getElementById('selectedCount');
            const selectAllCheckbox = document.getElementById('selectAll');

            if (checkboxes.length > 0) {
                bulkActionsBar.classList.remove('d-none');
                selectedCount.textContent = checkboxes.length;
            } else {
                bulkActionsBar.classList.add('d-none');
                selectAllCheckbox.checked = false;
            }
        }

        function clearSelection() {
            const checkboxes = document.querySelectorAll('.record-checkbox');
            checkboxes.forEach(cb => cb.checked = false);
            document.getElementById('selectAll').checked = false;
            updateBulkActionsBar();
        }

        function bulkDeleteRecords() {
            const checkboxes = document.querySelectorAll('.record-checkbox:checked');

            if (checkboxes.length === 0) {
                return;
            }

            // Group records by type
            const recordsByType = {};
            checkboxes.forEach(cb => {
                const type = cb.dataset.type;
                const id = cb.dataset.id;

                if (!recordsByType[type]) {
                    recordsByType[type] = [];
                }
                recordsByType[type].push(id);
            });

            // Update confirmation modal
            const totalRecords = checkboxes.length;
            document.getElementById('deleteCount').textContent = totalRecords;

            // Show record types summary
            const summaryDiv = document.getElementById('recordTypesSummary');
            summaryDiv.innerHTML = '';

            Object.keys(recordsByType).forEach(type => {
                const count = recordsByType[type].length;
                const badge = document.createElement('span');
                badge.className = 'badge bg-info bg-opacity-10 text-info';
                badge.style.fontSize = '0.875rem';
                badge.style.padding = '0.5rem 1rem';
                badge.innerHTML = `<i class="bi bi-telephone me-1"></i>${type}: ${count} record(s)`;
                summaryDiv.appendChild(badge);
            });

            // Show confirmation modal
            const confirmModal = new bootstrap.Modal(document.getElementById('bulkDeleteModal'));
            confirmModal.show();

            // Setup confirm button click handler
            document.getElementById('confirmBulkDeleteBtn').onclick = function() {
                // Hide confirmation modal
                confirmModal.hide();

                // Show progress modal
                const progressModal = new bootstrap.Modal(document.getElementById('bulkDeleteProgressModal'));
                progressModal.show();

                // Send bulk delete requests
                performBulkDelete(recordsByType, totalRecords, progressModal);
            };
        }

        function performBulkDelete(recordsByType, totalRecords, progressModal) {
            let completedRequests = 0;
            let totalDeletedCount = 0;
            let failedRecords = [];
            let stagedRecords = [];
            const totalTypes = Object.keys(recordsByType).length;

            Object.keys(recordsByType).forEach(type => {
                const ids = recordsByType[type];

                fetch('/Admin/CallLogs?handler=BulkDelete', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        type: type,
                        ids: ids
                    })
                })
                .then(response => response.json())
                .then(data => {
                    completedRequests++;

                    totalDeletedCount += data.deletedCount || 0;

                    if (data.failedRecords && data.failedRecords.length > 0) {
                        failedRecords.push(...data.failedRecords);
                    }

                    if (data.stagedRecords && data.stagedRecords.length > 0) {
                        stagedRecords.push(...data.stagedRecords);
                    }

                    // Check if all requests completed
                    if (completedRequests === totalTypes) {
                        progressModal.hide();
                        showBulkDeleteResult(totalDeletedCount, failedRecords, stagedRecords, totalRecords);
                    }
                })
                .catch(error => {
                    completedRequests++;
                    failedRecords.push(...ids);

                    if (completedRequests === totalTypes) {
                        progressModal.hide();
                        showBulkDeleteResult(totalDeletedCount, failedRecords, stagedRecords, totalRecords);
                    }
                });
            });
        }

        function showBulkDeleteResult(deletedCount, failedRecords, stagedRecords, totalRecords) {
            const resultModal = new bootstrap.Modal(document.getElementById('bulkDeleteResultModal'));
            const resultIcon = document.getElementById('resultIcon');
            const resultMessage = document.getElementById('resultMessage');

            const failedCount = failedRecords.length;
            const stagedCount = stagedRecords.length;
            const successCount = deletedCount;

            if (failedCount === 0 && stagedCount === 0) {
                // All deleted successfully
                resultIcon.className = 'rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-3';
                resultIcon.style.width = '48px';
                resultIcon.style.height = '48px';
                resultIcon.innerHTML = '<i class="bi bi-check-circle text-success" style="font-size: 24px;"></i>';

                resultMessage.innerHTML = `
                    <div class="alert alert-success border-0" style="border-radius: 12px;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-check-circle-fill text-success me-2" style="font-size: 20px;"></i>
                            <div>
                                <p class="mb-0 fw-semibold">Successfully deleted ${successCount} record(s).</p>
                            </div>
                        </div>
                    </div>
                `;
            } else if (successCount > 0) {
                // Partial success
                resultIcon.className = 'rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center me-3';
                resultIcon.style.width = '48px';
                resultIcon.style.height = '48px';
                resultIcon.innerHTML = '<i class="bi bi-exclamation-triangle text-warning" style="font-size: 24px;"></i>';

                let failureReasons = [];
                if (stagedCount > 0) {
                    failureReasons.push(`<li><strong>${stagedCount}</strong> record(s) are staged for verification</li>`);
                }
                if (failedCount > 0) {
                    failureReasons.push(`<li><strong>${failedCount}</strong> record(s) failed to delete</li>`);
                }

                resultMessage.innerHTML = `
                    <div class="alert alert-warning border-0" style="border-radius: 12px;">
                        <div class="d-flex align-items-start">
                            <i class="bi bi-info-circle-fill text-warning me-2" style="font-size: 20px;"></i>
                            <div>
                                <p class="mb-2 fw-semibold">Partial deletion completed:</p>
                                <ul class="mb-0">
                                    <li><strong>${successCount}</strong> record(s) deleted successfully</li>
                                    ${failureReasons.join('')}
                                </ul>
                            </div>
                        </div>
                    </div>
                `;
            } else {
                // All failed
                resultIcon.className = 'rounded-circle bg-warning bg-opacity-10 d-flex align-items-center justify-content-center me-3';
                resultIcon.style.width = '48px';
                resultIcon.style.height = '48px';
                resultIcon.innerHTML = '<i class="bi bi-exclamation-triangle text-warning" style="font-size: 24px;"></i>';

                resultMessage.innerHTML = `
                    <div class="alert alert-warning border-0" style="border-radius: 12px;">
                        <div class="d-flex align-items-start">
                            <i class="bi bi-exclamation-triangle-fill text-warning me-2" style="font-size: 20px;"></i>
                            <div>
                                <p class="mb-2 fw-semibold">Cannot Delete Records</p>
                                <p class="mb-0">All ${stagedCount} selected record(s) are staged for verification and cannot be deleted. Records that are part of the approval workflow must be removed from staging first.</p>
                            </div>
                        </div>
                    </div>
                `;
            }

            // Show result modal
            resultModal.show();

            // Reload page when modal is closed
            document.getElementById('bulkDeleteResultModal').addEventListener('hidden.bs.modal', function () {
                window.location.reload();
            }, { once: true });
        }

        // Handle page size change
        document.addEventListener('DOMContentLoaded', function() {
            const pageSizeSelect = document.getElementById('pageSizeSelect');
            if (pageSizeSelect) {
                pageSizeSelect.addEventListener('change', function() {
                    const url = new URL(window.location);
                    url.searchParams.set('PageSize', this.value);
                    url.searchParams.set('PageNumber', '1'); // Reset to first page when changing page size
                    window.location.href = url.toString();
                });
            }

            // Handle Recent Imports collapse chevron animation
            const recentImportsCollapse = document.getElementById('recentImportsCollapse');
            if (recentImportsCollapse) {
                recentImportsCollapse.addEventListener('show.bs.collapse', function () {
                    const header = document.querySelector('[data-bs-target="#recentImportsCollapse"]');
                    if (header) header.setAttribute('aria-expanded', 'true');
                });

                recentImportsCollapse.addEventListener('hide.bs.collapse', function () {
                    const header = document.querySelector('[data-bs-target="#recentImportsCollapse"]');
                    if (header) header.setAttribute('aria-expanded', 'false');
                });
            }
        });

        // Initialize billing period dropdowns
        document.addEventListener('DOMContentLoaded', function() {
            const billingYearSelect = document.getElementById('billingYear');
            const billingMonthSelect = document.getElementById('billingMonth');

            if (billingYearSelect && billingMonthSelect) {
                // Populate year dropdown (current year and 5 years back)
                const currentYear = new Date().getFullYear();
                for (let year = currentYear; year >= currentYear - 5; year--) {
                    const option = document.createElement('option');
                    option.value = year;
                    option.textContent = year;
                    billingYearSelect.appendChild(option);
                }

                // Set default to current month and year
                const currentMonth = new Date().getMonth() + 1;
                billingMonthSelect.value = currentMonth.toString();
                billingYearSelect.value = currentYear.toString();
            }
        });

        // Toggle between regular, PSTN, Private Wire, Safaricom, and Airtel format tables
        document.addEventListener('DOMContentLoaded', function() {
            const regularRadio = document.getElementById('typeRegular');
            const pstnRadio = document.getElementById('typePSTN');
            const privateWireRadio = document.getElementById('typePrivateWire');
            const safaricomRadio = document.getElementById('typeSafaricom');
            const airtelRadio = document.getElementById('typeAirtel');
            const regularTable = document.getElementById('regularFormatTable');
            const pstnTable = document.getElementById('pstnFormatTable');
            const privateWireTable = document.getElementById('privateWireFormatTable');
            const safaricomTable = document.getElementById('safaricomFormatTable');
            const airtelTable = document.getElementById('airtelFormatTable');
            const helpText = document.getElementById('fileUploadHelpText');
            const typeDesc = document.getElementById('typeDescription');

            function toggleFormatTable() {
                // Hide all tables first
                if (regularTable) regularTable.style.display = 'none';
                if (pstnTable) pstnTable.style.display = 'none';
                if (privateWireTable) privateWireTable.style.display = 'none';
                if (safaricomTable) safaricomTable.style.display = 'none';
                if (airtelTable) airtelTable.style.display = 'none';

                if (pstnRadio && pstnRadio.checked) {
                    if (pstnTable) pstnTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing PSTN call log data with extended fields.';
                    if (typeDesc) typeDesc.textContent = 'PSTN - Public Switched Telephone Network logs for traditional phone systems.';
                } else if (privateWireRadio && privateWireRadio.checked) {
                    if (privateWireTable) privateWireTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing Private Wire telecommunications service records.';
                    if (typeDesc) typeDesc.textContent = 'Private Wire - Dedicated telecommunications circuits with USD billing.';
                } else if (safaricomRadio && safaricomRadio.checked) {
                    if (safaricomTable) safaricomTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing Safaricom call records exported from their billing system.';
                    if (typeDesc) typeDesc.textContent = 'Safaricom - Leading telecommunications service provider in Kenya.';
                } else if (airtelRadio && airtelRadio.checked) {
                    if (airtelTable) airtelTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing Airtel call records exported from their billing system.';
                    if (typeDesc) typeDesc.textContent = 'Airtel - Major telecommunications service provider operating in Kenya and Africa.';
                } else {
                    if (regularTable) regularTable.style.display = 'block';
                    if (helpText) helpText.textContent = 'Upload a CSV file containing call log data. Phone numbers will be matched with E-bill users.';
                    if (typeDesc) typeDesc.textContent = 'Regular - Standard mobile/telephone billing records.';
                }
            }

            if (regularRadio) {
                regularRadio.addEventListener('change', toggleFormatTable);
            }
            if (pstnRadio) {
                pstnRadio.addEventListener('change', toggleFormatTable);
            }
            if (privateWireRadio) {
                privateWireRadio.addEventListener('change', toggleFormatTable);
            }
            if (safaricomRadio) {
                safaricomRadio.addEventListener('change', toggleFormatTable);
            }
            if (airtelRadio) {
                airtelRadio.addEventListener('change', toggleFormatTable);
            }

            // Initialize on page load
            toggleFormatTable();
        });

        // Preview CSV function
        function previewCSV() {
            const fileInput = document.getElementById('callLogFile');
            const file = fileInput.files[0];

            if (!file) {
                alert('Please select a CSV file first.');
                return;
            }

            // Get selected billing period values
            const billingMonth = document.getElementById('billingMonth').value;
            const billingYear = document.getElementById('billingYear').value;

            if (!billingMonth || !billingYear) {
                alert('Please select billing month and year first.');
                return;
            }

            // Calculate billing period string (first day of the month)
            const billingPeriodDate = new Date(parseInt(billingYear), parseInt(billingMonth) - 1, 1);
            const billingPeriodString = billingPeriodDate.toISOString().split('T')[0];
            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                              'July', 'August', 'September', 'October', 'November', 'December'];
            const monthName = monthNames[parseInt(billingMonth) - 1];

            const reader = new FileReader();
            reader.onload = function(e) {
                const text = e.target.result;
                const lines = text.split('\n').filter(line => line.trim());

                if (lines.length < 2) {
                    alert('The CSV file appears to be empty or has no data rows.');
                    return;
                }

                // Parse CSV
                const headers = parseCSVLine(lines[0]);
                const dataRows = lines.slice(1, Math.min(11, lines.length)) // Show first 10 data rows
                    .map(line => parseCSVLine(line));

                // Find indices for billing period columns
                const billingPeriodIndex = headers.findIndex(h => h.toLowerCase() === 'billingperiod');
                const callMonthIndex = headers.findIndex(h => h.toLowerCase() === 'call_month' || h.toLowerCase() === 'callmonth');
                const callYearIndex = headers.findIndex(h => h.toLowerCase() === 'call_year' || h.toLowerCase() === 'callyear');

                // Update preview summary
                const totalRows = lines.length - 1;
                document.getElementById('previewSummary').textContent =
                    `Found ${totalRows} row${totalRows !== 1 ? 's' : ''} in the CSV file. Showing first ${Math.min(10, totalRows)} rows. Billing Period: ${monthName} ${billingYear}`;
                document.getElementById('totalRowsCount').textContent = totalRows;
                document.getElementById('validRowsCount').textContent = totalRows; // Will be updated after validation

                // Build preview table headers
                const headerRow = document.getElementById('previewHeaders');
                headerRow.innerHTML = '';
                headers.forEach(header => {
                    const th = document.createElement('th');
                    th.textContent = header;
                    th.className = 'text-nowrap';
                    headerRow.appendChild(th);
                });

                // Build preview table body
                const tbody = document.getElementById('previewBody');
                tbody.innerHTML = '';
                dataRows.forEach((row, index) => {
                    const tr = document.createElement('tr');
                    headers.forEach((header, colIndex) => {
                        const td = document.createElement('td');

                        // Override billing period columns with selected values
                        if (colIndex === billingPeriodIndex) {
                            td.textContent = billingPeriodString;
                            td.className = 'text-nowrap fw-bold text-primary';
                            td.title = 'Will be set to: ' + billingPeriodString;
                        } else if (colIndex === callMonthIndex) {
                            td.textContent = billingMonth;
                            td.className = 'text-nowrap fw-bold text-primary';
                            td.title = 'Will be set to: ' + billingMonth;
                        } else if (colIndex === callYearIndex) {
                            td.textContent = billingYear;
                            td.className = 'text-nowrap fw-bold text-primary';
                            td.title = 'Will be set to: ' + billingYear;
                        } else {
                            td.textContent = row[colIndex] || '';
                            td.className = 'text-nowrap';
                        }

                        tr.appendChild(td);
                    });
                    tbody.appendChild(tr);
                });

                // Switch to preview step
                showPreviewStep();
            };

            reader.readAsText(file);
        }

        // Parse CSV line (handles quoted values)
        function parseCSVLine(line) {
            const result = [];
            let current = '';
            let inQuotes = false;

            for (let i = 0; i < line.length; i++) {
                const char = line[i];
                const nextChar = line[i + 1];

                if (char === '"') {
                    if (inQuotes && nextChar === '"') {
                        current += '"';
                        i++; // Skip next quote
                    } else {
                        inQuotes = !inQuotes;
                    }
                } else if (char === ',' && !inQuotes) {
                    result.push(current.trim());
                    current = '';
                } else {
                    current += char;
                }
            }

            result.push(current.trim());
            return result;
        }

        // Show preview step
        function showPreviewStep() {
            // Update step indicators
            document.getElementById('step1Indicator').classList.remove('active');
            document.getElementById('step1Indicator').classList.add('completed');
            document.getElementById('step2Indicator').classList.add('active');

            // Hide upload content, show preview
            document.getElementById('uploadStep').style.display = 'none';
            document.getElementById('previewStep').style.display = 'block';

            // Update buttons
            document.getElementById('previewButton').style.display = 'none';
            document.getElementById('backButton').style.display = 'inline-block';
            document.getElementById('importButton').style.display = 'inline-block';
        }

        // Go back to upload step
        function goBackToUpload() {
            // Update step indicators
            document.getElementById('step1Indicator').classList.add('active');
            document.getElementById('step1Indicator').classList.remove('completed');
            document.getElementById('step2Indicator').classList.remove('active');

            // Show upload content, hide preview
            document.getElementById('uploadStep').style.display = 'block';
            document.getElementById('previewStep').style.display = 'none';

            // Update buttons
            document.getElementById('previewButton').style.display = 'inline-block';
            document.getElementById('backButton').style.display = 'none';
            document.getElementById('importButton').style.display = 'none';
        }

