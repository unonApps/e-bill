        // Search users for linking
        async function searchUsersForLinking(searchTerm) {
            const resultsDiv = document.getElementById('userSearchResults');

            // Show loading
            resultsDiv.innerHTML = `
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Searching...</span>
                    </div>
                    <p class="mt-2 mb-0">Searching for users...</p>
                </div>
            `;

            try {
                const response = await fetch(`/Admin/CallLogs?handler=SearchUsers&searchTerm=${encodeURIComponent(searchTerm || '')}&accountNo=${encodeURIComponent(currentLinkingRecord?.accountNo || '')}`);
                const data = await response.json();

                if (data.users && data.users.length > 0) {
                    if (data.exactMatch && data.users.length === 1) {
                        // Auto-select exact match
                        resultsDiv.innerHTML = `
                            <div class="alert alert-success">
                                <i class="bi bi-check-circle me-2"></i>
                                <strong>Exact match found!</strong> Account number matched with user below.
                            </div>
                        `;
                    } else {
                        resultsDiv.innerHTML = '';
                    }

                    // Display users
                    const usersHtml = data.users.map(user => `
                        <div class="border rounded p-3 mb-2 user-select-card" style="cursor: pointer;"
                             onclick="selectUserForLinking(${user.id}, '${user.firstName}', '${user.lastName}', '${user.indexNumber}', '${user.email || 'N/A'}', '${user.phoneNumber || 'N/A'}', '${user.organizationName}', '${user.officeName}')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1">
                                        <i class="bi bi-person-circle me-2 text-primary"></i>
                                        ${user.firstName} ${user.lastName}
                                    </h6>
                                    <div class="small text-muted">
                                        <div><i class="bi bi-hash me-1"></i>Index: ${user.indexNumber}</div>
                                        <div><i class="bi bi-envelope me-1"></i>Email: ${user.email || 'N/A'}</div>
                                        <div><i class="bi bi-telephone me-1"></i>Phone: ${user.phoneNumber || 'N/A'}</div>
                                        <div><i class="bi bi-building me-1"></i>Org: ${user.organizationName} - ${user.officeName}</div>
                                    </div>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-primary">
                                        Select
                                    </button>
                                </div>
                            </div>
                        </div>
                    `).join('');

                    resultsDiv.innerHTML += usersHtml;

                    // Auto-select if exact match
                    if (data.exactMatch && data.users.length === 1) {
                        const user = data.users[0];
                        selectUserForLinking(user.id, user.firstName, user.lastName, user.indexNumber,
                                           user.email || 'N/A', user.phoneNumber || 'N/A',
                                           user.organizationName, user.officeName);
                    }
                } else {
                    resultsDiv.innerHTML = `
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            No users found matching "${searchTerm || currentLinkingRecord?.accountNo}".
                            Try searching with a different term.
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error searching users:', error);
                resultsDiv.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-x-circle me-2"></i>
                        Error searching for users. Please try again.
                    </div>
                `;
            }
        }

        // Select user for linking
        function selectUserForLinking(userId, firstName, lastName, indexNumber, email, phone, org, office) {
            selectedUserId = userId;

            // Update UI
            document.querySelectorAll('.user-select-card').forEach(card => {
                card.classList.remove('border-primary', 'bg-light');
            });
            event.currentTarget.classList.add('border-primary', 'bg-light');

            // Show preview
            const previewDiv = document.getElementById('selectedUserPreview');
            const detailsDiv = document.getElementById('selectedUserDetails');

            detailsDiv.innerHTML = `
                <div class="row">
                    <div class="col-md-6">
                        <strong>${firstName} ${lastName}</strong><br>
                        <span class="text-muted">Index: ${indexNumber}</span>
                    </div>
                    <div class="col-md-6">
                        <small class="text-muted">
                            Email: ${email}<br>
                            Phone: ${phone}<br>
                            ${org} - ${office}
                        </small>
                    </div>
                </div>
            `;

            previewDiv.classList.remove('d-none');
            document.getElementById('confirmLinkButton').disabled = false;
        }

        // Initialize search input
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('userSearchInput');
            if (searchInput) {
                let searchTimeout;
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        searchUsersForLinking(this.value);
                    }, 500);
                });
            }

            // Confirm link button
            const confirmButton = document.getElementById('confirmLinkButton');
            if (confirmButton) {
                confirmButton.addEventListener('click', async function() {
                    if (!selectedUserId || !currentLinkingRecord) return;

                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Linking...';

                    try {
                        const formData = new FormData();
                        formData.append('type', currentLinkingRecord.type);
                        formData.append('id', currentLinkingRecord.id);
                        formData.append('userId', selectedUserId);
                        formData.append('extension', currentLinkingRecord.extension || '');

                        const response = await fetch('/Admin/CallLogs?handler=LinkTelecom', {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: formData
                        });

                        const result = await response.json();

                        if (result.success) {
                            // Close modal
                            bootstrap.Modal.getInstance(document.getElementById('linkUserModal')).hide();

                            // Show success message with count of linked records
                            const countMsg = result.linkedCount > 1 ? ` (${result.linkedCount} records with same extension)` : '';
                            alert(`Success! Linked to ${result.userName}${countMsg}`);

                            // Reload page to show updated data
                            window.location.reload();
                        } else {
                            alert(`Error: ${result.message}`);
                            this.disabled = false;
                            this.innerHTML = '<i class="bi bi-link-45deg me-1"></i>Link User';
                        }
                    } catch (error) {
                        console.error('Error linking record:', error);
                        alert('An error occurred while linking the record.');
                        this.disabled = false;
                        this.innerHTML = '<i class="bi bi-link-45deg me-1"></i>Link User';
                    }
                });
            }

            // Confirm register extension button
            const confirmRegisterButton = document.getElementById('confirmRegisterButton');
            if (confirmRegisterButton) {
                confirmRegisterButton.addEventListener('click', async function() {
                    if (!currentRegisteringRecord) return;

                    // Check if LineType is Primary and show confirmation if needed
                    const lineType = document.getElementById('extensionLineTypeSelect').value;
                    if (lineType === '1' && !extensionRegisterFormSubmitting) {
                        pendingPrimaryAction = 'registerExtension';
                        const modal = new bootstrap.Modal(document.getElementById('primaryLineConfirmModal'));
                        modal.show();
                        return; // Stop here, will continue after confirmation
                    }

                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Registering...';

                    try {
                        const formData = new FormData();
                        formData.append('type', currentRegisteringRecord.type);
                        formData.append('id', currentRegisteringRecord.id);
                        formData.append('extension', currentRegisteringRecord.extension);
                        formData.append('userId', currentRegisteringRecord.userId);
                        formData.append('phoneType', document.getElementById('extensionTypeSelect').value);
                        formData.append('isPrimary', document.getElementById('extensionPrimaryCheckbox').checked);
                        formData.append('lineType', document.getElementById('extensionLineTypeSelect').value);
                        formData.append('classOfService', document.getElementById('extensionClassOfServiceSelect').value);
                        formData.append('location', document.getElementById('extensionLocationInput').value);
                        formData.append('notes', document.getElementById('extensionNotesInput').value);

                        const response = await fetch('/Admin/CallLogs?handler=RegisterExtension', {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: formData
                        });

                        const result = await response.json();

                        if (result.success) {
                            // Close modal and reload page to show updated data
                            bootstrap.Modal.getInstance(document.getElementById('registerExtensionModal')).hide();
                            window.location.reload();
                        } else {
                            alert(`Error: ${result.message}`);
                            this.disabled = false;
                            this.innerHTML = '<i class="bi bi-telephone-plus me-1"></i>Register Extension';
                        }
                    } catch (error) {
                        console.error('Error registering extension:', error);
                        alert('An error occurred while registering the extension.');
                        this.disabled = false;
                        this.innerHTML = '<i class="bi bi-telephone-plus me-1"></i>Register Extension';
                    }
                });
            }
        });

        // Delete import batch
        let currentBatchToDelete = null;

        function deleteImportBatch(importId, importType, totalRecords) {
            // Store batch info for deletion
            currentBatchToDelete = { importId, importType, totalRecords };

            // Update modal content
            document.getElementById('batchImportId').textContent = `#${importId}`;
            document.getElementById('batchImportType').textContent = importType.toUpperCase();
            document.getElementById('batchTotalRecords').textContent = totalRecords;

            // Update modal title and message based on whether batch is empty
            const modalTitle = document.querySelector('#deleteImportBatchModal .modal-title');
            const modalSubtitle = document.querySelector('#deleteImportBatchModal .modal-header .text-muted');
            const alertBox = document.querySelector('#deleteImportBatchModal .alert');
            const confirmBtn = document.getElementById('confirmDeleteImportBatchBtn');

            if (totalRecords === 0) {
                modalTitle.textContent = 'Remove Empty Import Batch';
                modalSubtitle.textContent = 'This batch has no records';
                alertBox.querySelector('p.fw-semibold').textContent = 'You are about to remove an empty import batch';
                alertBox.querySelector('p.small').textContent = 'This import batch contains no records and can be safely removed.';
                confirmBtn.innerHTML = '<i class="bi bi-trash me-1"></i>Remove Empty Batch';
            } else {
                modalTitle.textContent = 'Delete Import Batch';
                modalSubtitle.textContent = 'This action cannot be undone';
                alertBox.querySelector('p.fw-semibold').textContent = 'You are about to delete an entire import batch';
                alertBox.querySelector('p.small').textContent = 'This will permanently delete all records from this import. This action cannot be undone!';
                confirmBtn.innerHTML = '<i class="bi bi-trash me-1"></i>Delete Import Batch';
            }

            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('deleteImportBatchModal'));
            modal.show();
        }

        // Handle confirm button click
        document.addEventListener('DOMContentLoaded', function() {
            document.getElementById('confirmDeleteImportBatchBtn').addEventListener('click', function() {
                if (!currentBatchToDelete) return;

                const btn = this;
                const originalHTML = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Deleting...';

                fetch(`/Admin/CallLogs?handler=DeleteImportBatch&importId=${currentBatchToDelete.importId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        bootstrap.Modal.getInstance(document.getElementById('deleteImportBatchModal')).hide();
                        window.location.reload();
                    } else {
                        // Hide the delete confirmation modal
                        bootstrap.Modal.getInstance(document.getElementById('deleteImportBatchModal')).hide();

                        // Show error in modal
                        document.getElementById('errorMessageText').textContent = data.message;
                        const errorModal = new bootstrap.Modal(document.getElementById('deletionErrorModal'));
                        errorModal.show();

                        btn.disabled = false;
                        btn.innerHTML = originalHTML;
                    }
                })
                .catch(error => {
                    console.error('Error:', error);

                    // Hide the delete confirmation modal
                    bootstrap.Modal.getInstance(document.getElementById('deleteImportBatchModal')).hide();

                    // Show error in modal
                    document.getElementById('errorMessageText').textContent = 'An error occurred while deleting the import batch. Please try again.';
                    const errorModal = new bootstrap.Modal(document.getElementById('deletionErrorModal'));
                    errorModal.show();

                    btn.disabled = false;
                    btn.innerHTML = originalHTML;
                });
            });
        });

