                <button type="button" class="btn-close position-absolute" data-bs-dismiss="modal" aria-label="Close" style="top: 1rem; right: 1rem;"></button>
            </div>
            <div class="modal-body" style="padding: 1rem 2rem 2rem 2rem;">
                <!-- Step Indicator -->
                <div class="d-flex justify-content-center align-items-center mb-4">
                    <div class="d-flex align-items-center">
                        <div class="step-indicator active" id="uem-step1-indicator">
