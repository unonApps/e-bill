        // Link telecom record to user
        let currentLinkingRecord = null;
        let selectedUserId = null;
        let currentRegisteringRecord = null;

        function linkTelecomToUser(type, id, accountNo, extension) {
            currentLinkingRecord = { type, id, accountNo, extension };
            selectedUserId = null;

            // Update modal info
            document.getElementById('linkRecordInfo').textContent = `${type} Record - Extension: ${extension || 'N/A'}`;
            document.getElementById('userSearchInput').value = '';
            document.getElementById('userSearchResults').innerHTML = '';
            document.getElementById('selectedUserPreview').classList.add('d-none');
            document.getElementById('confirmLinkButton').disabled = true;

            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('linkUserModal'));
            modal.show();

            // Search for the account number automatically
            searchUsersForLinking(accountNo);
        }

        // Link to Registered Phone
        async function linkToRegisteredPhone(type, id, extension, userId) {
            if (!confirm(`Link this record to the registered phone with extension ${extension}?`)) {
                return;
            }

            try {
                const formData = new FormData();
                formData.append('type', type);
                formData.append('id', id);
                formData.append('extension', extension);
                formData.append('userId', userId);

                const response = await fetch('/Admin/CallLogs?handler=LinkToRegisteredPhone', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    window.location.reload();
                } else {
                    alert(`Error: ${result.message}`);
                }
            } catch (error) {
                console.error('Error linking to registered phone:', error);
                alert('An error occurred while linking to the registered phone.');
            }
        }

        // Register Extension
        async function registerExtension(type, id, extension, userId) {
            currentRegisteringRecord = { type, id, extension, userId };

            // Update modal info
            document.getElementById('registerExtensionInfo').textContent = `Extension: ${extension}`;
            document.getElementById('extensionNumberInput').value = extension;
            document.getElementById('extensionLineTypeSelect').value = '2'; // Default to Secondary
            document.getElementById('extensionPrimaryCheckbox').checked = false;
            document.getElementById('extensionPrimaryCheckbox').disabled = true; // Controlled by LineType
            document.getElementById('extensionClassOfServiceSelect').value = '';
            document.getElementById('extensionLocationInput').value = '';
            document.getElementById('extensionNotesInput').value = '';

            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('registerExtensionModal'));
            modal.show();

            // Load Class of Service options and fetch user details
            await Promise.all([
                loadClassOfServiceOptions(),
                loadUserDetailsForRegistration(userId)
            ]);
        }

        // Load Class of Service options
        async function loadClassOfServiceOptions() {
            const selectElement = document.getElementById('extensionClassOfServiceSelect');

            try {
                const response = await fetch('/Admin/CallLogs?handler=ClassOfServices');
                const data = await response.json();

                if (data.success && data.classOfServices) {
                    selectElement.innerHTML = '<option value="">Select Class of Service</option>';

                    data.classOfServices.forEach(cos => {
                        const option = document.createElement('option');
                        option.value = cos.class;
                        option.textContent = `${cos.class} - ${cos.service}`;
                        selectElement.appendChild(option);
                    });
                } else {
                    selectElement.innerHTML = '<option value="">No services available</option>';
                }
            } catch (error) {
                console.error('Error loading Class of Service options:', error);
                selectElement.innerHTML = '<option value="">Error loading services</option>';
            }
        }

        // Load user details and existing phones for registration modal
        async function loadUserDetailsForRegistration(userId) {
            const userInfoDiv = document.getElementById('registerUserInfo');
            const phonesInfoDiv = document.getElementById('existingPhonesInfo');

            try {
                const response = await fetch(`/Admin/CallLogs?handler=UserForRegistration&userId=${userId}`);
                const data = await response.json();

                if (data.success) {
                    // Display user information
                    userInfoDiv.innerHTML = `
                        <div class="row g-2">
                            <div class="col-md-6">
                                <small class="text-muted d-block" style="font-size: 0.75rem;">Name</small>
                                <div style="font-weight: 500;">${data.user.firstName} ${data.user.lastName}</div>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted d-block" style="font-size: 0.75rem;">Index Number</small>
                                <div style="font-weight: 500;">${data.user.indexNumber}</div>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted d-block" style="font-size: 0.75rem;">Email</small>
                                <div style="font-weight: 500;">${data.user.email || 'N/A'}</div>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted d-block" style="font-size: 0.75rem;">Organization</small>
                                <div style="font-weight: 500;">${data.user.organization}</div>
                            </div>
                            <div class="col-md-6">
                                <small class="text-muted d-block" style="font-size: 0.75rem;">Office</small>
                                <div style="font-weight: 500;">${data.user.office}</div>
                            </div>
                        </div>
                    `;

                    // Display existing phones
                    if (data.phones && data.phones.length > 0) {
                        const phonesHtml = data.phones.map(phone => `
                            <div class="d-flex align-items-center justify-content-between p-2 border-bottom">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge ${phone.isPrimary ? 'bg-primary' : 'bg-secondary'}" style="font-size: 0.7rem;">
                                            ${phone.phoneType}
                                        </span>
                                        <strong>${phone.phoneNumber}</strong>
                                        ${phone.isPrimary ? '<i class="bi bi-star-fill text-warning" title="Primary"></i>' : ''}
                                    </div>
                                    ${phone.classOfService ? `<small class="text-muted">COS: ${phone.classOfService}</small>` : ''}
                                    ${phone.location ? `<small class="text-muted d-block">Location: ${phone.location}</small>` : ''}
                                    ${phone.notes ? `<small class="text-muted d-block fst-italic">${phone.notes}</small>` : ''}
                                </div>
                                <div>
                                    <span class="badge ${phone.isActive ? 'bg-success' : 'bg-danger'}" style="font-size: 0.7rem;">
                                        ${phone.isActive ? 'Active' : 'Inactive'}
                                    </span>
                                </div>
                            </div>
                        `).join('');

                        phonesInfoDiv.innerHTML = `
                            <div style="max-height: 200px; overflow-y: auto;">
                                ${phonesHtml}
                            </div>
                            <small class="text-muted d-block mt-2">
                                <i class="bi bi-info-circle me-1"></i>Total: ${data.phones.length} phone(s) registered
                            </small>
                        `;
                    } else {
                        phonesInfoDiv.innerHTML = `
                            <div class="text-center py-3 text-muted">
                                <i class="bi bi-telephone-x" style="font-size: 1.5rem;"></i>
                                <p class="mb-0 mt-2">No phones registered yet</p>
                                <small>This will be the first phone for this user</small>
                            </div>
                        `;
                    }
                } else {
                    userInfoDiv.innerHTML = `
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Unable to load user details
                        </div>
                    `;
                    phonesInfoDiv.innerHTML = '';
                }
            } catch (error) {
                console.error('Error loading user details:', error);
                userInfoDiv.innerHTML = `
                    <div class="alert alert-danger mb-0">
                        <i class="bi bi-x-circle me-2"></i>
                        Error loading user information
                    </div>
                `;
                phonesInfoDiv.innerHTML = '';
