                            <div class="col-md-4">
                                <div class="form-group-modern">
                                    <label asp-for="Input.OfficeId" class="form-label-modern">Office</label>
                                    <select asp-for="Input.OfficeId" class="form-select form-select-modern" id="createOfficeId" onchange="filterSubOfficesByOffice('create')">
                                        <option value="">None selected</option>
                                    </select>
                                    <span asp-validation-for="Input.OfficeId" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="form-group-modern">
