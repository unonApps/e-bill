                                        <option value="">None selected</option>
                                        @foreach (var org in Model.AvailableOrganizations)
                                        {
                                            <option value="@org.Value">@org.Text</option>
                                        }
                                    </select>
                                    <span asp-validation-for="Input.OrganizationId" class="text-danger small"></span>
                                </div>
