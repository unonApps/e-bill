</div>

<!-- Role Management Modal -->
<div class="modal fade" id="roleManagementModal" tabindex="-1" aria-labelledby="roleManagementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0" style="padding: 2rem 2rem 1rem 2rem;">
                <div class="w-100 text-center">
                    <div class="mb-3">
                        <div class="bg-warning bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-person-gear text-warning" style="font-size: 24px;"></i>
                        </div>
                    </div>
                    <h4 class="modal-title fw-bold text-dark mb-1" id="roleManagementModalLabel">Manage User Roles</h4>
                    <p class="text-muted mb-0" id="roleModalUserInfo">Assign or remove roles for this user</p>
                </div>
                <button type="button" class="btn-close position-absolute" data-bs-dismiss="modal" aria-label="Close" style="top: 1rem; right: 1rem;"></button>
            </div>
            <div class="modal-body" style="padding: 1rem 2rem;">
                <!-- Current Roles Display -->
                <div class="mb-4">
                    <h6 class="text-muted text-uppercase fw-semibold mb-3" style="font-size: 0.75rem; letter-spacing: 1px;">Current Roles</h6>
                    <div id="currentRolesDisplay" class="d-flex flex-wrap gap-2 mb-3">
                        <!-- Current roles will be populated here -->
                    </div>
                </div>

                <!-- Role Actions -->
                <div class="mb-4">
                    <h6 class="text-muted text-uppercase fw-semibold mb-3" style="font-size: 0.75rem; letter-spacing: 1px;">Role Actions</h6>
                    <div id="roleActionsContainer">
                        <!-- Role action forms will be populated here -->
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0" style="padding: 1rem 2rem 2rem 2rem;">
                <div class="d-grid gap-2 d-md-flex justify-content-md-end w-100">
                    <button type="button" class="btn btn-light px-4 py-2" data-bs-dismiss="modal" style="border-radius: 12px; font-weight: 500;">Close</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Password Reset Result Modal -->
<div class="modal fade" id="passwordResetModal" tabindex="-1" aria-labelledby="passwordResetModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0" style="padding: 2rem 2rem 1rem 2rem; background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%); border-radius: 20px 20px 0 0;">
                <div class="w-100 text-center">
                    <div class="mb-3">
                        <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-key-fill text-warning" style="font-size: 24px;"></i>
                        </div>
                    </div>
                    <h4 class="modal-title fw-bold text-white mb-1" id="passwordResetModalLabel">Password Reset Successful</h4>
                    <p class="text-white-50 mb-0">New temporary password generated</p>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close" style="position: absolute; top: 1rem; right: 1rem;"></button>
            </div>
            <div class="modal-body" style="padding: 2rem;">
                <div class="alert alert-success mb-3" id="emailStatusAlert" style="display: none;">
                    <i class="bi bi-envelope-check me-2"></i>
                    <span id="emailStatusMessage"></span>
                </div>

                <div class="alert alert-warning mb-3" id="emailErrorAlert" style="display: none;">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    <span id="emailErrorMessage"></span>
                </div>

                <div class="card border-warning" style="border-radius: 16px; border-width: 2px;">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3">
                            <i class="bi bi-person-circle me-2 text-primary"></i>
                            User: <span id="resetUserEmail" class="text-muted"></span>
                        </h6>

                        <label class="form-label fw-semibold mb-2">Temporary Password:</label>
                        <div class="input-group mb-3">
                            <input type="text" class="form-control form-control-lg fw-bold text-center" id="generatedPassword" readonly style="font-size: 1.25rem; letter-spacing: 2px; background: #fef3c7; border: 2px solid #fbbf24; font-family: 'Courier New', monospace;">
                            <button class="btn btn-warning" type="button" onclick="copyPassword()" style="border: 2px solid #fbbf24;">
                                <i class="bi bi-clipboard" id="copyIcon"></i>
                                <span id="copyText">Copy</span>
                            </button>
                        </div>

                        <div class="alert alert-info mb-0" style="border-radius: 12px;">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Important:</strong>
                            <ul class="mb-0 mt-2 ps-3">
                                <li>Copy this password now - you won't be able to see it again</li>
                                <li>Share this password securely with the user</li>
                                <li>User must change this password on first login</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0" style="padding: 1rem 2rem 2rem 2rem;">
                <div class="d-grid w-100">
                    <button type="button" class="btn btn-warning btn-lg" data-bs-dismiss="modal" style="border-radius: 12px; font-weight: 600;">
                        <i class="bi bi-check-lg me-2"></i>Done
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Available roles from server-side
        const availableRoles = @Html.Raw(Json.Serialize(Model.AvailableRoles));
        
        // Enable Bootstrap dropdowns with smart positioning
        document.addEventListener('DOMContentLoaded', function () {
            var dropdownElementList = [].slice.call(document.querySelectorAll('.dropdown-toggle'))
            var dropdownList = dropdownElementList.map(function (dropdownToggleEl) {
                var dropdown = new bootstrap.Dropdown(dropdownToggleEl);
                
                // Add event listener to adjust dropdown position
                dropdownToggleEl.addEventListener('show.bs.dropdown', function (e) {
                    // Small delay to allow dropdown to be rendered
                    setTimeout(function() {
                        var dropdownMenu = dropdownToggleEl.nextElementSibling;
                        if (dropdownMenu && dropdownMenu.classList.contains('dropdown-menu')) {
                            var rect = dropdownMenu.getBoundingClientRect();
                            var viewportHeight = window.innerHeight;
                            
                            // If dropdown extends below viewport, add dropup class
                            if (rect.bottom > viewportHeight - 20) {
                                dropdownToggleEl.parentElement.classList.add('dropup');
                            } else {
                                dropdownToggleEl.parentElement.classList.remove('dropup');
                            }
                        }
                    }, 10);
                });
                
                return dropdown;
            });
        });
        
        // Function to populate edit user modal
        function editUser(userId, email, firstName, lastName, status, organizationId, officeId, subOfficeId) {
            document.getElementById('editUserId').value = userId;
            document.getElementById('editUserEmail').value = email;
            document.getElementById('editFirstName').value = firstName;
            document.getElementById('editLastName').value = lastName;
            document.getElementById('editStatus').value = status;
            document.getElementById('editOrganizationId').value = organizationId || '';

            // Load offices for the selected organization
            if (organizationId) {
                filterOfficesByOrganization('edit', function() {
                    document.getElementById('editOfficeId').value = officeId || '';
                    // Load sub-offices for the selected office
                    if (officeId) {
                        filterSubOfficesByOffice('edit', function() {
                            document.getElementById('editSubOfficeId').value = subOfficeId || '';
                        });
                    } else {
                        document.getElementById('editSubOfficeId').value = '';
                    }
                });
            } else {
                document.getElementById('editOfficeId').value = '';
                document.getElementById('editSubOfficeId').value = '';
            }

            // Get current user roles from the table
            var rolesCell = document.querySelector(`tr[data-user-id="${userId}"] td[data-roles]`);
            if (rolesCell) {
                var roles = rolesCell.getAttribute('data-roles');
                document.getElementById('editUserRoles').textContent = roles;
            }

            // Open the modal
            var editModal = new bootstrap.Modal(document.getElementById('editUserModal'));
            editModal.show();
        }
        
        // Function to manage user roles
        function manageRoles(userId, email, fullName) {
            document.getElementById('roleModalUserInfo').textContent = `Assign or remove roles for ${fullName} (${email})`;
            
            // Get current user roles from the table
            var rolesCell = document.querySelector(`tr[data-user-id="${userId}"] td[data-roles]`);
            var currentUserRoles = [];
            if (rolesCell) {
                var rolesText = rolesCell.getAttribute('data-roles');
                if (rolesText && rolesText.trim() !== '') {
                    currentUserRoles = rolesText.split(', ').map(role => role.trim());
                }
            }
            
            // Populate current roles display
            const currentRolesContainer = document.getElementById('currentRolesDisplay');
            currentRolesContainer.innerHTML = '';
            
            if (currentUserRoles.length === 0) {
                currentRolesContainer.innerHTML = '<span class="text-muted fst-italic">No roles assigned</span>';
            } else {
                currentUserRoles.forEach(role => {
                    const roleElement = document.createElement('span');
                    roleElement.className = 'badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 d-flex align-items-center';
                    roleElement.style.width = 'fit-content';
                    roleElement.innerHTML = `
                        ${role}
                        <button type="button" class="btn btn-link p-0 text-danger ms-2" style="font-size: 0.8rem; border: none; background: none;" 
                                onclick="removeRole('${userId}', '${role}')" title="Remove ${role}">
                            <i class="bi bi-x"></i>
                        </button>
                    `;
                    currentRolesContainer.appendChild(roleElement);
                });
            }
            
            // Populate role actions
            const roleActionsContainer = document.getElementById('roleActionsContainer');
            roleActionsContainer.innerHTML = '';
            
            // Show available roles to add
            const unassignedRoles = availableRoles.filter(role => !currentUserRoles.includes(role));
            
            if (unassignedRoles.length > 0) {
                const addRoleDiv = document.createElement('div');
                addRoleDiv.className = 'mb-3';
                addRoleDiv.innerHTML = '<h6 class="text-muted mb-2">Add Role:</h6>';
                
                const roleList = document.createElement('div');
                roleList.className = 'd-flex flex-wrap gap-2';
                
                unassignedRoles.forEach(role => {
                    const roleElement = document.createElement('span');
                    roleElement.className = 'badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 d-flex align-items-center';
                    roleElement.style.width = 'fit-content';
                    roleElement.innerHTML = `
                        ${role}
                        <button type="button" class="btn btn-link p-0 text-success ms-2" style="font-size: 0.8rem; border: none; background: none;" 
                                onclick="addRole('${userId}', '${role}')" title="Add ${role}">
                            <i class="bi bi-plus"></i>
                        </button>
                    `;
                    roleList.appendChild(roleElement);
                });
                
                addRoleDiv.appendChild(roleList);
                roleActionsContainer.appendChild(addRoleDiv);
            } else {
                roleActionsContainer.innerHTML = '<span class="text-muted fst-italic">All available roles are assigned</span>';
            }
            
            // Open the modal
            var roleModal = new bootstrap.Modal(document.getElementById('roleManagementModal'));
            roleModal.show();
        }
        
        // Function to add a role
        function addRole(userId, role) {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = '?handler=AddRole';
            
            const userIdInput = document.createElement('input');
            userIdInput.type = 'hidden';
            userIdInput.name = 'userId';
            userIdInput.value = userId;
            
            const roleInput = document.createElement('input');
            roleInput.type = 'hidden';
            roleInput.name = 'role';
            roleInput.value = role;
            
            // Add anti-forgery token
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            form.appendChild(userIdInput);
            form.appendChild(roleInput);
            form.appendChild(tokenInput);
            
            document.body.appendChild(form);
            form.submit();
        }
        
        // Function to remove a role
        function removeRole(userId, role) {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = '?handler=RemoveRole';
            
            const userIdInput = document.createElement('input');
            userIdInput.type = 'hidden';
            userIdInput.name = 'userId';
            userIdInput.value = userId;
            
            const roleInput = document.createElement('input');
            roleInput.type = 'hidden';
            roleInput.name = 'role';
            roleInput.value = role;
            
            // Add anti-forgery token
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
            
            form.appendChild(userIdInput);
            form.appendChild(roleInput);
            form.appendChild(tokenInput);
            
            document.body.appendChild(form);
            form.submit();
        }
        
        // Search functionality
        document.getElementById('searchUsers').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#usersTable tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });
        
        // Add animation to status badges
        document.querySelectorAll('.badge').forEach(badge => {
            badge.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-2px) scale(1.05)';
            });
            badge.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0) scale(1)';
            });
        });

        // Store all offices and sub-offices data
        var allOffices = @Html.Raw(Json.Serialize(Model.AvailableOffices));
        var allSubOffices = @Html.Raw(Json.Serialize(Model.AvailableSubOffices));

        // Function to filter offices by selected organization
        function filterOfficesByOrganization(formType, callback) {
            var organizationId = document.getElementById(formType + 'OrganizationId').value;
            var officeSelect = document.getElementById(formType + 'OfficeId');
            var subOfficeSelect = document.getElementById(formType + 'SubOfficeId');

            // Clear office dropdown
            officeSelect.innerHTML = '<option value="">None selected</option>';

            // Clear sub-office dropdown
            if (subOfficeSelect) {
                subOfficeSelect.innerHTML = '<option value="">None selected</option>';
            }

            if (organizationId) {
                // Filter offices that belong to the selected organization
                allOffices.forEach(function(office) {
                    // Check if this office belongs to the selected organization
                    // The text format is "Organization - Office"
                    var parts = office.text.split(' - ');
                    if (parts.length >= 2) {
                        var orgName = parts[0];
                        var officeName = parts[1];

                        // Find the organization name from the ID
                        var selectedOrgElement = document.querySelector('#' + formType + 'OrganizationId option[value="' + organizationId + '"]');
                        if (selectedOrgElement && selectedOrgElement.textContent === orgName) {
                            var option = document.createElement('option');
                            option.value = office.value;
                            option.textContent = officeName;
                            officeSelect.appendChild(option);
                        }
                    }
                });
            }

            if (callback) callback();
        }

        // Function to filter sub-offices by selected office
        function filterSubOfficesByOffice(formType, callback) {
            var officeId = document.getElementById(formType + 'OfficeId').value;
            var subOfficeSelect = document.getElementById(formType + 'SubOfficeId');

            // Clear sub-office dropdown
            if (subOfficeSelect) {
                subOfficeSelect.innerHTML = '<option value="">None selected</option>';

                if (officeId) {
                    // Get selected office text
                    var selectedOfficeElement = document.querySelector('#' + formType + 'OfficeId option[value="' + officeId + '"]');
                    var selectedOfficeName = selectedOfficeElement ? selectedOfficeElement.textContent : '';

                    // Get selected organization text
                    var organizationId = document.getElementById(formType + 'OrganizationId').value;
                    var selectedOrgElement = document.querySelector('#' + formType + 'OrganizationId option[value="' + organizationId + '"]');
                    var selectedOrgName = selectedOrgElement ? selectedOrgElement.textContent : '';

                    // Filter sub-offices that belong to the selected office
                    allSubOffices.forEach(function(subOffice) {
                        // The text format is "Organization - Office - SubOffice"
                        var parts = subOffice.text.split(' - ');
                        if (parts.length >= 3) {
                            var orgName = parts[0];
                            var officeName = parts[1];
                            var subOfficeName = parts[2];

                            if (orgName === selectedOrgName && officeName === selectedOfficeName) {
                                var option = document.createElement('option');
                                option.value = subOffice.value;
                                option.textContent = subOfficeName;
                                subOfficeSelect.appendChild(option);
                            }
                        }
                    });
                }
            }

            if (callback) callback();
        }

        // Function to reset user password
        function resetUserPassword() {
            // Get the userId from the edit modal (stored in hidden field)
            const userId = document.getElementById('editUserId').value;

            if (!userId) {
                alert('Error: No user selected');
                return;
            }

            // Get the reset button element
            const resetBtn = event.target.closest('button');
            const originalHtml = resetBtn.innerHTML;

            // Show loading state
            resetBtn.disabled = true;
            resetBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Generating...';

            // Make AJAX call to reset password
            fetch('?handler=ResetPassword', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: new URLSearchParams({ userId: userId })
            })
            .then(response => response.json())
            .then(data => {
                // Restore button state
                resetBtn.disabled = false;
                resetBtn.innerHTML = originalHtml;

                if (data.success) {
                    // Populate modal with data
                    document.getElementById('generatedPassword').value = data.password;
                    document.getElementById('resetUserEmail').textContent = data.email;

                    // Reset copy button state
                    document.getElementById('copyIcon').className = 'bi bi-clipboard';
                    document.getElementById('copyText').textContent = 'Copy';

                    // Show/hide email status
                    const emailStatusAlert = document.getElementById('emailStatusAlert');
                    const emailErrorAlert = document.getElementById('emailErrorAlert');

                    emailStatusAlert.style.display = 'none';
                    emailErrorAlert.style.display = 'none';

                    if (data.emailSent) {
                        emailStatusAlert.style.display = 'block';
                        document.getElementById('emailStatusMessage').textContent = `Password has been emailed to ${data.email}`;
                    }

                    if (data.emailError) {
                        emailErrorAlert.style.display = 'block';
                        document.getElementById('emailErrorMessage').textContent = `Email sending failed: ${data.emailError}. Please share the password manually with the user.`;
                    }

                    // Show the password modal
                    var passwordModal = new bootstrap.Modal(document.getElementById('passwordResetModal'));
                    passwordModal.show();
                } else {
                    alert('Error: ' + data.message);
                }
            })
            .catch(error => {
                // Restore button state
                resetBtn.disabled = false;
                resetBtn.innerHTML = originalHtml;
                alert('Error resetting password: ' + error);
            });
        }

        // Function to copy password to clipboard
        function copyPassword() {
            const passwordInput = document.getElementById('generatedPassword');
            passwordInput.select();
            passwordInput.setSelectionRange(0, 99999); // For mobile devices

            navigator.clipboard.writeText(passwordInput.value).then(() => {
                // Show success feedback
                document.getElementById('copyIcon').className = 'bi bi-check-lg';
                document.getElementById('copyText').textContent = 'Copied!';

                // Reset after 2 seconds
                setTimeout(() => {
                    document.getElementById('copyIcon').className = 'bi bi-clipboard';
                    document.getElementById('copyText').textContent = 'Copy';
                }, 2000);
            }).catch(err => {
                alert('Failed to copy password: ' + err);
            });
        }
    </script>
}
