                        <div class="row">
                            <div class="col-12 mb-2">
                                <div class="btn-group w-100" role="group" aria-label="Call log type">
                                    <input type="radio" class="btn-check" name="callLogType" id="typeRegular" value="regular" checked autocomplete="off">
                                    <label class="btn btn-outline-primary" for="typeRegular">
                                        <i class="bi bi-telephone me-1"></i>Regular
