@section Scripts {
    <script>
        // Page size change handler
        document.getElementById('pageSizeSelect').addEventListener('change', function() {
            const url = new URL(window.location);
            url.searchParams.set('PageSize', this.value);
            url.searchParams.set('PageNumber', '1');
            window.location.href = url.toString();
        });

        // Quick filter function
        function applyQuickFilter(filterType) {
            const url = new URL(window.location);
            url.searchParams.set('FilterType', filterType);
            url.searchParams.set('PageNumber', '1');
            window.location.href = url.toString();
        }

        // Auto-submit form on filter change
        document.querySelectorAll('.filter-select, .filter-input').forEach(element => {
            element.addEventListener('change', function() {
                if (this.closest('form')) {
                    // Add a small delay to allow user to potentially change multiple filters
                    setTimeout(() => {
                        this.closest('form').submit();
                    }, 500);
                }
            });
        });
        // Link telecom record to user
        let currentLinkingRecord = null;
        let selectedUserId = null;

        function linkTelecomToUser(type, id, accountNo) {
            currentLinkingRecord = { type, id, accountNo };
            selectedUserId = null;

            // Update modal info
            document.getElementById('linkRecordInfo').textContent = `${type} Record #${id} - Account: ${accountNo}`;
            document.getElementById('userSearchInput').value = '';
            document.getElementById('userSearchResults').innerHTML = '';
            document.getElementById('selectedUserPreview').classList.add('d-none');
            document.getElementById('confirmLinkButton').disabled = true;

            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('linkUserModal'));
            modal.show();

            // Search for the account number automatically
            searchUsersForLinking(accountNo);
        }

        // Search users for linking
        async function searchUsersForLinking(searchTerm) {
            const resultsDiv = document.getElementById('userSearchResults');

            // Show loading
            resultsDiv.innerHTML = `
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Searching...</span>
                    </div>
                    <p class="mt-2 mb-0">Searching for users...</p>
                </div>
            `;

            try {
                // Search for users
                const response = await fetch(`/Admin/CallLogs?handler=SearchUsers&searchTerm=${encodeURIComponent(searchTerm)}`);
                const data = await response.json();

                if (data.users && data.users.length > 0) {
                    resultsDiv.innerHTML = `
                        <div class="list-group">
                            ${data.users.map(user => `
                                <div class="list-group-item list-group-item-action" onclick="selectUserForLinking(${user.id}, '${user.firstName}', '${user.lastName}', '${user.email}', '${user.indexNumber}')">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                                             style="width: 40px; height: 40px;">
                                            <i class="bi bi-person text-primary"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <h6 class="mb-0">${user.firstName} ${user.lastName}</h6>
                                            <small class="text-muted">
                                                ${user.indexNumber} | ${user.email}
                                                ${user.phoneNumbers ? `<br>Phones: ${user.phoneNumbers}` : ''}
                                            </small>
                                        </div>
                                        ${user.matchType === 'exact' ? `
                                            <span class="badge bg-success">Exact Match</span>
                                        ` : ''}
                                    </div>
                                </div>
                            `).join('')}
                        </div>
                    `;
                } else {
                    resultsDiv.innerHTML = `
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            No users found matching "${searchTerm}". Try searching with a different term.
                        </div>
                    `;
                }
            } catch (error) {
                resultsDiv.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        An error occurred while searching. Please try again.
                    </div>
                `;
            }
        }

        // Select user for linking
        function selectUserForLinking(userId, firstName, lastName, email, indexNumber) {
            selectedUserId = userId;

            // Update preview
            const preview = document.getElementById('selectedUserPreview');
            const details = document.getElementById('selectedUserDetails');

            details.innerHTML = `
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-success bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                         style="width: 40px; height: 40px;">
                        <i class="bi bi-person-check text-success"></i>
                    </div>
                    <div>
                        <strong>${firstName} ${lastName}</strong><br>
                        <small class="text-muted">${indexNumber} | ${email}</small>
                    </div>
                </div>
            `;

            preview.classList.remove('d-none');
            document.getElementById('confirmLinkButton').disabled = false;

            // Highlight selected item
            document.querySelectorAll('#userSearchResults .list-group-item').forEach(item => {
                item.classList.remove('active');
            });
            event.currentTarget.classList.add('active');
        }

        // Setup user search input
        document.getElementById('userSearchInput')?.addEventListener('input', function(e) {
            const searchTerm = e.target.value.trim();
            if (searchTerm.length >= 2) {
                searchUsersForLinking(searchTerm);
            }
        });

        // Confirm link button
        document.getElementById('confirmLinkButton')?.addEventListener('click', async function() {
            if (!selectedUserId || !currentLinkingRecord) return;

            this.disabled = true;
            this.innerHTML = `
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                Linking...
            `;

            try {
                const formData = new FormData();
                formData.append('type', currentLinkingRecord.type);
                formData.append('id', currentLinkingRecord.id);
                formData.append('userId', selectedUserId);

                const response = await fetch('/Admin/CallLogs?handler=LinkTelecom', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    // Close modal and reload page
                    bootstrap.Modal.getInstance(document.getElementById('linkUserModal')).hide();
                    location.reload();
                } else {
                    alert('Failed to link user: ' + result.message);
                }
            } catch (error) {
                alert('An error occurred while linking the user.');
            } finally {
                this.disabled = false;
                this.innerHTML = '<i class="bi bi-link-45deg me-1"></i>Link User';
            }
        });

        // Delete telecom record
        let currentDeletingRecord = null;

        async function deleteTelecomRecord(type, id) {
            currentDeletingRecord = { type, id };

            // First check if the record can be deleted
            const checkResponse = await fetch(`/Admin/CallLogs?handler=CheckDeletePermission&type=${encodeURIComponent(type)}&id=${id}`);
            const checkResult = await checkResponse.json();

            const modalContent = document.getElementById('deleteConfirmContent');
            const confirmButton = document.getElementById('confirmDeleteButton');

            if (!checkResult.canDelete) {
                // Show warning that record cannot be deleted
                modalContent.innerHTML = `
                    <div class="alert alert-warning mb-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Cannot Delete This Record</strong>
                    </div>
                    <p class="mb-3">
                        This <strong>${type}</strong> record (#${id}) is part of an import batch and cannot be deleted individually.
                    </p>
                    <div class="bg-light rounded p-3">
                        <p class="mb-2"><strong>Reason:</strong></p>
                        <p class="mb-0">${checkResult.message}</p>
                    </div>
                    <div class="mt-3 text-muted">
                        <small>
                            <i class="bi bi-info-circle me-1"></i>
                            To remove this record, you must delete the entire import batch from the Import Audits page.
                        </small>
                    </div>
                `;
                confirmButton.style.display = 'none';
            } else {
                // Show delete confirmation
                modalContent.innerHTML = `
                    <p class="mb-3">
                        Are you sure you want to delete this <strong>${type}</strong> record (#${id})?
                    </p>
                    <div class="alert alert-danger mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Warning:</strong> This action cannot be undone.
                    </div>
                `;
                confirmButton.style.display = 'inline-block';
            }

            // Show the modal
            const modal = new bootstrap.Modal(document.getElementById('deleteConfirmModal'));
            modal.show();
        }

        // Confirm delete button
        document.getElementById('confirmDeleteButton')?.addEventListener('click', async function() {
            if (!currentDeletingRecord) return;

            this.disabled = true;
            this.innerHTML = `
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                Deleting...
            `;

            try {
                const formData = new FormData();
                formData.append('type', currentDeletingRecord.type);
                formData.append('id', currentDeletingRecord.id);

                const response = await fetch('/Admin/CallLogs?handler=DeleteTelecom', {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    // Close modal and reload page
                    bootstrap.Modal.getInstance(document.getElementById('deleteConfirmModal')).hide();
                    location.reload();
                } else {
                    alert('Failed to delete record: ' + result.message);
                }
            } catch (error) {
                alert('An error occurred while deleting the record.');
            } finally {
                this.disabled = false;
                this.innerHTML = '<i class="bi bi-trash me-1"></i>Delete Record';
            }
        });

        // View telecom details
        async function viewTelecomDetails(type, id) {
            // For now, show a simple alert
            alert(`Viewing details for ${type} record #${id}`);
            // You can implement a details modal here similar to the link and delete modals
        }
    </script>
}