    function updateAnomalyProgress(percent, status) {
        document.getElementById('anomalyProgressBar').style.width = percent + '%';
        document.getElementById('anomalyProgressPercent').textContent = percent + '%';
        if (status) {
            document.getElementById('anomalyProgressStatus').textContent = status;
