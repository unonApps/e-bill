@section Scripts {
<script>
    let currentBatchId = null;
    let progressInterval = null;
    let anomalyResultModal = null;
    let anomalyConfirmModal = null;
    let pendingConfirmAction = null;
    let staffLookupValid = false;

    // Initialize modals on page load
    document.addEventListener('DOMContentLoaded', function() {
        anomalyResultModal = new bootstrap.Modal(document.getElementById('anomalyResultModal'));
        anomalyConfirmModal = new bootstrap.Modal(document.getElementById('anomalyConfirmModal'));

        // Handle confirm modal proceed button
        document.getElementById('confirmModalProceedBtn').addEventListener('click', function() {
            anomalyConfirmModal.hide();
            if (pendingConfirmAction) {
                pendingConfirmAction();
                pendingConfirmAction = null;
            }
        });
    });

    // ==========================================
    // Staff Lookup
    // ==========================================
    function lookupStaff() {
        const indexNumber = document.getElementById('staffIndexNumber').value.trim();
        if (!indexNumber) return;

        const feedbackDiv = document.getElementById('staffLookupFeedback');
        feedbackDiv.style.display = 'block';
        feedbackDiv.innerHTML = `
            <div class="d-flex align-items-center p-2" style="background: #f3f4f6; border-radius: 8px;">
                <div class="spinner-border spinner-border-sm text-primary me-2" role="status"></div>
                <span class="small text-muted">Looking up staff member...</span>
            </div>`;

        fetch(`?handler=LookupStaff&indexNumber=${encodeURIComponent(indexNumber)}`)
            .then(response => response.json())
            .then(data => {
                if (data.found) {
                    document.getElementById('staffName').value = data.name;
                    document.getElementById('staffOrganization').value = data.organization;
                    staffLookupValid = true;

                    feedbackDiv.innerHTML = `
                        <div class="d-flex align-items-center p-2" style="background: #d1fae5; border-radius: 8px; border: 1px solid #22c55e;">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <span class="small"><strong>${data.name}</strong> - ${data.organization}</span>
                            <span class="badge bg-primary ms-2">${data.phoneCount} phone(s)</span>
                            ${!data.isActive ? '<span class="badge bg-warning ms-2">Inactive</span>' : ''}
                        </div>`;

                    // Enable preview button
                    document.getElementById('previewBtn').disabled = false;
                } else {
                    document.getElementById('staffName').value = '';
                    document.getElementById('staffOrganization').value = '';
                    staffLookupValid = false;

                    feedbackDiv.innerHTML = `
                        <div class="d-flex align-items-center p-2" style="background: #fee2e2; border-radius: 8px; border: 1px solid #ef4444;">
                            <i class="bi bi-x-circle-fill text-danger me-2"></i>
                            <span class="small text-danger">Staff member not found with index number "${indexNumber}"</span>
                        </div>`;

                    document.getElementById('previewBtn').disabled = true;
                    document.getElementById('startProcessingBtn').disabled = true;
