    // ==========================================
    // Reprocess Anomalies Functions
    // ==========================================
    function reprocessAnomalies(batchId, batchName, anomalyCount, button) {
        showConfirmModal({
            type: 'reprocess',
            message: `Re-check anomalies for <strong>"${batchName}"</strong>?`,
            details: `
                <div class="bg-light rounded-3 p-3">
                    <p class="mb-2 fw-semibold">This will:</p>
                    <ol class="mb-0 ps-3">
                        <li>Re-run anomaly detection on <strong>${anomalyCount.toLocaleString()}</strong> records</li>
                        <li>Auto-verify records that are now clean</li>
                        <li>Push newly verified records to production</li>
                    </ol>
                </div>
            `,
            note: 'Make sure you\'ve fixed the issues in EBill Users or User Phones first.'
        }, function() {
            executeReprocessAnomalies(batchId, batchName, button);
        });
    }

    function executeReprocessAnomalies(batchId, batchName, button) {
        const originalHtml = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        showAnomalyProgress('Re-checking Anomalies', batchName);
        updateAnomalyProgress(10, 'Matching phone numbers...');

        const formData = new FormData();
        formData.append('batchId', batchId);

        const progressSteps = [
            { percent: 25, status: 'Updating index numbers...' },
            { percent: 45, status: 'Re-running anomaly detection...' },
            { percent: 65, status: 'Auto-verifying clean records...' },
            { percent: 85, status: 'Pushing to production...' }
        ];
        let stepIndex = 0;
        const progressTimer = setInterval(() => {
            if (stepIndex < progressSteps.length) {
                updateAnomalyProgress(progressSteps[stepIndex].percent, progressSteps[stepIndex].status);
                stepIndex++;
            }
        }, 2000);

        fetch('?handler=ReprocessAnomalies', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(response => response.json())
        .then(data => {
            clearInterval(progressTimer);
            updateAnomalyProgress(100, 'Complete!');

            if (data.success) {
                button.innerHTML = '<i class="bi bi-check-lg"></i>';
                button.classList.remove('btn-outline-success');
                button.classList.add('btn-success');

                showAnomalyResultModal('reprocess', {
                    batchName: batchName,
                    originalCount: data.originalCount,
                    resolvedCount: data.resolvedCount,
                    remainingCount: data.remainingCount,
                    verifiedCount: data.verifiedCount
                });
            } else {
                showAnomalyResultModal('error', { message: data.message });
                button.innerHTML = originalHtml;
                button.disabled = false;
            }
        })
        .catch(error => {
            clearInterval(progressTimer);
            console.error('Error:', error);
            showAnomalyResultModal('error', { message: 'Error reprocessing anomalies. Please try again.' });
            button.innerHTML = originalHtml;
            button.disabled = false;
        });
    }

    // ==========================================
    // Upload Corrections Functions
    // ==========================================
    let uploadBatchId = null;
    let parsedCsvData = [];

    function showUploadModal(batchId, batchName) {
        uploadBatchId = batchId;
        document.getElementById('uploadBatchName').textContent = batchName;
        document.getElementById('correctionsFile').value = '';
        document.getElementById('uploadPreview').style.display = 'none';
        document.getElementById('uploadProgress').style.display = 'none';
        document.getElementById('uploadResult').style.display = 'none';
        document.getElementById('uploadCorrectionsBtn').disabled = true;
        parsedCsvData = [];

        new bootstrap.Modal(document.getElementById('uploadCorrectionsModal')).show();
    }

    function previewCsvFile(file) {
        if (!file) return;

        const reader = new FileReader();
        reader.onload = function(e) {
            const text = e.target.result;
            const lines = text.split('\n').filter(line => line.trim());

            if (lines.length < 2) {
                alert('CSV file must have a header row and at least one data row');
                return;
            }

            const headers = parseCSVLine(lines[0]);
            const requiredHeaders = ['Provider', 'Extension', 'Call Date'];

            const missingHeaders = requiredHeaders.filter(h => !headers.includes(h));
            if (missingHeaders.length > 0) {
                alert('Missing required columns: ' + missingHeaders.join(', '));
                return;
            }

            const hasIndexNumber = headers.includes('Index Number');

            parsedCsvData = [];
            for (let i = 1; i < lines.length && i <= 100; i++) {
                const values = parseCSVLine(lines[i]);
                if (values.length >= headers.length) {
                    const row = {};
                    headers.forEach((header, idx) => {
                        row[header] = values[idx] || '';
                    });
                    parsedCsvData.push(row);
                }
            }

            const thead = document.querySelector('#previewTable thead');
            const tbody = document.querySelector('#previewTable tbody');

            let displayHeaders = [...headers];
            if (!hasIndexNumber) {
                displayHeaders.push('Index Number');
            }

            thead.innerHTML = '<tr>' + displayHeaders.slice(0, 5).map(h => `<th class="small">${h}</th>`).join('') + '</tr>';
            tbody.innerHTML = parsedCsvData.slice(0, 5).map(row => {
                return '<tr>' + displayHeaders.slice(0, 5).map(h => `<td class="small">${row[h] || ''}</td>`).join('') + '</tr>';
            }).join('');

            const withIndex = parsedCsvData.filter(r => r['Index Number'] && r['Index Number'].trim()).length;

            document.getElementById('previewCount').textContent = `${parsedCsvData.length} records`;
            document.getElementById('previewWithIndex').textContent = `${withIndex} with Index Number`;
            document.getElementById('uploadPreview').style.display = 'block';
            document.getElementById('uploadCorrectionsBtn').disabled = parsedCsvData.length === 0;
        };

        reader.readAsText(file);
    }

    function parseCSVLine(line) {
        const result = [];
        let current = '';
        let inQuotes = false;

        for (let i = 0; i < line.length; i++) {
            const char = line[i];

            if (char === '"') {
                inQuotes = !inQuotes;
            } else if (char === ',' && !inQuotes) {
                result.push(current.trim());
                current = '';
            } else {
                current += char;
            }
        }
        result.push(current.trim());

        return result;
    }

    function uploadCorrections() {
        if (!uploadBatchId || parsedCsvData.length === 0) {
            alert('No data to upload');
            return;
        }

        document.getElementById('uploadPreview').style.display = 'none';
        document.getElementById('uploadProgress').style.display = 'block';
        document.getElementById('uploadCorrectionsBtn').disabled = true;

        const formData = new FormData();
        formData.append('batchId', uploadBatchId);
        formData.append('corrections', JSON.stringify(parsedCsvData));

        fetch('?handler=UploadCorrections', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(response => response.json())
        .then(data => {
            document.getElementById('uploadProgress').style.display = 'none';

            if (data.success) {
                document.getElementById('resultUpdated').textContent = data.updatedCount;
                document.getElementById('resultResolved').textContent = data.resolvedCount;
                document.getElementById('resultRemaining').textContent = data.remainingCount;
                document.getElementById('uploadResult').style.display = 'block';

                setTimeout(() => window.location.reload(), 3000);
            } else {
                alert('Error: ' + data.message);
                document.getElementById('uploadPreview').style.display = 'block';
                document.getElementById('uploadCorrectionsBtn').disabled = false;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error uploading corrections. Please try again.');
            document.getElementById('uploadProgress').style.display = 'none';
            document.getElementById('uploadPreview').style.display = 'block';
            document.getElementById('uploadCorrectionsBtn').disabled = false;
        });
    }
</script>
