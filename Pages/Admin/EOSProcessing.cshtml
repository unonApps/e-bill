    function hideAnomalyProgress() {
        document.getElementById('anomalyProgressCard').style.display = 'none';
    }

    // ==========================================
    // Anomaly Result Modal Helper Functions
    // ==========================================
    function showAnomalyResultModal(type, data) {
        const header = document.getElementById('anomalyResultHeader');
        const title = document.getElementById('anomalyResultTitle');
        const content = document.getElementById('anomalyResultContent');
        const stats = document.getElementById('anomalyResultStats');
        const verifiedContainer = document.getElementById('statVerifiedContainer');

        stats.style.display = 'none';
        verifiedContainer.style.display = 'none';

        switch(type) {
            case 'reprocess':
                header.style.background = 'linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%)';
                title.innerHTML = '<i class="bi bi-check-circle me-2 text-success"></i>Re-check Complete';
                content.innerHTML = `
                    <p class="mb-0">Anomaly re-check for <strong>${data.batchName}</strong> has completed successfully.</p>
                `;
                stats.style.display = 'block';
                verifiedContainer.style.display = 'block';
                document.getElementById('statOriginal').textContent = data.originalCount.toLocaleString();
                document.getElementById('statResolved').textContent = data.resolvedCount.toLocaleString();
                document.getElementById('statRemaining').textContent = data.remainingCount.toLocaleString();
                document.getElementById('statVerified').textContent = data.verifiedCount.toLocaleString();
                break;

            case 'dismiss':
                header.style.background = 'linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%)';
                title.innerHTML = '<i class="bi bi-check2-square me-2 text-primary"></i>Anomalies Dismissed';
                content.innerHTML = `
                    <div class="text-center">
                        <div class="display-4 fw-bold text-primary mb-2">${data.dismissedCount.toLocaleString()}</div>
                        <p class="text-muted mb-0">anomaly records have been dismissed</p>
                    </div>
                    <div class="alert alert-info mt-3 mb-0" style="border-radius: 8px;">
                        <i class="bi bi-info-circle me-2"></i>
                        Records have been kept for audit purposes. The batch can now be considered complete.
                    </div>
                `;
                break;

            case 'delete':
                header.style.background = 'linear-gradient(135deg, #fee2e2 0%, #fecaca 100%)';
                title.innerHTML = '<i class="bi bi-trash me-2 text-danger"></i>Anomalies Deleted';
                content.innerHTML = `
                    <div class="text-center">
                        <div class="display-4 fw-bold text-danger mb-2">${data.deletedCount.toLocaleString()}</div>
                        <p class="text-muted mb-0">anomaly records have been permanently deleted</p>
                    </div>
                    <div class="alert alert-warning mt-3 mb-0" style="border-radius: 8px;">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        Records have been permanently removed from staging.
                    </div>
                `;
                break;

            case 'error':
                header.style.background = 'linear-gradient(135deg, #fee2e2 0%, #fecaca 100%)';
                title.innerHTML = '<i class="bi bi-exclamation-circle me-2 text-danger"></i>Error';
                content.innerHTML = `
                    <div class="alert alert-danger mb-0" style="border-radius: 8px;">
                        <i class="bi bi-x-circle me-2"></i>
                        ${data.message}
                    </div>
                `;
                break;
        }

        hideAnomalyProgress();
        anomalyResultModal.show();
    }

    // ==========================================
    // Preview & Processing
    // ==========================================
    function loadPreview() {
        if (!staffLookupValid) {
            alert('Please look up a valid staff member first.');
            return;
        }

        const indexNumber = document.getElementById('staffIndexNumber').value.trim();
        const month = document.getElementById('billingMonth').value;
        const year = document.getElementById('billingYear').value;

        fetch(`?handler=Preview&indexNumber=${encodeURIComponent(indexNumber)}&month=${month}&year=${year}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('previewCard').style.display = 'block';

                    const formatKES = (value) => 'KES ' + (value || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                    const formatUSD = (value) => 'USD ' + (value || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

                    // Phone numbers list
                    const phoneListDiv = document.getElementById('phoneNumbersList');
                    if (data.phoneNumbers && data.phoneNumbers.length > 0) {
                        phoneListDiv.style.display = 'block';
                        phoneListDiv.innerHTML = `
                            <div class="d-flex align-items-center flex-wrap gap-2 p-2" style="background: #f3f4f6; border-radius: 8px;">
                                <i class="bi bi-phone text-primary me-1"></i>
                                <span class="small text-muted me-2">Staff phones:</span>
                                ${data.phoneNumbers.map(p => `<span class="badge bg-primary">${p}</span>`).join('')}
                            </div>`;
                    } else {
                        phoneListDiv.style.display = 'block';
                        phoneListDiv.innerHTML = `
                            <div class="d-flex align-items-center p-2" style="background: #fee2e2; border-radius: 8px; border: 1px solid #ef4444;">
                                <i class="bi bi-exclamation-triangle text-danger me-2"></i>
                                <span class="small text-danger">No active phone numbers found for this staff member.</span>
                            </div>`;
                    }

                    // Update counts and costs
                    document.getElementById('safaricomCount').textContent = data.safaricomCount.toLocaleString();
                    document.getElementById('safaricomKES').textContent = formatKES(data.safaricomCostKES);
                    document.getElementById('safaricomUSD').textContent = 'USD 0.00';

                    document.getElementById('airtelCount').textContent = data.airtelCount.toLocaleString();
                    document.getElementById('airtelKES').textContent = formatKES(data.airtelCostKES);
                    document.getElementById('airtelUSD').textContent = 'USD 0.00';

                    document.getElementById('pstnCount').textContent = data.pstnCount.toLocaleString();
                    document.getElementById('pstnKES').textContent = formatKES(data.pstnCostKES);
                    document.getElementById('pstnUSD').textContent = 'USD 0.00';

                    document.getElementById('privateWireCount').textContent = data.privateWireCount.toLocaleString();
                    document.getElementById('privateWireKES').textContent = 'KES 0.00';
                    document.getElementById('privateWireUSD').textContent = formatUSD(data.privateWireCostUSD);

                    document.getElementById('totalCount').textContent = data.totalCount.toLocaleString();
                    const totalKES = (data.safaricomCostKES || 0) + (data.airtelCostKES || 0) + (data.pstnCostKES || 0);
                    document.getElementById('totalKES').textContent = formatKES(totalKES);
                    document.getElementById('totalUSD').textContent = formatUSD(data.privateWireCostUSD);

                    // Deadlines
                    document.getElementById('staffDeadline').textContent = data.staffDeadline || '-';
                    document.getElementById('supervisorDeadline').textContent = data.supervisorDeadline || '-';

                    // Exchange rate status
                    const exchangeRateDiv = document.getElementById('exchangeRateStatus');
                    if (data.hasExchangeRate) {
                        exchangeRateDiv.innerHTML = `
                            <div class="d-flex align-items-center p-3" style="background: #d1fae5; border-radius: 10px; border: 1px solid #22c55e;">
                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                <span>Exchange Rate: <strong>1 USD = ${data.exchangeRate} KES</strong></span>
                            </div>`;
                    } else {
                        const monthName = new Date(year, month - 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
                        exchangeRateDiv.innerHTML = `
                            <div class="d-flex align-items-center justify-content-between p-3" style="background: #fef3c7; border-radius: 10px; border: 1px solid #f59e0b;">
                                <div>
                                    <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                                    <span>No exchange rate for ${monthName}</span>
                                </div>
                                <button class="btn btn-sm btn-warning" style="border-radius: 6px;" onclick="showAddExchangeRateModal('${monthName}')">
                                    <i class="bi bi-plus me-1"></i>Add
                                </button>
                            </div>`;
                    }

                    // Processing status warning
                    const existingBatchDiv = document.getElementById('existingBatchWarning');
                    if (data.isProcessing) {
                        existingBatchDiv.style.display = 'block';
                        existingBatchDiv.innerHTML = `
                            <div class="d-flex align-items-center p-3" style="background: #fef3c7; border-radius: 10px; border: 1px solid #f59e0b;">
                                <div class="spinner-border spinner-border-sm text-warning me-2" role="status"></div>
                                <span><strong>${data.processingBatchName}</strong> is currently processing.</span>
                            </div>`;
                    } else {
                        existingBatchDiv.style.display = 'none';
                    }

                    // Store preview data
                    previewData = data;

                    // Enable/disable start button
                    const startBtn = document.getElementById('startProcessingBtn');
                    const sepDate = document.getElementById('separationDate').value;
                    const sepReason = document.getElementById('separationReason').value;
                    startBtn.disabled = !data.hasExchangeRate || data.totalCount === 0 || data.isProcessing || data.noPhones || !sepDate || !sepReason;

                    if (data.isProcessing) {
                        startBtn.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Processing in Progress';
                    } else if (data.noPhones) {
                        startBtn.innerHTML = '<i class="bi bi-exclamation-circle me-2"></i>No Phone Numbers';
                    } else if (data.totalCount === 0) {
                        startBtn.innerHTML = '<i class="bi bi-exclamation-circle me-2"></i>No Records Found';
                    } else if (!data.hasExchangeRate) {
                        startBtn.innerHTML = '<i class="bi bi-exclamation-circle me-2"></i>Add Exchange Rate First';
                    } else if (!sepDate || !sepReason) {
                        startBtn.innerHTML = '<i class="bi bi-exclamation-circle me-2"></i>Fill Separation Details';
                    } else {
                        startBtn.innerHTML = '<i class="bi bi-play-circle me-2"></i>Start EOS Processing';
                    }
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error loading preview');
            });
    }

    function showAddExchangeRateModal(monthName) {
        document.getElementById('missingRateMonth').textContent = monthName;
        document.getElementById('newExchangeRate').value = '';
        new bootstrap.Modal(document.getElementById('addExchangeRateModal')).show();
    }

    function saveExchangeRate() {
        const month = document.getElementById('billingMonth').value;
        const year = document.getElementById('billingYear').value;
        const rate = document.getElementById('newExchangeRate').value;

        if (!rate || rate <= 0) {
            alert('Please enter a valid exchange rate');
            return;
        }

        const formData = new FormData();
        formData.append('month', month);
        formData.append('year', year);
        formData.append('rate', rate);

        fetch('?handler=AddExchangeRate', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('addExchangeRateModal')).hide();
                loadPreview();
            } else {
                alert('Error: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error saving exchange rate');
        });
    }

    // Store preview data for confirmation modal
    let previewData = null;

    function startProcessing() {
        if (!previewData) {
            alert('Please preview records first');
            return;
        }

        const sepDate = document.getElementById('separationDate').value;
        const sepReason = document.getElementById('separationReason').value;

        if (!sepDate || !sepReason) {
            alert('Please fill in Separation Date and Separation Reason before starting.');
            return;
        }

        const month = document.getElementById('billingMonth').value;
        const year = document.getElementById('billingYear').value;

        // Populate confirmation modal
        const monthName = new Date(year, month - 1).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
        document.getElementById('confirmBillingPeriod').textContent = monthName;
        document.getElementById('confirmDeadline').textContent = previewData.staffDeadline || 'Not set';

        // Staff details
        document.getElementById('confirmStaffName').textContent = document.getElementById('staffName').value;
        document.getElementById('confirmStaffIndex').textContent = document.getElementById('staffIndexNumber').value;
        document.getElementById('confirmSeparationReason').textContent = sepReason;
        document.getElementById('confirmSeparationDate').textContent = sepDate;

        const formatKES = (value) => 'KES ' + (value || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        const formatUSD = (value) => 'USD ' + (value || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

        // Provider summary
        document.getElementById('confirmSafaricomCount').textContent = (previewData.safaricomCount || 0).toLocaleString();
        document.getElementById('confirmSafaricomKES').textContent = formatKES(previewData.safaricomCostKES);
        document.getElementById('confirmSafaricomUSD').textContent = 'USD 0.00';

        document.getElementById('confirmAirtelCount').textContent = (previewData.airtelCount || 0).toLocaleString();
        document.getElementById('confirmAirtelKES').textContent = formatKES(previewData.airtelCostKES);
        document.getElementById('confirmAirtelUSD').textContent = 'USD 0.00';

        document.getElementById('confirmPSTNCount').textContent = (previewData.pstnCount || 0).toLocaleString();
        document.getElementById('confirmPSTNKES').textContent = formatKES(previewData.pstnCostKES);
        document.getElementById('confirmPSTNUSD').textContent = 'USD 0.00';

        document.getElementById('confirmPrivateWireCount').textContent = (previewData.privateWireCount || 0).toLocaleString();
        document.getElementById('confirmPrivateWireKES').textContent = 'KES 0.00';
        document.getElementById('confirmPrivateWireUSD').textContent = formatUSD(previewData.privateWireCostUSD);

        document.getElementById('confirmTotalRecords').textContent = (previewData.totalCount || 0).toLocaleString();
        const totalKES = (previewData.safaricomCostKES || 0) + (previewData.airtelCostKES || 0) + (previewData.pstnCostKES || 0);
        document.getElementById('confirmTotalKES').textContent = formatKES(totalKES);
        document.getElementById('confirmTotalUSD').textContent = formatUSD(previewData.privateWireCostUSD);

        new bootstrap.Modal(document.getElementById('confirmProcessingModal')).show();
    }

    function confirmStartProcessing() {
        const month = document.getElementById('billingMonth').value;
        const year = document.getElementById('billingYear').value;
        const days = document.getElementById('numberOfDays').value;

        bootstrap.Modal.getInstance(document.getElementById('confirmProcessingModal')).hide();

        const formData = new FormData();
        formData.append('StaffIndexNumber', document.getElementById('staffIndexNumber').value.trim());
        formData.append('StaffName', document.getElementById('staffName').value);
        formData.append('SeparationDate', document.getElementById('separationDate').value);
        formData.append('SeparationReason', document.getElementById('separationReason').value);
        formData.append('BillingMonth', month);
        formData.append('BillingYear', year);
        formData.append('NumberOfDays', days);

        document.getElementById('startProcessingBtn').disabled = true;
        document.getElementById('startProcessingBtn').innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Starting...';

        fetch('?handler=StartProcessing', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                currentBatchId = data.batchId;
                showProgressCard();
                startProgressPolling();
            } else {
                showErrorModal('Processing Error', data.message);
                document.getElementById('startProcessingBtn').disabled = false;
                document.getElementById('startProcessingBtn').innerHTML = '<i class="bi bi-play-circle me-2"></i>Start EOS Processing';
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showErrorModal('Connection Error', 'Failed to start processing. Please check your connection and try again.');
            document.getElementById('startProcessingBtn').disabled = false;
            document.getElementById('startProcessingBtn').innerHTML = '<i class="bi bi-play-circle me-2"></i>Start EOS Processing';
        });
    }

    function showErrorModal(title, message) {
        document.getElementById('failureBatchName').textContent = title;
        document.getElementById('failureReason').textContent = message;
        document.getElementById('failureDate').textContent = new Date().toLocaleString();
        document.getElementById('failureCreatedBy').textContent = '-';
        new bootstrap.Modal(document.getElementById('failureDetailsModal')).show();
    }

    function showFailureDetails(batchName, reason, date, createdBy) {
        document.getElementById('failureBatchName').textContent = batchName;
        document.getElementById('failureReason').textContent = reason || 'Unknown error occurred';
        document.getElementById('failureDate').textContent = date;
        document.getElementById('failureCreatedBy').textContent = createdBy;
        new bootstrap.Modal(document.getElementById('failureDetailsModal')).show();
    }

    function showProgressCard() {
        document.getElementById('progressCard').style.display = 'block';
        document.getElementById('processingResults').style.display = 'none';

        document.getElementById('progressBar').style.width = '0%';
        document.getElementById('progressPercent').textContent = '0%';
        document.getElementById('progressOperation').textContent = 'Initializing...';

        for (let i = 1; i <= 5; i++) {
            const step = document.getElementById('step' + i);
            step.classList.remove('step-active', 'step-complete');
        }
    }

    function startProgressPolling() {
        progressInterval = setInterval(checkProgress, 2000);
        checkProgress();
    }

    function checkProgress() {
        if (!currentBatchId) return;

        fetch(`?handler=Progress&batchId=${currentBatchId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    updateProgressUI(data);

                    if (data.isComplete || data.progress >= 100) {
                        clearInterval(progressInterval);
                        showResults(data);
                    }
                }
            })
            .catch(error => {
                console.error('Error checking progress:', error);
            });
    }

    function updateProgressUI(data) {
        document.getElementById('progressBar').style.width = data.progress + '%';
        document.getElementById('progressPercent').textContent = data.progress + '%';
        document.getElementById('progressOperation').textContent = data.currentOperation || 'Processing...';

        const topPercent = document.getElementById('currentProcessingPercent');
        const topBar = document.getElementById('currentProcessingBar');
        const topOperation = document.getElementById('currentProcessingOperation');
        if (topPercent) topPercent.textContent = data.progress + '%';
        if (topBar) topBar.style.width = data.progress + '%';
        if (topOperation) topOperation.textContent = data.currentOperation || 'Processing...';

        updateSteps(data.progress);
    }

    function updateSteps(progress) {
        const steps = [
            { id: 'step1', threshold: 10 },
            { id: 'step2', threshold: 50 },
            { id: 'step3', threshold: 60 },
            { id: 'step4', threshold: 75 },
            { id: 'step5', threshold: 100 }
        ];

        steps.forEach((step, index) => {
            const el = document.getElementById(step.id);

            if (progress >= step.threshold) {
                el.classList.remove('step-active');
                el.classList.add('step-complete');
            } else if (progress >= (steps[index - 1]?.threshold || 0)) {
                el.classList.add('step-active');
                el.classList.remove('step-complete');
            }
        });
    }

    function showResults(data) {
        const topAlert = document.getElementById('currentProcessingAlert');
        if (topAlert) {
            topAlert.style.display = 'none';
        }

        document.getElementById('processingResults').style.display = 'block';
        document.getElementById('resultTotal').textContent = (data.totalRecords || 0).toLocaleString();
        document.getElementById('resultVerified').textContent = (data.verifiedRecords || 0).toLocaleString();
        document.getElementById('resultAnomalies').textContent = (data.anomalyRecords || 0).toLocaleString();

        if (data.anomalyRecords > 0) {
            const downloadBtn = document.getElementById('downloadAnomaliesBtn');
            downloadBtn.style.display = 'block';
            downloadBtn.onclick = function() {
                window.location.href = `?handler=DownloadAnomalies&batchId=${currentBatchId}`;
            };
        }

        document.getElementById('startProcessingBtn').disabled = false;
        document.getElementById('startProcessingBtn').innerHTML = '<i class="bi bi-play-circle me-2"></i>Start EOS Processing';

        const resultsDiv = document.getElementById('processingResults');
        const reloadMsg = document.createElement('div');
        reloadMsg.className = 'alert alert-info mt-3 d-flex align-items-center';
        reloadMsg.innerHTML = '<i class="bi bi-arrow-clockwise me-2 spin"></i>Refreshing page to update history...';
        resultsDiv.appendChild(reloadMsg);

        setTimeout(() => {
            window.location.reload();
        }, 1500);
    }

    // Auto-load progress if there's an ongoing process
    document.addEventListener('DOMContentLoaded', function() {
        @if (Model.CurrentProcessingBatch != null)
        {
            <text>
            currentBatchId = '@Model.CurrentProcessingBatch.Id';
            showProgressCard();
            startProgressPolling();
            </text>
        }

        // Attach click handlers to failure details buttons
        document.querySelectorAll('.failure-details-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const batchName = this.dataset.batchName;
                const failureReason = this.dataset.failureReason;
                const date = this.dataset.date;
                const createdBy = this.dataset.createdBy;
                showFailureDetails(batchName, failureReason, date, createdBy);
            });
        });

        // Attach click handlers to send notifications buttons
        document.querySelectorAll('.send-notifications-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const batchId = this.dataset.batchId;
                const batchName = this.dataset.batchName;
                sendNotifications(batchId, batchName, this);
            });
        });

        // Attach click handlers to reprocess buttons
        document.querySelectorAll('.reprocess-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const batchId = this.dataset.batchId;
                const batchName = this.dataset.batchName;
                const anomalyCount = this.dataset.anomalyCount;
                reprocessAnomalies(batchId, batchName, anomalyCount, this);
            });
        });

        // Attach click handlers to cleanup staging buttons
        document.querySelectorAll('.cleanup-staging-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const batchId = this.dataset.batchId;
                const batchName = this.dataset.batchName;
                const recordCount = this.dataset.recordCount;
                cleanupStagingData(batchId, batchName, recordCount, this);
            });
        });

        // Attach click handlers to dismiss anomalies buttons
        document.querySelectorAll('.dismiss-anomalies-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const batchId = this.dataset.batchId;
                const batchName = this.dataset.batchName;
                const anomalyCount = this.dataset.anomalyCount;
                dismissAnomalies(batchId, batchName, anomalyCount, this);
            });
        });

        // Attach click handlers to delete anomalies buttons
        document.querySelectorAll('.delete-anomalies-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const batchId = this.dataset.batchId;
                const batchName = this.dataset.batchName;
                const anomalyCount = this.dataset.anomalyCount;
                deleteAnomalies(batchId, batchName, anomalyCount, this);
            });
        });

        // Attach click handlers to upload corrections buttons
        document.querySelectorAll('.upload-corrections-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                const batchId = this.dataset.batchId;
                const batchName = this.dataset.batchName;
                showUploadModal(batchId, batchName);
            });
        });

        // File input change handler
        document.getElementById('correctionsFile').addEventListener('change', function(e) {
            previewCsvFile(e.target.files[0]);
        });
    });

    function sendNotifications(batchId, batchName, button) {
        if (!confirm(`Are you sure you want to send notifications for "${batchName}"?\n\nThis will send email notifications to the staff member with call logs in this EOS batch.`)) {
            return;
        }

        const originalHtml = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        const formData = new FormData();
        formData.append('batchId', batchId);

        fetch('?handler=SendNotifications', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                button.innerHTML = '<i class="bi bi-check-lg"></i>';
                button.classList.remove('btn-outline-primary');
                button.classList.add('btn-success');

                alert('Notifications queued successfully!\n\nEmails will be sent in the background.');

                setTimeout(() => {
                    button.innerHTML = originalHtml;
                    button.classList.remove('btn-success');
                    button.classList.add('btn-outline-primary');
                    button.disabled = false;
                }, 3000);
            } else {
                alert('Error: ' + data.message);
                button.innerHTML = originalHtml;
                button.disabled = false;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error sending notifications. Please try again.');
            button.innerHTML = originalHtml;
            button.disabled = false;
        });
    }

    // ==========================================
    // Dismiss Anomalies Functions
    // ==========================================
    function dismissAnomalies(batchId, batchName, anomalyCount, button) {
        showConfirmModal({
            type: 'dismiss',
            message: `Dismiss all anomalies for <strong>"${batchName}"</strong>?`,
            details: `
                <div class="bg-light rounded-3 p-3">
                    <p class="mb-2 fw-semibold">This will:</p>
                    <ul class="mb-0 ps-3">
                        <li>Mark <strong>${anomalyCount.toLocaleString()}</strong> anomaly records as "Dismissed"</li>
                        <li>Keep records in staging for audit purposes</li>
                        <li>Allow the batch to be considered complete</li>
                    </ul>
                </div>
            `,
            note: 'Make sure you\'ve downloaded the anomaly report first.'
        }, function() {
            executeDismissAnomalies(batchId, batchName, button);
        });
    }

    function executeDismissAnomalies(batchId, batchName, button) {
        const originalHtml = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

        showAnomalyProgress('Dismissing Anomalies', batchName);
        updateAnomalyProgress(30, 'Marking records as dismissed...');

        const formData = new FormData();
        formData.append('batchId', batchId);

        fetch('?handler=DismissAnomalies', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(response => response.json())
        .then(data => {
            updateAnomalyProgress(100, 'Complete!');

            if (data.success) {
                button.innerHTML = '<i class="bi bi-check-lg"></i>';
                button.classList.remove('btn-outline-secondary');
                button.classList.add('btn-success');

                showAnomalyResultModal('dismiss', { dismissedCount: data.dismissedCount });
            } else {
                showAnomalyResultModal('error', { message: data.message });
                button.innerHTML = originalHtml;
                button.disabled = false;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            showAnomalyResultModal('error', { message: 'Error dismissing anomalies. Please try again.' });
            button.innerHTML = originalHtml;
            button.disabled = false;
        });
    }

    // ==========================================
    // Delete Anomalies Functions
    // ==========================================
    function deleteAnomalies(batchId, batchName, anomalyCount, button) {
        showConfirmModal({
            type: 'delete',
            message: `<span class="text-danger fw-bold">PERMANENTLY DELETE</span> all anomalies for <strong>"${batchName}"</strong>?`,
            details: `
                <div class="bg-danger bg-opacity-10 rounded-3 p-3 border border-danger border-opacity-25">
                    <p class="mb-2 fw-semibold text-danger"><i class="bi bi-exclamation-triangle me-2"></i>This action cannot be undone!</p>
                    <ul class="mb-0 ps-3">
                        <li>Remove <strong>${anomalyCount.toLocaleString()}</strong> anomaly records from staging</li>
                        <li>Records will be <strong>lost forever</strong></li>
                    </ul>
                </div>
            `,
            note: 'Make sure you\'ve downloaded the anomaly report first!'
        }, function() {
            executeDeleteAnomalies(batchId, batchName, button);
