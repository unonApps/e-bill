    // ==========================================
    // Confirmation Modal Helper Functions
    // ==========================================
    function showConfirmModal(config, onConfirm) {
        const header = document.getElementById('confirmModalHeader');
        const title = document.getElementById('confirmModalTitle');
        const message = document.getElementById('confirmModalMessage');
        const details = document.getElementById('confirmModalDetails');
        const noteDiv = document.getElementById('confirmModalNote');
        const noteText = document.getElementById('confirmModalNoteText');
        const proceedBtn = document.getElementById('confirmModalProceedBtn');

        switch(config.type) {
            case 'reprocess':
                header.style.background = 'linear-gradient(135deg, #d1fae5 0%, #a7f3d0 100%)';
                title.innerHTML = '<i class="bi bi-arrow-repeat me-2 text-success"></i>Re-check Anomalies';
                proceedBtn.className = 'btn btn-success btn-modern';
                proceedBtn.innerHTML = '<i class="bi bi-play-fill me-2"></i>Start Re-check';
                noteDiv.className = 'alert alert-info mb-0';
                noteDiv.style.borderRadius = '8px';
                break;
            case 'dismiss':
                header.style.background = 'linear-gradient(135deg, #e0e7ff 0%, #c7d2fe 100%)';
                title.innerHTML = '<i class="bi bi-check2-square me-2 text-primary"></i>Dismiss Anomalies';
                proceedBtn.className = 'btn btn-primary btn-modern';
                proceedBtn.innerHTML = '<i class="bi bi-check-lg me-2"></i>Dismiss All';
                noteDiv.className = 'alert alert-info mb-0';
                noteDiv.style.borderRadius = '8px';
                break;
            case 'delete':
                header.style.background = 'linear-gradient(135deg, #fee2e2 0%, #fecaca 100%)';
                title.innerHTML = '<i class="bi bi-trash me-2 text-danger"></i>Delete Anomalies';
                proceedBtn.className = 'btn btn-danger btn-modern';
                proceedBtn.innerHTML = '<i class="bi bi-trash me-2"></i>Delete Permanently';
                noteDiv.className = 'alert alert-warning mb-0';
                noteDiv.style.borderRadius = '8px';
                break;
        }

        message.innerHTML = config.message;
        details.innerHTML = config.details || '';
        noteText.textContent = config.note;

        pendingConfirmAction = onConfirm;
        anomalyConfirmModal.show();
    }

    // ==========================================
    // Anomaly Progress Helper Functions
