@page
@model TAB.Web.Pages.Admin.EmailSettingsModel
@{
    ViewData["Title"] = "Email Settings";
}

<h1>@ViewData["Title"]</h1>

@if (Model.StatusMessage != null)
{
    <div class="alert alert-@Model.StatusMessageClass">@Model.StatusMessage</div>
}

<div class="alert alert-info">
    <strong>Note:</strong> You need to configure a real SMTP server to send emails. If you don't have an SMTP server, you can use services like:
    <ul>
        <li>Gmail SMTP (smtp.gmail.com, port 587)</li>
        <li>Microsoft 365 / Outlook (smtp.office365.com, port 587)</li>
        <li>SendGrid, Mailgun, or other transactional email services</li>
    </ul>
    <p>Note that for services like Gmail, you may need to use an app password instead of your regular password.</p>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">SMTP Settings</h5>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Settings.SmtpServer" class="form-label"></label>
                                <input asp-for="Settings.SmtpServer" class="form-control" required placeholder="e.g., smtp.gmail.com" />
                                <span asp-validation-for="Settings.SmtpServer" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Settings.SmtpPort" class="form-label"></label>
                                <input asp-for="Settings.SmtpPort" class="form-control" required placeholder="e.g., 587" />
                                <span asp-validation-for="Settings.SmtpPort" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Settings.FromEmail" class="form-label"></label>
                                <input asp-for="Settings.FromEmail" class="form-control" required placeholder="your-email@example.com" />
                                <span asp-validation-for="Settings.FromEmail" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Settings.FromName" class="form-label"></label>
                                <input asp-for="Settings.FromName" class="form-control" required placeholder="TAB System" />
                                <span asp-validation-for="Settings.FromName" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Settings.Username" class="form-label"></label>
                                <input asp-for="Settings.Username" class="form-control" required placeholder="Usually your email address" />
                                <span asp-validation-for="Settings.Username" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Settings.Password" class="form-label"></label>
                                <input asp-for="Settings.Password" class="form-control" type="password" required />
                                <span asp-validation-for="Settings.Password" class="text-danger"></span>
                                <small class="text-muted">For Gmail, use an <a href="https://support.google.com/accounts/answer/185833" target="_blank">app password</a></small>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-check mb-3">
                        <input asp-for="Settings.EnableSsl" class="form-check-input" checked />
                        <label asp-for="Settings.EnableSsl" class="form-check-label"></label>
                    </div>
                    
                    <div class="mb-3">
                        <button type="submit" class="btn btn-primary">Save Settings</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">Send Test Email</h5>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="SendTestEmail">
                    <div class="form-group mb-3">
                        <label for="TestEmailAddress" class="form-label">Test Email Address</label>
                        <input asp-for="TestEmailAddress" class="form-control" placeholder="email@example.com" required />
                    </div>
                    <button type="submit" class="btn btn-info">Send Test Email</button>
                </form>
                <div class="mt-3">
                    <small class="text-muted">The test email will help verify that your SMTP settings are working correctly.</small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
} 