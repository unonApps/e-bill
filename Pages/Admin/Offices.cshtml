@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Auto-submit form on filter change
        document.addEventListener('DOMContentLoaded', function() {
            // Handle select changes
            const autoSubmitElements = document.querySelectorAll('.filter-auto-submit');
            autoSubmitElements.forEach(element => {
                element.addEventListener('change', function() {
                    document.getElementById('filterForm').submit();
                });
            });

            // Handle search input with debounce
            let searchTimeout;
            const searchInput = document.querySelector('.filter-search-input');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        document.getElementById('filterForm').submit();
                    }, 500); // Wait 500ms after user stops typing
                });

                // Also submit on Enter key
                searchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        clearTimeout(searchTimeout);
                        document.getElementById('filterForm').submit();
                    }
                });
            }

            // Update button text when filters are shown/hidden
            const filterToggle = document.querySelector('[data-bs-target="#filterCollapse"]');
            const filterCollapse = document.getElementById('filterCollapse');
            if (filterToggle && filterCollapse) {
                filterCollapse.addEventListener('show.bs.collapse', function () {
                    filterToggle.innerHTML = '<i class="bi bi-funnel-fill"></i> Hide Filters';
                });
                filterCollapse.addEventListener('hide.bs.collapse', function () {
                    filterToggle.innerHTML = '<i class="bi bi-funnel"></i> Show Filters';
                });

                // Check if any filters are active and show the filter section
                const hasActiveFilters = @Html.Raw((!string.IsNullOrEmpty(Model.SearchTerm) || Model.SelectedOrganizationId != null || Model.HasUsers != null).ToString().ToLower());
                if (hasActiveFilters) {
                    filterCollapse.classList.add('show');
                    filterToggle.innerHTML = '<i class="bi bi-funnel-fill"></i> Hide Filters';
                    filterToggle.setAttribute('aria-expanded', 'true');
                }
            }
        });

        function openOfficeModal() {
            document.getElementById('officeModalLabel').textContent = 'Add New Office';
            document.getElementById('officeForm').action = '?handler=CreateOffice';
            document.getElementById('officeId').value = '';
            document.getElementById('Input_Name').value = '';
            document.getElementById('Input_OrganizationId').value = '';
            document.getElementById('Input_Description').value = '';
        }

        function editOffice(id, name, code, organizationId, description) {
            document.getElementById('officeModalLabel').textContent = 'Edit Office';
            document.getElementById('officeForm').action = '?handler=EditOffice';
            document.getElementById('officeId').value = id;
            document.getElementById('Input_Name').value = name;
            document.getElementById('Input_Code').value = code || '';
            document.getElementById('Input_OrganizationId').value = organizationId;
            document.getElementById('Input_Description').value = description;

            var modal = new bootstrap.Modal(document.getElementById('officeModal'));
            modal.show();
        }

        function openSubOfficeModal() {
            document.getElementById('subOfficeModalLabel').textContent = 'Add New Sub-Office';
            document.getElementById('subOfficeForm').action = '?handler=CreateSubOffice';
            document.getElementById('subOfficeId').value = '';
            document.getElementById('SubOfficeInput_Name').value = '';
            document.getElementById('SubOfficeInput_OfficeId').value = '';
            document.getElementById('SubOfficeInput_ContactPerson').value = '';
            document.getElementById('SubOfficeInput_PhoneNumber').value = '';
            document.getElementById('SubOfficeInput_Email').value = '';
            document.getElementById('SubOfficeInput_Address').value = '';
            document.getElementById('SubOfficeInput_Description').value = '';
            document.getElementById('SubOfficeInput_IsActive').value = 'true';
        }

        function editSubOffice(id, name, description, contactPerson, phoneNumber, email, address, officeId, isActive) {
            document.getElementById('subOfficeModalLabel').textContent = 'Edit Sub-Office';
            document.getElementById('subOfficeForm').action = '?handler=EditSubOffice';
            document.getElementById('subOfficeId').value = id;
            document.getElementById('SubOfficeInput_Name').value = name;
            document.getElementById('SubOfficeInput_Description').value = description;
            document.getElementById('SubOfficeInput_ContactPerson').value = contactPerson;
            document.getElementById('SubOfficeInput_PhoneNumber').value = phoneNumber;
            document.getElementById('SubOfficeInput_Email').value = email;
            document.getElementById('SubOfficeInput_Address').value = address;
            document.getElementById('SubOfficeInput_OfficeId').value = officeId;
            document.getElementById('SubOfficeInput_IsActive').value = isActive;

            var modal = new bootstrap.Modal(document.getElementById('subOfficeModal'));
            modal.show();
        }

        function confirmDeleteOffice(id, name) {
            document.getElementById('deleteOfficeId').value = id;
            document.getElementById('deleteOfficeName').textContent = name;
            var modal = new bootstrap.Modal(document.getElementById('deleteOfficeModal'));
            modal.show();
        }

        function confirmDeleteSubOffice(id, name) {
            document.getElementById('deleteSubOfficeId').value = id;
            document.getElementById('deleteSubOfficeName').textContent = name;
            var modal = new bootstrap.Modal(document.getElementById('deleteSubOfficeModal'));
            modal.show();
        }

        // Search functionality
        document.getElementById('searchTable').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#officesTable tbody tr');

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });

        // Add animation to badges
        document.querySelectorAll('.badge').forEach(badge => {
            badge.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-2px) scale(1.05)';
            });
            badge.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0) scale(1)';
            });
        });
    </script>
}