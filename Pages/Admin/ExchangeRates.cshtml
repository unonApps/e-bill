@page
@model TAB.Web.Pages.Admin.ExchangeRatesModel
@{
    ViewData["Title"] = "Exchange Rates Management";
}

<style>
    /* Exchange Rate Card Styles */
    .rate-card {
        background: white;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        padding: 1.5rem;
        transition: all 0.3s ease;
        margin-bottom: 1rem;
    }

    .rate-card:hover {
        border-color: #009EDB;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 158, 219, 0.15);
    }

    .rate-period {
        font-size: 1.25rem;
        font-weight: 700;
        color: #1f2937;
        margin-bottom: 0.5rem;
    }

    .rate-value {
        font-size: 2rem;
        font-weight: 700;
        color: #009EDB;
        line-height: 1;
    }

    .rate-label {
        font-size: 0.875rem;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 0.25rem;
    }

    .rate-audit {
        font-size: 0.8125rem;
        color: #9ca3af;
        margin-top: 0.75rem;
        padding-top: 0.75rem;
        border-top: 1px solid #e5e7eb;
    }

    /* Form Styles */
    .form-card {
        background: white;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
    }

    .form-input-group {
        margin-bottom: 1.5rem;
    }

    .form-input-label {
        display: flex;
        align-items: center;
        font-weight: 600;
        font-size: 0.9375rem;
        color: #1f2937;
        margin-bottom: 0.5rem;
    }

    .form-input {
        width: 100%;
        padding: 0.75rem 1rem;
        font-size: 0.9375rem;
        color: #1f2937;
        background: white;
        border: 2px solid #e5e7eb;
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .form-input:hover {
        border-color: #009EDB;
        background-color: #f8fafc;
    }

    .form-input:focus {
        outline: none;
        border-color: #009EDB;
        box-shadow: 0 0 0 3px rgba(0, 158, 219, 0.1);
        background-color: white;
    }

    /* Modal Styles */
    .modal-content {
        border-radius: 16px;
        border: none;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    }

    .modal-header {
        background: linear-gradient(135deg, #009EDB 0%, #0084c7 100%);
        color: white;
        border-radius: 16px 16px 0 0;
        padding: 1.5rem;
    }

    .modal-header .btn-close {
        filter: brightness(0) invert(1);
    }

    .modal-body {
        padding: 2rem;
    }

    /* Header Styles */
    .page-header {
        background: linear-gradient(135deg, #009EDB 0%, #0084c7 100%);
        color: white;
        padding: 2rem;
        border-radius: 16px;
        margin-bottom: 2rem;
    }

    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border: 2px dashed #d1d5db;
        border-radius: 12px;
    }

    .empty-state-icon {
        font-size: 4rem;
        color: #d1d5db;
        margin-bottom: 1rem;
    }
</style>

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="page-header">
        <div class="d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <div class="bg-white bg-opacity-20 rounded-circle d-inline-flex align-items-center justify-content-center me-3"
                     style="width: 60px; height: 60px;">
                    <i class="bi bi-currency-exchange text-white" style="font-size: 28px;"></i>
                </div>
                <div>
                    <h3 class="fw-bold mb-1">Exchange Rates Management</h3>
                    <p class="mb-0 opacity-90">Manage KES to USD exchange rates for telecom billing</p>
                </div>
            </div>
            <button type="button" class="btn btn-light" data-bs-toggle="modal" data-bs-target="#createRateModal">
                <i class="bi bi-plus-circle me-2"></i>Add New Rate
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert alert-@Model.StatusMessageClass alert-dismissible fade show" role="alert">
            <i class="bi bi-@(Model.StatusMessageClass == "success" ? "check-circle" : Model.StatusMessageClass == "danger" ? "x-circle" : "info-circle") me-2"></i>
            @Model.StatusMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Exchange Rates List -->
    @if (Model.ExchangeRates.Any())
    {
        <div class="row">
            @foreach (var rate in Model.ExchangeRates)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="rate-card">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="rate-period">@rate.PeriodDisplay</div>
                                <div class="rate-label">Exchange Rate</div>
                            </div>
                            <div class="dropdown">
                                <button class="btn btn-sm btn-light" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li>
                                        <a class="dropdown-item" href="#" onclick="openUpdateModal(@rate.Id, @rate.Month, @rate.Year, @rate.Rate)">
                                            <i class="bi bi-pencil me-2"></i>Update Rate
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@rate.Id"
                                              onsubmit="return confirm('Are you sure you want to delete this exchange rate?');" class="d-inline">
                                            <button type="submit" class="dropdown-item text-danger">
                                                <i class="bi bi-trash me-2"></i>Delete
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="d-flex align-items-baseline gap-2">
                            <span class="rate-value">@rate.Rate.ToString("N4")</span>
                            <span class="text-muted">KES</span>
                        </div>
                        <div class="text-muted small mt-1">per 1 USD</div>

                        <div class="rate-audit">
                            <div><i class="bi bi-person me-1"></i> Created by @rate.CreatedBy</div>
                            <div><i class="bi bi-clock me-1"></i> @rate.CreatedDate.ToString("MMM dd, yyyy HH:mm")</div>
                            @if (rate.UpdatedBy != null)
                            {
                                <div class="mt-1 text-primary">
                                    <i class="bi bi-arrow-repeat me-1"></i> Updated by @rate.UpdatedBy on @rate.UpdatedDate?.ToString("MMM dd, yyyy HH:mm")
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <i class="bi bi-currency-exchange"></i>
            </div>
            <h5 class="text-muted mb-2">No Exchange Rates Defined</h5>
            <p class="text-muted mb-3">Get started by adding your first exchange rate.</p>
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createRateModal">
                <i class="bi bi-plus-circle me-2"></i>Add Exchange Rate
            </button>
        </div>
    }
</div>

<!-- Create Rate Modal -->
<div class="modal fade" id="createRateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle me-2"></i>Add New Exchange Rate
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Create">
                <div class="modal-body">
                    <div class="alert alert-info border-0" style="background-color: #e0f2fe;">
                        <i class="bi bi-info-circle me-2"></i>
                        <strong>Exchange Rate Format:</strong> Enter how many KES equals 1 USD. For example, if 1 USD = 150 KES, enter 150.
                    </div>

                    <div class="form-input-group">
                        <label for="month" class="form-input-label">
                            <i class="bi bi-calendar-month text-primary me-2"></i>
                            Month
                        </label>
                        <select name="month" id="month" class="form-input" required>
                            <option value="">Select month...</option>
                            <option value="1">January</option>
                            <option value="2">February</option>
                            <option value="3">March</option>
                            <option value="4">April</option>
                            <option value="5">May</option>
                            <option value="6">June</option>
                            <option value="7">July</option>
                            <option value="8">August</option>
                            <option value="9">September</option>
                            <option value="10">October</option>
                            <option value="11">November</option>
                            <option value="12">December</option>
                        </select>
                    </div>

                    <div class="form-input-group">
                        <label for="year" class="form-input-label">
                            <i class="bi bi-calendar text-primary me-2"></i>
                            Year
                        </label>
                        <select name="year" id="year" class="form-input" required></select>
                    </div>

                    <div class="form-input-group">
                        <label for="rate" class="form-input-label">
                            <i class="bi bi-currency-exchange text-primary me-2"></i>
                            Exchange Rate (1 USD = ? KES)
                        </label>
                        <input type="number" name="rate" id="rate" class="form-input"
                               step="0.0001" min="0.01" placeholder="150.5000" required />
                        <small class="text-muted mt-1 d-block">
                            <i class="bi bi-info-circle me-1"></i>
                            Enter up to 4 decimal places
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Create Exchange Rate
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Update Rate Modal -->
<div class="modal fade" id="updateRateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-pencil me-2"></i>Update Exchange Rate
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Update">
                <input type="hidden" name="id" id="updateId" />
                <div class="modal-body">
                    <div class="alert alert-warning border-0" style="background-color: #fff3cd;">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        <strong>Period:</strong> <span id="updatePeriod"></span>
                        <br><small>You can only update the exchange rate value. To change the period, delete and create a new rate.</small>
                    </div>

                    <div class="form-input-group">
                        <label for="updateRate" class="form-input-label">
                            <i class="bi bi-currency-exchange text-primary me-2"></i>
                            New Exchange Rate (1 USD = ? KES)
                        </label>
                        <input type="number" name="rate" id="updateRate" class="form-input"
                               step="0.0001" min="0.01" placeholder="150.5000" required />
                        <small class="text-muted mt-1 d-block">
                            <i class="bi bi-info-circle me-1"></i>
                            Enter up to 4 decimal places
                        </small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Update Exchange Rate
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Populate year dropdown
        document.addEventListener('DOMContentLoaded', function() {
            const yearSelect = document.getElementById('year');
            const currentYear = new Date().getFullYear();

            for (let year = currentYear; year >= currentYear - 10; year--) {
                const option = document.createElement('option');
                option.value = year;
                option.textContent = year;
                yearSelect.appendChild(option);
            }

            // Set default to current month/year
            const currentMonth = new Date().getMonth() + 1;
            document.getElementById('month').value = currentMonth;
            yearSelect.value = currentYear;
        });

        // Open update modal with pre-filled data
        function openUpdateModal(id, month, year, rate) {
            const monthNames = ['', 'January', 'February', 'March', 'April', 'May', 'June',
                              'July', 'August', 'September', 'October', 'November', 'December'];

            document.getElementById('updateId').value = id;
            document.getElementById('updatePeriod').textContent = `${monthNames[month]} ${year}`;
            document.getElementById('updateRate').value = rate.toFixed(4);

            const modal = new bootstrap.Modal(document.getElementById('updateRateModal'));
            modal.show();
        }
    </script>
}
