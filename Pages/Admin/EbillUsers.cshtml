        // Authentication Method Radio Button Handlers
        (function initAuthMethodToggle() {
            const authMethodAzure = document.getElementById('authMethodAzure');
            const authMethodLocal = document.getElementById('authMethodLocal');
            const authOptionAzure = document.getElementById('authOptionAzure');
            const authOptionLocal = document.getElementById('authOptionLocal');
            const passwordSection = document.getElementById('passwordSection');
            const checkbox = document.getElementById('createLoginAccount');

            function updateAuthMethodUI() {
                const isLocalSelected = authMethodLocal?.checked;

                // Update visual styling for options
                if (authOptionAzure) {
                    authOptionAzure.style.borderColor = !isLocalSelected ? '#0d6efd' : '#dee2e6';
                    authOptionAzure.style.backgroundColor = !isLocalSelected ? '#f0f7ff' : '#fff';
                }
                if (authOptionLocal) {
                    authOptionLocal.style.borderColor = isLocalSelected ? '#0d6efd' : '#dee2e6';
                    authOptionLocal.style.backgroundColor = isLocalSelected ? '#f0f7ff' : '#fff';
                }

                // Show/hide password section
                if (passwordSection) {
                    passwordSection.style.display = isLocalSelected ? 'block' : 'none';
                }

                // Update hidden checkbox for form submission
                if (checkbox) {
                    checkbox.checked = isLocalSelected;
                }
            }

            // Add event listeners
            authMethodAzure?.addEventListener('change', updateAuthMethodUI);
            authMethodLocal?.addEventListener('change', updateAuthMethodUI);

            // Make the entire option div clickable
            authOptionAzure?.addEventListener('click', function(e) {
                if (e.target.type !== 'radio') {
                    authMethodAzure.checked = true;
                    updateAuthMethodUI();
                }
            });
            authOptionLocal?.addEventListener('click', function(e) {
                if (e.target.type !== 'radio') {
                    authMethodLocal.checked = true;
                    updateAuthMethodUI();
                }
            });

            // Initialize UI state
            updateAuthMethodUI();
        })();

