<!-- Import Users Modal -->
<div class="modal fade" id="importUsersModal" tabindex="-1" aria-labelledby="importUsersModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0" style="padding: 2rem 2rem 1rem 2rem;">
                <div class="w-100 text-center">
                    <div class="mb-3">
                        <div class="bg-success bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-file-earmark-arrow-up text-success" style="font-size: 24px;"></i>
                        </div>
                    </div>
                    <h4 class="modal-title fw-bold text-dark mb-1" id="importUsersModalLabel">Import Ebill Users</h4>
                    <p class="text-muted mb-0">Upload a CSV file to bulk import users</p>
                </div>
                <button type="button" class="btn-close position-absolute" data-bs-dismiss="modal" aria-label="Close" style="top: 1rem; right: 1rem;"></button>
            </div>
            <form method="post" asp-page-handler="ImportUsers" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="modal-body" style="padding: 1rem 2rem;">
                    <!-- CSV Format Instructions -->
                    <div class="alert alert-info border-0" style="background-color: #e0f2fe; border-radius: 12px;">
                        <h6 class="fw-bold mb-2"><i class="bi bi-info-circle me-2"></i>CSV Format Requirements</h6>
                        <p class="mb-2">Your CSV file should include the following columns in this exact order:</p>
                        <code class="d-block bg-white p-2 rounded mb-2" style="font-size: 12px;">
                            FirstName,LastName,IndexNumber,Email,OfficialMobileNumber,IssuedDeviceID,ClassOfService,Location,Organization,Office,SupervisorIndexNumber,IsActive
                        </code>
                        <small class="text-muted">
                            <strong>Note:</strong> 
                            <ul class="mb-0 mt-1">
                                <li>The first row should contain column headers</li>
                                <li>IsActive should be TRUE or FALSE</li>
                                <li>Leave fields empty if not applicable (e.g., IssuedDeviceID, Organization)</li>
                                <li><strong>Important:</strong> The following fields must match existing values in the system:
                                    <ul>
                                        <li><strong>ClassOfService</strong> - Must match an active service class name</li>
                                        <li><strong>Organization</strong> - Must match an existing organization name</li>
                                        <li><strong>Office</strong> - Must match an existing office name</li>
                                        <li><strong>SupervisorIndexNumber</strong> - Must be the username/index number of an active supervisor</li>
                                    </ul>
                                </li>
                                <li>Invalid dropdown values will cause the row to fail import</li>
                            </ul>
                        </small>
                    </div>

                    <!-- File Upload -->
                    <div class="mb-4">
                        <label class="form-label-modern">Choose CSV File</label>
                        <div class="position-relative">
                            <input type="file" class="form-control form-control-modern" id="csvFile" name="csvFile" accept=".csv" required 
                                   style="padding: 12px;" />
                            <div class="form-text">Maximum file size: 5MB</div>
                        </div>
                    </div>

                    <!-- Download Sample -->
                    <div class="text-center mb-3">
                        <a href="#" onclick="downloadSampleCSV()" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-download me-2"></i>Download Sample CSV Template
                        </a>
                    </div>

                    <!-- Import Options -->
                    <div class="mb-4">
                        <h6 class="text-muted text-uppercase fw-semibold mb-3" style="font-size: 0.75rem; letter-spacing: 1px;">Import Options</h6>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="skipDuplicates" name="skipDuplicates" checked>
                            <label class="form-check-label" for="skipDuplicates">
                                Skip duplicate users (based on Index Number or Email)
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="updateExisting" name="updateExisting">
                            <label class="form-check-label" for="updateExisting">
                                Update existing users if found
                            </label>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0" style="padding: 1rem 2rem 2rem 2rem;">
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end w-100">
                        <button type="button" class="btn btn-light me-md-2 px-4 py-2" data-bs-dismiss="modal" style="border-radius: 12px; font-weight: 500;">Cancel</button>
                        <button type="submit" class="btn btn-success px-4 py-2" style="border-radius: 12px; font-weight: 500;">
                            <i class="bi bi-upload me-2"></i>Import Users
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>


