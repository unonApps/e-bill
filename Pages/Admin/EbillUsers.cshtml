@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Handle Delete Modal
        document.addEventListener('DOMContentLoaded', function() {
            var deleteModal = document.getElementById('deleteUserModal');
            deleteModal.addEventListener('show.bs.modal', function(event) {
                var button = event.relatedTarget;
                var userId = button.getAttribute('data-user-id');
                var userName = button.getAttribute('data-user-name');
                var userIndex = button.getAttribute('data-user-index');

                // Update modal content
                document.getElementById('deleteUserId').value = userId;
                document.getElementById('deleteUserName').textContent = userName || 'Unknown User';
                document.getElementById('deleteUserIndex').textContent = userIndex || 'N/A';
            });

            // Bulk delete functionality
            const selectAllCheckbox = document.getElementById('selectAllUsers');
            const userCheckboxes = document.querySelectorAll('.user-checkbox');
            const bulkDeleteControls = document.getElementById('bulkDeleteControls');
            const selectedCountElement = document.getElementById('selectedCount');
            const clearSelectionBtn = document.getElementById('clearSelectionBtn');
            const bulkDeleteModal = document.getElementById('bulkDeleteModal');
            const bulkStatusModal = document.getElementById('bulkStatusModal');

            let selectedUsers = new Set();

            // Update UI based on selection
            function updateBulkDeleteUI() {
                const count = selectedUsers.size;
                selectedCountElement.textContent = count;

                if (count > 0) {
                    bulkDeleteControls.classList.remove('d-none');
                    bulkDeleteControls.classList.add('d-flex');
                } else {
                    bulkDeleteControls.classList.add('d-none');
                    bulkDeleteControls.classList.remove('d-flex');
                }

                // Update select all checkbox state
                if (selectAllCheckbox) {
                    selectAllCheckbox.checked = count === userCheckboxes.length && count > 0;
                    selectAllCheckbox.indeterminate = count > 0 && count < userCheckboxes.length;
                }
            }

            // Handle individual checkbox change
            userCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const userId = this.getAttribute('data-user-id');
                    const userName = this.getAttribute('data-user-name');

                    if (this.checked) {
                        // Remove any existing entry with the same ID first
                        selectedUsers = new Set([...selectedUsers].filter(user => user.id !== userId));
                        // Add the user
                        selectedUsers.add({ id: userId, name: userName });
                    } else {
                        // Remove the user
                        selectedUsers = new Set([...selectedUsers].filter(user => user.id !== userId));
                    }
                    updateBulkDeleteUI();
                });
            });

            // Handle select all checkbox
            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener('change', function() {
                    if (this.checked) {
                        // Clear and rebuild the set with all users
                        selectedUsers.clear();
                        userCheckboxes.forEach(checkbox => {
                            checkbox.checked = true;
                            const userId = checkbox.getAttribute('data-user-id');
                            const userName = checkbox.getAttribute('data-user-name');
                            selectedUsers.add({ id: userId, name: userName });
                        });
                    } else {
                        // Uncheck all and clear the set
                        selectedUsers.clear();
                        userCheckboxes.forEach(checkbox => {
                            checkbox.checked = false;
                        });
                    }
                    updateBulkDeleteUI();
                });
            }

            // Clear selection button
            if (clearSelectionBtn) {
                clearSelectionBtn.addEventListener('click', function() {
                    selectedUsers.clear();
                    userCheckboxes.forEach(checkbox => {
                        checkbox.checked = false;
                    });
                    if (selectAllCheckbox) {
                        selectAllCheckbox.checked = false;
                    }
                    updateBulkDeleteUI();
                });
            }

            // Handle bulk delete modal show
            if (bulkDeleteModal) {
                bulkDeleteModal.addEventListener('show.bs.modal', function() {
                    const count = selectedUsers.size;
                    document.getElementById('bulkDeleteCount').textContent = count;
                    document.getElementById('bulkDeleteButtonCount').textContent = count;

                    // Populate user list
                    const usersList = document.getElementById('bulkDeleteUsersList');
                    usersList.innerHTML = '';

                    // Clear and add hidden inputs for user IDs
                    const selectedUserIdsDiv = document.getElementById('selectedUserIds');
                    selectedUserIdsDiv.innerHTML = '';

                    selectedUsers.forEach(user => {
                        // Add to list
                        const li = document.createElement('li');
                        li.className = 'mb-1';
                        li.innerHTML = `<i class="bi bi-person-x text-danger me-2"></i>${user.name || 'Unknown User'}`;
                        usersList.appendChild(li);

                        // Add hidden input
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'userIds';
                        input.value = user.id;
                        selectedUserIdsDiv.appendChild(input);
                    });
                });
            }

            // Handle bulk status change modal show
            if (bulkStatusModal) {
                bulkStatusModal.addEventListener('show.bs.modal', function() {
                    const count = selectedUsers.size;
                    document.getElementById('bulkStatusCount').textContent = count;

                    // Populate user list
                    const usersList = document.getElementById('bulkStatusUsersList');
                    usersList.innerHTML = '';

                    // Clear and add hidden inputs for user IDs
                    const statusSelectedUserIdsDiv = document.getElementById('statusSelectedUserIds');
                    statusSelectedUserIdsDiv.innerHTML = '';

                    selectedUsers.forEach(user => {
                        // Add to list
                        const li = document.createElement('li');
                        li.className = 'mb-1';
                        li.innerHTML = `<i class="bi bi-person me-2"></i>${user.name || 'Unknown User'}`;
                        usersList.appendChild(li);

                        // Add hidden input
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'userIds';
                        input.value = user.id;
                        statusSelectedUserIdsDiv.appendChild(input);
                    });
                });
            }
        });

        // Helper function to show error message
        function showError(message, isCreate) {
            var errorDiv = document.getElementById(isCreate ? 'createUserError' : 'editUserError');
            var errorMessage = document.getElementById(isCreate ? 'createUserErrorMessage' : 'editUserErrorMessage');

            if (errorDiv && errorMessage) {
                errorMessage.textContent = message;
                errorDiv.classList.remove('d-none');

                // Auto-hide after 5 seconds
                setTimeout(function() {
                    errorDiv.classList.add('d-none');
                }, 5000);
            }
        }

        // Helper function to hide error message
        function hideError(isCreate) {
            var errorDiv = document.getElementById(isCreate ? 'createUserError' : 'editUserError');
            if (errorDiv) {
                errorDiv.classList.add('d-none');
            }
        }

        // Function to load offices based on selected organization
        function loadOffices(organizationSelectId, officeSelectId, subOfficeSelectId, selectedOfficeId) {
            var organizationId = document.getElementById(organizationSelectId).value;
            var officeSelect = document.getElementById(officeSelectId);
            var subOfficeSelect = document.getElementById(subOfficeSelectId);

            // Clear office options
            officeSelect.innerHTML = '<option value="">Select office...</option>';
            // Clear sub-office options
            subOfficeSelect.innerHTML = '<option value="">Select sub office...</option>';

            if (!organizationId) {
                return;
            }

            // Determine if this is for create or edit form
            var isCreate = organizationSelectId.includes('Input');

            // Show loading state
            officeSelect.disabled = true;
            officeSelect.innerHTML = '<option value="">Loading offices...</option>';

            // Fetch offices for the selected organization
            fetch(`/Admin/EbillUsers?handler=Offices&organizationId=${organizationId}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`Failed to load offices: ${response.statusText}`);
                    }
                    return response.json();
                })
                .then(data => {
                    officeSelect.disabled = false;
                    officeSelect.innerHTML = '<option value="">Select office...</option>';

                    if (data.length === 0) {
                        officeSelect.innerHTML = '<option value="">No offices available for this organization</option>';
                        return;
                    }

                    data.forEach(office => {
                        var option = document.createElement('option');
                        option.value = office.value;
                        option.textContent = office.text;
                        if (selectedOfficeId && office.value == selectedOfficeId) {
                            option.selected = true;
                        }
                        officeSelect.appendChild(option);
                    });

                    // If an office was selected, load its sub-offices
                    if (selectedOfficeId) {
                        loadSubOffices(officeSelectId, subOfficeSelectId, null);
                    }

                    hideError(isCreate);
                })
                .catch(error => {
                    officeSelect.disabled = false;
                    officeSelect.innerHTML = '<option value="">Failed to load offices</option>';
                    showError('Failed to load offices. Please try again or contact support if the problem persists.', isCreate);
                    console.error('Error loading offices:', error);
                });
        }

        // Function to load suboffices based on selected office
        function loadSubOffices(officeSelectId, subOfficeSelectId, selectedSubOfficeId) {
            var officeId = document.getElementById(officeSelectId).value;
            var subOfficeSelect = document.getElementById(subOfficeSelectId);

            // Clear existing options
            subOfficeSelect.innerHTML = '<option value="">Select sub office...</option>';

            if (!officeId) {
                return;
            }

            // Determine if this is for create or edit form
            var isCreate = officeSelectId.includes('create');

            // Show loading state
            subOfficeSelect.disabled = true;
            subOfficeSelect.innerHTML = '<option value="">Loading sub offices...</option>';

            // Fetch suboffices for the selected office
            fetch(`/Admin/EbillUsers?handler=SubOffices&officeId=${officeId}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`Failed to load sub offices: ${response.statusText}`);
                    }
                    return response.json();
                })
                .then(data => {
                    subOfficeSelect.disabled = false;
                    subOfficeSelect.innerHTML = '<option value="">Select sub office...</option>';

                    if (data.length === 0) {
                        subOfficeSelect.innerHTML = '<option value="">No sub offices available for this office</option>';
                        return;
                    }

                    data.forEach(subOffice => {
                        var option = document.createElement('option');
                        option.value = subOffice.value;
                        option.textContent = subOffice.text;
                        if (selectedSubOfficeId && subOffice.value == selectedSubOfficeId) {
                            option.selected = true;
                        }
                        subOfficeSelect.appendChild(option);
                    });

                    hideError(isCreate);
                })
                .catch(error => {
                    subOfficeSelect.disabled = false;
                    subOfficeSelect.innerHTML = '<option value="">Failed to load sub offices</option>';
                    showError('Failed to load sub offices. Please try again or contact support if the problem persists.', isCreate);
                    console.error('Error loading sub offices:', error);
                });
        }

        // Add event listeners for cascading dropdowns
        document.addEventListener('DOMContentLoaded', function() {
            // Create form - Organization change
            var createOrganizationSelect = document.getElementById('Input_OrganizationId');
            if (createOrganizationSelect) {
                createOrganizationSelect.addEventListener('change', function() {
                    loadOffices('Input_OrganizationId', 'createOfficeId', 'createSubOfficeId', null);
                });
            }

            // Create form - Office change
            var createOfficeSelect = document.getElementById('createOfficeId');
            if (createOfficeSelect) {
                createOfficeSelect.addEventListener('change', function() {
                    loadSubOffices('createOfficeId', 'createSubOfficeId', null);
                });
            }

            // Edit form - Organization change
            var editOrganizationSelect = document.getElementById('editOrganization');
            if (editOrganizationSelect) {
                editOrganizationSelect.addEventListener('change', function() {
                    loadOffices('editOrganization', 'editOffice', 'editSubOffice', null);
                });
            }

            // Edit form - Office change
            var editOfficeSelect = document.getElementById('editOffice');
            if (editOfficeSelect) {
                editOfficeSelect.addEventListener('change', function() {
                    loadSubOffices('editOffice', 'editSubOffice', null);
                });
            }
        });
        document.addEventListener('DOMContentLoaded', function() {
            // Show modal if validation failed
            @if (ViewData["ShowCreateModal"] != null && ViewData["ShowCreateModal"] as bool? == true)
            {
                <text>
                var createModal = new bootstrap.Modal(document.getElementById('createUserModal'));
                createModal.show();
                </text>
            }
            
            
            // Clear the form when modal is opened fresh
            document.getElementById('createUserModal').addEventListener('show.bs.modal', function (event) {
                // Only clear if not showing due to validation error
                @if (ViewData["ShowCreateModal"] == null || ViewData["ShowCreateModal"] as bool? != true)
                {
                    <text>
                    var form = this.querySelector('form');
                    if (form) {
                        form.reset();
                        // Clear validation messages
                        var validationMessages = form.querySelectorAll('.text-danger');
                        validationMessages.forEach(function(elem) {
                            elem.textContent = '';
                        });
                    }
                    </text>
                }
            });
        });

        // Function to populate edit user modal
        // Handle edit user button clicks using event delegation
        document.addEventListener('click', function(event) {
            if (event.target.closest('.btn-edit-user')) {
                const btn = event.target.closest('.btn-edit-user');
                editUserFromButton(btn);
            }
        });

        function editUserFromButton(button) {
            try {
                const id = button.getAttribute('data-user-id');
                const firstName = button.getAttribute('data-first-name');
                const lastName = button.getAttribute('data-last-name');
                const indexNumber = button.getAttribute('data-index-number');
                const email = button.getAttribute('data-email');
                const mobileNumber = button.getAttribute('data-mobile-number');
                const deviceId = button.getAttribute('data-device-id');
                const location = button.getAttribute('data-location');
                const organization = button.getAttribute('data-organization');
                const office = button.getAttribute('data-office');
                const subOffice = button.getAttribute('data-sub-office');
                const isActive = button.getAttribute('data-is-active');
                const supervisorIndexNumber = button.getAttribute('data-supervisor');
                const hasLoginAccount = button.getAttribute('data-has-login') === 'True';
                const loginEnabled = button.getAttribute('data-login-enabled') === 'True';

                console.log('Edit User Data:', {
                    id, firstName, lastName, indexNumber, email,
                    organization, office, subOffice, isActive,
                    hasLoginAccount, loginEnabled
                });

                // Store for password reset/create account handlers
                window.currentEditUserId = id;

                // Update login account status
                updateLoginAccountStatus(hasLoginAccount, loginEnabled);

                editUser(id, firstName, lastName, indexNumber, email, mobileNumber, deviceId, location, organization, office, subOffice, isActive, supervisorIndexNumber);
            } catch (error) {
                console.error('Error in editUserFromButton:', error);
                alert('Failed to edit user. Please check the console for details.');
            }
        }

        function updateLoginAccountStatus(hasLoginAccount, loginEnabled) {
            const statusEl = document.getElementById('loginAccountStatus');
            const detailsEl = document.getElementById('loginAccountDetails');
            const resetBtn = document.getElementById('resetPasswordBtn');
            const createBtn = document.getElementById('createAccountBtn');

            if (hasLoginAccount) {
                statusEl.textContent = loginEnabled ? 'Login Account Active' : 'Login Account Disabled';
                statusEl.className = loginEnabled ? 'text-success' : 'text-warning';
                detailsEl.textContent = loginEnabled ?
                    'User can sign in with their email and password' :
                    'Login is currently disabled for this user';
                resetBtn.style.display = 'inline-block';
                createBtn.style.display = 'none';
            } else {
                statusEl.textContent = 'No Login Account';
                statusEl.className = 'text-muted';
                detailsEl.textContent = 'User cannot sign in to the system';
                resetBtn.style.display = 'none';
                createBtn.style.display = 'inline-block';
            }
        }

        function editUser(id, firstName, lastName, indexNumber, email, mobileNumber, deviceId, location, organization, office, subOffice, isActive, supervisorIndexNumber) {
            try {
                console.log('EditUser function called with ID:', id);

                // Clear any previous errors
                hideError(false);

                // Set the hidden ID field
                var idField = document.getElementById('editUserId');
                if (!idField) {
                    console.error('Edit user ID field not found!');
                    return;
                }
                idField.value = id;

                // Also set the EditInput.Id field if it exists
                var editInputId = document.getElementById('EditInput_Id');
                if (editInputId) {
                    editInputId.value = id;
                }

                console.log('Setting form fields...');
                document.getElementById('editFirstName').value = firstName || '';
                document.getElementById('editLastName').value = lastName || '';
                document.getElementById('editIndexNumber').value = indexNumber || '';
                document.getElementById('editEmail').value = email || '';
                document.getElementById('editOfficialMobileNumber').value = mobileNumber || '';
                document.getElementById('editIssuedDeviceID').value = deviceId || '';
                document.getElementById('editLocation').value = location || '';
                document.getElementById('editOrganization').value = organization || '';

            // Load offices for the selected organization, then load sub-offices
            if (organization) {
                var officeSelect = document.getElementById('editOffice');
                officeSelect.disabled = true;
                officeSelect.innerHTML = '<option value="">Loading offices...</option>';

                // Load offices for this organization
                fetch(`/Admin/EbillUsers?handler=Offices&organizationId=${organization}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`Failed to load offices: ${response.statusText}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        officeSelect.disabled = false;
                        officeSelect.innerHTML = '<option value="">Select office...</option>';

                        if (data.length === 0) {
                            officeSelect.innerHTML = '<option value="">No offices available for this organization</option>';
                            return;
                        }

                        data.forEach(officeItem => {
                            var option = document.createElement('option');
                            option.value = officeItem.value;
                            option.textContent = officeItem.text;
                            if (office && officeItem.value == office) {
                                option.selected = true;
                            }
                            officeSelect.appendChild(option);
                        });

                        // After offices are loaded, load sub-offices if an office is selected
                        if (office) {
                            loadSubOffices('editOffice', 'editSubOffice', subOffice);
                        }

                        hideError(false);
                    })
                    .catch(error => {
                        officeSelect.disabled = false;
                        officeSelect.innerHTML = '<option value="">Failed to load offices</option>';
                        showError('Failed to load offices for editing. Please try again.', false);
                        console.error('Error loading offices:', error);
                    });
            } else {
                document.getElementById('editOffice').innerHTML = '<option value="">Select office...</option>';
                document.getElementById('editSubOffice').innerHTML = '<option value="">Select sub office...</option>';
            }

            document.getElementById('editIsActive').checked = isActive === 'true' || isActive === true;
            document.getElementById('editSupervisorIndexNumber').value = supervisorIndexNumber || '';

            // Open the modal
            var editModal = new bootstrap.Modal(document.getElementById('editUserModal'));
            editModal.show();
            } catch (error) {
                console.error('Error opening edit modal:', error);
                showError('Failed to open edit modal. Please check the console for details.', false);
            }
        }

        // Clear form validation errors when modals are closed
        document.getElementById('createUserModal').addEventListener('hidden.bs.modal', function () {
            // Clear validation errors
            const validationSpans = document.querySelectorAll('#createUserModal .text-danger');
            validationSpans.forEach(span => {
                if (span.classList.contains('small')) {
                    span.textContent = '';
                }
            });
        });

        document.getElementById('editUserModal').addEventListener('hidden.bs.modal', function () {
            // Clear validation errors
            const validationSpans = document.querySelectorAll('#editUserModal .text-danger');
            validationSpans.forEach(span => {
                if (span.classList.contains('small')) {
                    span.textContent = '';
                }
            });
        });

        // Function to download sample CSV
        function downloadSampleCSV() {
            const csvContent = `FirstName,LastName,IndexNumber,Email,OfficialMobileNumber,IssuedDeviceID,ClassOfService,Location,Organization,Office,SupervisorIndexNumber,IsActive
John,Doe,EMP001,john.doe@example.com,+1234567890,DEV001,Local,Nairobi,UNON,Gigiri Office,SUP001,TRUE
Jane,Smith,EMP002,jane.smith@example.com,+1234567891,DEV002,International,Geneva,UNEP,Regional Office,SUP001,TRUE
Robert,Johnson,EMP003,robert.j@example.com,+1234567892,DEV003,Local,Mombasa,UN-Habitat,Field Office,SUP002,FALSE
Mary,Williams,EMP004,mary.w@example.com,+1234567893,DEV004,Local,Nakuru,UNON,Main Building,SUP002,TRUE
David,Brown,EMP005,david.brown@example.com,+1234567894,DEV005,International,Nairobi,UNEP,Satellite Office,SUP003,TRUE
Sarah,Davis,EMP006,sarah.davis@example.com,+1234567895,DEV006,Local,Kisumu,UN-Habitat,Regional Office,SUP003,TRUE

Note:
- All 12 columns must be present in each row (use empty values for optional fields)
- ClassOfService, Organization, Office must match existing values in your system
- Location is a free text field for user location information
- IsActive should be TRUE or FALSE
- Empty values are allowed for optional fields but the comma separators must be present`;
            
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            
            link.setAttribute('href', url);
            link.setAttribute('download', 'ebill_users_template.csv');
            link.style.visibility = 'hidden';
            
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }


        // Add form submission handler for edit form
        var editForm = document.getElementById('editUserForm');
        if (editForm) {
            editForm.addEventListener('submit', function(e) {
                console.log('Edit form is being submitted');
                console.log('Form action:', this.action);
                console.log('Form method:', this.method);
                console.log('Form data:', new FormData(this));
                // Let the form submit normally
            });
        } else {
            console.error('Edit form not found!');
        }

        // Show import result modal if there are results
        @if (TempData["ImportResults"] != null)
        {
            <text>
            var importModal = new bootstrap.Modal(document.getElementById('importResultsModal'));
            importModal.show();
            </text>
        }

        // Password generation and management
        function generateStrongPassword() {
            const length = 12;
            const charset = {
                upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
                lower: 'abcdefghijklmnopqrstuvwxyz',
                number: '0123456789',
                special: '!@@#$%^&*'
            };

            let password = '';
            password += charset.upper[Math.floor(Math.random() * charset.upper.length)];
            password += charset.lower[Math.floor(Math.random() * charset.lower.length)];
            password += charset.number[Math.floor(Math.random() * charset.number.length)];
            password += charset.special[Math.floor(Math.random() * charset.special.length)];

            const allChars = charset.upper + charset.lower + charset.number + charset.special;
            for (let i = password.length; i < length; i++) {
                password += allChars[Math.floor(Math.random() * allChars.length)];
            }

            return password.split('').sort(() => Math.random() - 0.5).join('');
        }

        document.getElementById('generatePasswordBtn')?.addEventListener('click', function() {
            const password = generateStrongPassword();
            document.getElementById('Input_Password').value = password;
            document.getElementById('Input_ConfirmPassword').value = password;
            document.getElementById('Input_Password').type = 'text';
            document.getElementById('Input_ConfirmPassword').type = 'text';
        });

        document.getElementById('createLoginAccount')?.addEventListener('change', function() {
            document.getElementById('passwordSection').style.display = this.checked ? 'block' : 'none';
        });

        window.copyToClipboard = function(elementId) {
            const element = document.getElementById(elementId);
            element.select();
            document.execCommand('copy');
            const toast = document.createElement('div');
            toast.className = 'position-fixed top-0 end-0 p-3';
            toast.style.zIndex = '9999';
            toast.innerHTML = '<div class="toast show" role="alert"><div class="toast-body bg-success text-white">Copied!</div></div>';
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 2000);
        };

        document.getElementById('resetPasswordBtn')?.addEventListener('click', async function() {
            if (!window.currentEditUserId || !confirm('Generate new password?')) return;
            this.disabled = true;
            try {
                const response = await fetch(`?handler=ResetPassword&userId=${window.currentEditUserId}`, {method: 'POST', headers: {'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value}});
                const result = await response.json();
                if (result.success) {
                    document.getElementById('displayEmail').value = result.email;
                    document.getElementById('displayPassword').value = result.tempPassword;
                    bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
                    new bootstrap.Modal(document.getElementById('passwordModal')).show();
                } else alert('Error: ' + result.message);
            } catch (error) {
                alert('Error: ' + error.message);
            } finally {
                this.disabled = false;
            }
        });

        document.getElementById('createAccountBtn')?.addEventListener('click', async function() {
            if (!window.currentEditUserId) return;
            this.disabled = true;
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Creating...';
            try {
                const response = await fetch(`?handler=CreateAccount&userId=${window.currentEditUserId}`, {method: 'POST', headers: {'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value}});
                const result = await response.json();
                if (result.success) {
                    document.getElementById('displayEmail').value = result.email;
                    document.getElementById('displayPassword').value = result.tempPassword;
                    bootstrap.Modal.getInstance(document.getElementById('editUserModal')).hide();
                    const pwdModal = new bootstrap.Modal(document.getElementById('passwordModal'));
                    pwdModal.show();
                    pwdModal._element.addEventListener('hidden.bs.modal', () => location.reload());
                } else alert('Error: ' + result.message);
            } catch (error) {
                alert('Error: ' + error.message);
            } finally {
                this.disabled = false;
                this.innerHTML = '<i class="bi bi-person-plus"></i> Create Login Account';
            }
        });

        // Search functionality
        document.getElementById('searchUsers').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#usersTable tbody tr');

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });
        
        // Add animation to status badges
        document.querySelectorAll('.badge').forEach(badge => {
            badge.addEventListener('mouseenter', function() {
                this.style.transform = 'translateY(-2px) scale(1.05)';
            });
            badge.addEventListener('mouseleave', function() {
                this.style.transform = 'translateY(0) scale(1)';
            });
        });
    </script>
}