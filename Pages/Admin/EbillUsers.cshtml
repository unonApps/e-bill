        // Search functionality - Client-side for current page, Enter for full search
        (function initSearch() {
            const searchInput = document.getElementById('searchUsers');
            const searchForm = document.getElementById('inlineSearchForm');
            const table = document.getElementById('usersTable');

            if (!searchInput || !table) {
                console.error('Search input or table not found!');
                return;
            }

            console.log('Search initialized');

            function performClientSearch() {
                const searchTerm = searchInput.value.toLowerCase().trim();
                const rows = table.querySelectorAll('tbody tr.user-row');

                let visibleCount = 0;
                rows.forEach(row => {
                    // Get all searchable fields from data attributes
                    const userName = (row.getAttribute('data-user-name') || '').toLowerCase();
                    const firstName = (row.getAttribute('data-first-name') || '').toLowerCase();
                    const lastName = (row.getAttribute('data-last-name') || '').toLowerCase();
                    const userIndex = (row.getAttribute('data-user-index') || '').toLowerCase();
                    const userEmail = (row.getAttribute('data-user-email') || '').toLowerCase();
                    const userPhone = (row.getAttribute('data-user-phone') || '').toLowerCase();
                    const userOrg = (row.getAttribute('data-user-org') || '').toLowerCase();
                    const userOffice = (row.getAttribute('data-user-office') || '').toLowerCase();

                    // Check if search term matches any of the searchable fields
                    const matches = searchTerm === '' ||
                                   userName.includes(searchTerm) ||
                                   firstName.includes(searchTerm) ||
                                   lastName.includes(searchTerm) ||
                                   userIndex.includes(searchTerm) ||
                                   userEmail.includes(searchTerm) ||
                                   userPhone.includes(searchTerm) ||
                                   userOrg.includes(searchTerm) ||
                                   userOffice.includes(searchTerm);

                    row.style.display = matches ? '' : 'none';
                    if (matches) visibleCount++;
                });
                console.log('Client search:', searchTerm, '| Visible on page:', visibleCount);
            }

            // Client-side instant filtering for current page
            searchInput.addEventListener('input', performClientSearch);
            searchInput.addEventListener('search', performClientSearch); // For clearing with X button

            // Enter key submits form for full database search
            searchInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter') {
                    // Allow form submission for server-side search
                    console.log('Submitting server-side search');
                }
            });
        })();

