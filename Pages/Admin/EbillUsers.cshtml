@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Handle Delete Modal
        document.addEventListener('DOMContentLoaded', function() {
            var deleteModal = document.getElementById('deleteUserModal');
            deleteModal.addEventListener('show.bs.modal', function(event) {
                var button = event.relatedTarget;
                var userId = button.getAttribute('data-user-id');
                var userName = button.getAttribute('data-user-name');
                var userIndex = button.getAttribute('data-user-index');

                // Update modal content
                document.getElementById('deleteUserId').value = userId;
                document.getElementById('deleteUserName').textContent = userName || 'Unknown User';
                document.getElementById('deleteUserIndex').textContent = userIndex || 'N/A';
            });

            // Bulk delete functionality
            const selectAllCheckbox = document.getElementById('selectAllUsers');
            const userCheckboxes = document.querySelectorAll('.user-checkbox');
            const bulkDeleteControls = document.getElementById('bulkDeleteControls');
            const selectedCountElement = document.getElementById('selectedCount');
            const clearSelectionBtn = document.getElementById('clearSelectionBtn');
            const bulkDeleteModal = document.getElementById('bulkDeleteModal');
            const bulkStatusModal = document.getElementById('bulkStatusModal');

            let selectedUsers = new Set();

            // Update UI based on selection
            function updateBulkDeleteUI() {
                const count = selectedUsers.size;
                selectedCountElement.textContent = count;

                if (count > 0) {
                    bulkDeleteControls.classList.remove('d-none');
                    bulkDeleteControls.classList.add('d-flex');
                } else {
                    bulkDeleteControls.classList.add('d-none');
                    bulkDeleteControls.classList.remove('d-flex');
                }

                // Update select all checkbox state
                if (selectAllCheckbox) {
                    selectAllCheckbox.checked = count === userCheckboxes.length && count > 0;
                    selectAllCheckbox.indeterminate = count > 0 && count < userCheckboxes.length;
                }
            }

            // Handle individual checkbox change
            userCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const userId = this.getAttribute('data-user-id');
                    const userName = this.getAttribute('data-user-name');

                    if (this.checked) {
                        // Remove any existing entry with the same ID first
                        selectedUsers = new Set([...selectedUsers].filter(user => user.id !== userId));
                        // Add the user
                        selectedUsers.add({ id: userId, name: userName });
                    } else {
                        // Remove the user
                        selectedUsers = new Set([...selectedUsers].filter(user => user.id !== userId));
                    }
                    updateBulkDeleteUI();
                });
            });

            // Handle select all checkbox
            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener('change', function() {
                    if (this.checked) {
                        // Clear and rebuild the set with all users
                        selectedUsers.clear();
                        userCheckboxes.forEach(checkbox => {
                            checkbox.checked = true;
                            const userId = checkbox.getAttribute('data-user-id');
                            const userName = checkbox.getAttribute('data-user-name');
                            selectedUsers.add({ id: userId, name: userName });
                        });
                    } else {
                        // Uncheck all and clear the set
                        selectedUsers.clear();
                        userCheckboxes.forEach(checkbox => {
                            checkbox.checked = false;
                        });
                    }
                    updateBulkDeleteUI();
                });
            }

            // Clear selection button
            if (clearSelectionBtn) {
                clearSelectionBtn.addEventListener('click', function() {
                    selectedUsers.clear();
                    userCheckboxes.forEach(checkbox => {
                        checkbox.checked = false;
                    });
                    if (selectAllCheckbox) {
                        selectAllCheckbox.checked = false;
                    }
                    updateBulkDeleteUI();
                });
            }

            // Handle bulk delete modal show
            if (bulkDeleteModal) {
                bulkDeleteModal.addEventListener('show.bs.modal', function() {
                    const count = selectedUsers.size;
                    document.getElementById('bulkDeleteCount').textContent = count;
                    document.getElementById('bulkDeleteButtonCount').textContent = count;

                    // Populate user list
                    const usersList = document.getElementById('bulkDeleteUsersList');
                    usersList.innerHTML = '';

                    // Clear and add hidden inputs for user IDs
                    const selectedUserIdsDiv = document.getElementById('selectedUserIds');
                    selectedUserIdsDiv.innerHTML = '';

                    selectedUsers.forEach(user => {
                        // Add to list
                        const li = document.createElement('li');
                        li.className = 'mb-1';
                        li.innerHTML = `<i class="bi bi-person-x text-danger me-2"></i>${user.name || 'Unknown User'}`;
                        usersList.appendChild(li);

                        // Add hidden input
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'userIds';
                        input.value = user.id;
                        selectedUserIdsDiv.appendChild(input);
                    });
                });
            }

            // Handle bulk status change modal show
            if (bulkStatusModal) {
                bulkStatusModal.addEventListener('show.bs.modal', function() {
                    const count = selectedUsers.size;
                    document.getElementById('bulkStatusCount').textContent = count;

                    // Populate user list
                    const usersList = document.getElementById('bulkStatusUsersList');
                    usersList.innerHTML = '';

                    // Clear and add hidden inputs for user IDs
                    const statusSelectedUserIdsDiv = document.getElementById('statusSelectedUserIds');
                    statusSelectedUserIdsDiv.innerHTML = '';

                    selectedUsers.forEach(user => {
                        // Add to list
                        const li = document.createElement('li');
                        li.className = 'mb-1';
                        li.innerHTML = `<i class="bi bi-person me-2"></i>${user.name || 'Unknown User'}`;
                        usersList.appendChild(li);

                        // Add hidden input
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'userIds';
                        input.value = user.id;
                        statusSelectedUserIdsDiv.appendChild(input);
                    });
                });
            }
        });

        // Helper function to show error message
        function showError(message, isCreate) {
            var errorDiv = document.getElementById(isCreate ? 'createUserError' : 'editUserError');
            var errorMessage = document.getElementById(isCreate ? 'createUserErrorMessage' : 'editUserErrorMessage');

            if (errorDiv && errorMessage) {
                // Handle multiple errors (array or single string)
                if (Array.isArray(message)) {
                    errorMessage.innerHTML = '<ul class="mb-0 ps-3">' + message.map(m => '<li>' + m + '</li>').join('') + '</ul>';
                } else {
                    errorMessage.textContent = message;
                }
                errorDiv.classList.remove('d-none');

                // Scroll error into view
                errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });

                // Add shake animation
                errorDiv.classList.add('animate__animated', 'animate__shakeX');
                setTimeout(() => {
                    errorDiv.classList.remove('animate__animated', 'animate__shakeX');
                }, 1000);
            }
        }

        // Helper function to hide error message
        function hideError(isCreate) {
            var errorDiv = document.getElementById(isCreate ? 'createUserError' : 'editUserError');
            if (errorDiv) {
                errorDiv.classList.add('d-none');
            }
        }

        // Function to load offices based on selected organization
        function loadOffices(organizationSelectId, officeSelectId, subOfficeSelectId, selectedOfficeId) {
            var organizationId = document.getElementById(organizationSelectId).value;
            var officeSelect = document.getElementById(officeSelectId);
            var subOfficeSelect = document.getElementById(subOfficeSelectId);

            // Clear office options
            officeSelect.innerHTML = '<option value="">Select office...</option>';
            // Clear sub-office options
            subOfficeSelect.innerHTML = '<option value="">Select sub office...</option>';

            if (!organizationId) {
                return;
            }

            // Determine if this is for create or edit form
            var isCreate = organizationSelectId.includes('Input');

            // Show loading state
            officeSelect.disabled = true;
            officeSelect.innerHTML = '<option value="">Loading offices...</option>';

            // Fetch offices for the selected organization
            fetch(`/Admin/EbillUsers?handler=Offices&organizationId=${organizationId}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`Failed to load offices: ${response.statusText}`);
                    }
                    return response.json();
                })
                .then(data => {
                    officeSelect.disabled = false;
                    officeSelect.innerHTML = '<option value="">Select office...</option>';

                    if (data.length === 0) {
                        officeSelect.innerHTML = '<option value="">No offices available for this organization</option>';
                        return;
                    }

                    data.forEach(office => {
                        var option = document.createElement('option');
                        option.value = office.value;
                        option.textContent = office.text;
                        if (selectedOfficeId && office.value == selectedOfficeId) {
                            option.selected = true;
                        }
                        officeSelect.appendChild(option);
                    });

                    // If an office was selected, load its sub-offices
                    if (selectedOfficeId) {
                        loadSubOffices(officeSelectId, subOfficeSelectId, null);
                    }

                    hideError(isCreate);
                })
                .catch(error => {
                    officeSelect.disabled = false;
                    officeSelect.innerHTML = '<option value="">Failed to load offices</option>';
                    showError('Failed to load offices. Please try again or contact support if the problem persists.', isCreate);
                    console.error('Error loading offices:', error);
                });
        }

        // Function to load suboffices based on selected office
        function loadSubOffices(officeSelectId, subOfficeSelectId, selectedSubOfficeId) {
            var officeId = document.getElementById(officeSelectId).value;
            var subOfficeSelect = document.getElementById(subOfficeSelectId);

            // Clear existing options
            subOfficeSelect.innerHTML = '<option value="">Select sub office...</option>';

            if (!officeId) {
                return;
            }

            // Determine if this is for create or edit form
            var isCreate = officeSelectId.includes('create');

            // Show loading state
            subOfficeSelect.disabled = true;
            subOfficeSelect.innerHTML = '<option value="">Loading sub offices...</option>';

            // Fetch suboffices for the selected office
            fetch(`/Admin/EbillUsers?handler=SubOffices&officeId=${officeId}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`Failed to load sub offices: ${response.statusText}`);
                    }
                    return response.json();
                })
                .then(data => {
                    subOfficeSelect.disabled = false;
                    subOfficeSelect.innerHTML = '<option value="">Select sub office...</option>';

                    if (data.length === 0) {
                        subOfficeSelect.innerHTML = '<option value="">No sub offices available for this office</option>';
                        return;
                    }

                    data.forEach(subOffice => {
                        var option = document.createElement('option');
                        option.value = subOffice.value;
                        option.textContent = subOffice.text;
                        if (selectedSubOfficeId && subOffice.value == selectedSubOfficeId) {
                            option.selected = true;
                        }
                        subOfficeSelect.appendChild(option);
                    });

                    hideError(isCreate);
                })
                .catch(error => {
                    subOfficeSelect.disabled = false;
                    subOfficeSelect.innerHTML = '<option value="">Failed to load sub offices</option>';
                    showError('Failed to load sub offices. Please try again or contact support if the problem persists.', isCreate);
                    console.error('Error loading sub offices:', error);
                });
        }

        // Add event listeners for cascading dropdowns
        document.addEventListener('DOMContentLoaded', function() {
            // Create form - Organization change handled by Select2 init

            // Create form - Office change
            var createOfficeSelect = document.getElementById('createOfficeId');
            if (createOfficeSelect) {
                createOfficeSelect.addEventListener('change', function() {
                    loadSubOffices('createOfficeId', 'createSubOfficeId', null);
                });
            }

            // Edit form - Organization change handled by Select2 init

            // Edit form - Office change
