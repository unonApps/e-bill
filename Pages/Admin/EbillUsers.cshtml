        function editUser(id, firstName, lastName, indexNumber, email, deviceId, location, organization, office, subOffice, isActive, supervisorName, supervisorEmail) {
            try {
                console.log('EditUser function called with ID:', id);

                // Clear any previous errors
                hideError(false);

                // Set the hidden ID field
                var idField = document.getElementById('editUserId');
                if (!idField) {
                    console.error('Edit user ID field not found!');
                    return;
                }
                idField.value = id;

                // Also set the EditInput.Id field if it exists
                var editInputId = document.getElementById('EditInput_Id');
                if (editInputId) {
                    editInputId.value = id;
                }

                console.log('Setting form fields...');
                document.getElementById('editFirstName').value = firstName || '';
                document.getElementById('editLastName').value = lastName || '';
                document.getElementById('editIndexNumber').value = indexNumber || '';
                document.getElementById('editEmail').value = email || '';
                document.getElementById('editLocation').value = location || '';
                $('#editOrganization').val(organization || '').trigger('change.select2');

            // Load offices for the selected organization, then load sub-offices
            if (organization) {
                var officeSelect = document.getElementById('editOffice');
                officeSelect.disabled = true;
                officeSelect.innerHTML = '<option value="">Loading offices...</option>';

                // Load offices for this organization
                fetch(`/Admin/EbillUsers?handler=Offices&organizationId=${organization}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error(`Failed to load offices: ${response.statusText}`);
                        }
                        return response.json();
                    })
                    .then(data => {
                        officeSelect.disabled = false;
                        officeSelect.innerHTML = '<option value="">Select office...</option>';

                        if (data.length === 0) {
                            officeSelect.innerHTML = '<option value="">No offices available for this organization</option>';
                            return;
                        }

                        data.forEach(officeItem => {
                            var option = document.createElement('option');
                            option.value = officeItem.value;
                            option.textContent = officeItem.text;
                            if (office && officeItem.value == office) {
                                option.selected = true;
                            }
                            officeSelect.appendChild(option);
                        });

                        // After offices are loaded, load sub-offices if an office is selected
                        if (office) {
                            loadSubOffices('editOffice', 'editSubOffice', subOffice);
                        }

                        hideError(false);
                    })
                    .catch(error => {
                        officeSelect.disabled = false;
                        officeSelect.innerHTML = '<option value="">Failed to load offices</option>';
                        showError('Failed to load offices for editing. Please try again.', false);
                        console.error('Error loading offices:', error);
                    });
            } else {
                document.getElementById('editOffice').innerHTML = '<option value="">Select office...</option>';
                document.getElementById('editSubOffice').innerHTML = '<option value="">Select sub office...</option>';
            }

            document.getElementById('editIsActive').checked = isActive === 'true' || isActive === true;
            document.getElementById('editSupervisorName').value = supervisorName || '';
            document.getElementById('editSupervisorEmail').value = supervisorEmail || '';

            // Open the modal
            var editModal = new bootstrap.Modal(document.getElementById('editUserModal'));
            editModal.show();
            } catch (error) {
                console.error('Error opening edit modal:', error);
                showError('Failed to open edit modal. Please check the console for details.', false);
            }
        }

