                            <h4 class="modal-title fw-bold text-dark mb-1">Confirm Deletion</h4>
                            <p class="text-muted mb-0">This action cannot be undone</p>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn-close position-absolute" data-bs-dismiss="modal" aria-label="Close" style="top: 1rem; right: 1rem;"></button>
            </div>
            <form method="post" asp-page-handler="DeleteUser" id="deleteUserForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteUserId" />
                <div class="modal-body" style="padding: 1rem 2rem;">
                    <div class="alert alert-warning border-0" style="background-color: #fef2f2; color: #991b1b;">
                        <div class="d-flex">
                            <i class="bi bi-info-circle-fill me-2 text-danger"></i>
                            <div>
                                <strong>Are you sure you want to delete this user?</strong>
                                <div class="mt-2">
                                    <p class="mb-1">User Name: <span id="deleteUserName" class="fw-semibold"></span></p>
                                    <p class="mb-0">Index Number: <span id="deleteUserIndex" class="fw-semibold"></span></p>
                                </div>
