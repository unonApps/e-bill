<!-- Verification Period Modal -->
<div class="modal fade" id="verificationPeriodModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius: 16px; border: none; overflow: hidden;">
            <div class="modal-header" style="background: #10b981; border: none; padding: 1.5rem;">
                <h5 class="modal-title text-white d-flex align-items-center">
                    <i class="bi bi-calendar-check me-2"></i>
                    Push to Production - Set Deadlines
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 2rem;">
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center rounded-circle"
                         style="width: 64px; height: 64px; background-color: #d1fae5;">
                        <i class="bi bi-cloud-upload text-success" style="font-size: 28px;"></i>
                    </div>
                </div>

                <h6 class="text-center mb-4">Configure verification and approval deadlines for production records</h6>

                <form id="verificationPeriodForm">
                    <input type="hidden" id="verificationBatchId" name="batchId" value="" />
                    <input type="hidden" id="approvalDaysConfig" value="@Model.DefaultApprovalDays" />

                    <!-- Period Type Selection -->
                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 600; color: #374151;">
                            <i class="bi bi-clock-history me-1"></i>Deadline Configuration Method
                        </label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="periodType" id="periodTypeDays" value="days" checked />
                            <label class="btn btn-outline-primary" for="periodTypeDays">
                                <i class="bi bi-calendar3 me-1"></i>Days from Now
                            </label>
                            <input type="radio" class="btn-check" name="periodType" id="periodTypeDate" value="date" />
                            <label class="btn btn-outline-primary" for="periodTypeDate">
                                <i class="bi bi-calendar-event me-1"></i>Specific Date
                            </label>
                        </div>
                    </div>

                    <!-- Days Input -->
                    <div class="mb-3" id="daysInputGroup">
                        <label for="verificationDays" class="form-label" style="font-weight: 600; color: #374151;">
                            <i class="bi bi-hourglass-split me-1"></i>Number of Days
                        </label>
                        <div class="input-group">
                            <input type="number" class="form-control" id="verificationDays" name="verificationDays"
                                   min="1" max="365" value="30"
                                   style="border: 2px solid #e5e7eb; border-radius: 8px;">
                            <span class="input-group-text bg-light" style="border: 2px solid #e5e7eb; border-left: none; border-radius: 0 8px 8px 0;">
                                days
                            </span>
                        </div>
                        <small class="text-muted mt-1">Staff must verify their calls within this period</small>
                    </div>

                    <!-- Date Picker -->
                    <div class="mb-3 d-none" id="dateInputGroup">
                        <label for="verificationDate" class="form-label" style="font-weight: 600; color: #374151;">
                            <i class="bi bi-calendar-date me-1"></i>Verification Deadline
                        </label>
                        <input type="date" class="form-control" id="verificationDate" name="verificationDate"
                               style="border: 2px solid #e5e7eb; border-radius: 8px;">
                        <small class="text-muted mt-1">Select the deadline for staff verification</small>
                    </div>

                    <!-- Calculated Deadlines Display -->
                    <div class="alert alert-info d-flex align-items-start" style="background-color: #dbeafe; border: none; border-radius: 12px; margin-top: 1.5rem;">
                        <i class="bi bi-info-circle me-2 mt-1" style="font-size: 1.25rem;"></i>
                        <div class="flex-grow-1">
                            <strong style="color: #1e40af;">Calculated Deadlines:</strong>
                            <div class="mt-2">
                                <div class="d-flex justify-content-between align-items-center mb-2 p-2" style="background-color: white; border-radius: 8px;">
                                    <span><i class="bi bi-person-check text-primary me-1"></i><strong>Staff Verification:</strong></span>
                                    <span class="badge bg-primary" id="staffDeadlineDisplay" style="font-size: 0.9rem;">-</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center p-2" style="background-color: white; border-radius: 8px;">
                                    <span><i class="bi bi-shield-check text-success me-1"></i><strong>Supervisor Approval:</strong></span>
                                    <span class="badge bg-success" id="supervisorDeadlineDisplay" style="font-size: 0.9rem;">-</span>
                                </div>
                                <small class="text-muted mt-2 d-block">
                                    <i class="bi bi-gear me-1"></i>
                                    Approval deadline is automatically set to <strong id="approvalDaysDisplay">@Model.DefaultApprovalDays</strong> days after verification deadline (from system settings)
                                </small>
                            </div>
                        </div>
                    </div>

                    <!-- Verification Type Selection -->
                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 600; color: #374151;">
                            <i class="bi bi-tag me-1"></i>Call Classification
                        </label>
                        <select class="form-select" id="verificationType" name="verificationType" style="border: 2px solid #e5e7eb; border-radius: 8px;">
                            <option value="">No Classification (Staff will classify)</option>
                            <option value="Official" selected>Official</option>
                            <option value="Personal">Personal</option>
                        </select>
                        <small class="text-muted mt-1">
                            <i class="bi bi-info-circle me-1"></i>By default, all calls are marked as "Official" (business calls). Change to "Personal" or "No Classification" if needed.
                        </small>
                    </div>

                    <!-- Workflow Information -->
                    <div class="alert alert-warning d-flex align-items-start mt-3" id="pushWorkflowInfo" style="background-color: #fef3c7; border: none; border-radius: 8px;">
                        <i class="bi bi-exclamation-triangle me-2 mt-1"></i>
                        <div>
                            <strong>What happens after pushing to production:</strong>
                            <ol class="mb-0 mt-2 ps-3">
                                <li>Records are moved to production with verification status = pending</li>
                                <li>Staff must verify their calls before the verification deadline</li>
                                <li>Unverified calls after deadline are automatically recovered as <strong>PERSONAL</strong></li>
                                <li>Supervisors must approve verifications before approval deadline</li>
                                <li>Unapproved calls after deadline are recovered as <strong>CLASS OF SERVICE</strong></li>
                            </ol>
                        </div>
                    </div>

                    <!-- Progress Section (Hidden by default) -->
                    <div id="pushProgress" class="d-none mt-3">
                        <div class="card border-0" style="background: #d1fae5;">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="spinner-border spinner-border-sm text-success me-3" role="status">
                                        <span class="visually-hidden">Processing...</span>
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1 fw-bold text-success">Pushing to Production...</h6>
                                        <p class="mb-0 small text-muted" id="pushProgressMessage">Starting push to production...</p>
                                    </div>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar progress-bar-striped progress-bar-animated bg-success"
                                         role="progressbar"
                                         id="pushProgressBar"
                                         style="width: 0%"
                                         aria-valuenow="0"
                                         aria-valuemin="0"
                                         aria-valuemax="100"></div>
                                </div>
                                <div class="d-flex justify-content-between mt-2">
                                    <small class="text-muted" id="pushProgressStats">Processing records...</small>
                                    <small class="text-muted" id="pushProgressPercent">0%</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer" id="pushModalFooter" style="background-color: #f8f9fa; border: none; padding: 1.5rem;">
                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal" id="pushCancelBtn"
                        style="border-radius: 8px; font-weight: 500;">
                    Cancel
                </button>
                <button type="button" class="btn btn-success px-4" onclick="submitPushToProduction()" id="pushToProductionBtn"
                        style="background: #10b981; border: none; border-radius: 8px; font-weight: 500;">
                    <i class="bi bi-cloud-upload me-2"></i>Push to Production
                </button>
            </div>
        </div>
    </div>
</div>


