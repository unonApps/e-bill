                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Anomalies Detected
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="padding: 2rem; max-height: 600px; overflow-y: auto;">
                <div id="anomaliesContent">
                    <!-- Content will be loaded dynamically -->
                    <div class="text-center">
                        <div class="spinner-border text-warning" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="background-color: #f8f9fa; border: none; padding: 1.5rem;">
                <button type="button" class="btn btn-warning px-4" onclick="markReviewRequired()"
                        style="border-radius: 8px; font-weight: 500;">
                    <i class="bi bi-flag me-2"></i>Mark for Review
                </button>
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal"
                        style="border-radius: 8px; font-weight: 500;">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Update chevron icon when filters are shown/hidden
        const filterCollapse = document.getElementById('filterCollapse');
        if (filterCollapse) {
            const chevronIcon = document.querySelector('[data-bs-toggle="collapse"][data-bs-target="#filterCollapse"] .bi-chevron-down');

            filterCollapse.addEventListener('show.bs.collapse', function () {
                if (chevronIcon) {
                    chevronIcon.classList.remove('bi-chevron-down');
                    chevronIcon.classList.add('bi-chevron-up');
                }
            });

            filterCollapse.addEventListener('hide.bs.collapse', function () {
                if (chevronIcon) {
                    chevronIcon.classList.remove('bi-chevron-up');
                    chevronIcon.classList.add('bi-chevron-down');
                }
            });

            // Check if any filters are active
            const hasActiveFilters = @Html.Raw((!string.IsNullOrEmpty(Model.SearchTerm) || Model.Status.HasValue ||
                                                Model.HasAnomalies.HasValue || Model.StartDate.HasValue ||
                                                Model.EndDate.HasValue).ToString().ToLower());
            if (hasActiveFilters) {
                filterCollapse.classList.add('show');
                if (chevronIcon) {
                    chevronIcon.classList.remove('bi-chevron-down');
                    chevronIcon.classList.add('bi-chevron-up');
                }
            }
        }

        // Allow Enter key to submit search
        const searchInput = document.getElementById('searchFilter');
        if (searchInput) {
            searchInput.addEventListener('keypress', function(e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    document.getElementById('filterForm').submit();
                }
            });
        }

        // Checkbox functionality
        const selectAll = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.row-checkbox');
        const selectedCount = document.getElementById('selectedCount');

        if (selectAll) {
            selectAll.addEventListener('change', function() {
                checkboxes.forEach(cb => {
                    // Only check/uncheck if not disabled
                    if (!cb.disabled) {
                        cb.checked = this.checked;
                    }
                });
                updateSelectedCount();
            });
        }

        checkboxes.forEach(cb => {
            cb.addEventListener('change', updateSelectedCount);
        });

        function updateSelectedCount() {
            const count = document.querySelectorAll('.row-checkbox:checked').length;
            if (selectedCount) {
                selectedCount.textContent = count;
            }
        }

        // Quick search
        document.getElementById('quickSearch')?.addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const rows = document.querySelectorAll('#stagingTable tbody tr');

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchTerm) ? '' : 'none';
            });
        });

        // Delete batch modal
        const deleteBatchModal = document.getElementById('deleteBatchModal');
        if (deleteBatchModal) {
            deleteBatchModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const batchId = button.getAttribute('data-batch-id');
                const batchName = button.getAttribute('data-batch-name');

                document.getElementById('deleteBatchId').value = batchId;
                document.getElementById('deleteBatchName').textContent = batchName;
            });
        }
    });

    // Action functions
    function verifyRecord(id) {
        fetch(`/Admin/CallLogStaging?handler=Verify&id=${id}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error: ' + data.error);
                }
            });
    }

    // Modal variables
    let currentRejectId = null;
    let currentRejectType = null;
    let currentAnomalyId = null;

    function rejectRecord(id) {
        currentRejectId = id;
        currentRejectType = 'single';
        document.getElementById('rejectionReason').value = '';
        const modal = new bootstrap.Modal(document.getElementById('rejectionModal'));
        modal.show();
    }

    function confirmVerifyAll() {
        const count = @Model.CurrentBatchPendingCount;
        document.getElementById('verifyAllCount').textContent = count.toLocaleString();
        const modal = new bootstrap.Modal(document.getElementById('verifyAllModal'));
        modal.show();
        return false; // Prevent form submission
    }

    function submitVerifyAll() {
        const modal = bootstrap.Modal.getInstance(document.getElementById('verifyAllModal'));
        modal.hide();
        document.getElementById('verifyAllForm').submit();
    }

    function verifySelected() {
        const selectedCheckboxes = document.querySelectorAll('.row-checkbox:checked');

        if (selectedCheckboxes.length === 0) {
            alert('Please select at least one record to verify.\n\nTip: Use the "Verify All" button to verify all records at once without selecting individual checkboxes.');
            return;
        }

        document.getElementById('verifySelectedCount').textContent = selectedCheckboxes.length;
        const modal = new bootstrap.Modal(document.getElementById('verifySelectedModal'));
        modal.show();
    }

    function submitVerifySelected() {
        const modal = bootstrap.Modal.getInstance(document.getElementById('verifySelectedModal'));
        modal.hide();
        document.getElementById('bulkActionsForm').submit();
    }

    function rejectSelected() {
        const selectedCount = document.querySelectorAll('.row-checkbox:checked').length;
        if (selectedCount === 0) {
            alert('Please select at least one record to reject.');
            return;
        }

        document.getElementById('rejectSelectedCount').textContent = selectedCount;
        document.getElementById('rejectSelectedReason').value = '';
        const modal = new bootstrap.Modal(document.getElementById('rejectSelectedModal'));
        modal.show();
    }

    function submitRejectSelected() {
        const reasonField = document.getElementById('rejectSelectedReason');
        const reason = reasonField.value.trim();
        if (!reason) {
            reasonField.classList.add('is-invalid');
            return;
        }

        const modal = bootstrap.Modal.getInstance(document.getElementById('rejectSelectedModal'));
        modal.hide();

        // Submit the form with rejection
        const selectedCheckboxes = document.querySelectorAll('.row-checkbox:checked');
        const selectedIds = Array.from(selectedCheckboxes).map(cb => cb.value);

        const form = document.getElementById('bulkActionsForm');
        form.action = '/Admin/CallLogStaging?handler=RejectSelected';

        // Add reason as form field
        let reasonInput = document.getElementById('bulkRejectReason');
        if (!reasonInput) {
            reasonInput = document.createElement('input');
            reasonInput.type = 'hidden';
            reasonInput.id = 'bulkRejectReason';
            reasonInput.name = 'reason';
            form.appendChild(reasonInput);
        }
        reasonInput.value = reason;

        form.submit();
    }

    // Clear validation errors when typing
    document.addEventListener('DOMContentLoaded', function() {
        const rejectReasonField = document.getElementById('rejectSelectedReason');
        if (rejectReasonField) {
            rejectReasonField.addEventListener('input', function() {
                this.classList.remove('is-invalid');
            });
        }
    });

    function submitRejection() {
        const reason = document.getElementById('rejectionReason').value.trim();
        if (!reason) {
            document.getElementById('rejectionReason').classList.add('is-invalid');
            return;
        }

        const modal = bootstrap.Modal.getInstance(document.getElementById('rejectionModal'));
        modal.hide();

        if (currentRejectType === 'single') {
            fetch(`/Admin/CallLogStaging?handler=Reject&id=${currentRejectId}&reason=${encodeURIComponent(reason)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        showErrorAlert('Error: ' + data.error);
                    }
                });
        } else if (currentRejectType === 'bulk') {
            const form = document.getElementById('bulkActionsForm');
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'reason';
            input.value = reason;
            form.appendChild(input);
            form.action = '?handler=RejectSelected';
            form.submit();
        }
    }

    function viewAnomalies(id) {
        currentAnomalyId = id;
        const modal = new bootstrap.Modal(document.getElementById('anomaliesModal'));
        modal.show();

        fetch(`/Admin/CallLogStaging?handler=Anomalies&id=${id}`)
            .then(response => response.json())
            .then(data => {
                const content = document.getElementById('anomaliesContent');
                if (data && data.length > 0) {
                    let html = '<div class="anomaly-list">';
                    data.forEach((anomaly, index) => {
                        const alertClass = anomaly.severity === 'High' ? 'danger' : anomaly.severity === 'Medium' ? 'warning' : 'info';
                        html += `
                            <div class="alert alert-${alertClass} d-flex align-items-start mb-3" style="border-radius: 10px;">
                                <i class="bi bi-exclamation-triangle-fill me-3 mt-1"></i>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">${anomaly.type || 'Anomaly ' + (index + 1)}</h6>
                                    <p class="mb-0">${anomaly.description || JSON.stringify(anomaly)}</p>
                                    ${anomaly.recommendation ? `<small class="d-block mt-2"><strong>Recommendation:</strong> ${anomaly.recommendation}</small>` : ''}
                                </div>
                            </div>
                        `;
                    });
                    html += '</div>';
                    content.innerHTML = html;
                } else {
                    content.innerHTML = '<div class="text-center text-muted">No anomalies data available.</div>';
                }
            })
            .catch(error => {
                document.getElementById('anomaliesContent').innerHTML =
                    '<div class="alert alert-danger">Error loading anomalies: ' + error.message + '</div>';
            });
    }

    function viewDetails(id) {
        const modal = new bootstrap.Modal(document.getElementById('detailsModal'));
        modal.show();

        // For now, show a placeholder while the API is being implemented
        const content = document.getElementById('detailsContent');
        content.innerHTML = `
            <div class="text-center">
                <i class="bi bi-info-circle text-primary" style="font-size: 3rem;"></i>
                <h5 class="mt-3">Record Details</h5>
                <p class="text-muted">Viewing details for Record ID: <strong>${id}</strong></p>
                <div class="mt-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="text-start p-3 bg-light rounded">
                                <label class="text-muted small d-block">Record ID</label>
                                <div class="fw-semibold">#${id}</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="text-start p-3 bg-light rounded">
                                <label class="text-muted small d-block">Status</label>
                                <span class="badge bg-warning">Pending Verification</span>
                            </div>
                        </div>
                    </div>
                </div>
                <small class="text-muted d-block mt-3">Full details will be available once the API endpoint is implemented.</small>
            </div>
        `;
    }

    function markReviewRequired() {
        if (currentAnomalyId) {
            console.log('Marking record ' + currentAnomalyId + ' for review');
            const modal = bootstrap.Modal.getInstance(document.getElementById('anomaliesModal'));
            modal.hide();
            // Implement the actual mark for review functionality
            showSuccessAlert('Record marked for review successfully.');
        }
    }

    function showErrorAlert(message) {
        showAlert(message, 'danger', 'exclamation-triangle-fill');
    }

    function showSuccessAlert(message) {
        showAlert(message, 'success', 'check-circle-fill');
    }

    function showAlert(message, type, icon) {
        const alertDiv = document.createElement('div');
        alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
        alertDiv.style.zIndex = '9999';
        alertDiv.style.minWidth = '300px';
        alertDiv.innerHTML = `
            <i class="bi bi-${icon} me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.body.appendChild(alertDiv);

        setTimeout(() => {
            alertDiv.remove();
        }, 5000);
    }

    // Clear rejection modal on hide
    document.getElementById('rejectionModal').addEventListener('hidden.bs.modal', function () {
        document.getElementById('rejectionReason').value = '';
        document.getElementById('rejectionReason').classList.remove('is-invalid');
        currentRejectId = null;
        currentRejectType = null;
    });

    // Consolidation Modal Enhancement
    const billingMonthInput = document.getElementById('billingMonth');
    const consolidationModal = document.getElementById('consolidateModal');
    let consolidationInfoLoaded = false;

    // Event listener for billing month change
    if (billingMonthInput) {
        billingMonthInput.addEventListener('change', function() {
            if (this.value) {
                loadConsolidationInfo(this.value);
            } else {
                hideConsolidationInfo();
            }
        });
    }

    // Event listener for modal show
    if (consolidationModal) {
        consolidationModal.addEventListener('show.bs.modal', function() {
            // Reset the form when modal opens
            document.getElementById('consolidationForm').reset();
            hideConsolidationInfo();
            hideConsolidationProgress();
            consolidationInfoLoaded = false;

            // Load pending verification summary immediately
            loadPendingVerificationSummary();

            // Reset to monthly consolidation
            document.getElementById('monthlyConsolidation').checked = true;
            showMonthlySection();
        });

        // Clean up when modal is hidden
        consolidationModal.addEventListener('hidden.bs.modal', function() {
            // Clear progress interval if running
            if (window.consolidationProgressInterval) {
                clearInterval(window.consolidationProgressInterval);
                window.consolidationProgressInterval = null;
            }

            // Reset progress UI
            hideConsolidationProgress();

            // Reset modal backdrop behavior
            const modal = bootstrap.Modal.getInstance(consolidationModal);
            if (modal) {
                modal._config.backdrop = true;
                modal._config.keyboard = true;
            }
        });
    }

    // Push to Production Modal Event Listeners
    const pushModal = document.getElementById('verificationPeriodModal');
    if (pushModal) {
        pushModal.addEventListener('show.bs.modal', function() {
            // Reset progress when modal opens
            hidePushProgress();
        });

        // Clean up when modal is hidden
        pushModal.addEventListener('hidden.bs.modal', function() {
            // Clear progress interval if running
            if (window.pushProgressInterval) {
                clearInterval(window.pushProgressInterval);
                window.pushProgressInterval = null;
            }

            // Reset progress UI
            hidePushProgress();

            // Reset modal backdrop behavior
            const modal = bootstrap.Modal.getInstance(pushModal);
            if (modal) {
                modal._config.backdrop = true;
                modal._config.keyboard = true;
            }
        });
    }

    // Handle consolidation type toggle
    document.getElementById('monthlyConsolidation')?.addEventListener('change', function() {
        if (this.checked) {
            showMonthlySection();
        }
    });

    document.getElementById('interimConsolidation')?.addEventListener('change', function() {
        if (this.checked) {
            showInterimSection();
        }
    });

    // Staff index number validation
    document.getElementById('staffIndexNumber')?.addEventListener('blur', function() {
        if (this.value) {
            validateStaffMember(this.value);
        }
    });

    function showMonthlySection() {
        document.getElementById('monthlySection').classList.remove('d-none');
        document.getElementById('staffSeparationSection').classList.add('d-none');

        // Update required attributes
        document.getElementById('billingMonth').setAttribute('required', 'required');
        document.getElementById('staffIndexNumber').removeAttribute('required');
        document.getElementById('staffName').removeAttribute('required');
        document.getElementById('separationDate').removeAttribute('required');
        document.getElementById('separationReason').removeAttribute('required');
        document.getElementById('interimBillingMonth').removeAttribute('required');
        document.getElementById('interimBillingYear').removeAttribute('required');
    }

    function showInterimSection() {
        document.getElementById('monthlySection').classList.add('d-none');
        document.getElementById('staffSeparationSection').classList.remove('d-none');

        // Update required attributes
        document.getElementById('billingMonth').removeAttribute('required');
        document.getElementById('staffIndexNumber').setAttribute('required', 'required');
        document.getElementById('staffName').setAttribute('required', 'required');
        document.getElementById('separationDate').setAttribute('required', 'required');
        document.getElementById('separationReason').setAttribute('required', 'required');
        document.getElementById('interimBillingMonth').setAttribute('required', 'required');
        document.getElementById('interimBillingYear').setAttribute('required', 'required');
    }

    function validateStaffMember(indexNumber) {
        const verificationDiv = document.getElementById('staffVerification');
        const messageSpan = document.getElementById('staffVerificationMessage');

        if (!verificationDiv || !messageSpan) {
            console.error('Verification elements not found');
            return;
        }

        // Show loading
        verificationDiv.classList.remove('d-none');
        verificationDiv.className = 'alert alert-info mt-3';
        verificationDiv.innerHTML = '<i class="bi bi-hourglass-split me-2"></i><strong>Staff Verification:</strong> <span id="staffVerificationMessage">Verifying staff member...</span>';

        // Fetch staff details
        fetch(`/Admin/CallLogStaging?handler=ValidateStaff&indexNumber=${indexNumber}`)
            .then(response => response.json())
            .then(data => {
                if (data.found) {
                    verificationDiv.className = 'alert alert-success mt-3';
                    verificationDiv.innerHTML = `<i class="bi bi-check-circle me-2"></i><strong>Staff Verification:</strong> <span id="staffVerificationMessage">Staff member found: ${data.name} (${data.organization})</span>`;

                    // Auto-fill name if empty
                    const staffNameInput = document.getElementById('staffName');
                    if (staffNameInput && !staffNameInput.value) {
                        staffNameInput.value = data.name;
                    }
                } else {
                    verificationDiv.className = 'alert alert-danger mt-3';
                    verificationDiv.innerHTML = '<i class="bi bi-x-circle me-2"></i><strong>Staff Verification:</strong> <span id="staffVerificationMessage">Staff member not found in the system. Please verify the index number.</span>';
                }
            })
            .catch(error => {
                console.error('Error validating staff:', error);
                verificationDiv.className = 'alert alert-danger mt-3';
                verificationDiv.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i><strong>Staff Verification:</strong> <span id="staffVerificationMessage">Error verifying staff member. Please try again.</span>';
            });
    }

    // Override form submission for interim consolidation
    document.getElementById('consolidationForm')?.addEventListener('submit', function(e) {
        if (document.getElementById('interimConsolidation').checked) {
            e.preventDefault();
            submitInterimConsolidation();
        } else {
            // For monthly consolidation, show progress and prevent modal close
            showConsolidationProgress('Consolidating monthly call logs...');
        }
    });

    // Progress functions
    function showConsolidationProgress(message) {
        const progressDiv = document.getElementById('consolidationProgress');
        const buttonsDiv = document.getElementById('consolidationButtons');
        const infoAlert = document.getElementById('consolidationInfoAlert');
        const cancelBtn = document.getElementById('cancelBtn');

        // Hide info alert and buttons, show progress
        infoAlert.classList.add('d-none');
        buttonsDiv.classList.add('d-none');
        progressDiv.classList.remove('d-none');

        // Update message
        document.getElementById('progressMessage').textContent = message;

        // Disable cancel button and prevent modal close
        cancelBtn.disabled = true;

        // Prevent modal from closing
        const modal = bootstrap.Modal.getInstance(document.getElementById('consolidateModal'));
        if (modal) {
            modal._config.backdrop = 'static';
            modal._config.keyboard = false;
        }

        // Simulate progress (since we don't have real-time progress from backend)
        simulateProgress();
    }

    function hideConsolidationProgress() {
        const progressDiv = document.getElementById('consolidationProgress');
        const buttonsDiv = document.getElementById('consolidationButtons');
        const infoAlert = document.getElementById('consolidationInfoAlert');
        const cancelBtn = document.getElementById('cancelBtn');

        // Show info alert and buttons, hide progress
        infoAlert.classList.remove('d-none');
        buttonsDiv.classList.remove('d-none');
        progressDiv.classList.add('d-none');

        // Reset progress
        document.getElementById('progressBar').style.width = '0%';
        document.getElementById('progressPercent').textContent = '0%';

        // Re-enable cancel button
        cancelBtn.disabled = false;
    }

    function updateProgress(percent, message, stats) {
        const progressBar = document.getElementById('progressBar');
        const progressMessage = document.getElementById('progressMessage');
        const progressPercent = document.getElementById('progressPercent');
        const progressStats = document.getElementById('progressStats');

        progressBar.style.width = percent + '%';
        progressBar.setAttribute('aria-valuenow', percent);
        progressPercent.textContent = percent + '%';

        if (message) progressMessage.textContent = message;
        if (stats) progressStats.textContent = stats;
    }

    function simulateProgress() {
        let progress = 0;
        const messages = [
            { percent: 10, message: 'Fetching call logs from Safaricom...', stats: 'Connecting to data source...' },
            { percent: 25, message: 'Processing Safaricom records...', stats: 'Importing records...' },
            { percent: 40, message: 'Fetching call logs from Airtel...', stats: 'Connecting to data source...' },
            { percent: 55, message: 'Processing Airtel records...', stats: 'Importing records...' },
            { percent: 70, message: 'Fetching PSTN records...', stats: 'Connecting to data source...' },
            { percent: 85, message: 'Consolidating all records...', stats: 'Merging data sources...' },
            { percent: 95, message: 'Finalizing consolidation...', stats: 'Almost done...' }
        ];

        let currentStep = 0;
        const interval = setInterval(() => {
            if (currentStep < messages.length) {
                const step = messages[currentStep];
                updateProgress(step.percent, step.message, step.stats);
                currentStep++;
            } else {
                clearInterval(interval);
            }
        }, 1000); // Update every second

        // Store interval ID so we can clear it if needed
        window.consolidationProgressInterval = interval;
    }

    function submitInterimConsolidation() {
        const formData = {
            ConsolidationType: 'INTERIM',
            StaffIndexNumber: document.getElementById('staffIndexNumber').value,
            StaffName: document.getElementById('staffName').value,
            SeparationDate: document.getElementById('separationDate').value,
            SeparationReason: document.getElementById('separationReason').value,
            InterimBillingMonth: parseInt(document.getElementById('interimBillingMonth').value),
            InterimBillingYear: parseInt(document.getElementById('interimBillingYear').value)
        };

        // Show progress
        showConsolidationProgress('Creating interim consolidation batch...');

        fetch('/Admin/CallLogStaging?handler=ConsolidateInterim', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
            // Clear progress interval
            if (window.consolidationProgressInterval) {
                clearInterval(window.consolidationProgressInterval);
            }

            if (data.success) {
                // Show completion message
                updateProgress(100, 'Consolidation complete! Redirecting...', 'Success');

                // Redirect after brief delay to show completion
                setTimeout(() => {
                    window.location.href = `/Admin/CallLogStaging?BatchId=${data.batchId}`;
                }, 1000);
            } else {
                // Hide progress and show error
                hideConsolidationProgress();
                showErrorAlert(data.error || 'Error creating interim batch');
            }
        })
        .catch(error => {
            // Clear progress interval
            if (window.consolidationProgressInterval) {
                clearInterval(window.consolidationProgressInterval);
            }

            // Hide progress and show error
            hideConsolidationProgress();
            showErrorAlert('Failed to create interim batch');
        });
    }

    function loadPendingVerificationSummary() {
        const loadingDiv = document.getElementById('pendingVerificationLoading');
        const contentDiv = document.getElementById('pendingVerificationContent');

        // Show loading
        loadingDiv.classList.remove('d-none');
        contentDiv.classList.add('d-none');

        // Fetch pending verification summary
        fetch('/Admin/CallLogStaging?handler=PendingVerificationSummary')
            .then(response => response.json())
            .then(data => {
                loadingDiv.classList.add('d-none');
                contentDiv.classList.remove('d-none');

                if (data.error) {
                    showErrorAlert('Error loading verification summary: ' + data.error);
                    return;
                }

                if (data.summary) {
                    const summary = data.summary;

                    if (summary.totalUnverified > 0) {
                        // Show unverified alert
                        document.getElementById('unverifiedAlert').classList.remove('d-none');
                        document.getElementById('noUnverifiedMessage').classList.add('d-none');

                        // Update counts
                        document.getElementById('totalUnverifiedCount').textContent = summary.totalUnverified.toLocaleString();
                        document.getElementById('totalPendingCount').textContent = summary.totalPending.toLocaleString();
                        document.getElementById('totalReviewCount').textContent = summary.totalRequiresReview.toLocaleString();
                        document.getElementById('totalUnverifiedAmount').textContent = summary.totalUnverifiedAmount.toFixed(2).toLocaleString();
                        document.getElementById('agingRecordsCount').textContent = summary.agingRecords.toLocaleString();

                        // Show batch breakdown if there are batches
                        if (data.batches && data.batches.length > 0) {
                            document.getElementById('batchBreakdown').classList.remove('d-none');
                            const batchList = document.getElementById('batchList');
                            batchList.innerHTML = '';

                            data.batches.forEach(batch => {
                                const batchCard = document.createElement('div');
                                batchCard.className = 'card mb-2 border-warning';
                                batchCard.innerHTML = `
                                    <div class="card-body p-3">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div>
                                                <h6 class="card-title mb-1">${batch.BatchName}</h6>
                                                <small class="text-muted">Created: ${new Date(batch.BatchCreatedDate).toLocaleDateString()}</small>
                                            </div>
                                            <span class="badge bg-${batch.BatchStatus === 'Processing' ? 'warning' : 'info'}">${batch.BatchStatus}</span>
                                        </div>
                                        <div class="row g-2 small">
                                            <div class="col-6">
                                                <span class="text-muted">Unverified:</span>
                                                <strong class="text-danger ms-1">${batch.TotalUnverified} / ${batch.TotalBatchRecords}</strong>
                                                <span class="text-muted ms-1">(${batch.PercentageUnverified.toFixed(1)}%)</span>
                                            </div>
                                            <div class="col-6">
                                                <span class="text-muted">Amount:</span>
                                                <strong class="ms-1">$${batch.TotalUnverifiedAmount.toFixed(2)}</strong>
                                            </div>
                                            <div class="col-6">
                                                <span class="text-muted">Pending:</span>
                                                <span class="badge bg-warning text-dark ms-1">${batch.PendingCount}</span>
                                            </div>
                                            <div class="col-6">
                                                <span class="text-muted">Review:</span>
                                                <span class="badge bg-info ms-1">${batch.RequiresReviewCount}</span>
                                            </div>
                                        </div>
                                        <div class="mt-2">
                                            <a href="/Admin/CallLogStaging?BatchId=${batch.BatchId}" class="btn btn-sm btn-outline-warning">
                                                <i class="bi bi-arrow-right-circle me-1"></i>Go to Batch
                                            </a>
                                        </div>
                                    </div>
                                `;
                                batchList.appendChild(batchCard);
                            });
                        }
                    } else {
                        // Hide unverified alert when there are no unverified records
                        document.getElementById('unverifiedAlert').classList.add('d-none');
                        document.getElementById('batchBreakdown').classList.add('d-none');
                    }
                }
            })
            .catch(error => {
                console.error('Error fetching verification summary:', error);
                loadingDiv.classList.add('d-none');
                contentDiv.classList.remove('d-none');
                showErrorAlert('Failed to load verification summary');
            });
    }

    function loadConsolidationInfo(billingMonth) {
        // Show the consolidation info section
        const infoSection = document.getElementById('consolidationInfo');
        const loadingDiv = document.getElementById('consolidationLoading');
        const statsDiv = document.getElementById('consolidationStats');

        if (!infoSection) return;

        infoSection.classList.remove('d-none');
        loadingDiv.classList.remove('d-none');
        statsDiv.classList.add('d-none');

        // Fetch consolidation information
        fetch(`/Admin/CallLogStaging?handler=ConsolidationInfo&billingMonth=${billingMonth}`)
            .then(response => response.json())
            .then(data => {
                loadingDiv.classList.add('d-none');

                if (data.error) {
                    showErrorAlert('Error loading consolidation info: ' + data.error);
                    hideConsolidationInfo();
                    return;
                }

                // Display the statistics
                statsDiv.classList.remove('d-none');

                // Update statistics
                if (data.statistics) {
                    document.getElementById('safaricomCount').textContent = data.statistics.safaricomCount.toLocaleString();
                    document.getElementById('airtelCount').textContent = data.statistics.airtelCount.toLocaleString();
                    document.getElementById('pstnCount').textContent = data.statistics.pstnCount.toLocaleString();
                    document.getElementById('privateWireCount').textContent = data.statistics.privateWireCount.toLocaleString();
                    document.getElementById('totalSourceRecords').textContent = data.statistics.totalSourceRecords.toLocaleString();

                    // Show already processed warning if any
                    if (data.statistics.alreadyProcessedCount > 0) {
                        const warningDiv = document.getElementById('alreadyProcessedWarning');
                        const warningMessage = document.getElementById('alreadyProcessedMessage');
                        warningDiv.classList.remove('d-none');
                        warningMessage.textContent = `${data.statistics.alreadyProcessedCount.toLocaleString()} records have already been processed in production for ${data.statistics.billingMonth}.`;
                    }
                }

                // Handle existing batch warning
                if (data.existingBatch) {
                    const warningDiv = document.getElementById('existingBatchWarning');
                    const warningMessage = document.getElementById('existingBatchMessage');
                    const consolidateBtn = document.getElementById('consolidateBtn');

                    warningDiv.classList.remove('d-none');
                    warningMessage.textContent = `A batch "${data.existingBatch.BatchName}" already exists for this period with status "${data.existingBatch.BatchStatus}". You must complete or delete the existing batch before creating a new one.`;

                    // Disable consolidate button if batch exists
                    consolidateBtn.disabled = true;
                    consolidateBtn.innerHTML = '<i class="bi bi-x-circle me-2"></i>Cannot Consolidate';
                    consolidateBtn.classList.remove('btn-primary');
                    consolidateBtn.classList.add('btn-secondary');
                } else {
                    // Enable consolidate button
                    const consolidateBtn = document.getElementById('consolidateBtn');
                    consolidateBtn.disabled = false;
                    consolidateBtn.innerHTML = '<i class="bi bi-arrow-repeat me-2"></i>Consolidate';
                    consolidateBtn.classList.remove('btn-secondary');
                    consolidateBtn.classList.add('btn-primary');
                }

                // Show no records warning if total is 0
                if (data.statistics && data.statistics.totalSourceRecords === 0) {
                    const totalBadge = document.getElementById('totalSourceRecords');
                    totalBadge.classList.remove('bg-success');
                    totalBadge.classList.add('bg-secondary');

                    // Add a warning message
                    const existingWarning = document.querySelector('#consolidationStats .alert-warning:not(#existingBatchWarning)');
                    if (!existingWarning) {
                        const noRecordsWarning = document.createElement('div');
                        noRecordsWarning.className = 'alert alert-warning mb-3';
                        noRecordsWarning.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i>No records found for the selected billing month. Please check if data has been imported into the source tables.';
                        document.getElementById('consolidationStats').insertBefore(noRecordsWarning, document.getElementById('consolidationStats').firstChild);
                    }
                }

                consolidationInfoLoaded = true;
            })
            .catch(error => {
                console.error('Error fetching consolidation info:', error);
                loadingDiv.classList.add('d-none');
                showErrorAlert('Failed to load consolidation information');
                hideConsolidationInfo();
            });
    }

    function hideConsolidationInfo() {
        const infoSection = document.getElementById('consolidationInfo');
        if (infoSection) {
            infoSection.classList.add('d-none');
        }

        // Reset any warnings
        document.getElementById('existingBatchWarning').classList.add('d-none');
        document.getElementById('alreadyProcessedWarning').classList.add('d-none');

        // Reset button state
        const consolidateBtn = document.getElementById('consolidateBtn');
        consolidateBtn.disabled = false;
        consolidateBtn.innerHTML = '<i class="bi bi-arrow-repeat me-2"></i>Consolidate';
        consolidateBtn.classList.remove('btn-secondary');
        consolidateBtn.classList.add('btn-primary');
    }

    // Verification Period Modal Functions
    function openVerificationPeriodModal(batchId) {
        document.getElementById('verificationBatchId').value = batchId;

        // Set default date to 30 days from now
        const defaultDate = new Date();
        defaultDate.setDate(defaultDate.getDate() + 30);
        document.getElementById('verificationDate').value = defaultDate.toISOString().split('T')[0];

        // Approval days config is already set from server-side value (@Model.DefaultApprovalDays)
        // No need to override it here

        // Update deadline display with initial values
        updateDeadlineDisplay();

        const modal = new bootstrap.Modal(document.getElementById('verificationPeriodModal'));
        modal.show();
    }

    // Toggle between days, date, and batch defaults
    document.querySelectorAll('input[name="periodType"]').forEach(radio => {
        radio.addEventListener('change', function() {
            const daysGroup = document.getElementById('daysInputGroup');
            const dateGroup = document.getElementById('dateInputGroup');

            if (this.value === 'days') {
                daysGroup.classList.remove('d-none');
                dateGroup.classList.add('d-none');
                updateDeadlineDisplay();  // Update when switching to days
            } else if (this.value === 'date') {
                daysGroup.classList.add('d-none');
                dateGroup.classList.remove('d-none');
                updateDeadlineDisplay();  // Update when switching to date
            }
        });
    });

    // Function to update deadline displays
    function updateDeadlineDisplay() {
        const periodType = document.querySelector('input[name="periodType"]:checked')?.value;
        const approvalDays = parseInt(document.getElementById('approvalDaysConfig').value) || @Model.DefaultApprovalDays;

        let verificationDate = null;

        if (periodType === 'days') {
            const days = parseInt(document.getElementById('verificationDays').value) || 30;
            verificationDate = new Date();
            verificationDate.setDate(verificationDate.getDate() + days);
        } else if (periodType === 'date') {
            const dateValue = document.getElementById('verificationDate').value;
            if (dateValue) {
                verificationDate = new Date(dateValue);
            }
        }

        if (verificationDate) {
            // Calculate approval date
            const approvalDate = new Date(verificationDate);
            approvalDate.setDate(approvalDate.getDate() + approvalDays);

            // Format dates
            const options = { year: 'numeric', month: 'short', day: 'numeric' };
            const staffDeadline = verificationDate.toLocaleDateString('en-US', options);
            const supervisorDeadline = approvalDate.toLocaleDateString('en-US', options);

            // Update display
            document.getElementById('staffDeadlineDisplay').textContent = staffDeadline;
            document.getElementById('supervisorDeadlineDisplay').textContent = supervisorDeadline;
            document.getElementById('approvalDaysDisplay').textContent = approvalDays;
        } else {
            document.getElementById('staffDeadlineDisplay').textContent = '-';
            document.getElementById('supervisorDeadlineDisplay').textContent = '-';
        }
    }

    // Update deadlines when days input changes
    document.getElementById('verificationDays')?.addEventListener('input', updateDeadlineDisplay);

    // Update deadlines when date input changes
    document.getElementById('verificationDate')?.addEventListener('change', updateDeadlineDisplay);

    // Push to Production Progress Functions
    function showPushProgress(message) {
        const progressDiv = document.getElementById('pushProgress');
        const footerDiv = document.getElementById('pushModalFooter');
        const workflowInfo = document.getElementById('pushWorkflowInfo');
        const cancelBtn = document.getElementById('pushCancelBtn');

        // Hide workflow info and footer, show progress
        workflowInfo.classList.add('d-none');
        footerDiv.classList.add('d-none');
        progressDiv.classList.remove('d-none');

        // Update message
        document.getElementById('pushProgressMessage').textContent = message;

        // Disable cancel button
        cancelBtn.disabled = true;

        // Prevent modal from closing
        const modal = bootstrap.Modal.getInstance(document.getElementById('verificationPeriodModal'));
        if (modal) {
            modal._config.backdrop = 'static';
            modal._config.keyboard = false;
        }

        // Simulate progress
        simulatePushProgress();
    }

    function hidePushProgress() {
        const progressDiv = document.getElementById('pushProgress');
        const footerDiv = document.getElementById('pushModalFooter');
        const workflowInfo = document.getElementById('pushWorkflowInfo');
        const cancelBtn = document.getElementById('pushCancelBtn');

        // Show workflow info and footer, hide progress
        workflowInfo.classList.remove('d-none');
        footerDiv.classList.remove('d-none');
        progressDiv.classList.add('d-none');

        // Reset progress
        document.getElementById('pushProgressBar').style.width = '0%';
        document.getElementById('pushProgressPercent').textContent = '0%';

        // Re-enable cancel button
        cancelBtn.disabled = false;
    }

    function updatePushProgress(percent, message, stats) {
        const progressBar = document.getElementById('pushProgressBar');
        const progressMessage = document.getElementById('pushProgressMessage');
        const progressPercent = document.getElementById('pushProgressPercent');
        const progressStats = document.getElementById('pushProgressStats');

        progressBar.style.width = percent + '%';
        progressBar.setAttribute('aria-valuenow', percent);
        progressPercent.textContent = percent + '%';

        if (message) progressMessage.textContent = message;
        if (stats) progressStats.textContent = stats;
    }

    function simulatePushProgress() {
        const messages = [
            { percent: 15, message: 'Validating records...', stats: 'Checking data integrity...' },
            { percent: 30, message: 'Setting up verification periods...', stats: 'Configuring deadlines...' },
            { percent: 50, message: 'Transferring records to production...', stats: 'Moving data...' },
            { percent: 70, message: 'Creating verification assignments...', stats: 'Assigning to staff...' },
            { percent: 85, message: 'Setting up recovery rules...', stats: 'Configuring automation...' },
            { percent: 95, message: 'Finalizing push to production...', stats: 'Almost done...' }
        ];

        let currentStep = 0;
        const interval = setInterval(() => {
            if (currentStep < messages.length) {
                const step = messages[currentStep];
                updatePushProgress(step.percent, step.message, step.stats);
                currentStep++;
            } else {
                clearInterval(interval);
            }
        }, 800);

        // Store interval ID
        window.pushProgressInterval = interval;
    }

    function submitPushToProduction() {
        const batchId = document.getElementById('verificationBatchId').value;
        const periodType = document.querySelector('input[name="periodType"]:checked').value;

        let verificationPeriod = null;

        if (periodType === 'days') {
            const days = parseInt(document.getElementById('verificationDays').value);
            if (!days || days < 1) {
                showErrorAlert('Please enter a valid number of days (minimum 1)');
                return;
            }
            // Calculate date from days
            const date = new Date();
            date.setDate(date.getDate() + days);
            verificationPeriod = date.toISOString().split('T')[0];
        } else if (periodType === 'date') {
            verificationPeriod = document.getElementById('verificationDate').value;
            if (!verificationPeriod) {
                showErrorAlert('Please select a verification deadline date');
                return;
            }

            // Validate that date is in the future
            const selectedDate = new Date(verificationPeriod);
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            if (selectedDate < today) {
                showErrorAlert('Verification deadline must be in the future');
                return;
            }
        }

        // Show progress
        showPushProgress('Preparing to push records to production...');

        // Create form and submit
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '?handler=PushToProduction';

        const batchIdInput = document.createElement('input');
        batchIdInput.type = 'hidden';
        batchIdInput.name = 'batchId';
        batchIdInput.value = batchId;
        form.appendChild(batchIdInput);

        const periodInput = document.createElement('input');
        periodInput.type = 'hidden';
        periodInput.name = 'verificationPeriod';
        periodInput.value = verificationPeriod;
        form.appendChild(periodInput);

        // Add verification type
        const verificationTypeSelect = document.getElementById('verificationType');
        if (verificationTypeSelect && verificationTypeSelect.value) {
            const verificationTypeInput = document.createElement('input');
            verificationTypeInput.type = 'hidden';
            verificationTypeInput.name = 'verificationType';
            verificationTypeInput.value = verificationTypeSelect.value;
            form.appendChild(verificationTypeInput);
        }

        // Add anti-forgery token
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        if (tokenInput) {
            const token = tokenInput.cloneNode();
            form.appendChild(token);
        }

        document.body.appendChild(form);
        form.submit();
    }

    // Handle batch selection from dropdown
    function selectBatch(batchId) {
        if (batchId) {
            window.location.href = '?BatchId=' + batchId;
        } else {
            // Clear batch selection
            window.location.href = '/Admin/CallLogStaging';
        }
    }

    // Send notifications for a published batch
    function sendNotifications(batchId, batchName, button) {
        if (!confirm(`Are you sure you want to send notifications for "${batchName}"?\n\nThis will send email notifications to all staff members with call logs in this batch.`)) {
            return;
        }

        // Disable button and show loading
        const originalHtml = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Sending...';

        const formData = new FormData();
        formData.append('batchId', batchId);

        fetch('?handler=SendNotifications', {
            method: 'POST',
            body: formData,
            headers: {
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Show success - change to check icon temporarily
                button.innerHTML = '<i class="bi bi-check-lg me-1"></i>Queued';
                button.classList.remove('btn-primary');
                button.classList.add('btn-success');

                // Show alert
                alert('Notifications queued successfully!\n\nEmails will be sent in the background. You can monitor progress in Hangfire dashboard.');

                // Reset button after 3 seconds
                setTimeout(() => {
                    button.innerHTML = originalHtml;
                    button.classList.remove('btn-success');
                    button.classList.add('btn-primary');
                    button.disabled = false;
                }, 3000);
            } else {
                alert('Error: ' + data.message);
                button.innerHTML = originalHtml;
                button.disabled = false;
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Error sending notifications. Please try again.');
            button.innerHTML = originalHtml;
            button.disabled = false;
        });
    }

    // =============================================
    // Auto-refresh DISABLED on CallLogStaging page
    // Auto-refresh is only enabled on ImportJobs page for monitoring
    // Users can manually refresh this page using browser refresh (F5)
    // =============================================
    @{
        var shouldAutoRefresh = false; // Always false - auto-refresh disabled
    }

    @if (shouldAutoRefresh)
    {
        @:// Auto-refresh disabled - this code won't run
        @:let refreshInterval;
        @:let refreshCountdown = 15;
        @:
        @:function updateRefreshCountdown() {
        @:    const countdownEl = document.getElementById('refreshCountdown');
        @:    if (countdownEl) {
        @:        countdownEl.textContent = refreshCountdown;
        @:        refreshCountdown--;
        @:
        @:        if (refreshCountdown < 0) {
        @:            window.location.reload();
        @:        }
        @:    }
        @:}
        @:
        @:// Show refresh indicator
        @:document.addEventListener('DOMContentLoaded', function() {
        @:    // Add refresh indicator to the page
        @:    const statusBar = document.createElement('div');
        @:    statusBar.className = 'alert alert-info d-flex align-items-center mb-3';
        @:    statusBar.style.borderRadius = '12px';
        @:    statusBar.innerHTML = `
        @:        <i class="bi bi-arrow-clockwise me-2"></i>
        @:        <strong>Background consolidation in progress...</strong>
        @:        <span class="ms-auto">Page will auto-refresh in <span id="refreshCountdown">${refreshCountdown}</span> seconds</span>
        @:    `;
        @:
        @:    // Insert at the top of the main content
        @:    const mainContent = document.querySelector('.container-fluid');
        @:    if (mainContent && mainContent.firstChild) {
        @:        mainContent.insertBefore(statusBar, mainContent.firstChild);
        @:    }
        @:
        @:    // Start countdown
        @:    refreshInterval = setInterval(updateRefreshCountdown, 1000);
        @:});
    }

</script>
}

@functions {
    private string GetBatchStatusBadgeClass(BatchStatus status)
    {
        return status switch
        {
            BatchStatus.Created => "bg-info",
            BatchStatus.Processing => "bg-warning",
            BatchStatus.PartiallyVerified => "bg-info",
            BatchStatus.Verified => "bg-success",
            BatchStatus.Published => "bg-primary",
            BatchStatus.Failed => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetStatusBadgeClass(VerificationStatus status)
    {
        return status switch
        {
            VerificationStatus.Pending => "bg-warning",
            VerificationStatus.Verified => "bg-success",
            VerificationStatus.Rejected => "bg-danger",
            VerificationStatus.RequiresReview => "bg-info",
            _ => "bg-secondary"
        };
    }

    private string GetStatColorClass(string statKey)
    {
        return statKey.ToLower() switch
        {
            "total" => "text-primary",
            "pending" => "text-warning",
            "verified" => "text-success",
            "rejected" => "text-danger",
            "requiresreview" => "text-info",
            "withanomalies" => "text-danger",
            "processed" => "text-success",
            _ => "text-dark"
        };
    }
}