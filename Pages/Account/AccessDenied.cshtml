@page
@model TAB.Web.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Access Denied";
    Layout = "_Layout";
}

<div class="text-center">
    <div class="mb-4">
        <i class="fas fa-lock fa-4x text-danger"></i>
    </div>
    <h1 class="text-danger mb-3">@ViewData["Title"]</h1>

    <div class="alert alert-danger d-inline-block text-start" role="alert" style="max-width: 600px;">
        <h5 class="alert-heading">
            <i class="fas fa-exclamation-triangle"></i> Access Restricted
        </h5>
        <hr />
        <p class="mb-0">@Model.Message</p>
    </div>

    @if (Model.Reason == "notProvisioned")
    {
        <div class="alert alert-info mt-3 d-inline-block text-start" style="max-width: 600px;">
            <h5 class="alert-heading">
                <i class="fas fa-info-circle"></i> What's Next?
            </h5>
            <p>Your Azure AD account was authenticated successfully, but you do not have an account provisioned in this system.</p>
            <p class="mb-0">To gain access, please contact your system administrator and request that they create an account for you.</p>
        </div>
    }

    <div class="mt-4">
        <a href="/" class="btn btn-primary">
            <i class="fas fa-home"></i> Go to Home
        </a>
        <a href="/Account/Logout" class="btn btn-secondary">
            <i class="fas fa-sign-out-alt"></i> Sign Out
        </a>
    </div>
</div> 