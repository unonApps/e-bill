@model string

@* Detail Header Row (Level 2) - Hidden by default *@
<tr class="detail-header-row" data-group="@Model" style="display: none; background-color: #e9ecef;">
    <th></th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-calendar me-1"></i>CALL DATE</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-calendar3 me-1"></i>MONTH</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-calendar-event me-1"></i>YEAR</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-telephone me-1"></i>NUMBER</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-geo-alt me-1"></i>DESTINATION</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-clock me-1"></i>DURATION</th>
    <th class="px-2 py-2 text-end" style="font-size: 11px;"><i class="bi bi-currency-dollar me-1"></i>COST</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-cash me-1"></i>CURRENCY</th>
    <th class="px-2 py-2 text-end" style="font-size: 11px;"><i class="bi bi-exclamation-triangle me-1"></i>RECOVERED</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-calendar-check me-1"></i>RECOVERY DATE</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-tag me-1"></i>REASON</th>
    <th class="px-2 py-2" style="font-size: 11px;"><i class="bi bi-arrow-right me-1"></i>ASSIGNMENT</th>
</tr>
