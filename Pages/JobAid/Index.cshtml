@page
@model TAB.Web.Pages.JobAid.IndexModel
@{
    ViewData["Title"] = "Job Aid & Training Materials";
    ViewData["PageIcon"] = "bi-book";
    ViewData["PageTitle"] = "Job Aid & Training Materials";
    ViewData["Breadcrumb"] = "Job Aid";
}

<!-- Hero Section -->
<div class="jobaid-hero">
    <div class="jobaid-hero-content">
        <div class="jobaid-hero-icon">
            <i class="bi bi-book"></i>
        </div>
        <div class="jobaid-hero-text">
            <h1 class="jobaid-hero-title">Job Aid & Training Materials</h1>
            <p class="jobaid-hero-subtitle">Step-by-step guides, workflows, and FAQs for each module in the UNON Services portal</p>
        </div>
    </div>
</div>

<!-- Module Cards Grid -->
<div class="jobaid-grid">
    <!-- SIM Card Management — Available -->
    <div class="jobaid-card">
        <div class="jobaid-card-inner">
            <div class="jobaid-icon-container">
                <div class="jobaid-icon jobaid-icon-blue">
                    <i class="bi bi-phone"></i>
                </div>
            </div>
            <div class="jobaid-card-content">
                <div class="jobaid-card-header">
                    <h3 class="jobaid-card-title">SIM Card Management</h3>
                    <span class="jobaid-badge jobaid-badge-available">Available</span>
                </div>
                <p class="jobaid-card-desc">Complete guide to requesting, tracking, and managing SIM cards — including workflows, roles, statuses, and troubleshooting.</p>
                <a href="/JobAid/SimManagement" class="jobaid-btn jobaid-btn-primary">
                    <i class="bi bi-arrow-right-circle"></i>
                    <span>View Guide</span>
                    <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- E-Bill Management — Coming Soon -->
    <div class="jobaid-card jobaid-card-disabled">
        <div class="jobaid-card-inner">
            <div class="jobaid-icon-container">
                <div class="jobaid-icon jobaid-icon-gray">
                    <i class="bi bi-file-text"></i>
                </div>
            </div>
            <div class="jobaid-card-content">
                <div class="jobaid-card-header">
                    <h3 class="jobaid-card-title">E-Bill Management</h3>
                    <span class="jobaid-badge jobaid-badge-soon">Coming Soon</span>
                </div>
                <p class="jobaid-card-desc">Guide to viewing, verifying, and managing electronic billing records and call logs.</p>
                <span class="jobaid-btn jobaid-btn-disabled">
                    <i class="bi bi-clock"></i>
                    <span>Coming Soon</span>
                </span>
            </div>
        </div>
    </div>

    <!-- Refund Management — Coming Soon -->
    <div class="jobaid-card jobaid-card-disabled">
        <div class="jobaid-card-inner">
            <div class="jobaid-icon-container">
                <div class="jobaid-icon jobaid-icon-gray">
                    <i class="bi bi-cash-coin"></i>
                </div>
            </div>
            <div class="jobaid-card-content">
                <div class="jobaid-card-header">
                    <h3 class="jobaid-card-title">Refund Management</h3>
                    <span class="jobaid-badge jobaid-badge-soon">Coming Soon</span>
                </div>
                <p class="jobaid-card-desc">Guide to submitting and tracking refund requests for device purchases and overpayments.</p>
                <span class="jobaid-btn jobaid-btn-disabled">
                    <i class="bi bi-clock"></i>
                    <span>Coming Soon</span>
                </span>
            </div>
        </div>
    </div>

    <!-- Supervisor Approvals — Coming Soon -->
    <div class="jobaid-card jobaid-card-disabled">
        <div class="jobaid-card-inner">
            <div class="jobaid-icon-container">
                <div class="jobaid-icon jobaid-icon-gray">
                    <i class="bi bi-person-check"></i>
                </div>
            </div>
            <div class="jobaid-card-content">
                <div class="jobaid-card-header">
                    <h3 class="jobaid-card-title">Supervisor Approvals</h3>
                    <span class="jobaid-badge jobaid-badge-soon">Coming Soon</span>
                </div>
                <p class="jobaid-card-desc">Guide to the supervisor approval workflow, including reviewing requests and setting class of service.</p>
                <span class="jobaid-btn jobaid-btn-disabled">
                    <i class="bi bi-clock"></i>
                    <span>Coming Soon</span>
                </span>
            </div>
        </div>
    </div>
</div>

<style>
/* Hero Section */
.jobaid-hero {
    background: linear-gradient(135deg, #009edb 0%, #0077b5 100%);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
    box-shadow: 0 2px 6px rgba(0, 102, 204, 0.12);
}

.jobaid-hero-content {
    display: flex;
    align-items: center;
    gap: 1.25rem;
}

.jobaid-hero-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 45px;
    height: 45px;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 10px;
    backdrop-filter: blur(10px);
    flex-shrink: 0;
}

.jobaid-hero-icon i {
    font-size: 1.25rem;
    color: white;
}

.jobaid-hero-text {
    text-align: left;
}

.jobaid-hero-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: white;
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
}

.jobaid-hero-subtitle {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
    line-height: 1.3;
}

/* Cards Grid */
.jobaid-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 3rem;
}

.jobaid-card {
    background: white;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 4px 25px rgba(0, 0, 0, 0.08);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: 1px solid rgba(0, 0, 0, 0.05);
    position: relative;
    overflow: hidden;
}

.jobaid-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: #009edb;
    transition: all 0.3s ease;
}

.jobaid-card:not(.jobaid-card-disabled):hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}

.jobaid-card:not(.jobaid-card-disabled):hover::before {
    height: 5px;
}

.jobaid-card-disabled {
    opacity: 0.7;
}

.jobaid-card-disabled::before {
    background: #AEA29A;
}

.jobaid-card-inner {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
}

.jobaid-icon-container {
    flex-shrink: 0;
}

.jobaid-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 15px;
}

.jobaid-icon i {
    font-size: 1.5rem;
    color: white;
}

.jobaid-icon-blue {
    background: #009edb;
}

.jobaid-icon-gray {
    background: #AEA29A;
}

.jobaid-card-content {
    flex: 1;
    text-align: left;
}

.jobaid-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
}

.jobaid-card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a202c;
    margin: 0;
    letter-spacing: -0.01em;
}

.jobaid-badge {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 20px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.jobaid-badge-available {
    background: #E6EFD0;
    color: #4a8c1c;
}

.jobaid-badge-soon {
    background: #EBEAE6;
    color: #6E6259;
}

.jobaid-card-desc {
    color: #718096;
    margin-bottom: 1.5rem;
    line-height: 1.5;
    font-size: 0.9rem;
}

.jobaid-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
}

.jobaid-btn-primary {
    background: #009edb;
    color: white;
    border: 1px solid #009edb;
}

.jobaid-btn-primary:hover {
    background: #0077b5;
    border-color: #0077b5;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0, 158, 219, 0.25);
    color: white;
    text-decoration: none;
}

.jobaid-btn-primary i {
    transition: transform 0.3s ease;
}

.jobaid-btn-primary:hover i {
    transform: translateX(4px);
}

.jobaid-btn-disabled {
    background: #EBEAE6;
    color: #AEA29A;
    cursor: default;
}

/* Responsive */
@@media (max-width: 768px) {
    .jobaid-grid {
        grid-template-columns: 1fr;
        gap: 1.5rem;
    }

    .jobaid-card {
        padding: 1.5rem;
    }
}

@@media (max-width: 480px) {
    .jobaid-card-inner {
        flex-direction: row;
        gap: 1rem;
    }

    .jobaid-icon {
        width: 50px;
        height: 50px;
    }

    .jobaid-icon i {
        font-size: 1.25rem;
    }
}
</style>
