                    <i class="bi bi-file-earmark-pdf me-3" style="font-size: 20px; color: #64748b;"></i>
                    <h6 class="mb-0" style="font-weight: 600; color: #475569;">Purchase Receipt</h6>
                </div>
                <div class="row g-3">
                    <div class="col-md-8">
                        <div class="mb-2">
                            <span class="detail-label">Receipt File</span>
                            @if (!string.IsNullOrEmpty(Model.CurrentRequest.PurchaseReceiptFileName))
                            {
                                <div class="detail-value d-flex align-items-center justify-content-between">
                                    <span>@Model.CurrentRequest.PurchaseReceiptFileName</span>
                                    <div>
                                        <a href="/Modules/RefundManagement/Requests/DownloadReceipt/@Model.CurrentRequest.Id" target="_blank" class="btn btn-sm btn-outline-success me-2" style="border-radius: 8px; font-size: 12px;">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                        <a href="/Modules/RefundManagement/Requests/DownloadReceipt/@Model.CurrentRequest.Id" download class="btn btn-sm btn-success" style="border-radius: 8px; font-size: 12px;">
                                            <i class="bi bi-download me-1"></i>Download
                                        </a>
                                    </div>
                                </div>
                            }
                            else if (!string.IsNullOrEmpty(Model.CurrentRequest.PurchaseReceiptPath) && !Model.CurrentRequest.PurchaseReceiptPath.StartsWith("database:"))
                            {
                                <!-- Legacy file path support -->
                                <div class="detail-value d-flex align-items-center justify-content-between">
                                    <span>@System.IO.Path.GetFileName(Model.CurrentRequest.PurchaseReceiptPath)</span>
                                    <div>
                                        <a href="@Model.CurrentRequest.PurchaseReceiptPath" target="_blank" class="btn btn-sm btn-outline-success me-2" style="border-radius: 8px; font-size: 12px;">
                                            <i class="bi bi-eye me-1"></i>View
                                        </a>
                                        <a href="@Model.CurrentRequest.PurchaseReceiptPath" download class="btn btn-sm btn-success" style="border-radius: 8px; font-size: 12px;">
                                            <i class="bi bi-download me-1"></i>Download
                                        </a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="detail-value">No receipt uploaded</div>
                            }
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Previous Reimbursement</span>
                            <div class="detail-value">@(Model.CurrentRequest.PreviousDeviceReimbursedDate?.ToString("MMM dd, yyyy") ?? "N/A")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Supervisor Approval Tab -->
        <div class="tab-pane fade" id="detail-supervisor">
            @if (Model.CurrentRequest.SupervisorApprovalDate.HasValue)
            {
                <!-- Approved Status -->
                <div class="mb-4" style="background: #f0fdf4; border-radius: 16px; padding: 24px; border: 1px solid #bbf7d0;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-check-circle me-3" style="font-size: 20px; color: #10b981;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #047857;">Approved by Supervisor</h6>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <span class="detail-label">Approved On</span>
                            <div class="detail-value">@Model.CurrentRequest.SupervisorApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">Supervisor</span>
                            <div class="detail-value">@(Model.CurrentRequest.SupervisorName ?? "N/A")</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CurrentRequest.SupervisorRemarks))
                    {
                        <div class="mt-3">
                            <span class="detail-label">Remarks</span>
                            <div class="detail-value">@Model.CurrentRequest.SupervisorRemarks</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <h5 class="text-muted mt-3 mb-2">Awaiting Supervisor Review</h5>
                    <p class="text-muted" style="font-size: 0.875rem;">This stage will be completed when the supervisor approves the request.</p>
                </div>
            }
        </div>

        <!-- Budget Officer Tab -->
        <div class="tab-pane fade show active" id="detail-budget">
            <!-- Request Summary Section -->
            <div class="mb-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-info-circle me-3" style="font-size: 20px; color: #64748b;"></i>
                    <h6 class="mb-0" style="font-weight: 600; color: #475569;">Request Summary</h6>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Class of Service</span>
                            <div class="detail-value">@(Model.CurrentRequest.ClassOfService ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Mobile Service</span>
                            <div class="detail-value">@(Model.CurrentRequest.MobileService ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Handset Allowance</span>
                            <div class="detail-value" style="color: #059669; font-weight: 600;">$@Model.CurrentRequest.DeviceAllowance.ToString("N2")</div>
                        </div>
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Device Purchase Currency</span>
                            <div class="detail-value">@(Model.CurrentRequest.DevicePurchaseCurrency ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Device Purchase Amount</span>
                            <div class="detail-value" style="color: #059669; font-weight: 600;">@Model.CurrentRequest.DevicePurchaseCurrency @Model.CurrentRequest.DevicePurchaseAmount.ToString("N2")</div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer)
            {
                <!-- Approval Form -->
                <div class="mb-4" style="background: #f0fdf4; border-radius: 16px; padding: 24px; border: 1px solid #bbf7d0;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-calculator me-3" style="font-size: 20px; color: #059669;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #047857;">Budget Officer Approval</h6>
                    </div>

                    <form method="post" asp-page-handler="BudgetApprove">
                        <input type="hidden" name="requestId" value="@Model.CurrentRequest.PublicId" />

                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                    Cost Object <span style="color: #ef4444;">*</span>
                                </label>
                                <input type="text" name="costObject" class="form-control" required placeholder="Enter cost object..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px;" value="@Model.CurrentRequest.CostObject" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                    Cost Center <span style="color: #ef4444;">*</span>
                                </label>
                                <input type="text" name="costCenter" class="form-control" required placeholder="Enter cost center..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px;" value="@Model.CurrentRequest.CostCenter" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                    Fund Commitment <span style="color: #ef4444;">*</span>
                                </label>
                                <input type="text" name="fundCommitment" class="form-control" required placeholder="Enter fund commitment..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px;" value="@Model.CurrentRequest.FundCommitment" />
                            </div>
                        </div>

                        <div class="row g-3 mt-2">
                            <div class="col-12">
                                <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                    Budget Officer Remarks <span class="text-muted">(max 200 characters)</span>
                                </label>
                                <textarea name="budgetOfficerRemarks" class="form-control" rows="4" maxlength="200" placeholder="Enter your remarks..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px; resize: none;"></textarea>
                            </div>
                        </div>

                        <div class="d-flex gap-3 justify-content-end mt-4 pt-3" style="border-top: 1px solid #e5e7eb;">
                            <a href="/Dashboard/Approver" class="btn btn-light" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                                Cancel
                            </a>
                            <button type="button" class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#detailReassignModal" onclick="setDetailRequestId('@Model.CurrentRequest.PublicId')" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                                <i class="bi bi-person-plus me-2"></i>Reassign
                            </button>
                            <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#detailRevertToRequestorModal" onclick="setDetailRequestId('@Model.CurrentRequest.PublicId')" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                                <i class="bi bi-arrow-left me-2"></i>Revert to Requestor
                            </button>
                            <button type="button" class="btn btn-info" data-bs-toggle="modal" data-bs-target="#detailRevertToSupervisorModal" onclick="setDetailRequestId('@Model.CurrentRequest.PublicId')" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                                <i class="bi bi-arrow-counterclockwise me-2"></i>Revert to Supervisor
                            </button>
                            <button type="submit" class="btn btn-success" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                                <i class="bi bi-check-circle me-2"></i>Approve Request
                            </button>
                        </div>
                    </form>
                </div>
            }
            else if (Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue)
            {
                <!-- Approved Status -->
                <div class="mb-4" style="background: #f0fdf4; border-radius: 16px; padding: 24px; border: 1px solid #bbf7d0;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-check-circle me-3" style="font-size: 20px; color: #10b981;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #047857;">Approved by Budget Officer</h6>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <span class="detail-label">Approved On</span>
                            <div class="detail-value">@Model.CurrentRequest.BudgetOfficerApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                        <div class="col-md-4">
                            <span class="detail-label">Budget Officer</span>
                            <div class="detail-value">@(Model.CurrentRequest.BudgetOfficerName ?? "N/A")</div>
                        </div>
                        <div class="col-md-4">
                            <span class="detail-label">Cost Object</span>
                            <div class="detail-value">@(Model.CurrentRequest.CostObject ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <span class="detail-label">Cost Center</span>
                            <div class="detail-value">@(Model.CurrentRequest.CostCenter ?? "N/A")</div>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">Fund Commitment</span>
                            <div class="detail-value">@(Model.CurrentRequest.FundCommitment ?? "N/A")</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CurrentRequest.BudgetOfficerRemarks))
                    {
                        <div class="mt-3">
                            <span class="detail-label">Remarks</span>
                            <div class="detail-value">@Model.CurrentRequest.BudgetOfficerRemarks</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <h5 class="text-muted mt-3 mb-2">Awaiting Budget Officer Review</h5>
                    <p class="text-muted" style="font-size: 0.875rem;">This stage will be completed when the budget officer approves the request.</p>
                </div>
            }
        </div>

        <!-- Claims Processing Tab -->
        <div class="tab-pane fade" id="detail-claims">
            @if (Model.CurrentRequest.Status >= TAB.Web.Models.RefundRequestStatus.PendingStaffClaimsUnit && Model.CurrentRequest.StaffClaimsApprovalDate.HasValue)
            {
                <!-- Claims Processed Status -->
                <div class="mb-4" style="background: #f0fdf4; border-radius: 16px; padding: 24px; border: 1px solid #bbf7d0;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-check-circle me-3" style="font-size: 20px; color: #10b981;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #047857;">Processed by Claims Unit</h6>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <span class="detail-label">Processed On</span>
                            <div class="detail-value">@Model.CurrentRequest.StaffClaimsApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">Claims Officer</span>
                            <div class="detail-value">@(Model.CurrentRequest.StaffClaimsOfficerName ?? "N/A")</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CurrentRequest.StaffClaimsRemarks))
                    {
                        <div class="mt-3">
                            <span class="detail-label">Remarks</span>
                            <div class="detail-value">@Model.CurrentRequest.StaffClaimsRemarks</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <h5 class="text-muted mt-3 mb-2">Awaiting Claims Unit Processing</h5>
                    <p class="text-muted" style="font-size: 0.875rem;">This stage will be completed when the claims unit processes the request.</p>
                </div>
            }
        </div>

        <!-- Workflow History Tab -->
        <div class="tab-pane fade" id="detail-workflow">
            <!-- Workflow History Section -->
            <div class="mb-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-diagram-3 me-3" style="font-size: 20px; color: #64748b;"></i>
                    <h6 class="mb-0" style="font-weight: 600; color: #475569;">Workflow History</h6>
                </div>

                <!-- Timeline Container -->
                <div class="workflow-timeline">
                    <!-- Request Submission -->
                    <div class="timeline-item">
                        <div class="timeline-marker timeline-submitted">
                            <i class="bi bi-file-plus"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <h6 class="timeline-title">Request Submitted</h6>
                                <span class="timeline-date">@Model.CurrentRequest.RequestDate.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <p class="timeline-description">Refund request created and submitted for approval</p>
                            <div class="timeline-details">
                                <small class="text-muted">Submitted by: <span>@Model.CurrentRequest.MobileNumberAssignedTo</span></small>
                            </div>
                        </div>
                    </div>

                    <!-- Supervisor Approval -->
                    <div class="timeline-item">
                        <div class="timeline-marker @(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? "timeline-approved" : Model.CurrentRequest.Status >= TAB.Web.Models.RefundRequestStatus.PendingSupervisor ? "timeline-current" : "timeline-pending")">
                            <i class="bi @(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? "bi-check-circle" : "bi-clock")"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <h6 class="timeline-title">Supervisor Review</h6>
                                <span class="timeline-date">@(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? Model.CurrentRequest.SupervisorApprovalDate.Value.ToString("MMM dd, yyyy HH:mm") : "Pending")</span>
                            </div>
                            <p class="timeline-description">@(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? "Approved by supervisor" : "Awaiting supervisor approval")</p>
                            <div class="timeline-details">
                                <small class="text-muted">Supervisor: <span>@(Model.CurrentRequest.SupervisorEmail ?? "N/A")</span></small>
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.SupervisorRemarks))
                                {
                                    <div class="timeline-remarks mt-1">
                                        <small class="text-muted"><strong>Remarks:</strong> <span>@Model.CurrentRequest.SupervisorRemarks</span></small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Budget Officer Approval -->
                    <div class="timeline-item">
                        <div class="timeline-marker @(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? "timeline-approved" : Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer ? "timeline-current" : "timeline-pending")">
                            <i class="bi @(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? "bi-calculator" : "bi-clock")"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <h6 class="timeline-title">Budget Officer Review</h6>
                                <span class="timeline-date">@(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? Model.CurrentRequest.BudgetOfficerApprovalDate.Value.ToString("MMM dd, yyyy HH:mm") : Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer ? "Current Stage" : "Pending")</span>
                            </div>
                            <p class="timeline-description">@(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? "Approved by budget officer" : "Pending budget officer approval")</p>
                            <div class="timeline-details">
                                <small class="text-muted">Budget Officer: <span>@(Model.CurrentRequest.BudgetOfficerEmail ?? "Not assigned")</span></small>
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.BudgetOfficerRemarks))
                                {
                                    <div class="timeline-remarks mt-1">
                                        <small class="text-muted"><strong>Remarks:</strong> <span>@Model.CurrentRequest.BudgetOfficerRemarks</span></small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Claims Processing -->
                    <div class="timeline-item">
                        <div class="timeline-marker @(Model.CurrentRequest.StaffClaimsApprovalDate.HasValue ? "timeline-approved" : Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingStaffClaimsUnit ? "timeline-current" : "timeline-pending")">
                            <i class="bi @(Model.CurrentRequest.StaffClaimsApprovalDate.HasValue ? "bi-receipt" : "bi-clock")"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <h6 class="timeline-title">Claims Unit Processing</h6>
                                <span class="timeline-date">@(Model.CurrentRequest.StaffClaimsApprovalDate.HasValue ? Model.CurrentRequest.StaffClaimsApprovalDate.Value.ToString("MMM dd, yyyy HH:mm") : Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingStaffClaimsUnit ? "Current Stage" : "Pending")</span>
                            </div>
                            <p class="timeline-description">@(Model.CurrentRequest.StaffClaimsApprovalDate.HasValue ? "Processed by claims unit" : "Pending claims unit processing")</p>
                            <div class="timeline-details">
                                <small class="text-muted">Claims Officer: <span>@(Model.CurrentRequest.StaffClaimsOfficerName ?? "Not assigned")</span></small>
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.StaffClaimsRemarks))
                                {
                                    <div class="timeline-remarks mt-1">
                                        <small class="text-muted"><strong>Remarks:</strong> <span>@Model.CurrentRequest.StaffClaimsRemarks</span></small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Completion -->
                    @if (Model.CurrentRequest.CompletionDate.HasValue)
                    {
                        <div class="timeline-item">
                            <div class="timeline-marker timeline-approved">
                                <i class="bi bi-check-circle-fill"></i>
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <h6 class="timeline-title">Request Completed</h6>
                                    <span class="timeline-date">@Model.CurrentRequest.CompletionDate.Value.ToString("MMM dd, yyyy HH:mm")</span>
                                </div>
                                <p class="timeline-description">Refund request has been fully processed and completed</p>
                            </div>
                        </div>
                    }

                    <!-- Cancellation -->
                    @if (Model.CurrentRequest.CancellationDate.HasValue)
                    {
                        <div class="timeline-item">
                            <div class="timeline-marker" style="background: #ef4444; color: white;">
                                <i class="bi bi-x-circle"></i>
                            </div>
                            <div class="timeline-content">
                                <div class="timeline-header">
                                    <h6 class="timeline-title">Request Rejected</h6>
                                    <span class="timeline-date">@Model.CurrentRequest.CancellationDate.Value.ToString("MMM dd, yyyy HH:mm")</span>
                                </div>
                                <p class="timeline-description">Request was rejected</p>
                                <div class="timeline-details">
                                    <small class="text-muted">Rejected by: <span>@(Model.CurrentRequest.CancelledBy ?? "N/A")</span></small>
                                    @if (!string.IsNullOrEmpty(Model.CurrentRequest.CancellationReason))
                                    {
                                        <div class="timeline-remarks mt-1">
                                            <small class="text-muted"><strong>Reason:</strong> <span>@Model.CurrentRequest.CancellationReason</span></small>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    }
