<script>
    let currentRequestId = null;

    function viewRequest(requestId) {
        // Fetch request details from the server
        fetch(`?handler=RequestDetails&requestId=${requestId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    populateViewDetailsModal(data);
                    new bootstrap.Modal(document.getElementById('viewDetailsModal')).show();
                } else {
                    alert('Error loading request details: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error loading request details');
            });
    }
    
    function getRequestDataFromRow(row) {
        // Extract data from the table row
        // This is a simplified version - in a real app, you'd fetch from the server
        return {
            id: row.getAttribute('data-request-id'),
            Staff: row.querySelector('.Staff-name')?.textContent || 'N/A',
            mobileNumber: row.querySelector('.Staff-details')?.textContent || 'N/A',
            amount: row.querySelector('td:nth-child(3)')?.textContent || 'N/A',
            status: row.querySelector('.status-badge')?.textContent?.trim() || 'N/A',
            requestDate: row.querySelector('td:nth-child(5)')?.textContent || 'N/A'
        };
    }
    
    function populateViewDetailsModal(data) {
        // Populate basic information
        document.getElementById('viewRequestId').textContent = '#' + data.id;
        
        // Staff Information Section
        document.getElementById('viewStaffName').textContent = data.staffName || 'N/A';
        document.getElementById('viewMobileNumber').textContent = data.primaryMobileNumber || 'N/A';
        document.getElementById('viewIndexNo').textContent = data.indexNo || 'N/A';
        
        // Mobile Service Details Section
        document.getElementById('viewOffice').textContent = data.office || 'N/A';
        document.getElementById('viewOrganization').textContent = data.organization || 'N/A';
        document.getElementById('viewMobileService').textContent = data.mobileService || 'N/A';
        document.getElementById('viewClassOfService').textContent = data.classOfService || 'N/A';
        document.getElementById('viewDeviceAllowance').textContent = data.deviceAllowance ? `$${data.deviceAllowance.toFixed(2)}` : 'N/A';
        document.getElementById('viewSupervisor').textContent = data.supervisor || 'N/A';
        
        // Financial Information Section
        const purchaseAmount = data.devicePurchaseAmount ? 
            `${data.devicePurchaseCurrency || ''} ${data.devicePurchaseAmount.toFixed(2)}` : 'N/A';
        document.getElementById('viewPurchaseAmount').textContent = purchaseAmount;
        
        const refundAmount = data.refundUsdAmount ? `$${data.refundUsdAmount.toFixed(2)}` : 'N/A';
        document.getElementById('viewRefundAmount').textContent = refundAmount;
        
        document.getElementById('viewRequestDate').textContent = data.requestDate || 'N/A';
        document.getElementById('viewCostObject').textContent = data.costObject || 'Not assigned';
        document.getElementById('viewCostCenter').textContent = data.costCenter || 'Not assigned';
        document.getElementById('viewFundCommitment').textContent = data.fundCommitment || 'Not assigned';
        
        // Budget Information Section
        updateStatusBadge(data.status);
        document.getElementById('viewBankName').textContent = data.umojaBankName || 'N/A';
        
        // Purchase Receipt Section
        populateReceiptSection(data);
        
        // Processing History & Remarks Section
        document.getElementById('viewSupervisorRemarks').textContent = 
            data.supervisorRemarks || 'No supervisor remarks provided.';
        document.getElementById('viewBudgetRemarks').textContent = 
            data.budgetOfficerRemarks || 'No budget officer remarks provided.';
        
        // Workflow History Section
        populateWorkflowHistory(data);
    }
    
    function updateModalServiceInfo(data) {
        // Update service information fields
        const serviceSection = document.querySelector('.modal-body .mb-4:nth-child(3)');
        if (serviceSection) {
            const fields = serviceSection.querySelectorAll('.row .col-md-4, .row .col-md-6');
            if (fields.length >= 5) {
                fields[0].querySelector('div:last-child').textContent = data.indexNo || 'N/A';
                fields[1].querySelector('div:last-child').textContent = data.mobileService || 'N/A';
                fields[2].querySelector('div:last-child').textContent = data.classOfService || 'N/A';
                fields[3].querySelector('div:last-child').textContent = data.office || 'N/A';
                fields[4].querySelector('div:last-child').textContent = data.organization || 'N/A';
            }
        }
    }
    
    function updateModalFinancialInfo(data) {
        // Update financial information
        const financialSection = document.querySelector('.modal-body .mb-4:nth-child(4)');
        if (financialSection) {
            const fields = financialSection.querySelectorAll('.row .col-md-4');
            if (fields.length >= 3) {
                fields[0].querySelector('div:last-child').textContent = '$' + (data.deviceAllowance ? data.deviceAllowance.toFixed(2) : '0.00');
                fields[1].querySelector('div:last-child').textContent = (data.devicePurchaseCurrency || '') + ' ' + (data.devicePurchaseAmount ? data.devicePurchaseAmount.toFixed(2) : '0.00');
                fields[2].querySelector('div:last-child').textContent = data.umojaBankName || 'N/A';
            }
        }
    }
    
    function updateModalComments(data) {
        // Update comments section
        const commentsSection = document.querySelector('.modal-body .mb-4:last-child');
        if (commentsSection) {
            const StaffRemarksDiv = commentsSection.querySelector('.col-md-6:first-child .mb-3 div:last-child');
            const supervisorRemarksDiv = commentsSection.querySelector('.col-md-6:last-child .mb-3 div:last-child');
            
            if (StaffRemarksDiv) {
                StaffRemarksDiv.textContent = data.remarks || 'No Staff remarks provided.';
            }
            if (supervisorRemarksDiv) {
                supervisorRemarksDiv.textContent = data.supervisorRemarks || 'No supervisor remarks provided.';
            }
        }
    }
    
    function getStatusDisplayText(status) {
        const statusMap = {
            'Draft': 'Draft',
            'PendingSupervisor': 'Pending Supervisor',
            'PendingBudgetOfficer': 'Pending Budget Officer',
            'PendingStaffClaimsUnit': 'Pending Staff Claims Unit',
            'PendingPaymentApproval': 'Pending Payment Approval',
            'Completed': 'Completed',
            'Cancelled': 'Cancelled'
        };
        return statusMap[status] || status;
    }

    function budgetOfficerApprove(requestId) {
        // Reset the budget officer modal form
        document.getElementById('costObject').value = '';
        document.getElementById('costCenter').value = '';
        document.getElementById('fundCommitment').value = '';
        document.getElementById('budgetOfficerRemarks').value = '';
        document.getElementById('budgetRemarksCount').textContent = '0';
        
        // Set the request ID
        currentRequestId = requestId;
        document.getElementById('budgetApproveRequestId').value = requestId;
        
        // Show the budget officer modal
        new bootstrap.Modal(document.getElementById('budgetOfficerApproveModal')).show();
    }
    
    function budgetApproveAndSubmit() {
        const costObject = document.getElementById('costObject').value.trim();
        const costCenter = document.getElementById('costCenter').value.trim();
        const fundCommitment = document.getElementById('fundCommitment').value.trim();
        const remarks = document.getElementById('budgetOfficerRemarks').value;
        
        // Validate required fields
        if (!costObject) {
            alert('Cost Object is required.');
            document.getElementById('costObject').focus();
            return;
        }
        
        if (!costCenter) {
            alert('Cost Center is required.');
            document.getElementById('costCenter').focus();
            return;
        }
        
        if (!fundCommitment) {
            alert('Fund Commitment is required.');
            document.getElementById('fundCommitment').focus();
            return;
        }
        
        if (confirm('Are you sure you want to approve this request and submit it to Staff Claims Unit?')) {
            // Set form values and submit
            document.getElementById('budgetApproveCostObject').value = costObject;
            document.getElementById('budgetApproveCostCenter').value = costCenter;
            document.getElementById('budgetApproveFundCommitment').value = fundCommitment;
            document.getElementById('budgetApproveRemarksHidden').value = remarks;
            document.getElementById('budgetApproveForm').submit();
        }
    }
    
    function budgetRevertToRequestor(requestId = null) {
        const id = requestId || currentRequestId;
        
        // Populate the modal with request information
        document.getElementById('revertRequestorRequestId').textContent = '#' + id;
        
        // Get Staff name from the table row
        const row = document.querySelector(`tr[data-request-id="${id}"]`);
        const StaffName = row ? (row.querySelector('.Staff-name')?.textContent || 'N/A') : 'N/A';
        document.getElementById('revertRequestorStaff').textContent = StaffName;
        
        // Clear the textarea and reset character count
        document.getElementById('revertRequestorRemarks').value = '';
        document.getElementById('revertRequestorCount').textContent = '0';
        
        // Store the request ID for later use
        document.getElementById('revertRequestorRemarks').setAttribute('data-request-id', id);
        
        // Show the modal
        new bootstrap.Modal(document.getElementById('revertToRequestorModal')).show();
    }
    
    function budgetRevertToSupervisor(requestId = null) {
        const id = requestId || currentRequestId;
        
        // Populate the modal with request information
        document.getElementById('revertSupervisorRequestId').textContent = '#' + id;
        document.getElementById('revertSupervisorName').textContent = 'Supervisor'; // You might want to fetch actual supervisor name
        
        // Clear the textarea and reset character count
        document.getElementById('revertSupervisorRemarks').value = '';
        document.getElementById('revertSupervisorCount').textContent = '0';
        
        // Store the request ID for later use
        document.getElementById('revertSupervisorRemarks').setAttribute('data-request-id', id);
        
        // Show the modal
        new bootstrap.Modal(document.getElementById('revertToSupervisorModal')).show();
    }
    
    function setRevertReason(textareaId, reason) {
        const textarea = document.getElementById(textareaId);
        textarea.value = reason;
        
        // Update character count
        const countElement = document.getElementById(textareaId.replace('Remarks', 'Count'));
        if (countElement) {
            countElement.textContent = reason.length;
        }
    }
    
    function confirmRevertToRequestor() {
        const remarks = document.getElementById('revertRequestorRemarks').value.trim();
        const requestId = document.getElementById('revertRequestorRemarks').getAttribute('data-request-id');
        
        if (!remarks) {
            alert('Please provide a reason for reverting this request.');
            document.getElementById('revertRequestorRemarks').focus();
            return;
        }
        
        // Submit the form
        document.getElementById('budgetRevertRequestorId').value = requestId;
        document.getElementById('budgetRevertRequestorRemarks').value = remarks;
        document.getElementById('budgetRevertRequestorForm').submit();
    }
    
    function confirmRevertToSupervisor() {
        const remarks = document.getElementById('revertSupervisorRemarks').value.trim();
        const requestId = document.getElementById('revertSupervisorRemarks').getAttribute('data-request-id');
        
        if (!remarks) {
            alert('Please provide a reason for reverting this request.');
            document.getElementById('revertSupervisorRemarks').focus();
            return;
        }
        
        // Submit the form
        document.getElementById('budgetRevertSupervisorId').value = requestId;
        document.getElementById('budgetRevertSupervisorRemarks').value = remarks;
        document.getElementById('budgetRevertSupervisorForm').submit();
    }

    function rejectRequest(requestId) {
        document.getElementById('rejectRequestId').value = requestId;
        new bootstrap.Modal(document.getElementById('rejectModal')).show();
    }

    // Character counter for budget officer remarks
    document.addEventListener('DOMContentLoaded', function() {
        const budgetRemarksTextarea = document.getElementById('budgetOfficerRemarks');
        const budgetRemarksCount = document.getElementById('budgetRemarksCount');
        
        if (budgetRemarksTextarea && budgetRemarksCount) {
            budgetRemarksTextarea.addEventListener('input', function() {
                budgetRemarksCount.textContent = this.value.length;
            });
        }
        
        // Character counter for revert to requestor modal
        const revertRequestorTextarea = document.getElementById('revertRequestorRemarks');
        const revertRequestorCount = document.getElementById('revertRequestorCount');
        
        if (revertRequestorTextarea && revertRequestorCount) {
            revertRequestorTextarea.addEventListener('input', function() {
                revertRequestorCount.textContent = this.value.length;
            });
        }
        
        // Character counter for revert to supervisor modal
        const revertSupervisorTextarea = document.getElementById('revertSupervisorRemarks');
        const revertSupervisorCount = document.getElementById('revertSupervisorCount');
        
        if (revertSupervisorTextarea && revertSupervisorCount) {
            revertSupervisorTextarea.addEventListener('input', function() {
                revertSupervisorCount.textContent = this.value.length;
            });
        }
    });

    // Enhanced View Details Modal Functions
    function updateStatusBadge(status) {
        const statusBadge = document.getElementById('viewStatus');
        const statusConfig = {
            'Draft': { text: 'Draft', color: '#6b7280' },
            'PendingSupervisor': { text: 'Pending Supervisor', color: '#f59e0b' },
            'PendingBudgetOfficer': { text: 'Pending Budget Officer', color: '#f59e0b' },
            'PendingStaffClaimsUnit': { text: 'Pending Claims Unit', color: '#3b82f6' },
            'PendingPaymentApproval': { text: 'Pending Payment', color: '#8b5cf6' },
            'Completed': { text: 'Completed', color: '#10b981' },
            'Cancelled': { text: 'Cancelled', color: '#ef4444' }
        };
        
        const config = statusConfig[status] || { text: status, color: '#6b7280' };
        statusBadge.textContent = config.text;
        statusBadge.style.background = config.color;
    }
    
    function populateReceiptSection(data) {
        const receiptFileName = document.getElementById('viewReceiptFileName');
        const viewReceiptBtn = document.getElementById('viewReceiptBtn');
        const downloadReceiptBtn = document.getElementById('downloadReceiptBtn');
        
        if (data.purchaseReceiptPath && data.purchaseReceiptFileName) {
            receiptFileName.textContent = data.purchaseReceiptFileName;
            viewReceiptBtn.style.display = 'inline-block';
            downloadReceiptBtn.style.display = 'inline-block';
            
            // Store the file path for later use
            viewReceiptBtn.setAttribute('data-file-path', data.purchaseReceiptPath);
            downloadReceiptBtn.setAttribute('data-file-path', data.purchaseReceiptPath);
        } else {
            receiptFileName.textContent = 'No receipt uploaded';
            viewReceiptBtn.style.display = 'none';
            downloadReceiptBtn.style.display = 'none';
        }
        
        document.getElementById('viewPreviousReimbursement').textContent = 
            data.previousReimbursement || 'No previous reimbursement';
    }
    
    function populateWorkflowHistory(data) {
        const currentStatus = data.status;
        
        // Update Request Submission (always completed)
        document.getElementById('workflowRequestDate').textContent = data.requestDate || 'N/A';
        document.getElementById('workflowRequestedBy').textContent = data.staffName || 'N/A';
        
        // Update workflow steps based on status
        updateWorkflowStep('supervisor', data, currentStatus);
        updateWorkflowStep('budget', data, currentStatus);
        updateWorkflowStep('claims', data, currentStatus);
        updateWorkflowStep('payment', data, currentStatus);
        updateWorkflowStep('completion', data, currentStatus);
    }
    
    function updateWorkflowStep(step, data, currentStatus) {
        const stepConfig = {
            supervisor: {
                date: data.supervisorApprovalDate,
                name: data.supervisorName || 'Not assigned',
                remarks: data.supervisorRemarks,
                statuses: ['PendingSupervisor', 'PendingBudgetOfficer', 'PendingStaffClaimsUnit', 'PendingPaymentApproval', 'Completed']
            },
            budget: {
                date: data.budgetOfficerApprovalDate,
                name: data.budgetOfficerName || 'Not assigned',
                remarks: data.budgetOfficerRemarks,
                statuses: ['PendingBudgetOfficer', 'PendingStaffClaimsUnit', 'PendingPaymentApproval', 'Completed']
            },
            claims: {
                date: data.claimsUnitActionDate,
                name: data.claimsUnitOfficerName || 'Not assigned',
                remarks: data.claimsUnitRemarks,
                statuses: ['PendingStaffClaimsUnit', 'PendingPaymentApproval', 'Completed']
            },
            payment: {
                date: data.paymentApprovalDate,
                name: data.paymentApproverName || 'Not assigned',
                remarks: data.paymentApprovalRemarks,
                statuses: ['PendingPaymentApproval', 'Completed']
            },
            completion: {
                date: data.completionDate,
                name: 'System',
                remarks: null,
                statuses: ['Completed']
            }
        };
        
        const config = stepConfig[step];
        if (!config) return;
        
        const isCompleted = config.date && currentStatus !== `Pending${step.charAt(0).toUpperCase() + step.slice(1)}`;
        const isCurrent = currentStatus === `Pending${step.charAt(0).toUpperCase() + step.slice(1)}` || 
                         (step === 'budget' && currentStatus === 'PendingBudgetOfficer');
        const isPending = !isCompleted && !isCurrent;
        
        // Update marker
        const marker = document.getElementById(`${step}Marker`);
        const dateElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Date`);
        const nameElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Name`) ||
                           document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}OfficerName`);
        const descriptionElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Description`);
        const remarksElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}RemarksTimeline`);
        
        if (marker) {
            marker.className = 'timeline-marker';
            if (isCompleted) {
                marker.classList.add('timeline-approved');
                marker.innerHTML = '<i class="bi bi-check"></i>';
            } else if (isCurrent) {
                marker.classList.add('timeline-current');
                marker.innerHTML = '<i class="bi bi-clock"></i>';
            } else {
                marker.classList.add('timeline-pending');
                marker.innerHTML = '<i class="bi bi-clock"></i>';
            }
        }
        
        // Update date
        if (dateElement) {
            if (config.date) {
                dateElement.textContent = config.date;
            } else if (isCurrent) {
                dateElement.textContent = 'In Progress';
            } else {
                dateElement.textContent = 'Pending';
            }
        }
        
        // Update name
        if (nameElement) {
            nameElement.textContent = config.name;
        }
        
        // Update description
        if (descriptionElement) {
            if (isCompleted) {
                descriptionElement.textContent = `${step.charAt(0).toUpperCase() + step.slice(1)} completed`;
            } else if (isCurrent) {
                descriptionElement.textContent = `Currently being processed by ${step} team`;
            } else {
                descriptionElement.textContent = `Awaiting ${step} processing`;
            }
        }
        
        // Update remarks
        if (remarksElement && config.remarks) {
            remarksElement.style.display = 'block';
            remarksElement.querySelector('span').textContent = config.remarks;
        } else if (remarksElement) {
            remarksElement.style.display = 'none';
        }
        
        // Special handling for completion step
        if (step === 'completion') {
            const paymentRefElement = document.getElementById('workflowPaymentReference');
            if (paymentRefElement) {
                paymentRefElement.textContent = data.paymentReference || 'Not assigned';
            }
        }
    }
    
    function viewReceipt() {
        const viewBtn = document.getElementById('viewReceiptBtn');
        const filePath = viewBtn.getAttribute('data-file-path');
        
        if (filePath) {
            // Open the receipt in a new window/tab
            window.open(`/uploads/receipts/${encodeURIComponent(filePath.split('/').pop())}`, '_blank');
        } else {
            alert('No receipt file available to view.');
        }
    }
    
    function downloadReceipt() {
        const downloadBtn = document.getElementById('downloadReceiptBtn');
        const filePath = downloadBtn.getAttribute('data-file-path');
        
        if (filePath) {
            // Create a temporary link to download the file
            const link = document.createElement('a');
            link.href = `/uploads/receipts/${encodeURIComponent(filePath.split('/').pop())}`;
            link.download = filePath.split('/').pop();
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        } else {
            alert('No receipt file available to download.');
        }
    }
</script> 
