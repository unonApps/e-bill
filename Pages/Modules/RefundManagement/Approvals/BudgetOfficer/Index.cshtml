<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.1);">
            <form method="post" asp-page-handler="Reject">
                <input type="hidden" id="rejectRequestId" name="requestId" />
                <div class="modal-header" style="border: none; padding: 32px 32px 0 32px;">
                    <div class="d-flex align-items-center">
                        <div class="me-3" style="width: 48px; height: 48px; background: #ef4444; border-radius: 16px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-x-circle text-white" style="font-size: 24px;"></i>
                        </div>
                        <div>
                            <h4 class="mb-1" style="font-weight: 700; color: #111827; font-size: 24px;">Reject Request</h4>
                            <p class="mb-0 text-muted" style="font-size: 14px;">Provide reason for rejection</p>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" style="margin: 0; padding: 12px;"></button>
                </div>
                <div class="modal-body" style="padding: 24px 32px 32px 32px;">
                    <div class="mb-4">
                        <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">Rejection Reason <span style="color: #ef4444;">*</span></label>
                        <textarea name="budgetOfficerRemarks" class="form-control" rows="3" required placeholder="Please provide a clear reason for rejecting this request..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px;"></textarea>
                    </div>
                    <div class="d-flex gap-3 justify-content-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">Cancel</button>
                        <button type="submit" class="btn btn-danger" style="background: #ef4444; border: none; border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                            <i class="bi bi-x-circle me-2"></i>Reject Request
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

