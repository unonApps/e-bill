                        <small class="text-muted">💡 This message will be sent to the Staff</small>
                        <small class="text-muted">
                            <span id="revertRequestorCount">0</span>/200 characters
                        </small>
                    </div>
                </div>

                <!-- Common Reasons (Quick Select) -->
                <div class="mb-4">
                    <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                        Quick Reasons (Optional)
                    </label>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-warning btn-sm" onclick="setRevertReason('revertRequestorRemarks', 'Missing or incomplete documentation required for budget approval.')" style="border-radius: 20px; font-size: 12px;">
                            Missing Documentation
                        </button>
                        <button type="button" class="btn btn-outline-warning btn-sm" onclick="setRevertReason('revertRequestorRemarks', 'Amount exceeds allowable limits. Please review and adjust.')" style="border-radius: 20px; font-size: 12px;">
                            Amount Issues
                        </button>
                        <button type="button" class="btn btn-outline-warning btn-sm" onclick="setRevertReason('revertRequestorRemarks', 'Additional information required for proper budget allocation.')" style="border-radius: 20px; font-size: 12px;">
                            Need More Info
                        </button>
                    </div>
                </div>
            </div>
            
            <div class="modal-footer" style="border: none; padding: 0 32px 32px 32px;">
                <div class="d-flex gap-3 justify-content-end w-100">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-warning" onclick="confirmRevertToRequestor()" style="background: #f59e0b; border: none; border-radius: 12px; padding: 12px 24px; font-weight: 500; color: white;">
