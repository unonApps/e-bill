<script>
    // Handle tab activation from URL parameter
    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        const tabParam = urlParams.get('tab');
        const requestId = urlParams.get('requestId');

        // If requestId is provided and tab parameter exists, activate the correct tab
        if (requestId && tabParam) {
            const tabMap = {
                'supervisor': 'detail-supervisor-tab',
                'budget': 'detail-budget-tab',
                'claims': 'detail-claims-tab',
                'financial': 'detail-financial-tab',
                'workflow': 'detail-workflow-tab',
                'remarks': 'detail-remarks-tab'
            };

            const tabId = tabMap[tabParam];
            if (tabId) {
                const tabElement = document.getElementById(tabId);
                if (tabElement) {
                    // Activate the tab
                    const tab = new bootstrap.Tab(tabElement);
                    tab.show();
                }
            }
        }
    });

    let currentRequestId = null;

    // Helper function to set request ID in detail view modals
    function setDetailRequestId(requestId) {
        document.getElementById('detailRevertRequestorRequestId').value = requestId;
        document.getElementById('detailRevertSupervisorRequestId').value = requestId;
        document.getElementById('detailReassignRequestId').value = requestId;
    }

    function viewRequest(requestId) {
        // Fetch request details from the server
        fetch(`?handler=RequestDetails&requestId=${requestId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    populateViewDetailsModal(data);
                    new bootstrap.Modal(document.getElementById('viewDetailsModal')).show();
                } else {
                    alert('Error loading request details: ' + data.message);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Error loading request details');
            });
    }
    
    function getRequestDataFromRow(row) {
        // Extract data from the table row
        // This is a simplified version - in a real app, you'd fetch from the server
        return {
            id: row.getAttribute('data-request-id'),
            Staff: row.querySelector('.Staff-name')?.textContent || 'N/A',
            mobileNumber: row.querySelector('.Staff-details')?.textContent || 'N/A',
            amount: row.querySelector('td:nth-child(3)')?.textContent || 'N/A',
            status: row.querySelector('.status-badge')?.textContent?.trim() || 'N/A',
            requestDate: row.querySelector('td:nth-child(5)')?.textContent || 'N/A'
        };
    }
    
    function populateViewDetailsModal(data) {
        // Populate basic information
        document.getElementById('viewRequestId').textContent = '#' + data.id;
        
        // Staff Information Section
        document.getElementById('viewStaffName').textContent = data.staffName || 'N/A';
        document.getElementById('viewMobileNumber').textContent = data.primaryMobileNumber || 'N/A';
        document.getElementById('viewIndexNo').textContent = data.indexNo || 'N/A';
        
        // Mobile Service Details Section
        document.getElementById('viewOffice').textContent = data.office || 'N/A';
        document.getElementById('viewOrganization').textContent = data.organization || 'N/A';
        document.getElementById('viewMobileService').textContent = data.mobileService || 'N/A';
        document.getElementById('viewClassOfService').textContent = data.classOfService || 'N/A';
        document.getElementById('viewDeviceAllowance').textContent = data.deviceAllowance ? `$${data.deviceAllowance.toFixed(2)}` : 'N/A';
        document.getElementById('viewSupervisor').textContent = data.supervisor || 'N/A';
        
        // Financial Information Section
        const purchaseAmount = data.devicePurchaseAmount ? 
            `${data.devicePurchaseCurrency || ''} ${data.devicePurchaseAmount.toFixed(2)}` : 'N/A';
        document.getElementById('viewPurchaseAmount').textContent = purchaseAmount;
        
        const refundAmount = data.refundUsdAmount ? `$${data.refundUsdAmount.toFixed(2)}` : 'N/A';
        document.getElementById('viewRefundAmount').textContent = refundAmount;
        
        document.getElementById('viewRequestDate').textContent = data.requestDate || 'N/A';
        document.getElementById('viewCostObject').textContent = data.costObject || 'Not assigned';
        document.getElementById('viewCostCenter').textContent = data.costCenter || 'Not assigned';
        document.getElementById('viewFundCommitment').textContent = data.fundCommitment || 'Not assigned';
        
        // Budget Information Section
        updateStatusBadge(data.status);
        document.getElementById('viewBankName').textContent = data.umojaBankName || 'N/A';
        
        // Purchase Receipt Section
        populateReceiptSection(data);
        
        // Processing History & Remarks Section
        document.getElementById('viewSupervisorRemarks').textContent = 
            data.supervisorRemarks || 'No supervisor remarks provided.';
        document.getElementById('viewBudgetRemarks').textContent = 
            data.budgetOfficerRemarks || 'No budget officer remarks provided.';
        
        // Workflow History Section
        populateWorkflowHistory(data);

        // Populate approval tabs
        populateSupervisorApproval(data);
        populateBudgetOfficerApproval(data);
        populateClaimsProcessing(data);
    }

    function populateSupervisorApproval(data) {
        const content = document.getElementById('supervisorContent');
        if (data.supervisorName || data.supervisorRemarks) {
            content.innerHTML = `
                <div class="mb-4" style="background: #f8fafc; border-radius: 8px; padding: 1.25rem; border: 1px solid #e2e8f0;">
                    <h6 style="font-size: 0.875rem; font-weight: 600; color: #4a5568; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e2e8f0; display: flex; align-items: center;">
                        <i class="bi bi-person-check me-2" style="color: #009EDB;"></i>Supervisor Information
                    </h6>
                    <div class="row">
                        ${data.supervisorName ? `
                            <div class="col-md-6 mb-3">
                                <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Supervisor Name</div>
                                <div style="font-size: 14px; color: #1f2937; font-weight: 500;">${data.supervisorName}</div>
                            </div>
                        ` : ''}
                        ${data.supervisorEmail ? `
                            <div class="col-md-6 mb-3">
                                <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Supervisor Email</div>
                                <div style="font-size: 14px; color: #1f2937; font-weight: 500;">${data.supervisorEmail}</div>
                            </div>
                        ` : ''}
                        ${data.supervisorRemarks ? `
                            <div class="col-12 mb-3">
                                <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Supervisor Remarks</div>
                                <div style="font-size: 14px; color: #1f2937; line-height: 1.5; background: white; padding: 12px; border-radius: 6px;">${data.supervisorRemarks}</div>
                            </div>
                        ` : ''}
                        ${data.supervisorNotes ? `
                            <div class="col-12 mb-3">
                                <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Supervisor Notes</div>
                                <div style="font-size: 14px; color: #1f2937; line-height: 1.5; background: white; padding: 12px; border-radius: 6px;">${data.supervisorNotes}</div>
                            </div>
                        ` : ''}
                    </div>
                </div>
            `;
        }
    }

    function populateBudgetOfficerApproval(data) {
        const content = document.getElementById('budgetContent');
        if (data.budgetOfficerName || data.budgetOfficerRemarks || data.costObject) {
            content.innerHTML = `
                ${(data.budgetOfficerName || data.budgetOfficerEmail) ? `
                    <div class="mb-4" style="background: #f8fafc; border-radius: 8px; padding: 1.25rem; border: 1px solid #e2e8f0;">
                        <h6 style="font-size: 0.875rem; font-weight: 600; color: #4a5568; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e2e8f0; display: flex; align-items: center;">
                            <i class="bi bi-person-check me-2" style="color: #009EDB;"></i>Budget Officer Information
                        </h6>
                        <div class="row">
                            ${data.budgetOfficerName ? `
                                <div class="col-md-6 mb-3">
                                    <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Budget Officer Name</div>
                                    <div style="font-size: 14px; color: #1f2937; font-weight: 500;">${data.budgetOfficerName}</div>
                                </div>
                            ` : ''}
                            ${data.budgetOfficerEmail ? `
                                <div class="col-md-6 mb-3">
                                    <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Budget Officer Email</div>
                                    <div style="font-size: 14px; color: #1f2937; font-weight: 500;">${data.budgetOfficerEmail}</div>
                                </div>
                            ` : ''}
                            ${data.budgetOfficerApprovalDate ? `
                                <div class="col-md-6 mb-3">
                                    <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Approval Date</div>
                                    <div style="font-size: 14px; color: #1f2937; font-weight: 500;">${new Date(data.budgetOfficerApprovalDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
                                </div>
                            ` : ''}
                        </div>
                    </div>
                ` : ''}
                ${(data.costObject || data.costCenter || data.fundCommitment) ? `
                    <div class="mb-4" style="background: #f8fafc; border-radius: 8px; padding: 1.25rem; border: 1px solid #e2e8f0;">
                        <h6 style="font-size: 0.875rem; font-weight: 600; color: #4a5568; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #e2e8f0; display: flex; align-items: center;">
                            <i class="bi bi-calculator me-2" style="color: #009EDB;"></i>Cost Accounting
                        </h6>
                        <div class="row">
                            ${data.costObject ? `
                                <div class="col-md-4 mb-3">
                                    <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Cost Object</div>
                                    <div style="font-size: 14px; color: #1f2937; font-weight: 500;">${data.costObject}</div>
                                </div>
                            ` : ''}
                            ${data.costCenter ? `
                                <div class="col-md-4 mb-3">
                                    <div style="font-size: 12px; color: #6b7280; margin-bottom: 4px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.025em;">Cost Center</div>
                                    <div style="font-size: 14px; color: #1f2937; font-weight: 500;">${data.costCenter}</div>
                                </div>
                            ` : ''}
                            ${data.fundCommitment ? `
