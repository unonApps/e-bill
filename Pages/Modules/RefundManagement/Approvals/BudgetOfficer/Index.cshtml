    function populateWorkflowHistory(data) {
        const currentStatus = data.status;
        
        // Update Request Submission (always completed)
        document.getElementById('workflowRequestDate').textContent = data.requestDate || 'N/A';
        document.getElementById('workflowRequestedBy').textContent = data.staffName || 'N/A';
        
        // Update workflow steps based on status
        updateWorkflowStep('supervisor', data, currentStatus);
        updateWorkflowStep('budget', data, currentStatus);
        updateWorkflowStep('claims', data, currentStatus);
        updateWorkflowStep('payment', data, currentStatus);
        updateWorkflowStep('completion', data, currentStatus);
    }
    
    function updateWorkflowStep(step, data, currentStatus) {
        const stepConfig = {
            supervisor: {
                date: data.supervisorApprovalDate,
                name: data.supervisorName || 'Not assigned',
                remarks: data.supervisorRemarks,
                statuses: ['PendingSupervisor', 'PendingBudgetOfficer', 'PendingStaffClaimsUnit', 'PendingPaymentApproval', 'Completed']
            },
            budget: {
                date: data.budgetOfficerApprovalDate,
                name: data.budgetOfficerName || 'Not assigned',
                remarks: data.budgetOfficerRemarks,
                statuses: ['PendingBudgetOfficer', 'PendingStaffClaimsUnit', 'PendingPaymentApproval', 'Completed']
            },
            claims: {
                date: data.claimsUnitActionDate,
                name: data.claimsUnitOfficerName || 'Not assigned',
                remarks: data.claimsUnitRemarks,
                statuses: ['PendingStaffClaimsUnit', 'PendingPaymentApproval', 'Completed']
            },
            payment: {
                date: data.paymentApprovalDate,
                name: data.paymentApproverName || 'Not assigned',
                remarks: data.paymentApprovalRemarks,
                statuses: ['PendingPaymentApproval', 'Completed']
            },
            completion: {
                date: data.completionDate,
                name: 'System',
                remarks: null,
                statuses: ['Completed']
            }
        };
        
        const config = stepConfig[step];
        if (!config) return;
        
        const isCompleted = config.date && currentStatus !== `Pending${step.charAt(0).toUpperCase() + step.slice(1)}`;
        const isCurrent = currentStatus === `Pending${step.charAt(0).toUpperCase() + step.slice(1)}` || 
                         (step === 'budget' && currentStatus === 'PendingBudgetOfficer');
        const isPending = !isCompleted && !isCurrent;
        
        // Update marker
        const marker = document.getElementById(`${step}Marker`);
        const dateElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Date`);
        const nameElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Name`) ||
                           document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}OfficerName`);
        const descriptionElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Description`);
        const remarksElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}RemarksTimeline`);
        
        if (marker) {
            marker.className = 'timeline-marker';
            if (isCompleted) {
                marker.classList.add('timeline-approved');
                marker.innerHTML = '<i class="bi bi-check"></i>';
            } else if (isCurrent) {
                marker.classList.add('timeline-current');
                marker.innerHTML = '<i class="bi bi-clock"></i>';
            } else {
                marker.classList.add('timeline-pending');
                marker.innerHTML = '<i class="bi bi-clock"></i>';
            }
        }
        
        // Update date
        if (dateElement) {
            if (config.date) {
                dateElement.textContent = config.date;
            } else if (isCurrent) {
                dateElement.textContent = 'In Progress';
            } else {
                dateElement.textContent = 'Pending';
            }
        }
        
        // Update name
        if (nameElement) {
            nameElement.textContent = config.name;
        }
        
        // Update description
        if (descriptionElement) {
            if (isCompleted) {
                descriptionElement.textContent = `${step.charAt(0).toUpperCase() + step.slice(1)} completed`;
            } else if (isCurrent) {
                descriptionElement.textContent = `Currently being processed by ${step} team`;
            } else {
                descriptionElement.textContent = `Awaiting ${step} processing`;
            }
        }
        
        // Update remarks
        if (remarksElement && config.remarks) {
            remarksElement.style.display = 'block';
            remarksElement.querySelector('span').textContent = config.remarks;
        } else if (remarksElement) {
            remarksElement.style.display = 'none';
        }
        
        // Special handling for completion step
        if (step === 'completion') {
            const paymentRefElement = document.getElementById('workflowPaymentReference');
            if (paymentRefElement) {
                paymentRefElement.textContent = data.paymentReference || 'Not assigned';
            }
        }
    }
    
    function viewReceipt() {
        const viewBtn = document.getElementById('viewReceiptBtn');
        const filePath = viewBtn.getAttribute('data-file-path');
        
        if (filePath) {
            // Open the receipt in a new window/tab
            window.open(`/uploads/receipts/${encodeURIComponent(filePath.split('/').pop())}`, '_blank');
        } else {
            alert('No receipt file available to view.');
        }
    }
    
    function downloadReceipt() {
        const downloadBtn = document.getElementById('downloadReceiptBtn');
        const filePath = downloadBtn.getAttribute('data-file-path');
        
        if (filePath) {
            // Create a temporary link to download the file
            const link = document.createElement('a');
            link.href = `/uploads/receipts/${encodeURIComponent(filePath.split('/').pop())}`;
            link.download = filePath.split('/').pop();
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        } else {
            alert('No receipt file available to download.');
        }
    }
