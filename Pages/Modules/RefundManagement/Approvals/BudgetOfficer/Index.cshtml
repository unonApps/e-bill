    function budgetOfficerApprove(requestId) {
        // Reset the budget officer modal form
        document.getElementById('costObject').value = '';
        document.getElementById('costCenter').value = '';
        document.getElementById('fundCommitment').value = '';
        document.getElementById('budgetOfficerRemarks').value = '';
        document.getElementById('budgetRemarksCount').textContent = '0';
        
        // Set the request ID
        currentRequestId = requestId;
        document.getElementById('budgetApproveRequestId').value = requestId;
        
        // Show the budget officer modal
        new bootstrap.Modal(document.getElementById('budgetOfficerApproveModal')).show();
    }
    
    function budgetApproveAndSubmit() {
        const costObject = document.getElementById('costObject').value.trim();
        const costCenter = document.getElementById('costCenter').value.trim();
        const fundCommitment = document.getElementById('fundCommitment').value.trim();
        const remarks = document.getElementById('budgetOfficerRemarks').value;
        
        // Validate required fields
        if (!costObject) {
            alert('Cost Object is required.');
            document.getElementById('costObject').focus();
            return;
        }
        
        if (!costCenter) {
            alert('Cost Center is required.');
            document.getElementById('costCenter').focus();
            return;
        }
        
        if (!fundCommitment) {
            alert('Fund Commitment is required.');
            document.getElementById('fundCommitment').focus();
            return;
        }
        
        if (confirm('Are you sure you want to approve this request and submit it to Staff Claims Unit?')) {
            // Set form values and submit
            document.getElementById('budgetApproveCostObject').value = costObject;
            document.getElementById('budgetApproveCostCenter').value = costCenter;
            document.getElementById('budgetApproveFundCommitment').value = fundCommitment;
            document.getElementById('budgetApproveRemarksHidden').value = remarks;
            document.getElementById('budgetApproveForm').submit();
        }
    }
    
    function budgetRevertToRequestor(requestId = null) {
        const id = requestId || currentRequestId;

        // Close the Budget Review modal first
        const budgetModal = bootstrap.Modal.getInstance(document.getElementById('budgetOfficerApproveModal'));
        if (budgetModal) {
            budgetModal.hide();
        }

        // Wait for the modal to close before opening the new one
        setTimeout(() => {
            // Populate the modal with request information
            document.getElementById('revertRequestorRequestId').textContent = '#' + id;

            // Get Staff name from the table row
            const row = document.querySelector(`tr[data-request-id="${id}"]`);
            const StaffName = row ? (row.querySelector('.Staff-name')?.textContent || 'N/A') : 'N/A';
            document.getElementById('revertRequestorStaff').textContent = StaffName;

            // Clear the textarea and reset character count
            document.getElementById('revertRequestorRemarks').value = '';
            document.getElementById('revertRequestorCount').textContent = '0';

            // Store the request ID for later use
            document.getElementById('revertRequestorRemarks').setAttribute('data-request-id', id);

            // Show the modal
            new bootstrap.Modal(document.getElementById('revertToRequestorModal')).show();
        }, 300); // Wait 300ms for the modal close animation
    }
    
