                            <div class="detail-value">@(Model.CurrentRequest.CostObject ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Cost Center</span>
                            <div class="detail-value">@(Model.CurrentRequest.CostCenter ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Fund Commitment</span>
                            <div class="detail-value">@(Model.CurrentRequest.FundCommitment ?? "N/A")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Budget Information Section -->
            <div class="mb-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-calculator me-3" style="font-size: 20px; color: #64748b;"></i>
                    <h6 class="mb-0" style="font-weight: 600; color: #475569;">Budget Information</h6>
                </div>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="mb-2">
                            <span class="detail-label">Current Status</span>
                            <div>
                                <span class="badge" style="background: #6366f1; color: white; font-size: 12px; padding: 6px 12px; border-radius: 8px; font-weight: 500;">@Model.CurrentRequest.Status</span>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-2">
                            <span class="detail-label">Umoja Bank Name</span>
                            <div class="detail-value">@(Model.CurrentRequest.UmojaBankName ?? "N/A")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Purchase Receipt Section -->
            <div class="mb-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
