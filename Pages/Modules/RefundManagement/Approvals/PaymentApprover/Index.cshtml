    function populateReceiptSection(data) {
        const receiptFileName = document.getElementById('viewReceiptFileName');
        const viewReceiptBtn = document.getElementById('viewReceiptBtn');
        const downloadReceiptBtn = document.getElementById('downloadReceiptBtn');
        const bankName = document.getElementById('viewBankName');
        
        if (data.purchaseReceiptPath) {
            const fileName = data.purchaseReceiptPath.split('/').pop() || 'receipt.pdf';
            receiptFileName.textContent = fileName;
            viewReceiptBtn.style.display = 'inline-block';
            downloadReceiptBtn.style.display = 'inline-block';
            
            // Store receipt path for functions
            window.currentReceiptPath = data.purchaseReceiptPath;
        } else {
            receiptFileName.textContent = 'No receipt uploaded';
            viewReceiptBtn.style.display = 'none';
            downloadReceiptBtn.style.display = 'none';
        }
        
        bankName.textContent = data.umojaBankName || 'Not specified';
    }
    
    function populateWorkflowHistory(data) {
        // Request Submission
        document.getElementById('workflowRequestDate').textContent = data.requestDate || 'N/A';
        document.getElementById('workflowRequestedBy').textContent = data.requestedBy || 'System';
        
        // Supervisor Review
        updateWorkflowStep('supervisor', data);
        
        // Budget Officer Review
        updateWorkflowStep('budget', data);
        
        // Claims Unit Processing
        updateWorkflowStep('claims', data);
        
        // Payment Approval
        updateWorkflowStep('payment', data);
        
        // Completion
        updateWorkflowStep('completion', data);
    }
    
    function updateWorkflowStep(step, data) {
        const status = data.status;
        let stepData = {};
        
        switch(step) {
            case 'supervisor':
                stepData = {
                    date: data.supervisorApprovalDate,
                    name: data.supervisorName || data.supervisor,
                    remarks: data.supervisorRemarks,
                    isCompleted: ['PendingBudgetOfficer', 'PendingStaffClaimsUnit', 'PendingPaymentApproval', 'Completed'].includes(status),
                    isCurrent: status === 'PendingSupervisor'
                };
                break;
            case 'budget':
                stepData = {
                    date: data.budgetOfficerApprovalDate,
                    name: data.budgetOfficerName,
                    remarks: data.budgetOfficerRemarks,
                    isCompleted: ['PendingStaffClaimsUnit', 'PendingPaymentApproval', 'Completed'].includes(status),
                    isCurrent: status === 'PendingBudgetOfficer'
                };
                break;
            case 'claims':
                stepData = {
                    date: data.staffClaimsApprovalDate,
                    name: data.staffClaimsOfficerName,
                    remarks: data.staffClaimsRemarks,
                    isCompleted: ['PendingPaymentApproval', 'Completed'].includes(status),
                    isCurrent: status === 'PendingStaffClaimsUnit'
                };
                break;
            case 'payment':
                stepData = {
                    date: data.paymentApprovalDate,
                    name: data.paymentApproverName,
                    remarks: data.paymentApprovalRemarks,
                    isCompleted: status === 'Completed',
                    isCurrent: status === 'PendingPaymentApproval'
                };
                break;
            case 'completion':
                stepData = {
                    date: data.completionDate,
                    name: data.paymentApproverName,
                    remarks: data.paymentReference,
                    isCompleted: status === 'Completed',
                    isCurrent: false
                };
                break;
        }
        
        // Update the UI elements
        const marker = document.getElementById(`${step}Marker`);
        const dateElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Date`);
        const nameElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}${step === 'completion' ? 'PaymentReference' : step === 'budget' ? 'OfficerName' : step === 'claims' ? 'OfficerName' : step === 'payment' ? 'ApproverName' : 'Name'}`);
        const remarksElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Remarks`);
        
        if (stepData.isCompleted) {
            marker.className = 'timeline-marker timeline-approved';
            marker.innerHTML = '<i class="bi bi-check"></i>';
            dateElement.textContent = stepData.date ? new Date(stepData.date).toLocaleDateString() : 'Completed';
        } else if (stepData.isCurrent) {
            marker.className = 'timeline-marker timeline-current';
            marker.innerHTML = '<i class="bi bi-clock"></i>';
            dateElement.textContent = 'In Progress';
        }
        
        if (nameElement && stepData.name) {
            nameElement.textContent = stepData.name;
        }
        
        if (remarksElement && stepData.remarks) {
            remarksElement.style.display = 'block';
            remarksElement.querySelector('span').textContent = stepData.remarks;
        }
    }
    
    // Receipt viewing functions
    function viewReceipt() {
        if (window.currentReceiptPath) {
            window.open(`/uploads/receipts/${window.currentReceiptPath}`, '_blank');
        }
    }
    
    function downloadReceipt() {
        if (window.currentReceiptPath) {
            const link = document.createElement('a');
            link.href = `/uploads/receipts/${window.currentReceiptPath}`;
            link.download = window.currentReceiptPath.split('/').pop() || 'receipt.pdf';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }
    }

    function getStatusDisplayText(status) {
        const statusMap = {
            'Draft': 'Draft',
            'PendingSupervisor': 'Pending Supervisor',
            'PendingBudgetOfficer': 'Pending Budget Officer',
            'PendingStaffClaimsUnit': 'Pending Staff Claims Unit',
            'PendingPaymentApproval': 'Pending Payment Approval',
            'Completed': 'Completed',
            'Cancelled': 'Cancelled'
        };
        return statusMap[status] || status;
    }
    
    function updateStatusBadge(status) {
        const statusBadge = document.getElementById('viewStatus');
        if (statusBadge) {
            statusBadge.className = 'badge';
            
            switch(status) {
                case 'PendingPaymentApproval':
                    statusBadge.style.background = '#6366f1';
                    statusBadge.style.color = 'white';
                    break;
                case 'Completed':
                    statusBadge.style.background = '#10b981';
                    statusBadge.style.color = 'white';
                    break;
                case 'Cancelled':
                    statusBadge.style.background = '#ef4444';
                    statusBadge.style.color = 'white';
                    break;
                default:
                    statusBadge.style.background = '#6b7280';
                    statusBadge.style.color = 'white';
            }
        }
    }

    function approvePayment(requestId) {
        currentRequestId = requestId;
        document.getElementById('paymentReference').value = '';
        document.getElementById('paymentRemarks').value = '';
        document.getElementById('paymentRemarksCount').textContent = '0';
        document.getElementById('approvePaymentRequestId').value = requestId;
        new bootstrap.Modal(document.getElementById('approvePaymentModal')).show();
    }

    function confirmPaymentApproval() {
        const paymentReference = document.getElementById('paymentReference').value;
        const paymentRemarks = document.getElementById('paymentRemarks').value;
        
        if (confirm('Are you sure you want to approve this payment and mark it as completed?')) {
            // Collect all form data
            const formData = {
                requestId: currentRequestId,
                paymentReference: paymentReference,
                paymentRemarks: paymentRemarks
            };
            
            // Set hidden form values
            document.getElementById('approvePaymentRemarks').value = JSON.stringify(formData);
            document.getElementById('approvePaymentForm').submit();
        }
    }

    function rejectPayment(requestId) {
        document.getElementById('rejectRequestId').value = requestId;
        new bootstrap.Modal(document.getElementById('rejectPaymentModal')).show();
    }

    function revertToClaims(requestId) {
        document.getElementById('revertRequestId').value = requestId;
        new bootstrap.Modal(document.getElementById('revertToClaimsModal')).show();
    }

    // Character counter for payment remarks
    document.addEventListener('DOMContentLoaded', function() {
        const paymentRemarksTextarea = document.getElementById('paymentRemarks');
        const paymentRemarksCount = document.getElementById('paymentRemarksCount');

        if (paymentRemarksTextarea && paymentRemarksCount) {
            paymentRemarksTextarea.addEventListener('input', function() {
                paymentRemarksCount.textContent = this.value.length;
            });
        }
    });

    // Detail view functions
    function setDetailRequestId(requestId) {
        document.getElementById('detailRevertRequestId').value = requestId;
        document.getElementById('detailRejectRequestId').value = requestId;
    }

    function submitDetailPaymentApproval(requestId) {
        const paymentReference = document.getElementById('detailPaymentReference').value;
        const paymentRemarks = document.getElementById('detailPaymentRemarks').value;

        if (confirm('Are you sure you want to approve this payment and mark it as completed?')) {
            // Create a form and submit it
            const form = document.createElement('form');
            form.method = 'post';
            form.action = '/Modules/RefundManagement/Approvals/PaymentApprover?handler=Approve';

            // Add request ID
            const requestIdInput = document.createElement('input');
            requestIdInput.type = 'hidden';
            requestIdInput.name = 'requestId';
            requestIdInput.value = requestId;
            form.appendChild(requestIdInput);

            // Add payment data as JSON
            const formData = {
                paymentReference: paymentReference,
                paymentRemarks: paymentRemarks
            };

            const remarksInput = document.createElement('input');
            remarksInput.type = 'hidden';
            remarksInput.name = 'paymentRemarks';
            remarksInput.value = JSON.stringify(formData);
            form.appendChild(remarksInput);

            // Add anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = token.value;
                form.appendChild(tokenInput);
            }

            document.body.appendChild(form);
            form.submit();
        }
    }
</script>

