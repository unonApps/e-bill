<script>
    let currentRequestId = null;

    function viewRequest(requestId) {
        // Fetch request details from the server
        fetch(`?handler=RequestDetails&requestId=${requestId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    populateViewDetailsModal(data);
                    new bootstrap.Modal(document.getElementById('viewDetailsModal')).show();
                } else {
                    alert('Error loading request details: ' + (data.message || 'Unknown error'));
                }
            })
            .catch(error => {
                console.error('Error fetching request details:', error);
                alert('Error loading request details');
            });
    }

    function populateViewDetailsModal(data) {
        // Populate the modal with comprehensive request data
        document.getElementById('viewRequestId').textContent = '#' + data.id;
        
        // Staff Information
        document.getElementById('viewStaffName').textContent = data.mobileNumberAssignedTo || 'N/A';
        document.getElementById('viewMobileNumber').textContent = data.primaryMobileNumber || 'N/A';
        document.getElementById('viewIndexNo').textContent = data.indexNo || 'N/A';
        
        // Mobile Service Details
        document.getElementById('viewOffice').textContent = data.office || 'N/A';
        document.getElementById('viewOrganization').textContent = data.organization || 'N/A';
        document.getElementById('viewMobileService').textContent = data.mobileService || 'N/A';
        document.getElementById('viewClassOfService').textContent = data.classOfService || 'N/A';
        document.getElementById('viewDeviceAllowance').textContent = data.deviceAllowance ? 
            ('$' + data.deviceAllowance.toFixed(2)) : 'N/A';
        document.getElementById('viewSupervisor').textContent = data.supervisor || 'N/A';
        
        // Financial Information
        document.getElementById('viewPurchaseAmount').textContent = (data.devicePurchaseCurrency || '') + ' ' + 
            (data.devicePurchaseAmount ? data.devicePurchaseAmount.toFixed(2) : '0.00');
        document.getElementById('viewRefundAmount').textContent = data.refundUsdAmount ? 
            ('USD ' + data.refundUsdAmount.toFixed(2)) : 'N/A';
        document.getElementById('viewRequestDate').textContent = data.requestDate || 'N/A';
        document.getElementById('viewCostObject').textContent = data.costObject || 'N/A';
        document.getElementById('viewCostCenter').textContent = data.costCenter || 'N/A';
        document.getElementById('viewFundCommitment').textContent = data.fundCommitment || 'N/A';
        
        // Payment Information
        document.getElementById('viewStatus').textContent = getStatusDisplayText(data.status);
        document.getElementById('viewUmojaDocId').textContent = data.umojaPaymentDocumentId || 'N/A';
        document.getElementById('viewPaymentReference').textContent = data.paymentReference || 'Not yet assigned';
        document.getElementById('viewClaimsActionDate').textContent = data.claimsActionDate || 'N/A';
        
        // Purchase Receipt Information
        populateReceiptSection(data);
        
        // Workflow History
        populateWorkflowHistory(data);

        // Processing History & Remarks
        document.getElementById('viewBudgetRemarks').textContent = data.budgetOfficerRemarks || 'No budget officer remarks provided.';
        document.getElementById('viewClaimsRemarks').textContent = data.staffClaimsRemarks || 'No claims unit remarks provided.';
        document.getElementById('viewPaymentRemarks').textContent = data.paymentApprovalRemarks || 'No payment approval remarks provided.';

        // Update status badge color based on actual status
        updateStatusBadge(data.status);

        // Populate approval tabs
        populateSupervisorApproval(data);
        populateBudgetOfficerApproval(data);
        populateClaimsProcessing(data);
