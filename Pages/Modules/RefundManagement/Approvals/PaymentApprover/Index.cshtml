                                                    aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                                Actions
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" href="/Modules/RefundManagement/Approvals/PaymentApprover?requestId=@request.Id">
                                                        <i class="bi bi-eye me-2" style="color: #009EDB;"></i>
                                                        View Details
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-check-circle"></i>
                    <h5 class="mt-3">No Completed Payments</h5>
                    <p>Completed payments will appear here.</p>
                </div>
            }
        </div>

        <!-- Rejected Payments Tab -->
        <div class="tab-pane fade" id="rejected" role="tabpanel">
            @{
                var rejectedPayments = Model.PendingRequests.Where(r => r.Status == TAB.Web.Models.RefundRequestStatus.Cancelled);
            }
            @if (rejectedPayments.Any())
            {
                <div class="table-responsive">
                    <table class="table minimal-table align-middle">
                        <thead>
                            <tr>
                                <th>Request ID</th>
                                <th>Staff Name</th>
                                <th>Organization</th>
                                <th>Mobile Number</th>
                                <th>Mobile Service</th>
                                <th>Class of Service</th>
                                <th>Purchase Amount</th>
                                <th>Refund Amount (USD)</th>
                                <th>Rejection Date</th>
                                <th>Status</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in rejectedPayments)
                            {
                                <tr data-request-id="@request.Id">
                                    <td>
                                        <strong style="color: #1e293b; font-size: 15px;">#@request.Id</strong>
                                    </td>
                                    <td>
                                        <div style="color: #1e293b; font-weight: 600;">@request.MobileNumberAssignedTo</div>
                                        <div style="color: #64748b; font-size: 13px;">@request.IndexNo</div>
                                    </td>
                                    <td>
                                        <div style="color: #1e293b;">@request.Organization</div>
                                        <div style="color: #64748b; font-size: 13px;">@(request.Office ?? "N/A")</div>
                                    </td>
                                    <td>
                                        <div style="color: #1e293b; font-family: monospace;">@request.PrimaryMobileNumber</div>
                                    </td>
                                    <td>
                                        <span style="color: #1e293b;">@(request.MobileService ?? "N/A")</span>
                                    </td>
                                    <td>
                                        <span style="color: #1e293b;">@(request.ClassOfService ?? "N/A")</span>
                                    </td>
                                    <td>
                                        <div style="color: #1e293b; font-weight: 600; font-size: 15px;">
                                            @request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")
                                        </div>
                                    </td>
                                    <td>
                                        <div style="color: #1e293b; font-weight: 600; font-size: 15px;">
                                            @if (request.RefundUsdAmount.HasValue)
                                            {
                                                <span>USD @request.RefundUsdAmount.Value.ToString("N2")</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">N/A</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div style="color: #1e293b;">@request.CancellationDate?.ToString("MMM dd, yyyy")</div>
                                        <div style="color: #64748b; font-size: 12px;">@request.CancellationDate?.ToString("HH:mm")</div>
                                    </td>
                                    <td>
                                        <span class="status-badge status-cancelled">
                                            <i class="bi bi-x-circle"></i>
                                            REJECTED
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="dropdown">
                                            <button class="btn btn-sm dropdown-toggle" type="button"
                                                    style="background-color: #009EDB; color: white; border: none; padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 500;"
                                                    data-bs-toggle="dropdown"
                                                    data-bs-auto-close="true"
                                                    data-bs-boundary="viewport"
                                                    aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                                Actions
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" href="/Modules/RefundManagement/Approvals/PaymentApprover?requestId=@request.Id">
                                                        <i class="bi bi-eye me-2" style="color: #009EDB;"></i>
                                                        View Details
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-x-circle"></i>
                    <h5 class="mt-3">No Rejected Payments</h5>
                    <p>Rejected payments will appear here.</p>
                </div>
            }
        </div>
    </div>
</div>
@* End of List View *@
}

