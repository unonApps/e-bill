@using Microsoft.EntityFrameworkCore
@model TAB.Web.Pages.Modules.RefundManagement.Approvals.IndexModel
@inject TAB.Web.Data.ApplicationDbContext _context
@{
    var claimsRequests = await _context.RefundRequests
        .Where(r => r.Status == TAB.Web.Models.RefundRequestStatus.PendingStaffClaimsUnit)
        .OrderByDescending(r => r.RequestDate)
        .ToListAsync();
}

<div class="content-wrapper">
    @if (claimsRequests.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Request Date</th>
                        <th>Index No</th>
                        <th>Employee Name</th>
                        <th>Organization</th>
                        <th>Purchase Amount</th>
                        <th>Cost Center</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in claimsRequests)
                    {
                        <tr>
                            <td>@request.RequestDate.ToString("dd-MMM-yyyy")</td>
                            <td>@request.IndexNo</td>
                            <td>@request.MobileNumberAssignedTo</td>
                            <td>@request.Organization</td>
                            <td>@request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")</td>
                            <td>@request.CostCenter</td>
                            <td>
                                <span class="badge bg-info">Pending Claims</span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button" class="btn btn-outline-info" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#viewClaimsModal_@request.Id">
                                        <i class="bi bi-eye"></i> View
                                    </button>
                                    <button type="button" class="btn btn-outline-primary" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#processClaimsModal_@request.Id">
                                        <i class="bi bi-gear"></i> Process
                                    </button>
                                    <button type="button" class="btn btn-outline-danger" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#rejectClaimsModal_@request.Id">
                                        <i class="bi bi-x-circle"></i> Reject
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Modals for each request -->
        @foreach (var request in claimsRequests)
        {
            <!-- View Modal -->
            <div class="modal fade" id="viewClaimsModal_@request.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <div class="modal-header bg-info text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-eye me-2"></i>View Refund Request - Claims Unit
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body compact-modal">
                            <div class="section-header">Request Information</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <label>Request Date:</label>
                                    <span>@request.RequestDate.ToString("dd-MMM-yyyy")</span>
                                </div>
                                <div class="info-item">
                                    <label>Index No:</label>
                                    <span>@request.IndexNo</span>
                                </div>
                                <div class="info-item">
                                    <label>Employee:</label>
                                    <span>@request.MobileNumberAssignedTo</span>
                                </div>
                                <div class="info-item">
                                    <label>Mobile Number:</label>
                                    <span>@request.PrimaryMobileNumber</span>
                                </div>
                                <div class="info-item">
                                    <label>Office:</label>
                                    <span>@request.Office</span>
                                </div>
                                <div class="info-item">
                                    <label>Organization:</label>
                                    <span>@request.Organization</span>
                                </div>
                            </div>

                            <div class="section-header mt-3">Financial Details</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <label>Device Allowance:</label>
                                    <span>USD @request.DeviceAllowance.ToString("N2")</span>
                                </div>
                                <div class="info-item">
                                    <label>Purchase Amount:</label>
                                    <span>@request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")</span>
                                </div>
                                <div class="info-item">
                                    <label>Bank Name:</label>
                                    <span>@request.UmojaBankName</span>
                                </div>
                                @if (request.PreviousDeviceReimbursedDate.HasValue)
                                {
                                    <div class="info-item">
                                        <label>Previous Reimbursement:</label>
                                        <span>@request.PreviousDeviceReimbursedDate.Value.ToString("dd-MMM-yyyy")</span>
                                    </div>
                                }
                            </div>

                            <div class="section-header mt-3">Cost Accounting (Budget Officer)</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <label>Cost Object:</label>
                                    <span>@(request.CostObject ?? "N/A")</span>
                                </div>
                                <div class="info-item">
                                    <label>Cost Center:</label>
                                    <span>@(request.CostCenter ?? "N/A")</span>
                                </div>
                                <div class="info-item">
                                    <label>Fund Commitment:</label>
                                    <span>@(request.FundCommitment ?? "N/A")</span>
                                </div>
                                <div class="info-item">
                                    <label>Budget Approved:</label>
                                    <span>@request.BudgetOfficerApprovalDate?.ToString("dd-MMM-yyyy")</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(request.BudgetOfficerNotes))
                            {
                                <div class="info-item full-width mt-2">
                                    <label>Budget Officer Notes:</label>
                                    <span>@request.BudgetOfficerNotes</span>
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Process Claims Modal -->
            <div class="modal fade" id="processClaimsModal_@request.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-primary text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-gear me-2"></i>Process Claims
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form method="post" asp-page-handler="ProcessClaims">
                            <div class="modal-body compact-modal">
                                <input type="hidden" name="requestId" value="@request.Id" />
                                
                                <div class="alert alert-info compact-alert">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <div>
                                        <strong>Employee:</strong> @request.MobileNumberAssignedTo<br/>
                                        <strong>Amount:</strong> @request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")<br/>
                                        <strong>Cost Center:</strong> @request.CostCenter
                                    </div>
                                </div>

                                <div class="section-header">Claims Processing Information</div>
                                
                                <div class="form-group compact-form">
                                    <label class="form-label required">Umoja Payment Document ID:</label>
                                    <input type="text" name="umojaPaymentDocumentId" class="form-control form-control-sm" required
                                           placeholder="Enter Umoja document ID"/>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label required">Refund USD Amount:</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">USD</span>
                                        <input type="number" name="refundUsdAmount" class="form-control form-control-sm" 
                                               step="0.01" min="0" required
                                               placeholder="0.00" value="@request.DevicePurchaseAmount"/>
                                    </div>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label required">Claims Action Date:</label>
                                    <input type="date" name="claimsActionDate" class="form-control form-control-sm" required
                                           value="@DateTime.Now.ToString("yyyy-MM-dd")"/>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label required">Processing Notes:</label>
                                    <textarea name="claimsNotes" class="form-control form-control-sm" rows="2" required
                                              placeholder="Enter processing notes..."></textarea>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label">Additional Remarks (Optional):</label>
                                    <input type="text" name="claimsRemarks" class="form-control form-control-sm" 
                                           placeholder="Optional remarks"/>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary btn-sm">
                                    <i class="bi bi-check-circle me-1"></i>Process & Forward
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Reject Modal -->
            <div class="modal fade" id="rejectClaimsModal_@request.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-x-circle me-2"></i>Reject - Claims Unit
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form method="post" asp-page-handler="RejectClaims">
                            <div class="modal-body compact-modal">
                                <input type="hidden" name="requestId" value="@request.Id" />
                                
                                <div class="alert alert-warning compact-alert">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    <div>
                                        <strong>Employee:</strong> @request.MobileNumberAssignedTo<br/>
                                        <strong>Amount:</strong> @request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")
                                    </div>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label required">Rejection Reason:</label>
                                    <select name="rejectionType" class="form-select form-select-sm mb-2" required>
                                        <option value="">Select reason...</option>
                                        <option value="Invalid Documentation">Invalid Documentation</option>
                                        <option value="Missing Receipt">Missing Receipt</option>
                                        <option value="Amount Discrepancy">Amount Discrepancy</option>
                                        <option value="Policy Violation">Policy Violation</option>
                                        <option value="Duplicate Claim">Duplicate Claim</option>
                                        <option value="Other">Other</option>
                                    </select>
                                    <textarea name="rejectionDetails" class="form-control form-control-sm" rows="3" required
                                              placeholder="Provide additional details..."></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="bi bi-x-circle me-1"></i>Reject Request
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-check-circle empty-icon"></i>
            <h4>No Pending Claims</h4>
            <p>There are no refund requests waiting for claims unit processing.</p>
        </div>
    }
</div>