<script>
    // Handle tab activation from URL parameter
    document.addEventListener('DOMContentLoaded', function() {
        const urlParams = new URLSearchParams(window.location.search);
        const tabParam = urlParams.get('tab');
        const requestId = urlParams.get('requestId');

        // If requestId is provided and tab parameter exists, activate the correct tab
        if (requestId && tabParam) {
            const tabMap = {
                'supervisor': 'detail-supervisor-tab',
                'budget': 'detail-budget-tab',
                'claims': 'detail-claims-tab',
                'financial': 'detail-financial-tab',
                'workflow': 'detail-workflow-tab',
                'remarks': 'detail-remarks-tab'
            };

            const tabId = tabMap[tabParam];
            if (tabId) {
                const tabElement = document.getElementById(tabId);
                if (tabElement) {
                    // Activate the tab
                    const tab = new bootstrap.Tab(tabElement);
                    tab.show();
                }
            }
        }

        // Set detail view Claims Action Date to today
        const detailClaimsActionDate = document.getElementById('detailClaimsActionDate');
        if (detailClaimsActionDate) {
            detailClaimsActionDate.value = new Date().toISOString().split('T')[0];
        }
    });

    let currentRequestData = null;

    function approveRequest(requestId) {
        // Clear all form fields
        document.getElementById('umojaPaymentDocId').value = '';
        document.getElementById('claimsActionDate').value = new Date().toISOString().split('T')[0]; // Set to today's date
        document.getElementById('purchaseCurrency').value = 'USD';
        document.getElementById('purchaseAmount').value = '';
        document.getElementById('refundUsdAmount').value = '';
        document.getElementById('claimsRemarks').value = '';
        document.getElementById('claimsRemarksCount').textContent = '0';
        document.getElementById('approveRequestId').value = requestId;
        
        // Fetch request details to pre-populate some fields
        fetch(`/ClaimsUnit/RefundRequests?handler=RequestDetails&requestId=${requestId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    // Pre-populate purchase amount if available
                    if (data.devicePurchaseAmount) {
                        document.getElementById('purchaseAmount').value = data.devicePurchaseAmount.toFixed(2);
                    }
                    if (data.devicePurchaseCurrency) {
                        document.getElementById('purchaseCurrency').value = data.devicePurchaseCurrency;
                    }
                }
            })
            .catch(error => {
                console.error('Error fetching request details:', error);
            });
        
        new bootstrap.Modal(document.getElementById('approveModal')).show();
    }

    function submitToPaymentApprover() {
        // Validate required fields
        const purchaseAmount = document.getElementById('purchaseAmount').value;
        const refundUsdAmount = document.getElementById('refundUsdAmount').value;
        
        if (!purchaseAmount || parseFloat(purchaseAmount) <= 0) {
            alert('Please enter a valid Purchase Amount.');
            document.getElementById('purchaseAmount').focus();
            return;
        }
        
        if (!refundUsdAmount || parseFloat(refundUsdAmount) <= 0) {
            alert('Please enter a valid Refund USD Amount.');
            document.getElementById('refundUsdAmount').focus();
            return;
        }
        
        if (confirm('Are you sure you want to submit this request to Payment Approver?')) {
            // Collect all form data
            const formData = {
                requestId: document.getElementById('approveRequestId').value,
                umojaPaymentDocId: document.getElementById('umojaPaymentDocId').value,
                claimsActionDate: document.getElementById('claimsActionDate').value,
                purchaseCurrency: document.getElementById('purchaseCurrency').value,
                purchaseAmount: document.getElementById('purchaseAmount').value,
                refundUsdAmount: document.getElementById('refundUsdAmount').value,
                claimsRemarks: document.getElementById('claimsRemarks').value
            };
            
            // Set hidden form values
            document.getElementById('approveRemarks').value = JSON.stringify(formData);
            document.getElementById('approveForm').submit();
        }
    }

    function revertToRequestor() {
        if (confirm('Are you sure you want to revert this request back to the Requestor? This will require them to review and resubmit.')) {
            // Collect form data for revert
            const formData = {
                requestId: document.getElementById('approveRequestId').value,
                claimsRemarks: document.getElementById('claimsRemarks').value,
                action: 'revertToRequestor'
            };
            
            // You'll need to create a new form handler for this action
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/ClaimsUnit/RefundRequests?handler=RevertToRequestor';
            
            Object.keys(formData).forEach(key => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = key;
                input.value = formData[key];
                form.appendChild(input);
            });
            
            // Add anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = token.value;
                form.appendChild(tokenInput);
            }
            
            document.body.appendChild(form);
            form.submit();
        }
    }

    function revertToBudgetOfficer() {
        const remarks = document.getElementById('claimsRemarks').value;
        
        if (confirm('Are you sure you want to revert this request back to the Budget Officer?')) {
            document.getElementById('revertRequestId').value = document.getElementById('approveRequestId').value;
            document.getElementById('revertRemarks').value = remarks;
            document.getElementById('revertForm').submit();
        }
    }

    function rejectRequest(requestId) {
        document.getElementById('rejectRequestId').value = requestId;
        new bootstrap.Modal(document.getElementById('rejectModal')).show();
    }

    function viewRequest(requestId) {
        // Fetch request details from the server
        fetch(`/ClaimsUnit/RefundRequests?handler=RequestDetails&requestId=${requestId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    populateViewDetailsModal(data);
                    new bootstrap.Modal(document.getElementById('viewDetailsModal')).show();
                } else {
                    alert('Error loading request details: ' + (data.message || 'Unknown error'));
                }
            })
            .catch(error => {
                console.error('Error fetching request details:', error);
                alert('Error loading request details');
            });
    }

    function populateViewDetailsModal(data) {
        // Populate basic information
        document.getElementById('viewRequestId').textContent = '#' + data.id;
        
        // Staff Information Section
        document.getElementById('viewStaffName').textContent = data.staffName || 'N/A';
        document.getElementById('viewMobileNumber').textContent = data.primaryMobileNumber || 'N/A';
        document.getElementById('viewIndexNo').textContent = data.indexNo || 'N/A';
        
        // Mobile Service Details Section
        document.getElementById('viewOffice').textContent = data.office || 'N/A';
        document.getElementById('viewOrganization').textContent = data.organization || 'N/A';
        document.getElementById('viewMobileService').textContent = data.mobileService || 'N/A';
        document.getElementById('viewClassOfService').textContent = data.classOfService || 'N/A';
        document.getElementById('viewDeviceAllowance').textContent = '$' + (data.deviceAllowance ? data.deviceAllowance.toFixed(2) : '0.00');
        document.getElementById('viewSupervisor').textContent = data.supervisor || 'N/A';
        
        // Financial Information Section
        document.getElementById('viewPurchaseAmount').textContent = (data.devicePurchaseCurrency || '') + ' ' + (data.devicePurchaseAmount ? data.devicePurchaseAmount.toFixed(2) : '0.00');
        document.getElementById('viewRefundAmount').textContent = '$' + (data.refundUsdAmount ? data.refundUsdAmount.toFixed(2) : '0.00');
        document.getElementById('viewRequestDate').textContent = data.requestDate || 'N/A';
        document.getElementById('viewCostObject').textContent = data.costObject || 'N/A';
        document.getElementById('viewCostCenter').textContent = data.costCenter || 'N/A';
        document.getElementById('viewFundCommitment').textContent = data.fundCommitment || 'N/A';
        
        // Claims Information Section
        updateStatusBadge(data.status);
        document.getElementById('viewBankName').textContent = data.umojaBankName || 'N/A';
        
        // Purchase Receipt Section
        populateReceiptSection(data);
        
        // Processing History & Remarks Section
        document.getElementById('viewSupervisorRemarks').textContent = data.supervisorRemarks || 'No supervisor remarks provided.';
        document.getElementById('viewBudgetRemarks').textContent = data.budgetOfficerRemarks || 'No budget officer remarks provided.';
        document.getElementById('viewClaimsRemarks').textContent = data.staffClaimsRemarks || 'No claims unit remarks provided.';
        
        // Workflow History Section
        populateWorkflowHistory(data);
    }
    
    function getStatusDisplayText(status) {
        const statusMap = {
            'Draft': 'Draft',
            'PendingSupervisor': 'Pending Supervisor',
            'PendingBudgetOfficer': 'Pending Budget Officer',
            'PendingStaffClaimsUnit': 'Pending Staff Claims Unit',
            'PendingPaymentApproval': 'Pending Payment Approval',
            'Completed': 'Completed',
            'Cancelled': 'Cancelled'
        };
        return statusMap[status] || status;
    }
    
    function updateStatusBadge(status) {
        const statusBadge = document.getElementById('viewStatus');
        const statusConfig = {
            'Draft': { text: 'Draft', color: '#94a3b8' },
            'PendingSupervisor': { text: 'Pending Supervisor', color: '#64748b' },
            'PendingBudgetOfficer': { text: 'Pending Budget Officer', color: '#64748b' },
            'PendingStaffClaimsUnit': { text: 'Pending Claims Unit', color: '#1e293b' },
            'PendingPaymentApproval': { text: 'Pending Payment', color: '#64748b' },
            'Completed': { text: 'Completed', color: '#059669' },
            'Cancelled': { text: 'Cancelled', color: '#dc2626' }
        };
        
        const config = statusConfig[status] || { text: status, color: '#64748b' };
        statusBadge.textContent = config.text;
        statusBadge.style.background = config.color;
        statusBadge.style.color = 'white';
    }

    function populateReceiptSection(data) {
        const receiptFileNameElement = document.getElementById('viewReceiptFileName');
        const viewReceiptBtn = document.getElementById('viewReceiptBtn');
        const downloadReceiptBtn = document.getElementById('downloadReceiptBtn');
        const previousReimbursementElement = document.getElementById('viewPreviousReimbursement');
        
        if (data.purchaseReceiptPath && data.purchaseReceiptFileName) {
            receiptFileNameElement.textContent = data.purchaseReceiptFileName;
            viewReceiptBtn.style.display = 'inline-block';
            downloadReceiptBtn.style.display = 'inline-block';
            
            // Store the receipt path for the download/view functions
            window.currentReceiptPath = data.purchaseReceiptPath;
        } else {
            receiptFileNameElement.textContent = 'No receipt uploaded';
            viewReceiptBtn.style.display = 'none';
            downloadReceiptBtn.style.display = 'none';
        }
        
        // Show previous reimbursement info
        const previousDate = data.previousDeviceReimbursedDate;
        if (previousDate) {
            previousReimbursementElement.textContent = `Previous device reimbursed: ${previousDate}`;
        } else {
            previousReimbursementElement.textContent = 'No previous reimbursement';
        }
    }

    function populateWorkflowHistory(data) {
        // Update workflow dates and names
        document.getElementById('workflowRequestDate').textContent = data.requestDate || '-';
        document.getElementById('workflowRequestedBy').textContent = data.requestedBy || '-';
        
        // Update each workflow step
        updateWorkflowStep('supervisor', data.supervisorApprovalDate, data.supervisorName, data.supervisorRemarks, data.status);
        updateWorkflowStep('budget', data.budgetOfficerApprovalDate, data.budgetOfficerName, data.budgetOfficerRemarks, data.status);
        updateWorkflowStep('claims', data.staffClaimsApprovalDate, data.staffClaimsOfficerName, data.staffClaimsRemarks, data.status);
        updateWorkflowStep('payment', data.paymentApprovalDate, data.paymentApproverName, null, data.status);
        updateWorkflowStep('completion', data.completionDate, null, null, data.status, data.paymentReference);
    }

    function updateWorkflowStep(step, date, officerName, remarks, status, paymentRef = null) {
        const dateElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Date`);
        const descriptionElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Description`);
        const markerElement = document.getElementById(`${step}Marker`);
        const nameElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}Name`) || 
                           document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}OfficerName`);
        const remarksElement = document.getElementById(`workflow${step.charAt(0).toUpperCase() + step.slice(1)}RemarksTimeline`);
        
        if (date && dateElement) {
            dateElement.textContent = date;
            markerElement.className = 'timeline-marker timeline-approved';
            markerElement.innerHTML = '<i class="bi bi-check"></i>';
        } else {
            if (dateElement) dateElement.textContent = '-';
            
            // Determine current step based on status
            const isCurrentStep = 
                (step === 'supervisor' && status === 'PendingSupervisor') ||
                (step === 'budget' && status === 'PendingBudgetOfficer') ||
                (step === 'claims' && status === 'PendingStaffClaimsUnit') ||
                (step === 'payment' && status === 'PendingPaymentApproval');
                
            if (isCurrentStep) {
                markerElement.className = 'timeline-marker timeline-current';
                markerElement.innerHTML = '<i class="bi bi-clock"></i>';
            } else {
                markerElement.className = 'timeline-marker timeline-pending';
                markerElement.innerHTML = '<i class="bi bi-clock"></i>';
            }
        }
        
        if (nameElement && officerName) {
            nameElement.textContent = officerName;
        } else if (nameElement) {
            nameElement.textContent = '-';
        }
        
        if (remarksElement && remarks) {
            remarksElement.style.display = 'block';
            remarksElement.querySelector('span').textContent = remarks;
        } else if (remarksElement) {
            remarksElement.style.display = 'none';
        }
        
        // Special handling for completion step
        if (step === 'completion' && paymentRef) {
            const paymentRefElement = document.getElementById('workflowPaymentReference');
            if (paymentRefElement) {
                paymentRefElement.textContent = paymentRef;
            }
        }
    }

    function viewReceipt() {
        if (window.currentReceiptPath) {
            const receiptUrl = `/uploads/receipts/${window.currentReceiptPath.split('/').pop()}`;
            window.open(receiptUrl, '_blank');
        } else {
            alert('No receipt available to view.');
        }
    }

    function downloadReceipt() {
        if (window.currentReceiptPath) {
            const fileName = window.currentReceiptPath.split('/').pop();
            const link = document.createElement('a');
            link.href = `/uploads/receipts/${fileName}`;
            link.download = fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        } else {
            alert('No receipt available to download.');
        }
    }

    // Character counter for remarks
    document.addEventListener('DOMContentLoaded', function() {
        const claimsRemarksTextarea = document.getElementById('claimsRemarks');
        const claimsRemarksCount = document.getElementById('claimsRemarksCount');
        
        if (claimsRemarksTextarea && claimsRemarksCount) {
            claimsRemarksTextarea.addEventListener('input', function() {
                claimsRemarksCount.textContent = this.value.length;
            });
        }
        
        // Auto-calculate refund amount based on purchase amount and currency
        const purchaseAmountInput = document.getElementById('purchaseAmount');
        const purchaseCurrencySelect = document.getElementById('purchaseCurrency');
        const refundUsdAmountInput = document.getElementById('refundUsdAmount');
        
        if (purchaseAmountInput && purchaseCurrencySelect && refundUsdAmountInput) {
            function updateRefundAmount() {
                const amount = parseFloat(purchaseAmountInput.value) || 0;
                const currency = purchaseCurrencySelect.value;
                
                // Simple conversion rates (in a real app, you'd fetch these from an API)
                const conversionRates = {
                    'USD': 1.0,
                    'EUR': 1.1,
                    'GBP': 1.3,
                    'KES': 0.0078
                };
                
                const usdAmount = amount * (conversionRates[currency] || 1.0);
                refundUsdAmountInput.value = usdAmount.toFixed(2);
            }
            
            purchaseAmountInput.addEventListener('input', updateRefundAmount);
            purchaseCurrencySelect.addEventListener('change', updateRefundAmount);
        }
    });

    // Detail View Functions
    function setDetailRequestId(requestId) {
        document.getElementById('detailRevertRequestorRequestId').value = requestId;
        document.getElementById('detailRevertBudgetOfficerRequestId').value = requestId;
        document.getElementById('detailRejectRequestId').value = requestId;
    }

    function submitDetailClaimsApproval() {
        const refundUsdAmount = document.getElementById('detailRefundUsdAmount').value;

        if (!refundUsdAmount || parseFloat(refundUsdAmount) <= 0) {
            alert('Please enter a valid Refund USD Amount.');
            document.getElementById('detailRefundUsdAmount').focus();
            return;
        }

        const formData = {
            umojaPaymentDocId: document.getElementById('detailUmojaPaymentDocId').value,
            claimsActionDate: document.getElementById('detailClaimsActionDate').value,
            refundUsdAmount: document.getElementById('detailRefundUsdAmount').value,
            claimsRemarks: document.getElementById('detailClaimsRemarks').value
        };

        // Create a hidden input for claimsRemarks to submit JSON data
        const claimsRemarksInput = document.createElement('input');
        claimsRemarksInput.type = 'hidden';
        claimsRemarksInput.name = 'claimsRemarks';
        claimsRemarksInput.value = JSON.stringify(formData);

        const form = document.getElementById('detailClaimsApprovalForm');
        form.appendChild(claimsRemarksInput);
        form.submit();
    }
</script>

