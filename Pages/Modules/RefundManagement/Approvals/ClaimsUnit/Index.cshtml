                        <div class="col-md-6">
                            <span class="detail-label">Approved On</span>
                            <div class="detail-value">@Model.CurrentRequest.BudgetOfficerApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">Budget Officer</span>
                            <div class="detail-value">@(Model.CurrentRequest.BudgetOfficerName ?? "N/A")</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CurrentRequest.BudgetOfficerRemarks))
                    {
                        <div class="mt-3">
                            <span class="detail-label">Remarks</span>
                            <div class="detail-value">@Model.CurrentRequest.BudgetOfficerRemarks</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <h5 class="text-muted mt-3 mb-2">Awaiting Budget Officer Review</h5>
                    <p class="text-muted" style="font-size: 0.875rem;">This stage will be completed when the budget officer approves the request.</p>
                </div>
            }
        </div>

        <!-- Claims Processing Tab -->
        <div class="tab-pane fade show active" id="detail-claims">
            <!-- Request Summary Section -->
            <div class="mb-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-info-circle me-3" style="font-size: 20px; color: #64748b;"></i>
                    <h6 class="mb-0" style="font-weight: 600; color: #475569;">Request Summary</h6>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Class of Service</span>
                            <div class="detail-value">@(Model.CurrentRequest.ClassOfService ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Mobile Service</span>
                            <div class="detail-value">@(Model.CurrentRequest.MobileService ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Handset Allowance</span>
                            <div class="detail-value" style="color: #059669; font-weight: 600;">$@Model.CurrentRequest.DeviceAllowance.ToString("N2")</div>
                        </div>
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Device Purchase Currency</span>
                            <div class="detail-value">@(Model.CurrentRequest.DevicePurchaseCurrency ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Device Purchase Amount</span>
                            <div class="detail-value" style="color: #059669; font-weight: 600;">@Model.CurrentRequest.DevicePurchaseCurrency @Model.CurrentRequest.DevicePurchaseAmount.ToString("N2")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Budget Officer Information Section -->
            <div class="mb-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-calculator me-3" style="font-size: 20px; color: #64748b;"></i>
                    <h6 class="mb-0" style="font-weight: 600; color: #475569;">Budget Officer Details</h6>
                </div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Cost Object</span>
                            <div class="detail-value">@(Model.CurrentRequest.CostObject ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Cost Center</span>
                            <div class="detail-value">@(Model.CurrentRequest.CostCenter ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-2">
                            <span class="detail-label">Fund Commitment</span>
                            <div class="detail-value">@(Model.CurrentRequest.FundCommitment ?? "N/A")</div>
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingStaffClaimsUnit)
            {
                @if (Model.CurrentUserRole == "Staff Claims Unit" || Model.CurrentUserRole == "Admin")
                {
                    <!-- Approval Form -->
                    <div class="mb-4" style="background: #f0fdf4; border-radius: 16px; padding: 24px; border: 1px solid #bbf7d0;">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-clipboard-check me-3" style="font-size: 20px; color: #059669;"></i>
                            <h6 class="mb-0" style="font-weight: 600; color: #047857;">Staff Claims Unit Processing</h6>
                        </div>
                        <form method="post" asp-page-handler="Approve" id="detailClaimsApprovalForm">
                            <input type="hidden" name="requestId" value="@Model.CurrentRequest.Id" />
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Umoja Payment Document ID</label>
                                    <input type="text" class="form-control" id="detailUmojaPaymentDocId" placeholder="Enter Umoja Payment Document ID..." />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Claims Action Date</label>
                                    <input type="date" class="form-control" id="detailClaimsActionDate" />
                                </div>
                            </div>
                            <div class="row g-3 mt-2">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Refund USD Amount <span class="text-danger">*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text">$</span>
                                        <input type="number" class="form-control" id="detailRefundUsdAmount" placeholder="0.00" step="0.01" required />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Remarks</label>
                                    <textarea class="form-control" id="detailClaimsRemarks" rows="1" maxlength="200" placeholder="Enter your remarks..."></textarea>
                                </div>
                            </div>
                            <div class="d-flex gap-2 justify-content-end mt-4">
                                <button type="button" class="btn btn-outline-warning" onclick="setDetailRequestId(@Model.CurrentRequest.Id); new bootstrap.Modal(document.getElementById('detailRevertToRequestorModal')).show();">
                                    <i class="bi bi-arrow-counterclockwise me-2"></i>Revert to Requestor
                                </button>
                                <button type="button" class="btn btn-outline-secondary" onclick="setDetailRequestId(@Model.CurrentRequest.Id); new bootstrap.Modal(document.getElementById('detailRevertToBudgetOfficerModal')).show();">
                                    <i class="bi bi-arrow-left me-2"></i>Revert to Budget Officer
                                </button>
                                <button type="button" class="btn btn-success" onclick="submitDetailClaimsApproval()">
                                    <i class="bi bi-check-circle me-2"></i>Approve & Forward to Payment
                                </button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-info-circle" style="font-size: 3rem; color: #cbd5e1;"></i>
                        <h5 class="text-muted mt-3 mb-2">Pending Staff Claims Unit Review</h5>
                        <p class="text-muted" style="font-size: 0.875rem;">You do not have permission to approve this request. Only Staff Claims Unit members can process this stage.</p>
                    </div>
                }
            }
            else if (Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingPaymentApproval || Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.Completed)
            {
                <!-- Approved Status -->
                <div class="mb-4" style="background: #f0fdf4; border-radius: 16px; padding: 24px; border: 1px solid #bbf7d0;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-check-circle me-3" style="font-size: 20px; color: #10b981;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #047857;">Processed by Claims Unit</h6>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <span class="detail-label">Processed On</span>
                            <div class="detail-value">@(Model.CurrentRequest.StaffClaimsApprovalDate?.ToString("MMM dd, yyyy HH:mm") ?? "N/A")</div>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">Claims Officer</span>
                            <div class="detail-value">@(Model.CurrentRequest.StaffClaimsOfficerName ?? "N/A")</div>
                        </div>
                    </div>
                    <div class="row g-3 mt-2">
                        <div class="col-md-6">
                            <span class="detail-label">Umoja Payment Document ID</span>
                            <div class="detail-value">@(Model.CurrentRequest.UmojaPaymentDocumentId ?? "N/A")</div>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">Refund USD Amount</span>
                            <div class="detail-value">@(Model.CurrentRequest.RefundUsdAmount.HasValue ? Model.CurrentRequest.RefundUsdAmount.Value.ToString("C") : "N/A")</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CurrentRequest.StaffClaimsRemarks))
                    {
                        <div class="mt-3">
                            <span class="detail-label">Remarks</span>
                            <div class="detail-value">@Model.CurrentRequest.StaffClaimsRemarks</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <h5 class="text-muted mt-3 mb-2">Awaiting Claims Unit Review</h5>
                    <p class="text-muted" style="font-size: 0.875rem;">This stage will be completed when the claims unit processes the request.</p>
                </div>
            }
        </div>

        <!-- Workflow History Tab -->
        <div class="tab-pane fade" id="detail-workflow">
            <div class="mb-4">
                <div class="timeline">
                    <!-- Request Submitted -->
                    <div class="timeline-item">
                        <div class="timeline-marker" style="background: #10b981;">
                            <i class="bi bi-check text-white"></i>
                        </div>
                        <div class="timeline-content">
                            <h6 class="mb-1">Request Submitted</h6>
                            <p class="mb-1 text-muted" style="font-size: 0.875rem;">@Model.CurrentRequest.RequestDate.ToString("MMM dd, yyyy HH:mm")</p>
                            <p class="mb-0" style="font-size: 0.875rem;">By @(Model.CurrentRequest.MobileNumberAssignedTo ?? "Unknown")</p>
                        </div>
                    </div>

                    <!-- Supervisor Review -->
                    <div class="timeline-item">
                        <div class="timeline-marker" style="background: @(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? "#10b981" : "#cbd5e1");">
                            <i class="bi bi-@(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? "check" : "clock") text-white"></i>
                        </div>
                        <div class="timeline-content">
                            <h6 class="mb-1">Supervisor Review</h6>
                            @if (Model.CurrentRequest.SupervisorApprovalDate.HasValue)
                            {
                                <p class="mb-1 text-muted" style="font-size: 0.875rem;">@Model.CurrentRequest.SupervisorApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</p>
                                <p class="mb-0" style="font-size: 0.875rem;">Approved by @(Model.CurrentRequest.SupervisorName ?? "Unknown")</p>
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.SupervisorRemarks))
                                {
                                    <div class="mt-2 p-2" style="background: #f3f4f6; border-radius: 8px; font-size: 12px; color: #6b7280;">
                                        <strong>Remarks:</strong> @Model.CurrentRequest.SupervisorRemarks
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="mb-0 text-muted" style="font-size: 0.875rem;">Pending</p>
                            }
                        </div>
                    </div>

                    <!-- Budget Officer Review -->
                    <div class="timeline-item">
                        <div class="timeline-marker" style="background: @(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? "#10b981" : "#cbd5e1");">
                            <i class="bi bi-@(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? "check" : "clock") text-white"></i>
                        </div>
                        <div class="timeline-content">
                            <h6 class="mb-1">Budget Officer Review</h6>
                            @if (Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue)
                            {
                                <p class="mb-1 text-muted" style="font-size: 0.875rem;">@Model.CurrentRequest.BudgetOfficerApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</p>
                                <p class="mb-0" style="font-size: 0.875rem;">Approved by @(Model.CurrentRequest.BudgetOfficerName ?? "Unknown")</p>
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.BudgetOfficerRemarks))
                                {
                                    <div class="mt-2 p-2" style="background: #f3f4f6; border-radius: 8px; font-size: 12px; color: #6b7280;">
                                        <strong>Remarks:</strong> @Model.CurrentRequest.BudgetOfficerRemarks
                                    </div>
                                }
                            }
                            else
                            {
                                <p class="mb-0 text-muted" style="font-size: 0.875rem;">Pending</p>
                            }
                        </div>
                    </div>

                    <!-- Claims Unit Processing -->
                    <div class="timeline-item">
                        <div class="timeline-marker" style="background: @(Model.CurrentRequest.StaffClaimsApprovalDate.HasValue ? "#10b981" : (Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingStaffClaimsUnit ? "#3b82f6" : "#cbd5e1"));">
                            <i class="bi bi-@(Model.CurrentRequest.StaffClaimsApprovalDate.HasValue ? "check" : "clock") text-white"></i>
                        </div>
                        <div class="timeline-content">
                            <h6 class="mb-1">Claims Unit Processing</h6>
                            @if (Model.CurrentRequest.StaffClaimsApprovalDate.HasValue)
                            {
                                <p class="mb-1 text-muted" style="font-size: 0.875rem;">@Model.CurrentRequest.StaffClaimsApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</p>
                                <p class="mb-0" style="font-size: 0.875rem;">Processed by @(Model.CurrentRequest.StaffClaimsOfficerName ?? "Unknown")</p>
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.StaffClaimsRemarks))
                                {
                                    <div class="mt-2 p-2" style="background: #f3f4f6; border-radius: 8px; font-size: 12px; color: #6b7280;">
                                        <strong>Remarks:</strong> @Model.CurrentRequest.StaffClaimsRemarks
                                    </div>
                                }
                            }
                            else if (Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingStaffClaimsUnit)
                            {
                                <p class="mb-0 text-primary" style="font-size: 0.875rem; font-weight: 600;">In Progress</p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted" style="font-size: 0.875rem;">Pending</p>
                            }
                        </div>
                    </div>

                    <!-- Payment Approval -->
                    <div class="timeline-item">
                        <div class="timeline-marker" style="background: @(Model.CurrentRequest.PaymentApprovalDate.HasValue ? "#10b981" : "#cbd5e1");">
                            <i class="bi bi-@(Model.CurrentRequest.PaymentApprovalDate.HasValue ? "check" : "clock") text-white"></i>
                        </div>
                        <div class="timeline-content">
                            <h6 class="mb-1">Payment Approval</h6>
                            @if (Model.CurrentRequest.PaymentApprovalDate.HasValue)
                            {
                                <p class="mb-1 text-muted" style="font-size: 0.875rem;">@Model.CurrentRequest.PaymentApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</p>
                                <p class="mb-0" style="font-size: 0.875rem;">Approved by @(Model.CurrentRequest.PaymentApproverName ?? "Unknown")</p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted" style="font-size: 0.875rem;">Pending</p>
                            }
                        </div>
                    </div>

                    <!-- Request Completion -->
                    <div class="timeline-item">
                        <div class="timeline-marker" style="background: @(Model.CurrentRequest.CompletionDate.HasValue ? "#10b981" : "#cbd5e1");">
                            <i class="bi bi-@(Model.CurrentRequest.CompletionDate.HasValue ? "check-circle-fill" : "clock") text-white"></i>
                        </div>
                        <div class="timeline-content">
                            <h6 class="mb-1">Request Completion</h6>
                            @if (Model.CurrentRequest.CompletionDate.HasValue)
                            {
                                <p class="mb-1 text-muted" style="font-size: 0.875rem;">@Model.CurrentRequest.CompletionDate.Value.ToString("MMM dd, yyyy HH:mm")</p>
                                <p class="mb-0" style="font-size: 0.875rem;">Payment processed successfully</p>
                            }
                            else
                            {
                                <p class="mb-0 text-muted" style="font-size: 0.875rem;">Pending</p>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @if (Model.RequestHistory.Any())
            {
                <!-- Detailed Action History -->
                <div class="mt-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-clock-history me-3" style="font-size: 20px; color: #64748b;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #475569;">Detailed Action History</h6>
                    </div>
                    <div class="timeline">
                        @foreach (var historyItem in Model.RequestHistory)
                        {
                            var isRevert = historyItem.Action.Contains("Reverted");
                            var isReject = historyItem.Action.Contains("Rejected");
                            var markerColor = isReject ? "#ef4444" : (isRevert ? "#f59e0b" : "#10b981");
                            var iconClass = isReject ? "x-circle" : (isRevert ? "arrow-counterclockwise" : "check-circle");

                            <div class="timeline-item">
                                <div class="timeline-marker" style="background: @markerColor;">
                                    <i class="bi bi-@iconClass text-white"></i>
                                </div>
                                <div class="timeline-content">
                                    <h6 class="mb-1" style="color: @(isReject ? "#dc2626" : (isRevert ? "#d97706" : "#111827"));">@historyItem.Action</h6>
                                    <p class="mb-1 text-muted" style="font-size: 0.875rem;">@historyItem.Timestamp.ToString("MMM dd, yyyy HH:mm")</p>
                                    <p class="mb-0" style="font-size: 0.875rem;">By @historyItem.UserName</p>
                                    @if (!string.IsNullOrEmpty(historyItem.Comments))
                                    {
                                        <div class="mt-2 p-2" style="background: @(isReject ? "#fef2f2" : (isRevert ? "#fffbeb" : "#f3f4f6")); border-radius: 8px; font-size: 12px; color: #6b7280;">
                                            <strong>Comments:</strong> @historyItem.Comments
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(historyItem.PreviousStatus) && !string.IsNullOrEmpty(historyItem.NewStatus))
                                    {
                                        <p class="mb-0 mt-1" style="font-size: 0.75rem; color: #9ca3af;">
                                            Status: @historyItem.PreviousStatus <i class="bi bi-arrow-right"></i> @historyItem.NewStatus
                                        </p>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

    </div>
</div>
}
@* End of Detail View *@

<!-- View Details Modal -->
<div class="modal fade" id="viewDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: 20px; box-shadow: 0 25px 50px rgba(0,0,0,0.08);">
            <div class="modal-header" style="border: none; padding: 32px 32px 0 32px;">
                <div class="d-flex align-items-center">
                    <div class="me-3" style="width: 52px; height: 52px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 16px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-eye text-white" style="font-size: 22px;"></i>
                    </div>
                    <div>
                        <h4 class="mb-1" style="font-weight: 600; color: #2d3748; font-size: 24px; letter-spacing: -0.5px;">Request Details <span id="viewRequestId" class="text-muted" style="font-size: 18px; font-weight: 400;">#0</span></h4>
                        <p class="mb-0" style="font-size: 14px; color: #718096;">Comprehensive request information and workflow tracking</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" style="font-size: 14px; padding: 8px;"></button>
            </div>
            
            <div class="modal-body" style="padding: 0 32px; max-height: 75vh; overflow-y: auto;">
                <!-- Staff Information Section -->
                <div class="mb-4" style="background: linear-gradient(135deg, #f7fafc, #edf2f7); border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -10px; right: -10px; width: 80px; height: 80px; background: linear-gradient(135deg, #667eea, #764ba2); opacity: 0.1; border-radius: 50%;"></div>
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-person-circle me-3" style="font-size: 18px; color: #667eea;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #2d3748; font-size: 15px;">Staff Information</h6>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="detail-label" style="color: #4a5568;">Staff Name</div>
                            <div id="viewStaffName" class="detail-value" style="color: #2d3748; font-weight: 500;">-</div>
                        </div>
                        <div class="col-md-4">
                            <div class="detail-label" style="color: #4a5568;">Mobile Number</div>
                            <div id="viewMobileNumber" class="detail-value" style="color: #2d3748; font-weight: 500;">-</div>
                        </div>
                        <div class="col-md-4">
                            <div class="detail-label" style="color: #4a5568;">Index Number</div>
                            <div id="viewIndexNo" class="detail-value" style="color: #2d3748; font-weight: 500;">-</div>
                        </div>
                    </div>
                </div>

                <!-- Mobile Service Details Section -->
                <div class="mb-4" style="background: linear-gradient(135deg, #f0fff4, #f7fafc); border-radius: 16px; padding: 24px; border: 1px solid #c6f6d5; position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -10px; right: -10px; width: 80px; height: 80px; background: linear-gradient(135deg, #48bb78, #38a169); opacity: 0.1; border-radius: 50%;"></div>
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-phone me-3" style="font-size: 18px; color: #48bb78;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #2d3748; font-size: 15px;">Mobile Service Details</h6>
                    </div>
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="detail-label" style="color: #4a5568;">Office</div>
                            <div id="viewOffice" class="detail-value" style="color: #2d3748; font-weight: 500;">-</div>
                        </div>
                        <div class="col-md-4">
                            <div class="detail-label" style="color: #4a5568;">Organization</div>
                            <div id="viewOrganization" class="detail-value" style="color: #2d3748; font-weight: 500;">-</div>
                        </div>
                        <div class="col-md-4">
                            <div class="detail-label" style="color: #4a5568;">Mobile Service</div>
                            <div id="viewMobileService" class="detail-value" style="color: #2d3748; font-weight: 500;">-</div>
