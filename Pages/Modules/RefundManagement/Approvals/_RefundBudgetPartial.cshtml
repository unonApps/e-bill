@using Microsoft.EntityFrameworkCore
@model TAB.Web.Pages.Modules.RefundManagement.Approvals.IndexModel
@inject TAB.Web.Data.ApplicationDbContext _context
@{
    var budgetRequests = await _context.RefundRequests
        .Where(r => r.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer)
        .OrderByDescending(r => r.RequestDate)
        .ToListAsync();
}

<div class="content-wrapper">
    @if (budgetRequests.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Request Date</th>
                        <th>Index No</th>
                        <th>Staff Name</th>
                        <th>Organization</th>
                        <th>Device Amount</th>
                        <th>Supervisor</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in budgetRequests)
                    {
                        <tr>
                            <td>@request.RequestDate.ToString("dd-MMM-yyyy")</td>
                            <td>@request.IndexNo</td>
                            <td>@request.MobileNumberAssignedTo</td>
                            <td>@request.Organization</td>
                            <td>@request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")</td>
                            <td>@request.SupervisorName</td>
                            <td>
                                <span class="badge bg-warning text-dark">Pending Budget</span>
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <button type="button" class="btn btn-outline-info" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#viewBudgetModal_@request.Id">
                                        <i class="bi bi-eye"></i> View
                                    </button>
                                    <button type="button" class="btn btn-outline-success" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#approveBudgetModal_@request.Id">
                                        <i class="bi bi-check-circle"></i> Approve
                                    </button>
                                    <button type="button" class="btn btn-outline-danger" 
                                            data-bs-toggle="modal" 
                                            data-bs-target="#rejectBudgetModal_@request.Id">
                                        <i class="bi bi-x-circle"></i> Reject
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Modals for each request -->
        @foreach (var request in budgetRequests)
        {
            <!-- View Modal -->
            <div class="modal fade" id="viewBudgetModal_@request.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content">
                        <div class="modal-header bg-info text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-eye me-2"></i>View Refund Request - Budget Review
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body compact-modal">
                            <div class="section-header">Staff Information</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <label>Request Date:</label>
                                    <span>@request.RequestDate.ToString("dd-MMM-yyyy")</span>
                                </div>
                                <div class="info-item">
                                    <label>Index No:</label>
                                    <span>@request.IndexNo</span>
                                </div>
                                <div class="info-item">
                                    <label>Employee:</label>
                                    <span>@request.MobileNumberAssignedTo</span>
                                </div>
                                <div class="info-item">
                                    <label>Mobile Number:</label>
                                    <span>@request.PrimaryMobileNumber</span>
                                </div>
                                <div class="info-item">
                                    <label>Office:</label>
                                    <span>@request.Office</span>
                                </div>
                                <div class="info-item">
                                    <label>Organization:</label>
                                    <span>@request.Organization</span>
                                </div>
                            </div>

                            <div class="section-header mt-3">Financial Information</div>
                            <div class="info-grid">
                                <div class="info-item">
                                    <label>Class of Service:</label>
                                    <span>@request.ClassOfService</span>
                                </div>
                                <div class="info-item">
                                    <label>Device Allowance:</label>
                                    <span>USD @request.DeviceAllowance.ToString("N2")</span>
                                </div>
                                <div class="info-item">
                                    <label>Purchase Amount:</label>
                                    <span>@request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")</span>
                                </div>
                                <div class="info-item">
                                    <label>Bank Name:</label>
                                    <span>@request.UmojaBankName</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(request.SupervisorNotes) || !string.IsNullOrEmpty(request.SupervisorRemarks))
                            {
                                <div class="section-header mt-3">Supervisor Approval Details</div>
                                <div class="info-grid">
                                    @if (!string.IsNullOrEmpty(request.SupervisorNotes))
                                    {
                                        <div class="info-item full-width">
                                            <label>Supervisor Notes:</label>
                                            <span>@request.SupervisorNotes</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(request.SupervisorRemarks))
                                    {
                                        <div class="info-item full-width">
                                            <label>Supervisor Remarks:</label>
                                            <span>@request.SupervisorRemarks</span>
                                        </div>
                                    }
                                    <div class="info-item">
                                        <label>Approved By:</label>
                                        <span>@request.SupervisorName</span>
                                    </div>
                                    <div class="info-item">
                                        <label>Approval Date:</label>
                                        <span>@request.SupervisorApprovalDate?.ToString("dd-MMM-yyyy")</span>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Approve Modal -->
            <div class="modal fade" id="approveBudgetModal_@request.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-success text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-check-circle me-2"></i>Budget Officer Approval
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form method="post" asp-page-handler="ApproveBudget">
                            <div class="modal-body compact-modal">
                                <input type="hidden" name="requestId" value="@request.PublicId" />
                                
                                <div class="alert alert-info compact-alert">
                                    <i class="bi bi-info-circle me-2"></i>
                                    <div>
                                        <strong>Employee:</strong> @request.MobileNumberAssignedTo<br/>
                                        <strong>Amount:</strong> @request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")<br/>
                                        <strong>Allowance:</strong> USD @request.DeviceAllowance.ToString("N2")
                                    </div>
                                </div>

                                <div class="section-header">Cost Accounting Information</div>
                                
                                <div class="form-group compact-form">
                                    <label class="form-label required">Cost Object:</label>
                                    <input type="text" name="costObject" class="form-control form-control-sm" required
                                           placeholder="Enter cost object code"/>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label required">Cost Center:</label>
                                    <input type="text" name="costCenter" class="form-control form-control-sm" required
                                           placeholder="Enter cost center"/>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label required">Fund Commitment:</label>
                                    <input type="text" name="fundCommitment" class="form-control form-control-sm" required
                                           placeholder="Enter fund commitment number"/>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label required">Budget Officer Notes:</label>
                                    <textarea name="budgetNotes" class="form-control form-control-sm" rows="2" required
                                              placeholder="Enter budget approval notes..."></textarea>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label">Additional Remarks (Optional):</label>
                                    <input type="text" name="budgetRemarks" class="form-control form-control-sm" 
                                           placeholder="Optional remarks"/>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-success btn-sm">
                                    <i class="bi bi-check-circle me-1"></i>Approve with Budget
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Reject Modal -->
            <div class="modal fade" id="rejectBudgetModal_@request.Id" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-danger text-white">
                            <h5 class="modal-title">
                                <i class="bi bi-x-circle me-2"></i>Reject - Budget Review
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form method="post" asp-page-handler="RejectBudget">
                            <div class="modal-body compact-modal">
                                <input type="hidden" name="requestId" value="@request.PublicId" />
                                
                                <div class="alert alert-warning compact-alert">
                                    <i class="bi bi-exclamation-triangle me-2"></i>
                                    <div>
                                        <strong>Employee:</strong> @request.MobileNumberAssignedTo<br/>
                                        <strong>Amount:</strong> @request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")
                                    </div>
                                </div>

                                <div class="form-group compact-form">
                                    <label class="form-label required">Rejection Reason:</label>
                                    <select name="rejectionType" class="form-select form-select-sm mb-2" required>
                                        <option value="">Select reason...</option>
                                        <option value="Insufficient Budget">Insufficient Budget</option>
                                        <option value="Invalid Cost Center">Invalid Cost Center</option>
                                        <option value="Documentation Issues">Documentation Issues</option>
                                        <option value="Policy Violation">Policy Violation</option>
                                        <option value="Other">Other</option>
                                    </select>
                                    <textarea name="rejectionDetails" class="form-control form-control-sm" rows="3" required
                                              placeholder="Provide additional details..."></textarea>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="bi bi-x-circle me-1"></i>Reject Request
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-calculator empty-icon"></i>
            <h4>No Pending Budget Reviews</h4>
            <p>There are no refund requests waiting for budget officer approval.</p>
        </div>
    }
</div>

<style>
    .section-header {
        font-size: 0.875rem;
        font-weight: 600;
        color: #495057;
        border-bottom: 1px solid #dee2e6;
        padding-bottom: 0.25rem;
        margin-bottom: 0.75rem;
    }
</style>