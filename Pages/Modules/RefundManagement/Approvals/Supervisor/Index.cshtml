                    else
                    {
                        <div class="alert alert-info" style="border-radius: 12px;">
                            <i class="bi bi-info-circle me-2"></i>
                            This request is awaiting supervisor approval. Only supervisors can approve or reject this request.
                        </div>
                    }
                </div>
            }
            else if (Model.CurrentRequest.SupervisorApprovalDate.HasValue)
            {
                <!-- Approved Status -->
                <div class="mb-4" style="background: #f0fdf4; border-radius: 16px; padding: 24px; border: 1px solid #bbf7d0;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-check-circle me-3" style="font-size: 20px; color: #10b981;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #047857;">Approved by Supervisor</h6>
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <span class="detail-label">Approved On</span>
                            <div class="detail-value">@Model.CurrentRequest.SupervisorApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                        <div class="col-md-6">
                            <span class="detail-label">Supervisor</span>
                            <div class="detail-value">@(Model.CurrentRequest.SupervisorName ?? "N/A")</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.CurrentRequest.SupervisorRemarks))
                    {
                        <div class="mt-3">
                            <span class="detail-label">Remarks</span>
                            <div class="detail-value">@Model.CurrentRequest.SupervisorRemarks</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-clock-history" style="font-size: 3rem; color: #cbd5e1;"></i>
                    <h5 class="text-muted mt-3 mb-2">Awaiting Supervisor Review</h5>
                    <p class="text-muted" style="font-size: 0.875rem;">This stage will be completed when the supervisor approves the request.</p>
                </div>
            }
        </div>

        <!-- Budget Officer Tab -->
        <div class="tab-pane fade" id="detail-budget">
            <div class="text-center py-5">
                <div class="mb-3">
                    @if (Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer)
                    {
                        <i class="bi bi-hourglass-split" style="font-size: 3rem; color: #cbd5e1;"></i>
                    }
                    else if (Model.CurrentRequest.Status > TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer)
                    {
                        <i class="bi bi-check-circle" style="font-size: 3rem; color: #10b981;"></i>
                    }
                    else
                    {
                        <i class="bi bi-clock" style="font-size: 3rem; color: #cbd5e1;"></i>
                    }
                </div>
                <h5 class="text-muted mb-2">
                    @if (Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer)
                    {
                        <text>Pending Budget Officer Approval</text>
                    }
                    else if (Model.CurrentRequest.Status > TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer)
                    {
                        <text>Budget Officer Approved</text>
                    }
                    else
                    {
                        <text>Awaiting Supervisor Approval</text>
                    }
                </h5>
                <p class="text-muted" style="font-size: 0.875rem;">
                    @if (Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue)
                    {
                        <text>Approved on @Model.CurrentRequest.BudgetOfficerApprovalDate.Value.ToString("MMM dd, yyyy HH:mm")</text>
                    }
                    else if (Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer)
                    {
                        <text>The budget officer has not yet reviewed and approved this request.</text>
                    }
                    else
                    {
                        <text>Waiting for supervisor approval before budget review.</text>
                    }
                </p>
            </div>
        </div>

        <!-- Claims Processing Tab -->
        <div class="tab-pane fade" id="detail-claims">
            <div class="text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-hourglass-split" style="font-size: 3rem; color: #cbd5e1;"></i>
                </div>
                <h5 class="text-muted mb-2">Pending Claims Processing</h5>
                <p class="text-muted" style="font-size: 0.875rem;">
                    The claims unit has not yet processed this request.
                </p>
            </div>
        </div>

        <!-- Workflow History Tab -->
        <div class="tab-pane fade" id="detail-workflow">
            <!-- Workflow History Section -->
            <div class="mb-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-diagram-3 me-3" style="font-size: 20px; color: #64748b;"></i>
                    <h6 class="mb-0" style="font-weight: 600; color: #475569;">Workflow History</h6>
                </div>

                <!-- Timeline Container -->
                <div class="workflow-timeline">
                    <!-- Request Submission -->
                    <div class="timeline-item">
                        <div class="timeline-marker timeline-submitted">
                            <i class="bi bi-file-plus"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <h6 class="timeline-title">Request Submitted</h6>
                                <span class="timeline-date">@Model.CurrentRequest.RequestDate.ToString("MMM dd, yyyy HH:mm")</span>
                            </div>
                            <p class="timeline-description">Refund request created and submitted for approval</p>
                            <div class="timeline-details">
                                <small class="text-muted">Submitted by: <span>@Model.CurrentRequest.MobileNumberAssignedTo</span></small>
                            </div>
                        </div>
                    </div>

                    <!-- Supervisor Approval -->
                    <div class="timeline-item">
                        <div class="timeline-marker @(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? "timeline-submitted" : Model.CurrentRequest.Status >= TAB.Web.Models.RefundRequestStatus.PendingSupervisor ? "timeline-current" : "timeline-pending")">
                            <i class="bi @(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? "bi-check-circle" : "bi-clock")"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <h6 class="timeline-title">Supervisor Review</h6>
                                <span class="timeline-date">@(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? Model.CurrentRequest.SupervisorApprovalDate.Value.ToString("MMM dd, yyyy HH:mm") : "Pending")</span>
                            </div>
                            <p class="timeline-description">@(Model.CurrentRequest.SupervisorApprovalDate.HasValue ? "Approved by supervisor" : "Awaiting supervisor approval")</p>
                            <div class="timeline-details">
                                <small class="text-muted">Supervisor: <span>@(Model.CurrentRequest.SupervisorEmail ?? "N/A")</span></small>
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.SupervisorRemarks))
                                {
                                    <div class="timeline-remarks mt-1">
                                        <small class="text-muted"><strong>Remarks:</strong> <span>@Model.CurrentRequest.SupervisorRemarks</span></small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Budget Officer Approval -->
                    <div class="timeline-item">
                        <div class="timeline-marker @(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? "timeline-submitted" : Model.CurrentRequest.Status >= TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer ? "timeline-current" : "timeline-pending")">
                            <i class="bi @(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? "bi-calculator" : "bi-clock")"></i>
                        </div>
                        <div class="timeline-content">
                            <div class="timeline-header">
                                <h6 class="timeline-title">Budget Officer Review</h6>
                                <span class="timeline-date">@(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? Model.CurrentRequest.BudgetOfficerApprovalDate.Value.ToString("MMM dd, yyyy HH:mm") : Model.CurrentRequest.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer ? "Current Stage" : "Pending")</span>
                            </div>
                            <p class="timeline-description">@(Model.CurrentRequest.BudgetOfficerApprovalDate.HasValue ? "Approved by budget officer" : "Pending budget officer approval")</p>
                            <div class="timeline-details">
                                <small class="text-muted">Budget Officer: <span>@(Model.CurrentRequest.BudgetOfficerEmail ?? "Not assigned")</span></small>
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.BudgetOfficerRemarks))
                                {
                                    <div class="timeline-remarks mt-1">
                                        <small class="text-muted"><strong>Remarks:</strong> <span>@Model.CurrentRequest.BudgetOfficerRemarks</span></small>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Additional stages can be added here as needed -->
                </div>
            </div>

            @if (Model.RequestHistory.Any())
            {
                <!-- Detailed Action History -->
                <div class="mt-4" style="background: #f8fafc; border-radius: 16px; padding: 24px; border: 1px solid #e2e8f0;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-clock-history me-3" style="font-size: 20px; color: #64748b;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #475569;">Detailed Action History</h6>
                    </div>
                    <div class="workflow-timeline">
                        @foreach (var historyItem in Model.RequestHistory)
                        {
                            var isRevert = historyItem.Action.Contains("Reverted");
                            var isReject = historyItem.Action.Contains("Rejected");
                            var markerClass = isReject ? "timeline-rejected" : (isRevert ? "timeline-reverted" : "timeline-submitted");
                            var iconClass = isReject ? "bi-x-circle" : (isRevert ? "bi-arrow-counterclockwise" : "bi-check-circle");

                            <div class="timeline-item">
                                <div class="timeline-marker @markerClass">
                                    <i class="bi @iconClass"></i>
                                </div>
                                <div class="timeline-content">
                                    <div class="timeline-header">
                                        <h6 class="timeline-title" style="color: @(isReject ? "#dc2626" : (isRevert ? "#d97706" : "#111827"));">@historyItem.Action</h6>
                                        <span class="timeline-date">@historyItem.Timestamp.ToString("MMM dd, yyyy HH:mm")</span>
                                    </div>
                                    <p class="timeline-description">By @historyItem.UserName</p>
                                    @if (!string.IsNullOrEmpty(historyItem.Comments))
                                    {
                                        <div class="timeline-remarks mt-1" style="background: @(isReject ? "#fef2f2" : (isRevert ? "#fffbeb" : "#f3f4f6")); padding: 8px 12px; border-radius: 8px;">
                                            <small class="text-muted"><strong>Comments:</strong> @historyItem.Comments</small>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(historyItem.PreviousStatus) && !string.IsNullOrEmpty(historyItem.NewStatus))
                                    {
                                        <div class="timeline-details mt-1">
                                            <small class="text-muted">Status: @historyItem.PreviousStatus <i class="bi bi-arrow-right"></i> @historyItem.NewStatus</small>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

    </div>

    }
    @* End of Detail View *@

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.1);">
            <div class="modal-header" style="border: none; padding: 32px 32px 0 32px;">
                <div class="d-flex align-items-center">
                    <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #10b981, #059669); border-radius: 16px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-check-circle text-white" style="font-size: 24px;"></i>
                    </div>
                    <div>
                        <h4 class="mb-1" style="font-weight: 700; color: #111827; font-size: 24px;">Review Request</h4>
                        <p class="mb-0 text-muted" style="font-size: 14px;">Review details and take action on this refund request</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" style="margin: 0; padding: 12px;"></button>
            </div>
            <div class="modal-body" style="padding: 24px 32px;">
                <!-- Request Details Section -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="detail-group mb-3">
                            <label class="detail-label">Class of Service *</label>
                            <div class="detail-value" id="modalClassOfService">-</div>
                        </div>
                        <div class="detail-group mb-3">
                            <label class="detail-label">Mobile Service *</label>
                            <div class="detail-value" id="modalMobileService">-</div>
                        </div>
                        <div class="detail-group mb-3">
                            <label class="detail-label">Handset Allowance</label>
                            <div class="detail-value" id="modalDeviceAllowance">-</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-group mb-3">
                            <label class="detail-label">Supervisor Name & Email *</label>
                            <div class="detail-value" id="modalSupervisorInfo">-</div>
                        </div>
                        <div class="detail-group mb-3">
                            <label class="detail-label">Supervisor Action Date</label>
                            <div class="detail-value" id="modalActionDate">@DateTime.Now.ToString("MMM dd, yyyy HH:mm")</div>
                        </div>
                    </div>
                </div>

                <!-- Form Section -->
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                @if (Model.CurrentUserRole.Contains("Budget"))
                                {
                                    <text>Budget Officer Remarks</text>
                                }
                                else
                                {
                                    <text>Supervisor Remarks</text>
                                }
                                <span class="text-muted">(max 200 characters)</span>
                            </label>
                            <textarea id="supervisorRemarks" class="form-control" rows="3" maxlength="200" placeholder="Enter your remarks..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px; resize: none;"></textarea>
                            <div class="text-end text-muted small mt-1">
                                <span id="remarksCount">0</span>/200 characters
                            </div>
                        </div>
                    </div>
                    @if (Model.HasSupervisorAccess)
                    {
                        <div class="col-md-6">
                            <div class="mb-3">
                                <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                    Budget Officer *
                                </label>
                                <select id="budgetOfficerSelect" class="form-select" style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px;">
                                    <option value="">Select Budget Officer...</option>
                                    @if (Model.BudgetOfficers != null && Model.BudgetOfficers.Any())
                                    {
                                        @foreach (var officer in Model.BudgetOfficers)
                                        {
                                            <option value="@officer.Email">@officer.FirstName @officer.LastName (@officer.Email)</option>
                                        }
                                    }
                                    else
                                    {
                                        <option value="" disabled>@(Model.BudgetOfficers == null ? "Budget Officers not loaded" : "No Budget Officers found")</option>
                                    }
                                </select>
                                @if (Model.BudgetOfficers == null || !Model.BudgetOfficers.Any())
                                {
                                    <div class="text-danger small mt-1">
                                        <i class="bi bi-exclamation-triangle"></i>
                                        @(Model.BudgetOfficers == null ? "Budget Officers not loaded. Please refresh the page." : "No Budget Officers found in the system. Please contact your administrator.")
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Action Buttons -->
                <div class="d-flex gap-3 justify-content-end pt-3" style="border-top: 1px solid #e5e7eb;">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-outline-warning" onclick="revertToRequestor()" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                        <i class="bi bi-arrow-left me-2"></i>Revert to Requestor
                    </button>
                    <button type="button" class="btn btn-success" onclick="approveAndSubmit()" style="background: linear-gradient(135deg, #10b981, #059669); border: none; border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                        <i class="bi bi-check-circle me-2"></i>Approve & Submit to Budget Officer
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Budget Officer Approve Modal -->
<div class="modal fade" id="budgetOfficerApproveModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.1);">
            <div class="modal-header" style="border: none; padding: 32px 32px 0 32px;">
                <div class="d-flex align-items-center">
                    <div class="me-3" style="width: 48px; height: 48px; background: linear-gradient(135deg, #3b82f6, #1d4ed8); border-radius: 16px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-calculator text-white" style="font-size: 24px;"></i>
                    </div>
                    <div>
                        <h4 class="mb-1" style="font-weight: 700; color: #111827; font-size: 24px;">Budget Officer Review</h4>
                        <p class="mb-0 text-muted" style="font-size: 14px;">Complete cost accounting details and approve request</p>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" style="margin: 0; padding: 12px;"></button>
            </div>
            <div class="modal-body" style="padding: 24px 32px;">
                <!-- Cost Accounting Section -->
                <div class="section-title mb-3" style="font-weight: 600; color: #374151; font-size: 16px; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;">
                    <i class="bi bi-receipt me-2"></i>Cost Accounting Details
                </div>
                
                <div class="row mb-4">
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                Cost Object <span style="color: #ef4444;">*</span>
                            </label>
                            <input type="text" id="costObject" class="form-control" required placeholder="Enter cost object..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px;" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                Cost Center <span style="color: #ef4444;">*</span>
                            </label>
                            <input type="text" id="costCenter" class="form-control" required placeholder="Enter cost center..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px;" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                Fund Commitment <span style="color: #ef4444;">*</span>
                            </label>
                            <input type="text" id="fundCommitment" class="form-control" required placeholder="Enter fund commitment..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px;" />
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                Budget Officer Action Date
                            </label>
                            <input type="text" id="budgetActionDate" class="form-control" readonly value="@DateTime.Now.ToString("MMM dd, yyyy HH:mm")" style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px; background-color: #f9fafb;" />
                        </div>
                    </div>
                </div>

                <!-- Remarks Section -->
                <div class="row mb-4">
                    <div class="col-12">
                        <div class="mb-3">
                            <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                Budget Officer Remarks <span class="text-muted">(max 200 characters)</span>
                            </label>
                            <textarea id="budgetOfficerRemarks" class="form-control" rows="3" maxlength="200" placeholder="Enter your remarks..." style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px; resize: none;"></textarea>
                            <div class="text-end text-muted small mt-1">
                                <span id="budgetRemarksCount">0</span>/200 characters
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex gap-3 justify-content-end pt-3" style="border-top: 1px solid #e5e7eb;">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                        Cancel
                    </button>
                    <button type="button" class="btn btn-outline-warning" onclick="budgetRevertToRequestor()" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                        <i class="bi bi-arrow-left me-2"></i>Revert to Requestor
                    </button>
                    <button type="button" class="btn btn-outline-secondary" onclick="budgetRevertToSupervisor()" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                        <i class="bi bi-arrow-counterclockwise me-2"></i>Revert to Supervisor
                    </button>
                    <button type="button" class="btn btn-success" onclick="budgetApproveAndSubmit()" style="background: linear-gradient(135deg, #10b981, #059669); border: none; border-radius: 12px; padding: 12px 24px; font-weight: 500;">
                        <i class="bi bi-check-circle me-2"></i>Approve & Submit to Staff Claims Unit
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Hidden Forms for Actions -->
<form id="approveForm" method="post" asp-page-handler="Approve" style="display: none;">
    <input type="hidden" id="approveRequestId" name="requestId" />
    <input type="hidden" id="approveRemarks" name="supervisorRemarks" />
    <input type="hidden" id="approveBudgetOfficer" name="budgetOfficerEmail" />
</form>

<form id="budgetApproveForm" method="post" asp-page-handler="BudgetApprove" style="display: none;">
    <input type="hidden" id="budgetApproveRequestId" name="requestId" />
    <input type="hidden" id="budgetApproveCostObject" name="costObject" />
    <input type="hidden" id="budgetApproveCostCenter" name="costCenter" />
    <input type="hidden" id="budgetApproveFundCommitment" name="fundCommitment" />
    <input type="hidden" id="budgetApproveRemarksHidden" name="budgetOfficerRemarks" />
</form>

<form id="budgetRevertRequestorForm" method="post" asp-page-handler="BudgetRevertToRequestor" style="display: none;">
    <input type="hidden" id="budgetRevertRequestorId" name="requestId" />
    <input type="hidden" id="budgetRevertRequestorRemarks" name="budgetOfficerRemarks" />
</form>

<form id="budgetRevertSupervisorForm" method="post" asp-page-handler="BudgetRevertToSupervisor" style="display: none;">
    <input type="hidden" id="budgetRevertSupervisorId" name="requestId" />
    <input type="hidden" id="budgetRevertSupervisorRemarks" name="budgetOfficerRemarks" />
</form>

<form id="revertForm" method="post" asp-page-handler="Revert" style="display: none;">
    <input type="hidden" id="revertRequestId" name="requestId" />
    <input type="hidden" id="revertRemarks" name="supervisorRemarks" />
</form>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border: none; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,0.1);">
            <form method="post" asp-page-handler="Reject">
                <input type="hidden" id="rejectRequestId" name="requestId" />
