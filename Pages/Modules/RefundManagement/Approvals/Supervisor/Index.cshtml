                        <thead>
                            <tr>
                                <th>Request</th>
                                <th>Staff</th>
                                <th>Amount</th>
                                <th>Approval Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in processedRequests)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-credit-card text-success me-3 fs-5"></i>
                                            <span class="request-id">#@request.Id</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="Staff-name">@request.MobileNumberAssignedTo</div>
                                        <div class="Staff-details">@request.PrimaryMobileNumber</div>
                                    </td>
