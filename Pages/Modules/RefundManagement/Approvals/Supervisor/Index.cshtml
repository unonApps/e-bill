                                    </td>
                                    <td>
                                        <span class="status-badge @Model.GetStatusClass(request.Status)">
                                            <i class="bi bi-check-circle"></i>
                                            @Model.GetStatusText(request.Status)
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-check-circle"></i>
                    <h5 class="mt-3">No Processed Requests</h5>
                    <p>Approved requests will appear here.</p>
                </div>
            }
        </div>

        <!-- Rejected Requests Tab -->
        <div class="tab-pane fade" id="rejected" role="tabpanel">
            @if (Model.PendingRequests.Where(r => r.Status == TAB.Web.Models.RefundRequestStatus.Cancelled).Any())
            {
                <div class="table-responsive">
                    <table class="table minimal-table">
                        <thead>
                            <tr>
                                <th>Request</th>
                                <th>Staff</th>
                                <th>Amount</th>
                                <th>Rejection Date</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var request in Model.PendingRequests.Where(r => r.Status == TAB.Web.Models.RefundRequestStatus.Cancelled))
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-credit-card text-danger me-3 fs-5"></i>
                                            <span class="request-id">#@request.Id</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="Staff-name">@request.MobileNumberAssignedTo</div>
                                        <div class="Staff-details">@request.PrimaryMobileNumber</div>
                                    </td>
                                    <td>@request.DevicePurchaseCurrency @request.DevicePurchaseAmount.ToString("N2")</td>
                                    <td>
                                        <span class="text-muted">@request.SupervisorApprovalDate?.ToString("MMM dd, yyyy HH:mm")</span>
                                    </td>
                                    <td>
                                        <span class="text-muted small">@request.SupervisorRemarks</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-x-circle"></i>
                    <h5 class="mt-3">No Rejected Requests</h5>
                    <p>Rejected requests will appear here.</p>
                </div>
            }
        </div>
    </div>

    }
