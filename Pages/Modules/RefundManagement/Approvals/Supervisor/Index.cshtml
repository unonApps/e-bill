        <!-- Processed Requests Tab -->
        <div class="tab-pane fade" id="processed" role="tabpanel">
            @{
                var processedRequests = Model.HasSupervisorAccess 
                    ? Model.PendingRequests.Where(r => r.Status == TAB.Web.Models.RefundRequestStatus.PendingBudgetOfficer)
                    : Model.CurrentUserRole.Contains("Budget")
                        ? Model.PendingRequests.Where(r => r.Status == TAB.Web.Models.RefundRequestStatus.PendingStaffClaimsUnit)
                        : Model.PendingRequests.Where(r => r.Status == TAB.Web.Models.RefundRequestStatus.Completed);
