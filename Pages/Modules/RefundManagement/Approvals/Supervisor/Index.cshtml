                                <!-- Step 1: Submitted -->
                                <div class="d-flex flex-column align-items-center" style="flex: 1;">
                                    <div id="step-submitted" class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: #e5e7eb; border-radius: 50%; margin-bottom: 8px;">
                                        <i class="bi bi-circle text-gray-400" style="font-size: 18px;"></i>
                                    </div>
                                    <small class="text-center" style="font-weight: 500; color: #9ca3af;">Submitted</small>
                                </div>
                                <div id="line-1" style="flex: 1; height: 2px; background: #e5e7eb; margin: 0 16px;"></div>
                                
                                <!-- Step 2: Supervisor -->
                                <div class="d-flex flex-column align-items-center" style="flex: 1;">
                                    <div id="step-supervisor" class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: #e5e7eb; border-radius: 50%; margin-bottom: 8px;">
                                        <i class="bi bi-circle text-gray-400" style="font-size: 18px;"></i>
                                    </div>
                                    <small class="text-center" style="font-weight: 500; color: #9ca3af;">Supervisor</small>
                                </div>
                                <div id="line-2" style="flex: 1; height: 2px; background: #e5e7eb; margin: 0 16px;"></div>
                                
                                <!-- Step 3: Budget Officer -->
                                <div class="d-flex flex-column align-items-center" style="flex: 1;">
                                    <div id="step-budget" class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: #e5e7eb; border-radius: 50%; margin-bottom: 8px;">
                                        <i class="bi bi-circle text-gray-400" style="font-size: 18px;"></i>
                                    </div>
                                    <small class="text-center" style="font-weight: 500; color: #9ca3af;">Budget Officer</small>
                                </div>
                                <div id="line-3" style="flex: 1; height: 2px; background: #e5e7eb; margin: 0 16px;"></div>
                                
                                <!-- Step 4: Staff Claims -->
                                <div class="d-flex flex-column align-items-center" style="flex: 1;">
                                    <div id="step-claims" class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: #e5e7eb; border-radius: 50%; margin-bottom: 8px;">
                                        <i class="bi bi-circle text-gray-400" style="font-size: 18px;"></i>
                                    </div>
                                    <small class="text-center" style="font-weight: 500; color: #9ca3af;">Staff Claims</small>
                                </div>
                                <div id="line-4" style="flex: 1; height: 2px; background: #e5e7eb; margin: 0 16px;"></div>
                                
                                <!-- Step 5: Payment -->
                                <div class="d-flex flex-column align-items-center" style="flex: 1;">
                                    <div id="step-payment" class="d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background: #e5e7eb; border-radius: 50%; margin-bottom: 8px;">
                                        <i class="bi bi-circle text-gray-400" style="font-size: 18px;"></i>
                                    </div>
                                    <small class="text-center" style="font-weight: 500; color: #9ca3af;">Payment</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Comments & Remarks -->
                <div class="mb-4" style="background: #fff7ed; border-radius: 16px; padding: 24px; border: 1px solid #fed7aa;">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-chat-square-text me-3" style="font-size: 20px; color: #ea580c;"></i>
                        <h6 class="mb-0" style="font-weight: 600; color: #9a3412;">Comments & Remarks</h6>
                    </div>
                    <div id="commentsContainer">
                        <p class="text-muted text-center py-3">Loading comments...</p>
                    </div>
                </div>

            </div>
            <div class="modal-footer" style="border: none; padding: 24px 32px 32px 32px;">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 12px; padding: 12px 24px; font-weight: 500;">Close</button>
            </div>
        </div>
    </div>
</div>

<script>
    let currentRequestData = null;

    function approveRequest(requestId) {
        // Fetch request details first
        fetch(`/Supervisor/RefundRequests?handler=RequestDetails&requestId=${requestId}`)
            .then(response => response.json())
            .then(data => {
                currentRequestData = data;
                populateApprovalModal(data);
                document.getElementById('approveRequestId').value = requestId;
                new bootstrap.Modal(document.getElementById('approveModal')).show();
            })
            .catch(error => {
                console.error('Error fetching request details:', error);
                alert('Error loading request details');
            });
    }

    function populateApprovalModal(data) {
        document.getElementById('modalClassOfService').textContent = data.classOfService || '-';
        document.getElementById('modalMobileService').textContent = data.mobileService || '-';
        document.getElementById('modalDeviceAllowance').textContent = data.deviceAllowance ? `$${data.deviceAllowance.toFixed(2)}` : '-';
        document.getElementById('modalSupervisorInfo').textContent = data.supervisor || '-';
        
        // Reset form
        document.getElementById('supervisorRemarks').value = '';
        const budgetOfficerSelect = document.getElementById('budgetOfficerSelect');
        if (budgetOfficerSelect) {
            budgetOfficerSelect.value = '';
        }
        document.getElementById('remarksCount').textContent = '0';
    }

    function approveAndSubmit() {
        const remarks = document.getElementById('supervisorRemarks').value;
        const budgetOfficerSelect = document.getElementById('budgetOfficerSelect');
        
        // For supervisors, budget officer selection is required
        // For budget officers, it's not needed
        if (budgetOfficerSelect && budgetOfficerSelect.style.display !== 'none') {
            const budgetOfficer = budgetOfficerSelect.value;
            if (!budgetOfficer) {
                alert('Please select a Budget Officer before approving.');
                return;
            }
            document.getElementById('approveBudgetOfficer').value = budgetOfficer;
        } else {
            document.getElementById('approveBudgetOfficer').value = '';
        }
        
        // Set form values and submit
        document.getElementById('approveRemarks').value = remarks;
        document.getElementById('approveForm').submit();
    }

    function revertToRequestor() {
        const remarks = document.getElementById('supervisorRemarks').value;
        
        if (confirm('Are you sure you want to revert this request to the requestor?')) {
            document.getElementById('revertRequestId').value = document.getElementById('approveRequestId').value;
            document.getElementById('revertRemarks').value = remarks;
            document.getElementById('revertForm').submit();
        }
    }

    function rejectRequest(requestId) {
        document.getElementById('rejectRequestId').value = requestId;
        new bootstrap.Modal(document.getElementById('rejectModal')).show();
    }

    function viewRequest(requestId) {
        // Fetch request details and show modal
        fetch(`/Supervisor/RefundRequests?handler=RequestDetails&requestId=${requestId}`)
            .then(response => response.json())
            .then(data => {
                populateViewDetailsModal(data);
                new bootstrap.Modal(document.getElementById('viewDetailsModal')).show();
            })
            .catch(error => {
                console.error('Error fetching request details:', error);
                alert('Error loading request details');
            });
    }

    function populateViewDetailsModal(data) {
        // Populate request overview
        document.getElementById('viewRequestId').textContent = `#${data.id}`;
        document.getElementById('viewStaffName').textContent = data.mobileNumberAssignedTo || '-';
        document.getElementById('viewMobileNumber').textContent = data.primaryMobileNumber || '-';
        document.getElementById('viewIndexNo').textContent = data.indexNo || '-';
        document.getElementById('viewOffice').textContent = data.office || '-';
        document.getElementById('viewOrganization').textContent = data.organization || '-';
        document.getElementById('viewRequestDate').textContent = data.requestDate ? new Date(data.requestDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '-';
        
        // Populate status
        const statusBadge = document.getElementById('viewStatus');
        statusBadge.textContent = getStatusText(data.status);
        statusBadge.className = `badge ${getStatusClass(data.status)}`;
        
        // Populate mobile service details
        document.getElementById('viewMobileService').textContent = data.mobileService || '-';
        document.getElementById('viewClassOfService').textContent = data.classOfService || '-';
        document.getElementById('viewOfficeExtension').textContent = data.officeExtension || '-';
        document.getElementById('viewSupervisor').textContent = data.supervisor || '-';
        
        // Populate financial details
        document.getElementById('viewDeviceAllowance').textContent = data.deviceAllowance ? `$${data.deviceAllowance.toFixed(2)}` : '-';
        document.getElementById('viewPurchaseAmount').textContent = data.devicePurchaseAmount && data.devicePurchaseCurrency ? 
            `${data.devicePurchaseCurrency} ${data.devicePurchaseAmount.toFixed(2)}` : '-';
        document.getElementById('viewUmojaBankName').textContent = data.umojaBankName || '-';
        document.getElementById('viewPreviousReimbursedDate').textContent = data.previousDeviceReimbursedDate ? 
            new Date(data.previousDeviceReimbursedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : 'None';
        
        // Populate workflow status
        updateWorkflowStatus(data.status);
        
        // Populate comments and remarks
        populateComments(data);
        
        // Show/hide receipt
        const receiptSection = document.getElementById('receiptSection');
        const receiptLink = document.getElementById('receiptLink');
        if (data.purchaseReceiptPath) {
            receiptLink.href = data.purchaseReceiptPath;
            receiptSection.style.display = 'block';
        } else {
            receiptSection.style.display = 'none';
        }
    }

    function getStatusText(status) {
        const statusMap = {
            0: 'Draft',
            1: 'Pending Supervisor',
            2: 'Pending Budget Officer',
            3: 'Pending Staff Claims Unit',
            4: 'Pending Payment Approval',
            5: 'Completed',
            6: 'Cancelled'
        };
        return statusMap[status] || 'Unknown';
    }

    function getStatusClass(status) {
        const statusClassMap = {
            0: 'status-draft',
            1: 'status-pending',
            2: 'status-pending',
            3: 'status-pending',
            4: 'status-pending',
            5: 'status-approved',
            6: 'status-rejected'
        };
        return statusClassMap[status] || 'status-draft';
    }

    function updateWorkflowStatus(status) {
        // Update workflow progress indicators
        const steps = [
            { id: 'step-submitted', completed: status >= 1 },
            { id: 'step-supervisor', completed: status >= 2 },
            { id: 'step-budget', completed: status >= 3 },
            { id: 'step-claims', completed: status >= 4 },
            { id: 'step-payment', completed: status >= 5 }
        ];

        steps.forEach((step, index) => {
            const element = document.getElementById(step.id);
            const line = document.getElementById(`line-${index + 1}`);
            
            if (element) {
                const icon = element.querySelector('i');
                if (step.completed) {
                    element.style.background = '#10b981';
                    icon.className = 'bi bi-check2 text-white';
                } else if (status === index + 1) {
                    element.style.background = '#fbbf24';
                    element.style.animation = 'pulse 2s infinite';
                    icon.className = 'bi bi-clock text-white';
                } else {
                    element.style.background = '#e5e7eb';
                    icon.className = 'bi bi-circle text-gray-400';
                }
            }
            
            if (line) {
                line.style.background = step.completed ? '#10b981' : '#e5e7eb';
            }
        });
    }

    function populateComments(data) {
        const commentsContainer = document.getElementById('commentsContainer');
        commentsContainer.innerHTML = '';

        const comments = [];
        
        if (data.supervisorNotes || data.supervisorRemarks) {
            comments.push({
                type: 'Supervisor',
                icon: 'bi-person-badge',
                color: '#3b82f6',
                notes: data.supervisorNotes || data.supervisorRemarks,
                date: data.supervisorApprovalDate,
                author: data.supervisorName || 'Supervisor'
            });
        }

        if (data.budgetOfficerNotes || data.budgetOfficerRemarks) {
            comments.push({
                type: 'Budget Officer',
                icon: 'bi-calculator',
                color: '#f59e0b',
                notes: data.budgetOfficerNotes || data.budgetOfficerRemarks,
                date: data.budgetOfficerApprovalDate,
                author: data.budgetOfficerName || 'Budget Officer'
            });
        }

        if (data.staffClaimsNotes || data.staffClaimsRemarks) {
            comments.push({
                type: 'Staff Claims Unit',
                icon: 'bi-check2-square',
                color: '#10b981',
                notes: data.staffClaimsNotes || data.staffClaimsRemarks,
                date: data.staffClaimsApprovalDate,
                author: data.staffClaimsOfficerName || 'Staff Claims Officer'
            });
        }

        if (data.paymentApprovalNotes) {
            comments.push({
                type: 'Payment Approval',
                icon: 'bi-credit-card',
                color: '#8b5cf6',
                notes: data.paymentApprovalNotes,
                date: data.paymentApprovalDate,
                author: data.paymentApprovalOfficerName || 'Payment Officer'
            });
        }

        if (data.remarks) {
            comments.push({
                type: 'Requestor Notes',
                icon: 'bi-chat-left-text',
                color: '#6b7280',
                notes: data.remarks,
                date: data.requestDate,
                author: data.mobileNumberAssignedTo || 'Requestor'
            });
        }

        if (comments.length === 0) {
            commentsContainer.innerHTML = '<p class="text-muted text-center py-3">No comments or remarks available</p>';
            return;
        }

        comments.forEach(comment => {
            const commentHtml = `
                <div class="mb-3 p-3" style="background: #f8fafc; border-radius: 12px; border-left: 4px solid ${comment.color};">
                    <div class="d-flex align-items-center mb-2">
                        <i class="${comment.icon} me-2" style="color: ${comment.color}; font-size: 16px;"></i>
                        <span style="font-weight: 600; color: #111827; font-size: 14px;">${comment.type}</span>
                        <span class="text-muted ms-auto" style="font-size: 12px;">
                            ${comment.date ? new Date(comment.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : ''}
                        </span>
                    </div>
                    <p class="mb-1" style="color: #374151; font-size: 14px; line-height: 1.5;">${comment.notes}</p>
                    <small class="text-muted">� ${comment.author}</small>
                </div>
            `;
            commentsContainer.innerHTML += commentHtml;
        });
    }

    // Character counter for remarks
    document.addEventListener('DOMContentLoaded', function() {
        const remarksTextarea = document.getElementById('supervisorRemarks');
        const remarksCount = document.getElementById('remarksCount');
        
        if (remarksTextarea && remarksCount) {
            remarksTextarea.addEventListener('input', function() {
                remarksCount.textContent = this.value.length;
            });
        }
        
        // Character counter for budget officer remarks
        const budgetRemarksTextarea = document.getElementById('budgetOfficerRemarks');
        const budgetRemarksCount = document.getElementById('budgetRemarksCount');
        
        if (budgetRemarksTextarea && budgetRemarksCount) {
            budgetRemarksTextarea.addEventListener('input', function() {
                budgetRemarksCount.textContent = this.value.length;
            });
        }
    });
    
    // Budget Officer Functions
    function budgetOfficerApprove(requestId) {
        // Reset the budget officer modal form
        document.getElementById('costObject').value = '';
        document.getElementById('costCenter').value = '';
        document.getElementById('fundCommitment').value = '';
        document.getElementById('budgetOfficerRemarks').value = '';
        document.getElementById('budgetRemarksCount').textContent = '0';
        
        // Set the request ID
        document.getElementById('budgetApproveRequestId').value = requestId;
        
        // Show the budget officer modal
        new bootstrap.Modal(document.getElementById('budgetOfficerApproveModal')).show();
    }
    
    function budgetApproveAndSubmit() {
        const costObject = document.getElementById('costObject').value.trim();
        const costCenter = document.getElementById('costCenter').value.trim();
        const fundCommitment = document.getElementById('fundCommitment').value.trim();
        const remarks = document.getElementById('budgetOfficerRemarks').value;
        
        // Validate required fields
        if (!costObject) {
            alert('Cost Object is required.');
            document.getElementById('costObject').focus();
            return;
        }
        
        if (!costCenter) {
            alert('Cost Center is required.');
            document.getElementById('costCenter').focus();
            return;
        }
        
        if (!fundCommitment) {
            alert('Fund Commitment is required.');
            document.getElementById('fundCommitment').focus();
            return;
        }
        
        if (confirm('Are you sure you want to approve this request and submit it to Staff Claims Unit?')) {
            // Set form values and submit
            document.getElementById('budgetApproveCostObject').value = costObject;
            document.getElementById('budgetApproveCostCenter').value = costCenter;
            document.getElementById('budgetApproveFundCommitment').value = fundCommitment;
            document.getElementById('budgetApproveRemarksHidden').value = remarks;
            document.getElementById('budgetApproveForm').submit();
        }
    }
    
    function budgetRevertToRequestor() {
        const remarks = document.getElementById('budgetOfficerRemarks').value;
        
        if (confirm('Are you sure you want to revert this request to the requestor?')) {
            document.getElementById('budgetRevertRequestorId').value = document.getElementById('budgetApproveRequestId').value;
            document.getElementById('budgetRevertRequestorRemarks').value = remarks;
            document.getElementById('budgetRevertRequestorForm').submit();
        }
    }
    
    function budgetRevertToSupervisor() {
        const remarks = document.getElementById('budgetOfficerRemarks').value;
        
        if (confirm('Are you sure you want to revert this request to the supervisor?')) {
            document.getElementById('budgetRevertSupervisorId').value = document.getElementById('budgetApproveRequestId').value;
            document.getElementById('budgetRevertSupervisorRemarks').value = remarks;
            document.getElementById('budgetRevertSupervisorForm').submit();
        }
    }
</script>
 
 