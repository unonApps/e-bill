                            </div>
                            <div class="compact-info-row">
                                <span class="compact-label">Request Date</span>
                                <span class="compact-value">@request.RequestDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>

                        <!-- Rejection Reason -->
                        <div>
                            <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                Reason for Rejection <span style="color: #ef4444;">*</span>
                            </label>
