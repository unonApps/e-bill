                        <!-- Warning Alert -->
                        <div class="d-flex align-items-start mt-3" style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 6px; padding: 10px;">
                            <i class="bi bi-exclamation-triangle-fill me-2" style="color: #ef4444; font-size: 14px; flex-shrink: 0; margin-top: 1px;"></i>
                            <small style="color: #991b1b;">This action will reject the request and notify the employee. The request will need to be resubmitted if required.</small>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer" style="border-top: 1px solid #e5e7eb; padding: 16px 24px; gap: 10px; background: #f8fafc; border-radius: 0 0 16px 16px;">
                        <button type="button" class="btn btn-sm" data-bs-dismiss="modal" 
                                style="border: 1px solid #d1d5db; border-radius: 6px; padding: 8px 20px; background: #ffffff; color: #6b7280; font-weight: 500; font-size: 13px;">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-sm" 
                                style="border: none; border-radius: 6px; padding: 8px 20px; background: #ef4444; color: #ffffff; font-weight: 500; font-size: 13px;">
                            <i class="bi bi-x-circle me-1"></i>
                            Reject Request
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

