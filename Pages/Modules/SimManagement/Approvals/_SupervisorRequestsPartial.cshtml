                                    placeholder="Please provide a clear reason for rejecting this request..." 
                                    style="border: 1px solid #d1d5db; border-radius: 6px; padding: 10px 12px; font-size: 13px; resize: none;"></textarea>
                            <small class="text-muted">This reason will be shared with the requestor.</small>
