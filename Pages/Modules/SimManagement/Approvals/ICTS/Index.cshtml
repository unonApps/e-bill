                                                                    <div class="mb-2">
                                                                        <span class="text-muted" style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Supervisor Remarks</span>
                                                                        <div style="color: #6b7280; background: #ffffff; padding: 12px; border-radius: 8px; font-size: 13px; line-height: 1.4;">@request.SupervisorRemarks</div>
                                                                    </div>
                                                                </div>
                                                                }
                                                                @if (!string.IsNullOrEmpty(request.IctsRemark))
                                                                {
                                                                <div class="col-md-4">
                                                                    <div class="mb-2">
                                                                        <span class="text-muted" style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">ICTS Remarks</span>
                                                                        <div style="color: #6b7280; background: #ffffff; padding: 12px; border-radius: 8px; font-size: 13px; line-height: 1.4;">@request.IctsRemark</div>
                                                                    </div>
                                                                </div>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>
                                                    }

                                                </div>
                                            </div>

                                            <!-- Footer -->
                                            <div class="modal-footer" style="border: none; padding: 0 32px 32px 32px; justify-content: center;">
