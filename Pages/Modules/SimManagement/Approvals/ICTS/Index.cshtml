                                                                        <div style="color: #6b7280; background: #ffffff; padding: 12px; border-radius: 8px; font-size: 13px; line-height: 1.4;">@request.Remarks</div>
                                                                    </div>
                                                                </div>
                                                                }
                                                                @if (!string.IsNullOrEmpty(request.SupervisorRemarks))
                                                                {
