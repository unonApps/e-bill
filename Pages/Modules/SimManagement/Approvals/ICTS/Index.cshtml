                                                    <button type="submit" name="action" value="newsim" class="btn" style="border: none; border-radius: 12px; padding: 12px 24px; background: linear-gradient(135deg, #10b981, #059669); color: #ffffff; font-weight: 500; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);">
                                                        <i class="bi bi-sim me-2"></i>
                                                        Request New SIM
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                                }

