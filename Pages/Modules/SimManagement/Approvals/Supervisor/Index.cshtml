                                                        Cancel
                                                    </button>
                                                    <button type="submit" name="action" value="revert" class="btn" style="border: 1px solid #f59e0b; border-radius: 12px; padding: 12px 24px; background: #fef3c7; color: #92400e; font-weight: 500; transition: all 0.2s;">
                                                        <i class="bi bi-arrow-left me-2"></i>
                                                        Revert To Requestor
                                                    </button>
                                                    <button type="submit" name="action" value="approve" class="btn" style="border: none; border-radius: 12px; padding: 12px 24px; background: linear-gradient(135deg, #10b981, #059669); color: #ffffff; font-weight: 500; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3); transition: all 0.2s;">
                                                        <i class="bi bi-check-lg me-2"></i>
                                                        Approve & Submit to ICTS
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                                <!-- Reject Modal -->
                                <div class="modal fade" id="rejectModal@(request.Id)" tabindex="-1">
                                    <div class="modal-dialog modal-dialog-centered">
                                        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
