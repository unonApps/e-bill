                                                                <div class="d-flex align-items-center">
                                                                    <i class="bi bi-info-circle me-2" style="color: #3b82f6; font-size: 14px;"></i>
                                                                    <span id="descriptionText@(request.Id)" style="color: #1e40af; font-size: 13px; font-weight: 500;"></span>
                                                                </div>
                                                            </div>
                                                        </div>

