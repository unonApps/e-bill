                                }
                                @if (!string.IsNullOrEmpty(Model.CurrentRequest.Remarks))
                                {
                                    <div class="mb-3">
                                        <span class="text-muted" style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Remarks</span>
                                        <div style="color: #6b7280; font-size: 14px;">@Model.CurrentRequest.Remarks</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @* Supervisor Approval Tab - With Action Forms *@
                <div class="tab-pane fade show active" id="supervisor-approval">
                    <form method="post" asp-page-handler="Approve" id="supervisorApprovalForm">
                        <input type="hidden" name="requestId" value="@Model.CurrentRequest.PublicId" />
                        <input type="hidden" name="action" id="actionInput" value="" />

                        @* Class of Service Card *@
                        <div class="mb-4" style="background: #ffffff; border-radius: 12px; padding: 1.5rem; border: 1px solid #e2e8f0;">
                            <h6 style="font-size: 0.875rem; font-weight: 600; color: #004987; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #E3EDF6; display: flex; align-items-center;">
                                <i class="bi bi-gear me-2" style="color: #009EDB;"></i>Class of Service
                            </h6>

                            @* Mobile Service *@
                            <div class="mb-3">
                                <label class="form-label fw-medium">Mobile Service <span class="text-danger">*</span></label>
                                <select name="mobileService" class="form-select" required>
                                    <option value="">Select Mobile Service</option>
                                    <option value="LOCAL (VOICE)">LOCAL (VOICE) - Drivers & maintenance staff</option>
                                    <option value="LOCAL (VOICE + DATA)">LOCAL (VOICE + DATA) - Technical staff</option>
                                    <option value="VOICE (LOCAL + INTERNATIONAL)/DATA (LOCAL + INTERNATIONAL)">VOICE (LOCAL + INTERNATIONAL)/DATA (LOCAL + INTERNATIONAL) - Substantive staff</option>
                                    <option value="Voice (local + international)/Data (local + international)">Voice (local + international)/Data (local + international) - D2 and above</option>
                                </select>
                            </div>

                            @* Allowances Grid *@
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-medium">Mobile Service Allowance (USD)</label>
                                    <input type="text" name="mobileServiceAllowance" class="form-control" readonly placeholder="Auto-filled from database" style="background: #f9fafb;" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-medium">Handset Allowance (USD)</label>
                                    <input type="text" name="handsetAllowance" class="form-control" readonly placeholder="Auto-filled from database" style="background: #f9fafb;" />
                                </div>
                            </div>
                        </div>

                        @* Supervisor Information Card *@
                        <div class="mb-4" style="background: #ffffff; border-radius: 12px; padding: 1.5rem; border: 1px solid #e2e8f0;">
                            <h6 style="font-size: 0.875rem; font-weight: 600; color: #004987; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #E3EDF6; display: flex; align-items-center;">
                                <i class="bi bi-person-badge me-2" style="color: #009EDB;"></i>Supervisor Information
                            </h6>

                            @* Supervisor Remark *@
                            <div class="mb-3">
                                <label class="form-label fw-medium">Supervisor Remark</label>
                                <textarea name="supervisorRemarks" class="form-control" rows="3" maxlength="200" placeholder="Add your comments here..."></textarea>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <small class="text-muted">Optional comments for the request</small>
                                    <small class="text-muted">Max 200 characters</small>
                                </div>
                            </div>

                            @* Supervisor Details Grid *@
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-medium">Supervisor Name</label>
                                    <input type="text" name="supervisorName" class="form-control" value="@Model.CurrentSupervisorName" readonly style="background: #f9fafb;" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-medium">Supervisor Email</label>
                                    <input type="email" name="supervisorEmail" class="form-control" value="@Model.CurrentSupervisorEmail" readonly style="background: #f9fafb;" />
                                </div>
                            </div>

                            <div class="mt-3">
                                <label class="form-label fw-medium">Action Date</label>
                                <input type="datetime-local" name="supervisorActionDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" readonly style="background: #f9fafb;" />
                            </div>
                        </div>

                        @* Action Buttons *@
                        <div class="d-flex gap-3 justify-content-end">
                            <a href="/Dashboard/Approver" class="btn btn-outline-secondary" style="min-width: 120px;">
                                Cancel
                            </a>
                            <button type="button" class="btn btn-warning" style="min-width: 200px;" data-bs-toggle="modal" data-bs-target="#revertModal">
                                <i class="bi bi-arrow-left me-2"></i>Revert To Requestor
                            </button>
                            <button type="submit" class="btn btn-success" style="min-width: 220px;" onclick="document.getElementById('actionInput').value='approve';">
                                <i class="bi bi-check-lg me-2"></i>Approve & Submit to ICTS
                            </button>
                        </div>
                    </form>
                </div>

                @* Additional Details Tab *@
                <div class="tab-pane fade" id="additional-details">
                    <div class="mb-4" style="background: #f8fafc; border-radius: 8px; padding: 1.25rem; border: 1px solid #e2e8f0;">
                        <h6 style="font-size: 0.875rem; font-weight: 600; color: #004987; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #E3EDF6; display: flex; align-items: center;">
                            <i class="bi bi-info-circle me-2" style="color: #009EDB;"></i>Request Timeline
                        </h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <span class="text-muted" style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Request Date</span>
                                    <div style="color: #6b7280; font-size: 14px;">@Model.CurrentRequest.RequestDate.ToString("MMM dd, yyyy HH:mm")</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (Model.RequestHistory.Any())
                    {
                        <div class="mb-4" style="background: #f8fafc; border-radius: 8px; padding: 1.25rem; border: 1px solid #e2e8f0;">
                            <h6 style="font-size: 0.875rem; font-weight: 600; color: #004987; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #E3EDF6; display: flex; align-items: center;">
                                <i class="bi bi-clock-history me-2" style="color: #009EDB;"></i>Request History
                            </h6>
                            <div class="timeline">
                                @foreach (var history in Model.RequestHistory)
                                {
                                    <div class="timeline-item mb-3 pb-3" style="border-bottom: 1px solid #e5e7eb;">
                                        <div class="d-flex justify-content-between mb-2">
                                            <strong style="color: #111827;">@history.Action</strong>
                                            <small class="text-muted">@history.Timestamp.ToString("MMM dd, yyyy HH:mm")</small>
                                        </div>
                                        <div class="text-muted" style="font-size: 13px;">By: @history.UserName</div>
                                        @if (!string.IsNullOrEmpty(history.Comments))
                                        {
                                            <div class="mt-2" style="font-size: 13px; color: #6b7280;">@history.Comments</div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut();
        }, 5000);
        
        // Function to auto-populate allowances based on selected mobile service
        function loadClassOfServiceAllowances(serviceValue) {
            if (!serviceValue) {
                // Clear allowance fields if no service selected
                const mobileServiceAllowanceInput = document.querySelector('input[name="mobileServiceAllowance"]');
                const handsetAllowanceInput = document.querySelector('input[name="handsetAllowance"]');
                if (mobileServiceAllowanceInput) mobileServiceAllowanceInput.value = '';
                if (handsetAllowanceInput) handsetAllowanceInput.value = '';
                return;
            }

            // Show loading state
            const mobileServiceAllowanceInput = document.querySelector('input[name="mobileServiceAllowance"]');
            const handsetAllowanceInput = document.querySelector('input[name="handsetAllowance"]');

            if (mobileServiceAllowanceInput) mobileServiceAllowanceInput.value = 'Loading...';
            if (handsetAllowanceInput) handsetAllowanceInput.value = 'Loading...';

            // Fetch allowances from the API
            fetch(`?handler=ClassOfService&service=${encodeURIComponent(serviceValue)}`)
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        if (mobileServiceAllowanceInput) {
                            mobileServiceAllowanceInput.value = data.mobileServiceAllowance;
                        }
                        if (handsetAllowanceInput) {
                            handsetAllowanceInput.value = data.handsetAllowance;
                        }
                    } else {
                        console.error('Error loading allowances:', data.message);
                        if (mobileServiceAllowanceInput) mobileServiceAllowanceInput.value = 'Error';
                        if (handsetAllowanceInput) handsetAllowanceInput.value = 'Error';
                    }
                })
                .catch(error => {
                    console.error('Error fetching Class of Service:', error);
                    if (mobileServiceAllowanceInput) mobileServiceAllowanceInput.value = 'Error';
                    if (handsetAllowanceInput) handsetAllowanceInput.value = 'Error';
                });
        }

        // Add smooth transitions
        document.addEventListener('DOMContentLoaded', function() {
            // Animate cards on load
            const cards = document.querySelectorAll('.minimal-card');
            cards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                setTimeout(() => {
                    card.style.transition = 'all 0.5s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 100);
            });

            // Attach event listener to mobile service dropdown
            const mobileServiceSelect = document.querySelector('select[name="mobileService"]');
            if (mobileServiceSelect) {
                mobileServiceSelect.addEventListener('change', function() {
                    loadClassOfServiceAllowances(this.value);
                });
            }

            // Add character counting for all supervisor remark textareas
            const remarkTextareas = document.querySelectorAll('textarea[name="supervisorRemarks"]');
            remarkTextareas.forEach(textarea => {
                const form = textarea.closest('form');
                if (form) {
                    const requestIdInput = form.querySelector('input[name="requestId"]');
                    if (requestIdInput) {
                        const requestId = requestIdInput.value;
                        textarea.addEventListener('input', function() {
                            updateCharCount(this, requestId);
                        });
                    } else {
                        console.warn('No requestId found for textarea, skipping character count setup');
                    }
                } else {
                    console.warn('No form found for textarea, skipping character count setup');
                }
            });
        });

        // Update service description and fetch allowances based on selected mobile service
        function updateServiceDescription(selectElement) {
            console.log('updateServiceDescription called with:', selectElement.value);
            
            // Get request ID from the modal ID (more reliable method)
            const modal = selectElement.closest('.modal');
            if (!modal) {
                console.error('Could not find parent modal');
                return;
            }
            
            const modalId = modal.id;
            console.log('Modal ID:', modalId);
            
            // Extract request ID from modal ID (e.g., "approveModal1006" -> "1006")
            const match = modalId.match(/approveModal(\d+)/);
            if (!match) {
                console.error('Could not extract request ID from modal ID:', modalId);
                return;
            }
            
            const requestId = match[1];
            console.log('Extracted Request ID:', requestId);
            
            const selectedOption = selectElement.options[selectElement.selectedIndex];
            const description = selectedOption.getAttribute('data-description');
            const descriptionDiv = document.getElementById('serviceDescription' + requestId);
            const descriptionText = document.getElementById('descriptionText' + requestId);
            const mobileServiceAllowanceInput = document.getElementById('mobileServiceAllowance' + requestId);
            const handsetAllowanceInput = document.getElementById('handsetAllowance' + requestId);
            
            console.log('Found elements:', {
                descriptionDiv: !!descriptionDiv,
                descriptionText: !!descriptionText,
                mobileServiceAllowanceInput: !!mobileServiceAllowanceInput,
                handsetAllowanceInput: !!handsetAllowanceInput
            });
            
            // Update description
            if (description && selectElement.value) {
                if (descriptionText && descriptionDiv) {
                    descriptionText.textContent = description;
                    descriptionDiv.style.display = 'block';
                }
                
                // Fetch allowances from database
                console.log('Calling fetchServiceAllowances with service:', selectElement.value);
                fetchServiceAllowances(selectElement.value, requestId);
            } else {
                if (descriptionDiv) {
                    descriptionDiv.style.display = 'none';
                }
                // Clear allowances when no service is selected
                if (mobileServiceAllowanceInput) mobileServiceAllowanceInput.value = '';
                if (handsetAllowanceInput) handsetAllowanceInput.value = '';
            }
        }

        // Fetch service allowances from database
        async function fetchServiceAllowances(service, requestId) {
            console.log('fetchServiceAllowances called with:', service, requestId);
            const mobileServiceAllowanceInput = document.getElementById('mobileServiceAllowance' + requestId);
            const handsetAllowanceInput = document.getElementById('handsetAllowance' + requestId);
            
            if (!mobileServiceAllowanceInput || !handsetAllowanceInput) {
                console.error('Could not find allowance input fields for request:', requestId);
                return;
            }
            
            try {
                // Show loading state
                mobileServiceAllowanceInput.value = 'Loading...';
                handsetAllowanceInput.value = 'Loading...';
                
                const url = `?handler=ServiceAllowances&service=${encodeURIComponent(service)}`;
                console.log('Fetching from URL:', url);
                
                const response = await fetch(url, {
                    method: 'GET',
                    credentials: 'same-origin', // Include cookies for authentication
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });
                
                console.log('Response status:', response.status);
                console.log('Response headers:', response.headers);
                
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                
                const contentType = response.headers.get('content-type');
                console.log('Content-Type:', contentType);
                
                if (!contentType || !contentType.includes('application/json')) {
                    // If not JSON, it might be HTML (login page redirect)
                    const text = await response.text();
                    console.error('Expected JSON but got:', text.substring(0, 200));
                    throw new Error('Server returned HTML instead of JSON - possible authentication issue');
                }
                
                const data = await response.json();
                console.log('Response data:', data);
                
                if (data.success) {
                    // Update allowance fields with database values
                    mobileServiceAllowanceInput.value = data.mobileServiceAllowance || '0';
                    handsetAllowanceInput.value = data.handsetAllowance || '0';
                    console.log('Successfully updated allowances:', {
                        mobile: data.mobileServiceAllowance,
                        handset: data.handsetAllowance
                    });
                } else {
                    // Show error or default values
                    mobileServiceAllowanceInput.value = 'Not configured';
                    handsetAllowanceInput.value = 'Not configured';
                    console.warn('Service allowances not found:', data.message);
                }
            } catch (error) {
                // Handle fetch error
                mobileServiceAllowanceInput.value = 'Error loading';
                handsetAllowanceInput.value = 'Error loading';
                console.error('Error fetching service allowances:', error);
                
                // Show user-friendly error
                alert('Failed to load service allowances. Please refresh the page and try again.');
            }
        }

        // Update character count for supervisor remarks
        function updateCharCount(textarea, requestId) {
            const maxLength = 200;
            const currentLength = textarea.value.length;
            const countElement = document.getElementById('remarkCount' + requestId);
            
            if (countElement) {
                countElement.textContent = currentLength;
                
                // Change color based on character count
                if (currentLength > maxLength * 0.9) {
                    countElement.style.color = '#dc2626'; // Red when near limit
                } else if (currentLength > maxLength * 0.7) {
                    countElement.style.color = '#d97706'; // Orange when getting close
                } else {
                    countElement.style.color = '#64748b'; // Default color
                }
            }
        }

        // Test function to manually trigger allowance population
        function testAllowancePopulation(requestId) {
            console.log('Testing allowance population for request:', requestId);
            const dropdown = document.querySelector(`select[name="mobileService"]`);
            if (dropdown && dropdown.value) {
                console.log('Found dropdown with value:', dropdown.value);
                updateServiceDescription(dropdown);
            } else {
                alert('Please select a mobile service first');
            }
        }

        // Prevent multiple form submissions
        document.addEventListener('DOMContentLoaded', function() {
            const forms = document.querySelectorAll('form');

            forms.forEach(form => {
                form.addEventListener('submit', function(e) {
                    const submitButtons = form.querySelectorAll('button[type="submit"]');

                    // Check if form is already being submitted
                    if (form.classList.contains('submitting')) {
                        e.preventDefault();
                        return false;
                    }

                    // Mark form as submitting
                    form.classList.add('submitting');

                    // Disable all submit buttons in this form
                    submitButtons.forEach(button => {
                        button.disabled = true;
                        const originalText = button.innerHTML;
                        button.setAttribute('data-original-text', originalText);
                        button.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Processing...';
                    });
                });
            });
        });
    </script>

    @* Revert to Requestor Modal - Only render in detail view *@
    @if (Model.IsDetailView && Model.CurrentRequest != null)
    {
        <div class="modal fade" id="revertModal" tabindex="-1" aria-labelledby="revertModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header bg-warning text-white">
                        <h5 class="modal-title" id="revertModalLabel">
                            <i class="bi bi-arrow-left me-2"></i>Revert to Requestor
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <form method="post" asp-page-handler="Approve">
                        <div class="modal-body">
                            <input type="hidden" name="requestId" value="@Model.CurrentRequest.PublicId" />
                            <input type="hidden" name="action" value="revert" />

                        <div class="alert alert-warning d-flex align-items-start" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
                            <div>
                                <strong>Important:</strong> This will send the request back to the requestor for revision. Please provide a clear reason for the revert.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="revertReason" class="form-label fw-bold">
                                Reason for Revert <span class="text-danger">*</span>
                            </label>
                            <textarea
                                class="form-control"
                                id="revertReason"
                                name="supervisorRemarks"
                                rows="5"
                                maxlength="1000"
                                required
                                placeholder="Please explain why this request needs to be revised..."></textarea>
                            <div class="d-flex justify-content-between align-items-center mt-1">
                                <small class="text-muted">Provide a clear explanation for the requestor</small>
                                <small class="text-muted">
                                    <span id="revertReasonCharCount">0</span> / 1000 characters
                                </small>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="bi bi-x-circle me-2"></i>Cancel
                        </button>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-arrow-left me-2"></i>Confirm Revert
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

        <script>
            // Character counter for revert reason textarea
            document.addEventListener('DOMContentLoaded', function() {
                const revertReasonTextarea = document.getElementById('revertReason');
                const revertReasonCharCount = document.getElementById('revertReasonCharCount');

                if (revertReasonTextarea && revertReasonCharCount) {
                    revertReasonTextarea.addEventListener('input', function() {
                        revertReasonCharCount.textContent = this.value.length;
                    });
                }
            });
        </script>
    }
}
