        </ul>

        @* Tab Content Container *@
        <div class="minimal-card" style="border-radius: 0 0 12px 12px; border-top: none; padding: 0;">
            <div class="tab-content" style="background: white; padding: 2rem; border-radius: 0 0 12px 12px;">

                @* Personal Information Tab *@
                <div class="tab-pane fade" id="personal-info">
                    <div class="mb-4" style="background: #f8fafc; border-radius: 8px; padding: 1.25rem; border: 1px solid #e2e8f0;">
