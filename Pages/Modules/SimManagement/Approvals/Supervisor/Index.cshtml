                @* SIM Configuration Tab *@
                <div class="tab-pane fade" id="sim-config">
                    <div class="mb-4" style="background: #f8fafc; border-radius: 8px; padding: 1.25rem; border: 1px solid #e2e8f0;">
                        <h6 style="font-size: 0.875rem; font-weight: 600; color: #004987; margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 2px solid #E3EDF6; display: flex; align-items: center;">
                            <i class="bi bi-sim me-2" style="color: #009EDB;"></i>SIM Configuration
                        </h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <span class="text-muted" style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">SIM Type</span>
                                    <div style="font-weight: 500; color: #111827;">@(Model.CurrentRequest.SimType == TAB.Web.Models.SimType.Physical ? "Physical SIM" : "eSIM")</div>
                                </div>
                                <div class="mb-3">
                                    <span class="text-muted" style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Service Provider</span>
                                    <div style="color: #6b7280; font-size: 14px;">@(Model.CurrentRequest.ServiceProvider?.ServiceProviderName ?? "N/A")</div>
