                                        }
                                    </td>
                                    <td>
                                        @if (simRequest != null)
                                        {
                                            <span style="color: #1e293b;">@(simRequest.MobileService ?? "N/A")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (simRequest != null)
                                        {
                                            <span style="color: #1e293b;">@(simRequest.LineType ?? "N/A")</span>
                                        }
