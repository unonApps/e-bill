                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <span class="text-muted" style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Organization</span>
                                    <div style="color: #6b7280; font-size: 14px;">@Model.CurrentRequest.Organization</div>
                                </div>
                                <div class="mb-3">
                                    <span class="text-muted" style="font-size: 12px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px;">Office</span>
