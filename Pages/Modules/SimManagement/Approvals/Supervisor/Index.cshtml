                                                                <select name="mobileService" class="form-select" required style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px; background: #ffffff; transition: all 0.2s;" onchange="updateServiceDescription(this)">
                                                                    <option value="">Select Mobile Service</option>
                                                                    <option value="LOCAL (VOICE)" data-description="Drivers & maintenance staff">LOCAL (VOICE)</option>
                                                                    <option value="LOCAL (VOICE + DATA)" data-description="Technical staff">LOCAL (VOICE + DATA)</option>
                                                                    <option value="VOICE (LOCAL + INTERNATIONAL)/DATA (LOCAL + INTERNATIONAL)" data-description="Substantive staff, Chiefs of Services/Sections/Units">VOICE (LOCAL + INTERNATIONAL)/DATA (LOCAL + INTERNATIONAL)</option>
                                                                    <option value="Voice (local + international)/Data (local + international)" data-description="D2 and above">Voice (local + international)/Data (local + international)</option>
                                                                </select>
                                                                <button type="button" class="btn" onclick="testAllowancePopulation(@request.Id)" title="Refresh Allowances" style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px; background: #ffffff; color: #6b7280; transition: all 0.2s;">
                                                                    <i class="bi bi-arrow-clockwise"></i>
                                                                </button>
