                                            <span class="status-badge status-approved">
                                                <i class="bi bi-check-circle-fill"></i>
                                                COMPLETED
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="dropdown">
                                            <button class="btn btn-sm dropdown-toggle" type="button"
                                                    style="background-color: #009EDB; color: white; border: none; padding: 8px 16px; border-radius: 6px; font-size: 13px; font-weight: 500;"
