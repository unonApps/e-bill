                                                            <div><strong>Staff:</strong> @request.StaffName</div>
                                                            @if (simRequest != null)
                                                            {
                                                                <div><strong>Service:</strong> @simRequest.MobileService</div>
                                                                <div><strong>Line Type:</strong> @simRequest.LineType</div>
                                                            }
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-medium">Reason for Rejection <span class="text-danger">*</span>:</label>
                                                        <textarea name="notes" class="form-control" rows="3" placeholder="Please provide a reason for rejection..." required style="border-radius: 8px;"></textarea>
                                                    </div>
                                                </div>
                                                <div class="modal-footer border-0 pt-0">
                                                    <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border-radius: 8px;">Cancel</button>
                                                    <button type="submit" class="btn btn-danger" style="border-radius: 8px;">
                                                        <i class="bi bi-x-lg me-1"></i>
                                                        Reject Request
                                                    </button>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-sim"></i>
                    <h4 class="fw-bold">No Pending SIM Requests</h4>
                    <p>All SIM requests have been processed.</p>
