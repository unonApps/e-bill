                                                        <i class="bi bi-x-circle text-danger me-2"></i>
                                                        Reject SIM Request
                                                    </h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
