                                                                <div style="position: relative;">
                                                                    <input type="text" name="mobileServiceAllowance" id="mobileServiceAllowance@(request.Id)" class="form-control" readonly placeholder="Auto-filled from database" style="border: 1px solid #d1d5db; border-radius: 12px; padding: 12px 16px; font-size: 14px; background: #f9fafb; color: #374151; font-weight: 500;" />
                                                                    <div style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: #9ca3af; font-size: 12px;">USD</div>
