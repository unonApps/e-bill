@model TAB.Web.Pages.Modules.SimManagement.Approvals.IndexModel

<style>
    .icts-table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
        border: none;
    }
    
    .icts-table thead th {
        background: #f8fafc;
        border: none;
        padding: 16px;
        font-weight: 600;
        font-size: 13px;
        color: #475569;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .icts-table tbody td {
        border: none;
        padding: 16px;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
        font-size: 14px;
    }
    
    .icts-table tbody tr:last-child td {
        border-bottom: none;
    }
    
    .icts-table tbody tr:hover {
        background: #f8fafc;
    }
    
    .action-group {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }
    
    .action-btn-sm {
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 500;
        border: 1px solid;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        text-decoration: none;
        cursor: pointer;
        background: white;
    }
    
    .btn-icts-view {
        border-color: #0ea5e9;
        color: #0c4a6e;
    }
    
    .btn-icts-view:hover {
        background: #0ea5e9;
        color: white;
    }
    
    .btn-icts-process {
        border-color: #10b981;
        color: #15803d;
    }
    
    .btn-icts-process:hover {
        background: #10b981;
        color: white;
    }
    
    .btn-icts-revert {
        border-color: #f59e0b;
        color: #92400e;
    }
    
    .btn-icts-revert:hover {
        background: #f59e0b;
        color: white;
    }
</style>

<div class="requests-content">
    @if (Model.IctsRequests.Any())
    {
        <div class="table-responsive">
            <table class="icts-table table">
                <thead>
                    <tr>
                        <th>Request ID</th>
                        <th>Employee</th>
                        <th>Organization</th>
                        <th>Service</th>
                        <th>Provider</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model.IctsRequests)
                    {
                        <tr>
                            <td>
                                <span class="fw-bold text-primary">#SIM-@request.Id.ToString("D6")</span>
                            </td>
                            <td>
                                <div class="fw-semibold">@request.FirstName @request.LastName</div>
                                <small class="text-muted">@request.IndexNo</small>
                            </td>
                            <td>
                                <div>@request.Organization</div>
                                <small class="text-muted">@request.Office</small>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(request.MobileService))
                                {
                                    <small class="text-muted">@request.MobileService</small>
                                }
                                else
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                            </td>
                            <td>
                                <span class="badge bg-info">@(request.ServiceProvider?.ServiceProviderName ?? "N/A")</span>
                            </td>
                            <td>
                                <div>@request.RequestDate.ToString("MMM dd")</div>
                                <small class="text-muted">@request.RequestDate.ToString("yyyy")</small>
                            </td>
                            <td>
                                <div class="action-group">
                                    <button type="button" 
                                            class="action-btn-sm btn-icts-view"
                                            data-bs-toggle="modal" 
                                            data-bs-target="#ictsViewModal@(request.Id)">
                                        <i class="bi bi-eye" style="font-size: 11px;"></i> View
                                    </button>
                                    <button type="button" 
                                            class="action-btn-sm btn-icts-process"
                                            data-bs-toggle="modal" 
                                            data-bs-target="#ictsProcessModal@(request.Id)">
                                        <i class="bi bi-sim" style="font-size: 11px;"></i> New SIM
                                    </button>
                                    <button type="button" 
                                            class="action-btn-sm btn-icts-revert"
                                            data-bs-toggle="modal" 
                                            data-bs-target="#ictsRevertModal@(request.Id)">
                                        <i class="bi bi-arrow-left" style="font-size: 11px;"></i> Revert
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox" style="font-size: 3rem; color: #d1d5db;"></i>
            <h5 class="mt-3">No Pending ICTS Requests</h5>
            <p class="text-muted">There are no SIM requests waiting for ICTS processing.</p>
        </div>
    }
</div>

<!-- ICTS Modals for each request -->
@foreach (var request in Model.IctsRequests)
{
    <!-- View Details Modal -->
    <div class="modal fade" id="ictsViewModal@(request.Id)" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" style="border: none; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); max-height: 90vh; overflow: hidden;">
                <!-- Header -->
                <div class="modal-header" style="border: none; padding: 20px 24px; background: #f8fafc; border-radius: 16px 16px 0 0;">
                    <div class="d-flex align-items-center">
                        <div class="me-2" style="width: 40px; height: 40px; background: #0ea5e9; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-eye text-white" style="font-size: 20px;"></i>
                        </div>
                        <div>
                            <h5 class="mb-0" style="font-weight: 600; color: #111827; font-size: 18px;">ICTS Review</h5>
                            <small class="text-muted">@request.FirstName @request.LastName • #SIM-@request.Id.ToString("D6")</small>
                        </div>
                    </div>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body" style="padding: 20px 24px; max-height: calc(90vh - 140px); overflow-y: auto;">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <!-- Employee Info -->
                            <div style="background: #f8fafc; border-radius: 8px; padding: 16px;">
                                <h6 style="font-weight: 600; color: #1e293b; font-size: 14px; margin-bottom: 12px;">
                                    <i class="bi bi-person me-1" style="color: #f59e0b; font-size: 12px;"></i>Employee
                                </h6>
                                <div class="compact-info-row">
                                    <span class="compact-label">Name</span>
                                    <span class="compact-value">@request.FirstName @request.LastName</span>
                                </div>
                                <div class="compact-info-row">
                                    <span class="compact-label">Index No</span>
                                    <span class="compact-value">@request.IndexNo</span>
                                </div>
                                <div class="compact-info-row">
                                    <span class="compact-label">Grade</span>
                                    <span class="compact-value">@request.Grade</span>
                                </div>
                                <div class="compact-info-row">
                                    <span class="compact-label">Email</span>
                                    <span class="compact-value" style="font-size: 12px;">@request.OfficialEmail</span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <!-- Approval Info -->
                            <div style="background: #f8fafc; border-radius: 8px; padding: 16px;">
                                <h6 style="font-weight: 600; color: #1e293b; font-size: 14px; margin-bottom: 12px;">
                                    <i class="bi bi-check-square me-1" style="color: #10b981; font-size: 12px;"></i>Supervisor Approval
                                </h6>
                                <div class="compact-info-row">
                                    <span class="compact-label">Approved By</span>
                                    <span class="compact-value">@(request.SupervisorName ?? "-")</span>
                                </div>
                                <div class="compact-info-row">
                                    <span class="compact-label">Date</span>
                                    <span class="compact-value">@(request.SupervisorApprovalDate?.ToString("MMM dd, yyyy") ?? "-")</span>
                                </div>
                                <div class="compact-info-row">
                                    <span class="compact-label">Service</span>
                                    <span class="compact-value">@(request.MobileService ?? "-")</span>
                                </div>
                                <div class="compact-info-row">
                                    <span class="compact-label">Mobile Allow.</span>
                                    <span class="compact-value">$@(request.MobileServiceAllowance ?? "0")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- SIM Details -->
                    <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px; margin-top: 12px;">
                        <h6 style="font-weight: 600; color: #1e293b; font-size: 14px; margin-bottom: 12px;">
                            <i class="bi bi-sim me-1" style="color: #009edb; font-size: 12px;"></i>SIM Details
                        </h6>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="compact-info-row">
                                    <span class="compact-label">Type</span>
                                    <span class="badge bg-info" style="font-size: 11px;">@request.SimType</span>
                                </div>
                                <div class="compact-info-row">
                                    <span class="compact-label">Provider</span>
                                    <span class="compact-value">@(request.ServiceProvider?.ServiceProviderName ?? "N/A")</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="compact-info-row">
                                    <span class="compact-label">Organization</span>
                                    <span class="compact-value">@request.Organization</span>
                                </div>
                                <div class="compact-info-row">
                                    <span class="compact-label">Office</span>
                                    <span class="compact-value">@request.Office</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer" style="border-top: 1px solid #e5e7eb; padding: 16px 24px; background: #f8fafc; border-radius: 0 0 16px 16px;">
                    <button type="button" class="btn btn-sm" data-bs-dismiss="modal" style="border: 1px solid #0ea5e9; border-radius: 6px; padding: 8px 20px; background: #f0f9ff; color: #0c4a6e; font-weight: 500; font-size: 13px;">
                        <i class="bi bi-x-lg me-1"></i>Close
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- New SIM Modal -->
    <div class="modal fade" id="ictsProcessModal@(request.Id)" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content" style="border: none; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); max-height: 90vh; overflow: hidden;">
                <form method="post" asp-page-handler="ProcessIcts">
                    <input type="hidden" name="requestId" value="@request.Id" />
                    
                    <!-- Header -->
                    <div class="modal-header" style="border: none; padding: 20px 24px; background: #f0fdf4; border-radius: 16px 16px 0 0;">
                        <div class="d-flex align-items-center">
                            <div class="me-2" style="width: 40px; height: 40px; background: #10b981; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-sim-fill text-white" style="font-size: 20px;"></i>
                            </div>
                            <div>
                                <h5 class="mb-0" style="font-weight: 600; color: #111827; font-size: 18px;">Assign New SIM Card</h5>
                                <small class="text-muted">@request.FirstName @request.LastName • #SIM-@request.Id.ToString("D6")</small>
                            </div>
                        </div>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body" style="padding: 20px 24px;">
                        <!-- Request Summary -->
                        <div style="background: #f8fafc; border-radius: 8px; padding: 16px; margin-bottom: 16px;">
                            <h6 style="font-weight: 600; color: #1e293b; font-size: 14px; margin-bottom: 12px;">
                                <i class="bi bi-info-circle me-1" style="color: #009edb; font-size: 12px;"></i>Request Summary
                            </h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="compact-info-row">
                                        <span class="compact-label">Employee</span>
                                        <span class="compact-value">@request.FirstName @request.LastName</span>
                                    </div>
                                    <div class="compact-info-row">
                                        <span class="compact-label">Service</span>
                                        <span class="compact-value">@(request.MobileService ?? "Not specified")</span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="compact-info-row">
                                        <span class="compact-label">SIM Type</span>
                                        <span class="badge bg-info" style="font-size: 11px;">@request.SimType</span>
                                    </div>
                                    <div class="compact-info-row">
                                        <span class="compact-label">Provider</span>
                                        <span class="compact-value">@(request.ServiceProvider?.ServiceProviderName ?? "N/A")</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SIM Details Form -->
                        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 8px; padding: 16px;">
                            <h6 style="font-weight: 600; color: #1e293b; font-size: 14px; margin-bottom: 12px;">
                                <i class="bi bi-sim me-1" style="color: #10b981; font-size: 12px;"></i>SIM Configuration
                            </h6>
                            
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size: 13px; font-weight: 500;">SIM Serial Number <span class="text-danger">*</span></label>
                                    <input type="text" name="simSerialNo" class="form-control form-control-sm" required 
                                           placeholder="Enter SIM serial" style="font-size: 13px;">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size: 13px; font-weight: 500;">Service Request No</label>
                                    <input type="text" name="serviceRequestNo" class="form-control form-control-sm" 
                                           placeholder="Enter service request" style="font-size: 13px;">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size: 13px; font-weight: 500;">Phone Number <span class="text-danger">*</span></label>
                                    <input type="text" name="phoneNumber" class="form-control form-control-sm" required 
                                           placeholder="Enter phone number" style="font-size: 13px;">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size: 13px; font-weight: 500;">Line Type</label>
                                    <select name="lineType" class="form-select form-select-sm" style="font-size: 13px;">
                                        <option value="">Select line type</option>
                                        <option value="Voice">Voice</option>
                                        <option value="Data">Data</option>
                                        <option value="Voice + Data">Voice + Data</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size: 13px; font-weight: 500;">SIM PUK</label>
                                    <input type="text" name="simPuk" class="form-control form-control-sm" 
                                           placeholder="Enter PUK code" style="font-size: 13px;">
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label" style="font-size: 13px; font-weight: 500;">PIN</label>
                                    <input type="text" name="pin" class="form-control form-control-sm" 
                                           placeholder="Enter PIN" style="font-size: 13px;">
                                </div>
                            </div>
                            
                            <div class="mt-3">
                                <label class="form-label" style="font-size: 13px; font-weight: 500;">Processing Notes</label>
                                <textarea name="processingNotes" class="form-control form-control-sm" rows="2" 
                                          placeholder="Add any processing notes..." style="font-size: 13px;"></textarea>
                            </div>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer" style="border-top: 1px solid #e5e7eb; padding: 16px 24px; gap: 10px; background: #f8fafc; border-radius: 0 0 16px 16px;">
                        <button type="button" class="btn btn-sm" data-bs-dismiss="modal" 
                                style="border: 1px solid #d1d5db; border-radius: 6px; padding: 8px 20px; background: #ffffff; color: #6b7280; font-weight: 500; font-size: 13px;">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-sm" 
                                style="border: none; border-radius: 6px; padding: 8px 20px; background: #10b981; color: #ffffff; font-weight: 500; font-size: 13px;">
                            <i class="bi bi-sim-fill me-1"></i>
                            Assign SIM & Complete
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Revert Modal -->
    <div class="modal fade" id="ictsRevertModal@(request.Id)" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border: none; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
                <form method="post" asp-page-handler="RevertIcts">
                    <input type="hidden" name="requestId" value="@request.Id" />
                    
                    <!-- Header -->
                    <div class="modal-header" style="border: none; padding: 20px 24px; background: #fffbeb; border-radius: 16px 16px 0 0;">
                        <div class="d-flex align-items-center">
                            <div class="me-2" style="width: 40px; height: 40px; background: #f59e0b; border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                                <i class="bi bi-arrow-left-circle text-white" style="font-size: 20px;"></i>
                            </div>
                            <div>
                                <h5 class="mb-0" style="font-weight: 600; color: #111827; font-size: 18px;">Revert to Requestor</h5>
                                <small class="text-muted">@request.FirstName @request.LastName • #SIM-@request.Id.ToString("D6")</small>
                            </div>
                        </div>
                        <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                    </div>

                    <div class="modal-body" style="padding: 20px 24px;">
                        <!-- Request Info -->
                        <div style="background: #f8fafc; border-radius: 8px; padding: 16px; margin-bottom: 16px;">
                            <div class="compact-info-row">
                                <span class="compact-label">Employee</span>
                                <span class="compact-value">@request.FirstName @request.LastName</span>
                            </div>
                            <div class="compact-info-row">
                                <span class="compact-label">SIM Type</span>
                                <span class="badge bg-info" style="font-size: 11px;">@request.SimType</span>
                            </div>
                            <div class="compact-info-row">
                                <span class="compact-label">Organization</span>
                                <span class="compact-value">@request.Organization</span>
                            </div>
                        </div>

                        <!-- Revert Reason -->
                        <div>
                            <label class="form-label" style="font-weight: 500; color: #374151; font-size: 14px; margin-bottom: 8px;">
                                Reason for Reverting <span style="color: #ef4444;">*</span>
                            </label>
                            <textarea name="revertReason" class="form-control" rows="3" required 
                                    placeholder="Explain why this request needs to be corrected..." 
                                    style="border: 1px solid #d1d5db; border-radius: 6px; padding: 10px 12px; font-size: 13px; resize: none;"></textarea>
                            <small class="text-muted">This message will be sent to the requestor.</small>
                        </div>

                        <!-- Warning -->
                        <div class="d-flex align-items-start mt-3" style="background: #fffbeb; border: 1px solid #fbbf24; border-radius: 6px; padding: 10px;">
                            <i class="bi bi-exclamation-triangle-fill me-2" style="color: #f59e0b; font-size: 14px; flex-shrink: 0; margin-top: 1px;"></i>
                            <small style="color: #92400e;">This will send the request back to the employee for corrections.</small>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer" style="border-top: 1px solid #e5e7eb; padding: 16px 24px; gap: 10px; background: #f8fafc; border-radius: 0 0 16px 16px;">
                        <button type="button" class="btn btn-sm" data-bs-dismiss="modal" 
                                style="border: 1px solid #d1d5db; border-radius: 6px; padding: 8px 20px; background: #ffffff; color: #6b7280; font-weight: 500; font-size: 13px;">
                            Cancel
                        </button>
                        <button type="submit" class="btn btn-sm" 
                                style="border: none; border-radius: 6px; padding: 8px 20px; background: #f59e0b; color: #ffffff; font-weight: 500; font-size: 13px;">
                            <i class="bi bi-arrow-left me-1"></i>
                            Revert to Requestor
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

<style>
    .compact-info-row {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
        border-bottom: 1px solid #f1f5f9;
    }
    .compact-info-row:last-child {
        border-bottom: none;
    }
    .compact-label {
        font-size: 12px;
        color: #64748b;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .compact-value {
        font-size: 13px;
        color: #1e293b;
        font-weight: 500;
    }
</style>