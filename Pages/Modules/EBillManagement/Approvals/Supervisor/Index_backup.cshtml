@page
@model TAB.Web.Pages.Modules.EBillManagement.Approvals.Supervisor.IndexModel
@{
    ViewData["Title"] = "E-Bills - Supervisor Dashboard";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-2 bg-light border-end vh-100 position-fixed">
            <div class="d-flex flex-column p-3">
                <h5 class="text-primary mb-4">
                    <i class="bi bi-person-badge"></i> Supervisor
                </h5>
                <ul class="nav nav-pills flex-column">
                    <li class="nav-item mb-2">
                        <a class="nav-link" href="/Supervisor/Dashboard">
                            <i class="bi bi-speedometer2"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a class="nav-link" href="/Supervisor/SimRequests">
                            <i class="bi bi-sim"></i> SIM Requests
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a class="nav-link" href="/Supervisor/RefundRequests">
                            <i class="bi bi-cash-coin"></i> Refund Requests
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a class="nav-link active" href="/Supervisor/EBills">
                            <i class="bi bi-receipt"></i> E-Bills
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a class="nav-link" href="/Supervisor/ICTS">
                            <i class="bi bi-gear-fill"></i> ICTS Processing
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-10 offset-md-2">
            <div class="p-4">
                <!-- Header -->
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="mb-1">
                            <i class="bi bi-receipt text-primary"></i> E-Bills Management
                        </h2>
                        <p class="text-muted mb-0">Manage electronic bill requests requiring your approval</p>
                    </div>
                    <div class="text-end">
                        <small class="text-muted">Supervisor: @Model.CurrentSupervisorName</small>
                    </div>
                </div>

                <!-- Status Messages -->
                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="alert alert-@Model.StatusMessageClass alert-dismissible fade show" role="alert">
                        @Model.StatusMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <!-- Summary Cards -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <div class="card border-warning">
                            <div class="card-body text-center">
                                <i class="bi bi-clock-history fs-1 text-warning"></i>
                                <h3 class="card-title text-warning">@Model.PendingCount</h3>
                                <p class="card-text">Pending Approval</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-success">
                            <div class="card-body text-center">
                                <i class="bi bi-check-circle fs-1 text-success"></i>
                                <h3 class="card-title text-success">@Model.ProcessedCount</h3>
                                <p class="card-text">Processed</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-danger">
                            <div class="card-body text-center">
                                <i class="bi bi-x-circle fs-1 text-danger"></i>
                                <h3 class="card-title text-danger">@Model.RejectedCount</h3>
                                <p class="card-text">Rejected</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tabs -->
                <ul class="nav nav-tabs" id="ebillTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab">
                            <i class="bi bi-clock"></i> Pending (@Model.PendingCount)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="processed-tab" data-bs-toggle="tab" data-bs-target="#processed" type="button" role="tab">
                            <i class="bi bi-check-circle"></i> Processed (@Model.ProcessedCount)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="rejected-tab" data-bs-toggle="tab" data-bs-target="#rejected" type="button" role="tab">
                            <i class="bi bi-x-circle"></i> Rejected (@Model.RejectedCount)
                        </button>
                    </li>
                </ul>

                <!-- Tab Content -->
                <div class="tab-content" id="ebillTabsContent">
                    <!-- Pending Requests -->
                    <div class="tab-pane fade show active" id="pending" role="tabpanel">
                        <div class="card">
                            <div class="card-body">
                                @if (Model.PendingRequests.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Request Details</th>
                                                    <th>Bill Info</th>
                                                    <th>Amount</th>
                                                    <th>Due Date</th>
                                                    <th>Priority</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var request in Model.PendingRequests)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div>
                                                                <strong>@request.FullName</strong>
                                                                <br><small class="text-muted">@request.Email</small>
                                                                <br><small class="text-muted">@request.Department</small>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div>
                                                                <i class="bi @Model.GetBillTypeIcon(request.BillType)"></i>
                                                                <strong>@request.BillType</strong>
                                                                <br><small>@request.ServiceProvider?.ServiceProviderName</small>
                                                                <br><small class="text-muted">Acc: @request.AccountNumber</small>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span class="fw-bold">$@request.BillAmount.ToString("N2")</span>
                                                        </td>
                                                        <td>
                                                            <small>@request.DueDate.ToString("MMM dd, yyyy")</small>
                                                        </td>
                                                        <td>
                                                            @{
                                                                var priority = Model.GetPriority(request.RequestDate, request.DueDate);
                                                                var priorityClass = priority == "Overdue" || priority == "Urgent" ? "danger" : 
                                                                                   (priority == "High" ? "warning" : 
                                                                                   (priority == "Medium" ? "info" : "success"));
                                                            }
                                                            <span class="badge bg-@priorityClass">@priority</span>
                                                        </td>
                                                        <td>
                                                            <div class="btn-group" role="group">
                                                                <button type="button" class="btn btn-sm btn-success" 
                                                                        onclick="approveRequest(@request.Id, '@request.FullName')">
                                                                    <i class="bi bi-check"></i> Approve
                                                                </button>
                                                                <button type="button" class="btn btn-sm btn-warning" 
                                                                        onclick="rejectRequest(@request.Id, '@request.FullName')">
                                                                    <i class="bi bi-x"></i> Reject
                                                                </button>
                                                                <button type="button" class="btn btn-sm btn-info" 
                                                                        onclick="revertRequest(@request.Id, '@request.FullName')">
                                                                    <i class="bi bi-arrow-counterclockwise"></i> Revert
                                                                </button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-5">
                                        <i class="bi bi-inbox display-1 text-muted"></i>
                                        <h4 class="text-muted">No pending E-bill requests</h4>
                                        <p class="text-muted">All E-bill requests have been processed.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Processed Requests -->
                    <div class="tab-pane fade" id="processed" role="tabpanel">
                        <div class="card">
                            <div class="card-body">
                                @if (Model.ProcessedRequests.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Request Details</th>
                                                    <th>Bill Info</th>
                                                    <th>Amount</th>
                                                    <th>Status</th>
                                                    <th>Processed Date</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var request in Model.ProcessedRequests)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div>
                                                                <strong>@request.FullName</strong>
                                                                <br><small class="text-muted">@request.Email</small>
                                                                <br><small class="text-muted">@request.Department</small>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div>
                                                                <i class="bi @Model.GetBillTypeIcon(request.BillType)"></i>
                                                                <strong>@request.BillType</strong>
                                                                <br><small>@request.ServiceProvider?.ServiceProviderName</small>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span class="fw-bold">$@request.BillAmount.ToString("N2")</span>
                                                        </td>
                                                        <td>
                                                            <span class="@Model.GetStatusBadgeClass(request.Status)">
                                                                <i class="bi @Model.GetStatusIcon(request.Status)"></i>
                                                                @request.Status.ToString()
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <small>@request.SupervisorApprovalDate?.ToString("MMM dd, yyyy HH:mm")</small>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-5">
                                        <i class="bi bi-inbox display-1 text-muted"></i>
                                        <h4 class="text-muted">No processed E-bill requests</h4>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Rejected Requests -->
                    <div class="tab-pane fade" id="rejected" role="tabpanel">
                        <div class="card">
                            <div class="card-body">
                                @if (Model.RejectedRequests.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-hover">
                                            <thead class="table-light">
                                                <tr>
                                                    <th>Request Details</th>
                                                    <th>Bill Info</th>
                                                    <th>Amount</th>
                                                    <th>Rejection Date</th>
                                                    <th>Notes</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var request in Model.RejectedRequests)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div>
                                                                <strong>@request.FullName</strong>
                                                                <br><small class="text-muted">@request.Email</small>
                                                                <br><small class="text-muted">@request.Department</small>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <div>
                                                                <i class="bi @Model.GetBillTypeIcon(request.BillType)"></i>
                                                                <strong>@request.BillType</strong>
                                                                <br><small>@request.ServiceProvider?.ServiceProviderName</small>
                                                            </div>
                                                        </td>
                                                        <td>
                                                            <span class="fw-bold">$@request.BillAmount.ToString("N2")</span>
                                                        </td>
                                                        <td>
                                                            <small>@request.SupervisorApprovalDate?.ToString("MMM dd, yyyy HH:mm")</small>
                                                        </td>
                                                        <td>
                                                            <small>@request.SupervisorNotes</small>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-center py-5">
                                        <i class="bi bi-inbox display-1 text-muted"></i>
                                        <h4 class="text-muted">No rejected E-bill requests</h4>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Action Modals -->
<div class="modal fade" id="actionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="actionModalTitle">Confirm Action</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="actionForm" method="post">
                <div class="modal-body">
                    <div id="actionMessage"></div>
                    <div class="mb-3">
                        <label for="notes" class="form-label">Notes (Optional)</label>
                        <textarea class="form-control" id="notes" name="notes" rows="3" placeholder="Enter any additional notes..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn" id="actionButton">Confirm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function approveRequest(requestId, fullName) {
            showActionModal('Approve E-Bill Request', 
                `Are you sure you want to approve the E-bill request for <strong>${fullName}</strong>?`, 
                'OnPostApprove', requestId, 'btn-success', 'Approve');
        }

        function rejectRequest(requestId, fullName) {
            showActionModal('Reject E-Bill Request', 
                `Are you sure you want to reject the E-bill request for <strong>${fullName}</strong>?`, 
                'OnPostReject', requestId, 'btn-warning', 'Reject');
        }

        function revertRequest(requestId, fullName) {
            showActionModal('Revert E-Bill Request', 
                `Are you sure you want to revert the E-bill request for <strong>${fullName}</strong> back to the requestor?`, 
                'OnPostRevert', requestId, 'btn-info', 'Revert');
        }

        function showActionModal(title, message, action, requestId, buttonClass, buttonText) {
            document.getElementById('actionModalTitle').textContent = title;
            document.getElementById('actionMessage').innerHTML = message;
            document.getElementById('actionForm').action = `?handler=${action}`;
            
            // Add hidden input for requestId
            let existingInput = document.getElementById('requestIdInput');
            if (existingInput) {
                existingInput.remove();
            }
            let input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'requestId';
            input.value = requestId;
            input.id = 'requestIdInput';
            document.getElementById('actionForm').appendChild(input);
            
            // Set button styling
            const actionButton = document.getElementById('actionButton');
            actionButton.className = `btn ${buttonClass}`;
            actionButton.textContent = buttonText;
            
            // Show modal
            new bootstrap.Modal(document.getElementById('actionModal')).show();
        }
    </script>
} 