        // Verify all calls to a specific dialed number
        function verifyAllDialedNumber(dialedGroupId, verificationType) {
            // Get all call checkboxes in this dialed number group that are not locked/expired
            const dialedNumberCheckboxes = document.querySelectorAll(`.call-checkbox[data-group="${dialedGroupId}"]`);
            const verifiableCallIds = [];
            let lockedCount = 0;
            let expiredCount = 0;
            let submittedPendingCount = 0;

            dialedNumberCheckboxes.forEach(checkbox => {
                const isLocked = checkbox.getAttribute('data-locked') === 'true';
                const isExpired = checkbox.getAttribute('data-expired') === 'true';
                const isVerified = checkbox.getAttribute('data-verified') === 'true';
                const isSubmitted = checkbox.getAttribute('data-submitted') === 'true';
                const approvalStatus = checkbox.getAttribute('data-approval-status') || '';

                if (isLocked) {
                    // Locked means approved/partially approved by supervisor - cannot change
                    lockedCount++;
                } else if (isExpired) {
                    expiredCount++;
                } else if (isVerified && isSubmitted && approvalStatus === 'Pending') {
                    // Submitted but still pending - can still be changed, so it's verifiable
                    submittedPendingCount++;
                    verifiableCallIds.push(checkbox.value);
                } else if (isVerified && !isSubmitted) {
                    // Verified but not submitted yet - can still be changed
                    verifiableCallIds.push(checkbox.value);
                } else if (!isVerified) {
                    // Not verified at all
                    verifiableCallIds.push(checkbox.value);
                }
            });

            // Check if there are any calls to verify
            if (verifiableCallIds.length === 0) {
                const totalCalls = dialedNumberCheckboxes.length;

                // Build detailed message
                let details = [];
                if (lockedCount > 0) details.push(`${lockedCount} locked (approved by supervisor)`);
                if (expiredCount > 0) details.push(`${expiredCount} expired`);

                let message = '';
                if (totalCalls === 0) {
                    message = 'No calls found for this number.';
                } else if (details.length > 0) {
                    message = `All ${totalCalls} call(s) to this number are: ${details.join(', ')}.`;
                } else {
                    message = `All ${totalCalls} call(s) to this number cannot be verified at this time.`;
                }

                showNotification('info', 'No Calls to Mark', message);
                return;
            }

            // Prepare confirmation modal content
            const callWord = verifiableCallIds.length === 1 ? 'call' : 'calls';
            const typeLabel = verificationType === 'Official' ? 'Official (work-related)' : 'Personal';
            const typeColor = verificationType === 'Official' ? 'success' : 'warning';

            let noteHtml = '';
            if (lockedCount > 0 || expiredCount > 0 || submittedPendingCount > 0) {
                let notes = [];
                if (lockedCount > 0) notes.push(`<li>${lockedCount} locked (approved by supervisor) call(s) will be skipped</li>`);
                if (expiredCount > 0) notes.push(`<li>${expiredCount} expired call(s) will be skipped</li>`);
                if (submittedPendingCount > 0) notes.push(`<li>${submittedPendingCount} call(s) are submitted and pending approval - they will be updated</li>`);
                noteHtml = `<div class="alert alert-info mt-3"><strong>Note:</strong><ul class="mb-0 mt-2">${notes.join('')}</ul></div>`;
            }

            // Show custom confirmation modal
            showConfirmation(
                `Mark ${verifiableCallIds.length} ${callWord} to this number?`,
                `You are about to mark <strong>${verifiableCallIds.length} ${callWord}</strong> to this dialed number as <span class="badge bg-${typeColor}">${typeLabel}</span>.${noteHtml}`,
                'Yes, Mark',
                () => {
                    // User confirmed - submit form
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '?handler=QuickVerify';

                    // Add anti-forgery token
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    form.appendChild(tokenInput);

                    // Add verification type
                    const typeInput = document.createElement('input');
                    typeInput.type = 'hidden';
                    typeInput.name = 'verificationType';
                    typeInput.value = verificationType;
                    form.appendChild(typeInput);

                    // Add all verifiable call IDs
                    verifiableCallIds.forEach(callId => {
                        const idInput = document.createElement('input');
                        idInput.type = 'hidden';
                        idInput.name = 'selectedIds';
                        idInput.value = callId;
                        form.appendChild(idInput);
                    });

                    // Show loading overlay
                    showLoadingOverlay(
                        'Marking Calls...',
                        `Marking ${verifiableCallIds.length} call(s) as ${verificationType}. This may take a moment.`
                    );

                    document.body.appendChild(form);
                    form.submit();
                }
            );
        }

        // Custom confirmation modal function
        function showConfirmation(title, message, confirmText, onConfirm, onCancel) {
            // Remove existing modal if any
            const existingModal = document.getElementById('customConfirmModal');
            if (existingModal) {
                existingModal.remove();
            }

            // Create modal HTML with your app's design style
            const modalHtml = `
                <div class="modal fade" id="customConfirmModal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.15);">
                            <div class="modal-header bg-primary text-white" style="border-bottom: none; padding: 1.5rem; border-radius: 16px 16px 0 0;">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-white rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                        <i class="bi bi-question-circle-fill text-primary" style="font-size: 1.5rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="modal-title fw-bold text-white mb-0">${title}</h5>
                                        <p class="text-white text-opacity-75 small mb-0">Please confirm your action</p>
                                    </div>
                                </div>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body" style="padding: 1.5rem;">
                                ${message}
                            </div>
                            <div class="modal-footer" style="border-top: 1px solid #e5e7eb; padding: 1rem 1.5rem;">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 8px;">
                                    <i class="bi bi-x-lg me-1"></i>Cancel
                                </button>
                                <button type="button" class="btn btn-primary" id="confirmModalBtn" style="border-radius: 8px;">
                                    <i class="bi bi-check-lg me-1"></i>${confirmText}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            // Add modal to page
            document.body.insertAdjacentHTML('beforeend', modalHtml);

            // Get modal element
            const modalElement = document.getElementById('customConfirmModal');
            const modal = new bootstrap.Modal(modalElement);

            // Handle confirm button
            document.getElementById('confirmModalBtn').addEventListener('click', () => {
                modal.hide();
                if (onConfirm) onConfirm();
            });

            // Handle modal hidden (cleanup)
            modalElement.addEventListener('hidden.bs.modal', () => {
                if (!modalElement.classList.contains('confirmed')) {
                    if (onCancel) onCancel();
                }
                modalElement.remove();
            });

            // Handle confirm button to mark as confirmed
            document.getElementById('confirmModalBtn').addEventListener('click', () => {
                modalElement.classList.add('confirmed');
            }, { once: true });

            // Show modal
            modal.show();
        }

        // Store selected IDs for confirmation
        let pendingVerificationIds = [];
        let pendingVerificationType = '';

        function quickVerifySelected(verificationType) {
            // Only get unverified, non-expired calls (both static and AJAX-loaded)
            const selectedCheckboxes = Array.from(document.querySelectorAll('.call-checkbox:checked, .call-checkbox-ajax:checked'));
            const expiredCount = selectedCheckboxes.filter(cb => cb.getAttribute('data-expired') === 'true').length;
            const selectedIds = selectedCheckboxes
                .filter(cb => cb.getAttribute('data-verified') === 'false' && cb.getAttribute('data-expired') === 'false')
                .map(cb => cb.value);

            if (expiredCount > 0) {
                // Show warning in modal instead of alert
                showWarningModal(`Warning: ${expiredCount} expired call(s) cannot be verified. They will be automatically recovered.`);
            }

            if (selectedIds.length === 0) {
                showWarningModal('Please select at least one unverified, non-expired call.');
                return;
            }

            // Store the data for later submission
            pendingVerificationIds = selectedIds;
            pendingVerificationType = verificationType;

            // Show appropriate modal
            if (verificationType === 'Official') {
                document.getElementById('officialCallCount').textContent = `${selectedIds.length} call${selectedIds.length !== 1 ? 's' : ''}`;
                const modal = new bootstrap.Modal(document.getElementById('confirmOfficialModal'));
                modal.show();
            } else if (verificationType === 'Personal') {
                document.getElementById('personalCallCount').textContent = `${selectedIds.length} call${selectedIds.length !== 1 ? 's' : ''}`;
                const modal = new bootstrap.Modal(document.getElementById('confirmPersonalModal'));
                modal.show();
            }
        }

