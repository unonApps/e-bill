        function showWarningModal(message) {
            // Create a simple alert-style modal for warnings
            const alertDiv = document.createElement('div');
            alertDiv.className = 'alert alert-warning alert-dismissible fade show position-fixed';
            alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; max-width: 400px;';
            alertDiv.innerHTML = `
                <i class="bi bi-exclamation-triangle me-2"></i>${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);

            // Auto-dismiss after 5 seconds
            setTimeout(() => {
                alertDiv.classList.remove('show');
                setTimeout(() => alertDiv.remove(), 300);
            }, 5000);
        }

        // Assignment Accept/Reject Functions
        let currentCallRecordId = null;

        function showAcceptModal(callRecordId, callNumber, amount, fromUser) {
            currentCallRecordId = callRecordId;
            document.getElementById('acceptCallNumber').textContent = callNumber;
            document.getElementById('acceptCallAmount').textContent = '$' + amount;
            document.getElementById('acceptFromUser').textContent = fromUser || 'Unknown';
            const modal = new bootstrap.Modal(document.getElementById('acceptAssignmentModal'));
            modal.show();
        }

        async function confirmAcceptAssignment() {
            try {
                const response = await fetch(`/Modules/EBillManagement/CallRecords/MyCallLogs?handler=AcceptAssignment&callRecordId=${currentCallRecordId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();

                if (result.success) {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('acceptAssignmentModal'));
                    modal.hide();
                    alert('Assignment accepted successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                alert('Error accepting assignment: ' + error.message);
            }
        }

        function showRejectModal(callRecordId, callNumber, amount, fromUser) {
            currentCallRecordId = callRecordId;
            document.getElementById('rejectCallNumber').textContent = callNumber;
            document.getElementById('rejectCallAmount').textContent = '$' + amount;
            document.getElementById('rejectFromUser').textContent = fromUser || 'Unknown';
            document.getElementById('rejectionReason').value = '';
            document.getElementById('rejectionReason').classList.remove('is-invalid');
            const modal = new bootstrap.Modal(document.getElementById('rejectAssignmentModal'));
            modal.show();
        }

        async function confirmRejectAssignment() {
            const reason = document.getElementById('rejectionReason').value.trim();
            const reasonField = document.getElementById('rejectionReason');

            if (!reason) {
                reasonField.classList.add('is-invalid');
                return;
            }

            reasonField.classList.remove('is-invalid');

            try {
                const response = await fetch(`/Modules/EBillManagement/CallRecords/MyCallLogs?handler=RejectAssignment`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        callRecordId: currentCallRecordId,
                        reason: reason
                    })
                });

                const result = await response.json();

                if (result.success) {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('rejectAssignmentModal'));
                    modal.hide();
                    alert('Assignment rejected successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                alert('Error rejecting assignment: ' + error.message);
            }
        }

