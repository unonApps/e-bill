        function validateOverageJustifications() {
            const justifications = document.querySelectorAll('.phone-overage-justification');
            const documents = document.querySelectorAll('.phone-overage-document');

            let valid = true;

            justifications.forEach(textarea => {
                if (textarea.required && !textarea.value.trim()) {
                    textarea.classList.add('is-invalid');
                    valid = false;
                } else {
                    textarea.classList.remove('is-invalid');
                }
            });

            documents.forEach(input => {
                if (input.required && input.files.length === 0) {
                    input.classList.add('is-invalid');
                    valid = false;
                } else {
                    input.classList.remove('is-invalid');
                }
            });

            if (!valid) {
                showNotification('warning', 'Validation Error', 'Please provide justification and supporting document for all overage extensions.');
            }

            return valid;
        }

        async function confirmSubmitToSupervisor() {
            // Validate overage justifications if required
            if (submissionData && submissionData.hasAnyPhoneOverage) {
                if (!validateOverageJustifications()) {
                    return;
                }
            }

            // Collect form data
            const formData = new FormData();

            // Add call record IDs
            submissionData.callRecordIds.forEach(id => formData.append('callRecordIds', id));

            // Add phone overage justifications
            const justifications = document.querySelectorAll('.phone-overage-justification');
            const documents = document.querySelectorAll('.phone-overage-document');
            const userPhoneIds = document.querySelectorAll('.phone-overage-userphoneid');

            let index = 0;
            userPhoneIds.forEach((input) => {
                const userPhoneId = input.value;
                const justificationTextarea = document.querySelector(`.phone-overage-justification[data-userphone-id="${userPhoneId}"]`);
                const documentInput = document.querySelector(`.phone-overage-document[data-userphone-id="${userPhoneId}"]`);

                if (justificationTextarea && justificationTextarea.value.trim()) {
                    formData.append(`phoneOverageJustifications[${index}].UserPhoneId`, userPhoneId);
                    formData.append(`phoneOverageJustifications[${index}].Justification`, justificationTextarea.value.trim());

                    if (documentInput && documentInput.files.length > 0) {
                        formData.append(`phoneOverageJustifications[${index}].Document`, documentInput.files[0]);
                    }
                    index++;
                }
            });

            // Add antiforgery token to form data
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                formData.append('__RequestVerificationToken', token.value);
            }

            // Show loading state on button
            const btn = document.getElementById('btnConfirmSubmit');
            const originalText = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Submitting...';

            try {
                // Submit
                const response = await fetch('?handler=SubmitToSupervisor', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();

                if (result.success) {
                    bootstrap.Modal.getInstance(document.getElementById('submitToSupervisorModal')).hide();
                    showNotification('success', 'Success', result.message);
                    // Refresh page after a short delay to show updated status
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showNotification('error', 'Submission Failed', result.message);
                    btn.disabled = false;
                    btn.innerHTML = originalText;
                }
            } catch (error) {
                console.error('Error submitting to supervisor:', error);
                showNotification('error', 'Error', 'Failed to submit. Please try again.');
                btn.disabled = false;
                btn.innerHTML = originalText;
            }
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Store current verification data
        let currentVerificationData = null;

        // Quick verify single call from inline dropdown
        function quickVerifyCall(callId, verificationType, callNumber, costUSD, costKSH, duration, callDate, dropdownElement) {
            // Reset dropdown if no selection
            if (!verificationType) {
                return;
            }

            // Validate: Check if call is expired
            const isExpired = dropdownElement.getAttribute('data-expired') === 'true';
            const isLocked = dropdownElement.getAttribute('data-locked') === 'true';
            const deadline = dropdownElement.getAttribute('data-deadline');

            if (isExpired) {
                showNotification('error', 'Verification Expired',
                    `This call cannot be verified. The verification deadline (${deadline}) has passed.`);
                // Reset dropdown
                dropdownElement.selectedIndex = 0;
                return;
            }

            if (isLocked) {
                showNotification('warning', 'Call Locked',
                    'This call is locked and cannot be verified at this time. It may be pending assignment acceptance or already approved by supervisor.');
                // Reset dropdown
                dropdownElement.selectedIndex = 0;
                return;
            }

            // Store data for confirmation
            currentVerificationData = { callId, verificationType };

            // Configure modal based on verification type
            const isOfficial = verificationType === 'Official';
            const modalHeader = document.getElementById('quickVerifyModalHeader');
            const modalIcon = document.getElementById('quickVerifyIcon');
            const modalTitle = document.getElementById('quickVerifyTitle');
            const modalMessage = document.getElementById('quickVerifyMessage');
            const confirmBtn = document.getElementById('confirmQuickVerifyBtn');
            const noteAlert = document.getElementById('quickVerifyNote');
            const noteIcon = document.getElementById('quickVerifyNoteIcon');
            const noteText = document.getElementById('quickVerifyNoteText');
            const btnText = document.getElementById('confirmVerifyBtnText');

            // Set colors and content
            if (isOfficial) {
                modalHeader.style.background = '#10b981';
                modalHeader.style.color = 'white';
                modalHeader.querySelector('.btn-close').classList.add('btn-close-white');
                modalIcon.className = 'bi bi-check-circle-fill me-2';
                modalTitle.textContent = 'Mark as Official';
                modalMessage.textContent = 'You are about to mark this call as Official (work-related).';
                confirmBtn.className = 'btn btn-success';
                btnText.textContent = 'Mark as Official';
                noteAlert.className = 'alert alert-success mt-3 mb-0';
                noteIcon.className = 'bi bi-check-circle-fill me-2';
                noteText.textContent = 'This call will count towards your official usage and allowance.';
            } else {
                modalHeader.style.background = '#f59e0b';
                modalHeader.style.color = 'white';
                modalHeader.querySelector('.btn-close').classList.add('btn-close-white');
                modalIcon.className = 'bi bi-exclamation-triangle-fill me-2';
                modalTitle.textContent = 'Mark as Personal';
                modalMessage.textContent = 'You are about to mark this call as Personal (non-work-related).';
                confirmBtn.className = 'btn btn-warning';
                btnText.textContent = 'Mark as Personal';
                noteAlert.className = 'alert alert-warning mt-3 mb-0';
                noteIcon.className = 'bi bi-exclamation-triangle-fill me-2';
                noteText.textContent = 'This call may require payment or reimbursement.';
            }

            // Fill in call details
            document.getElementById('verifyCallNumber').textContent = callNumber;
            document.getElementById('verifyCallCost').textContent = `$${costUSD} (KSh ${costKSH})`;
            document.getElementById('verifyCallDuration').textContent = `${duration} min`;
            document.getElementById('verifyCallDate').textContent = callDate;

            // Show modal
            const modalElement = document.getElementById('quickVerifyModal');
            const modal = new bootstrap.Modal(modalElement);

            // Reset dropdown if modal is dismissed without confirming
            modalElement.addEventListener('hidden.bs.modal', function () {
                if (currentVerificationData) {
                    const dropdown = document.querySelector(`select[data-call-id="${currentVerificationData.callId}"]`);
                    if (dropdown) {
                        dropdown.selectedIndex = 0;
                    }
                    currentVerificationData = null;
                }
            }, { once: true });

            modal.show();
        }

        // Confirm quick verification from modal
        function confirmQuickVerify() {
            if (!currentVerificationData) return;

            const { callId, verificationType } = currentVerificationData;

            // Close modal
            const modalElement = document.getElementById('quickVerifyModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            modal.hide();

            // Create form and submit
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=QuickVerify';

            // Add anti-forgery token
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
            form.appendChild(tokenInput);

            // Add verification type
            const typeInput = document.createElement('input');
            typeInput.type = 'hidden';
            typeInput.name = 'verificationType';
            typeInput.value = verificationType;
            form.appendChild(typeInput);

            // Add call ID
            const idInput = document.createElement('input');
            idInput.type = 'hidden';
            idInput.name = 'selectedIds';
            idInput.value = callId;
            form.appendChild(idInput);

            // Show loading overlay
            showLoadingOverlay('Marking Call...', `Marking call as ${verificationType}.`);

            document.body.appendChild(form);
            form.submit();
        }

        // Verify ALL calls for an extension in a specific month/year (server-side)
        // This verifies all records in the database, not just visible ones
        function verifyAllCallsForExtensionMonth(extension, month, year, verificationType, totalCallCount) {
            // Reset dropdown if no selection
            if (!verificationType) {
                return;
            }

            const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
                              'July', 'August', 'September', 'October', 'November', 'December'];
            const monthName = monthNames[month - 1];

            // Prepare confirmation modal content
            const typeLabel = verificationType === 'Official' ? 'Official (work-related)' : 'Personal';
            const typeColor = verificationType === 'Official' ? 'success' : 'warning';

            // Show custom confirmation modal
            showConfirmation(
                `Mark All Calls?`,
                `You are about to mark <strong>ALL calls</strong> for extension <strong>${extension}</strong> in <strong>${monthName} ${year}</strong> as <span class="badge bg-${typeColor}">${typeLabel}</span>.`,
                'Yes, Mark All',
                () => {
                    // User confirmed - submit form
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '?handler=VerifyAllByExtensionMonth';

                    // Add anti-forgery token
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    form.appendChild(tokenInput);

                    // Add extension
                    const extInput = document.createElement('input');
                    extInput.type = 'hidden';
                    extInput.name = 'extension';
                    extInput.value = extension;
                    form.appendChild(extInput);

                    // Add month
                    const monthInput = document.createElement('input');
                    monthInput.type = 'hidden';
                    monthInput.name = 'month';
                    monthInput.value = month;
                    form.appendChild(monthInput);

                    // Add year
                    const yearInput = document.createElement('input');
                    yearInput.type = 'hidden';
                    yearInput.name = 'year';
                    yearInput.value = year;
                    form.appendChild(yearInput);

                    // Add verification type
                    const typeInput = document.createElement('input');
                    typeInput.type = 'hidden';
                    typeInput.name = 'verificationType';
                    typeInput.value = verificationType;
                    form.appendChild(typeInput);

                    // Show loading overlay before submit
                    showLoadingOverlay(
                        'Marking Calls...',
                        `Marking all calls for ${extension} as ${verificationType}. This may take a moment.`
                    );

                    document.body.appendChild(form);
                    form.submit();
                },
                () => {
                    // User cancelled - reset dropdown
                    event.target.selectedIndex = 0;
                }
            );
        }

        // Verify all calls in a group (extension + month + year) - OLD VERSION (visible calls only)
        function verifyAllCallsInGroup(groupId, verificationType) {
            // Reset dropdown if no selection
            if (!verificationType) {
                return;
            }

            // Get all call checkboxes in this group that are not locked/expired
            // Note: groupId is extension-level, but calls have data-group like "groupId_dialed_number"
            // So we need to find all checkboxes whose data-group starts with groupId + "_dialed_"
            const groupCheckboxes = document.querySelectorAll(`.call-checkbox[data-group^="${groupId}_dialed_"]`);
            const verifiableCallIds = [];
            let lockedCount = 0;
            let expiredCount = 0;
            let submittedPendingCount = 0;

            groupCheckboxes.forEach(checkbox => {
                const isLocked = checkbox.getAttribute('data-locked') === 'true';
                const isExpired = checkbox.getAttribute('data-expired') === 'true';
                const isVerified = checkbox.getAttribute('data-verified') === 'true';
                const isSubmitted = checkbox.getAttribute('data-submitted') === 'true';
                const approvalStatus = checkbox.getAttribute('data-approval-status') || '';

                if (isLocked) {
                    // Locked means approved/partially approved by supervisor - cannot change
                    lockedCount++;
                } else if (isExpired) {
                    expiredCount++;
                } else if (isVerified && isSubmitted && approvalStatus === 'Pending') {
                    // Submitted but still pending - can still be changed, so it's verifiable
                    submittedPendingCount++;
                    verifiableCallIds.push(checkbox.value);
                } else if (isVerified && !isSubmitted) {
                    // Verified but not submitted yet - can still be changed
                    verifiableCallIds.push(checkbox.value);
                } else if (!isVerified) {
                    // Not verified at all
                    verifiableCallIds.push(checkbox.value);
                }
            });

            // Check if there are any calls to verify
            if (verifiableCallIds.length === 0) {
                const totalCalls = groupCheckboxes.length;

                // Build detailed message
                let details = [];
                if (lockedCount > 0) details.push(`${lockedCount} locked (approved by supervisor)`);
                if (expiredCount > 0) details.push(`${expiredCount} expired`);

                let message = '';
                if (totalCalls === 0) {
                    message = 'No calls found in this group.';
                } else if (details.length > 0) {
                    message = `All ${totalCalls} call(s) in this group are: ${details.join(', ')}.`;
                } else {
                    message = `All ${totalCalls} call(s) in this group cannot be verified at this time.`;
                }

                showNotification('info', 'No Calls to Mark', message);

                // Reset dropdown
                event.target.selectedIndex = 0;
                return;
            }

            // Prepare confirmation modal content
            const callWord = verifiableCallIds.length === 1 ? 'call' : 'calls';
            const typeLabel = verificationType === 'Official' ? 'Official (work-related)' : 'Personal';
