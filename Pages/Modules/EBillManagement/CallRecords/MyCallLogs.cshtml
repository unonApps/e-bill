@section Scripts {
    <script>
        // Extension collapse/expand functionality
        function toggleExtension(extensionId) {
            const rows = document.querySelectorAll(`tr.extension-row[data-extension="${extensionId}"]`);
            const toggle = document.getElementById('toggle-' + extensionId);

            if (rows.length > 0) {
                const isHidden = rows[0].style.display === 'none';

                rows.forEach(row => {
                    row.style.display = isHidden ? '' : 'none';
                });

                if (isHidden) {
                    toggle.classList.remove('bi-chevron-right');
                    toggle.classList.add('bi-chevron-down');
                } else {
                    toggle.classList.remove('bi-chevron-down');
                    toggle.classList.add('bi-chevron-right');
                }
            }
        }

        function expandAllExtensions() {
            document.querySelectorAll('.extension-row').forEach(row => {
                row.style.display = '';
            });
            document.querySelectorAll('.extension-toggle').forEach(toggle => {
                toggle.classList.remove('bi-chevron-right');
                toggle.classList.add('bi-chevron-down');
            });
        }

        function collapseAllExtensions() {
            document.querySelectorAll('.extension-row').forEach(row => {
                row.style.display = 'none';
            });
            document.querySelectorAll('.extension-toggle').forEach(toggle => {
                toggle.classList.remove('bi-chevron-down');
                toggle.classList.add('bi-chevron-right');
            });
        }

        // Extension-level checkbox functions
        function toggleExtensionCalls(extensionCheckbox) {
            const extensionId = extensionCheckbox.getAttribute('data-extension');
            const checkboxes = document.querySelectorAll(`.call-checkbox[data-extension="${extensionId}"]`);

            checkboxes.forEach(cb => {
                // Only toggle unlocked checkboxes
                if (cb.getAttribute('data-locked') === 'false') {
                    cb.checked = extensionCheckbox.checked;
                }
            });

            updateQuickVerifyButtons();
        }

        function updateExtensionCheckbox(extensionId) {
            const extensionCheckbox = document.getElementById('ext-check-' + extensionId);
            if (!extensionCheckbox) return;

            const checkboxes = Array.from(document.querySelectorAll(`.call-checkbox[data-extension="${extensionId}"]`))
                .filter(cb => cb.getAttribute('data-locked') === 'false');

            if (checkboxes.length === 0) return;

            const checkedCount = checkboxes.filter(cb => cb.checked).length;

            if (checkedCount === 0) {
                extensionCheckbox.checked = false;
                extensionCheckbox.indeterminate = false;
            } else if (checkedCount === checkboxes.length) {
                extensionCheckbox.checked = true;
                extensionCheckbox.indeterminate = false;
            } else {
                extensionCheckbox.checked = false;
                extensionCheckbox.indeterminate = true;
            }
        }

        function toggleSelectAll(checkbox) {
            const checkboxes = document.querySelectorAll('.call-checkbox');
            checkboxes.forEach(cb => {
                // Select all unlocked calls (both verified and unverified)
                // Skip only locked calls (assigned out pending)
                if (cb.getAttribute('data-locked') === 'false') {
                    cb.checked = checkbox.checked;
                }
            });

            // Update all extension checkboxes
            document.querySelectorAll('.extension-checkbox').forEach(extCheck => {
                const extensionId = extCheck.getAttribute('data-extension');
                updateExtensionCheckbox(extensionId);
            });

            updateQuickVerifyButtons();
        }

        function updateQuickVerifyButtons() {
            const selectedCheckboxes = document.querySelectorAll('.call-checkbox:checked');
            const selectedCount = selectedCheckboxes.length;

            // Count how many selected calls are unverified
            const unverifiedCount = Array.from(selectedCheckboxes)
                .filter(cb => cb.getAttribute('data-verified') === 'false')
                .length;

            const quickVerifyButtons = document.getElementById('quickVerifyButtons');
            const selectedCountElement = document.getElementById('selectedCount');
            const selectedCountNumber = document.getElementById('selectedCountNumber');

            // Show selection count if anything is selected
            if (selectedCount > 0) {
                selectedCountElement.style.display = 'inline';
                selectedCountNumber.textContent = selectedCount;
            } else {
                selectedCountElement.style.display = 'none';
            }

            // Only show Mark as Official/Personal buttons if unverified calls are selected
            if (unverifiedCount > 0) {
                quickVerifyButtons.style.display = 'inline-flex';
            } else {
                quickVerifyButtons.style.display = 'none';
            }
        }

        function submitToSupervisor() {
            const selectedCheckboxes = Array.from(document.querySelectorAll('.call-checkbox:checked'));

            if (selectedCheckboxes.length === 0) {
                alert('Please select at least one call to submit to supervisor.');
                return;
            }

            // Filter by different criteria
            const expiredCalls = selectedCheckboxes.filter(cb => cb.getAttribute('data-expired') === 'true');
            const alreadySubmittedCalls = selectedCheckboxes.filter(cb => {
                const isSubmitted = cb.getAttribute('data-submitted') === 'true';
                const approvalStatus = cb.getAttribute('data-approval-status');
                // Call is already submitted if it's submitted AND has Pending/Approved/PartiallyApproved status
                return isSubmitted && (approvalStatus === 'Pending' || approvalStatus === 'Approved' || approvalStatus === 'PartiallyApproved');
            });
            const validCalls = selectedCheckboxes
                .filter(cb => cb.getAttribute('data-expired') === 'false')
                .filter(cb => {
                    const isSubmitted = cb.getAttribute('data-submitted') === 'true';
                    const approvalStatus = cb.getAttribute('data-approval-status');
                    return !(isSubmitted && (approvalStatus === 'Pending' || approvalStatus === 'Approved' || approvalStatus === 'PartiallyApproved'));
                });

            const selectedIds = validCalls.map(cb => cb.value);

            // Build warning message
            let warnings = [];
            if (expiredCalls.length > 0) {
                warnings.push(`${expiredCalls.length} expired call(s) cannot be submitted (will be auto-recovered)`);
            }
            if (alreadySubmittedCalls.length > 0) {
                warnings.push(`${alreadySubmittedCalls.length} call(s) already submitted to supervisor`);
            }

            if (warnings.length > 0) {
                alert('Warning:\n• ' + warnings.join('\n• '));
            }

            if (selectedIds.length === 0) {
                alert('No valid calls to submit. Please select calls that are:\n• Not expired\n• Not already submitted to supervisor\n• Verified as Official or Personal');
                return;
            }

            // Redirect to submit page with selected IDs
            window.location.href = '/Modules/EBillManagement/CallRecords/SubmitToSupervisor?ids=' + selectedIds.join(',');
        }

        // Store current verification data
        let currentVerificationData = null;

        // Quick verify single call from inline dropdown
        function quickVerifyCall(callId, verificationType, callNumber, costUSD, costKSH, duration, callDate) {
            // Reset dropdown if no selection
            if (!verificationType) {
                return;
            }

            // Store data for confirmation
            currentVerificationData = { callId, verificationType };

            // Configure modal based on verification type
            const isOfficial = verificationType === 'Official';
            const modalHeader = document.getElementById('quickVerifyModalHeader');
            const modalIcon = document.getElementById('quickVerifyIcon');
            const modalTitle = document.getElementById('quickVerifyTitle');
            const modalMessage = document.getElementById('quickVerifyMessage');
            const confirmBtn = document.getElementById('confirmQuickVerifyBtn');
            const noteAlert = document.getElementById('quickVerifyNote');
            const noteIcon = document.getElementById('quickVerifyNoteIcon');
            const noteText = document.getElementById('quickVerifyNoteText');
            const btnText = document.getElementById('confirmVerifyBtnText');

            // Set colors and content
            if (isOfficial) {
                modalHeader.style.background = 'linear-gradient(135deg, #10b981, #34d399)';
                modalHeader.style.color = 'white';
                modalHeader.querySelector('.btn-close').classList.add('btn-close-white');
                modalIcon.className = 'bi bi-check-circle-fill me-2';
                modalTitle.textContent = 'Mark as Official';
                modalMessage.textContent = 'You are about to mark this call as Official (work-related).';
                confirmBtn.className = 'btn btn-success';
                btnText.textContent = 'Mark as Official';
                noteAlert.className = 'alert alert-success mt-3 mb-0';
                noteIcon.className = 'bi bi-check-circle-fill me-2';
                noteText.textContent = 'This call will count towards your official usage and allowance.';
            } else {
                modalHeader.style.background = 'linear-gradient(135deg, #f59e0b, #fbbf24)';
                modalHeader.style.color = 'white';
                modalHeader.querySelector('.btn-close').classList.add('btn-close-white');
                modalIcon.className = 'bi bi-exclamation-triangle-fill me-2';
                modalTitle.textContent = 'Mark as Personal';
                modalMessage.textContent = 'You are about to mark this call as Personal (non-work-related).';
                confirmBtn.className = 'btn btn-warning';
                btnText.textContent = 'Mark as Personal';
                noteAlert.className = 'alert alert-warning mt-3 mb-0';
                noteIcon.className = 'bi bi-exclamation-triangle-fill me-2';
                noteText.textContent = 'This call may require payment or reimbursement.';
            }

            // Fill in call details
            document.getElementById('verifyCallNumber').textContent = callNumber;
            document.getElementById('verifyCallCost').textContent = `$${costUSD} (KSh ${costKSH})`;
            document.getElementById('verifyCallDuration').textContent = `${duration} min`;
            document.getElementById('verifyCallDate').textContent = callDate;

            // Show modal
            const modalElement = document.getElementById('quickVerifyModal');
            const modal = new bootstrap.Modal(modalElement);

            // Reset dropdown if modal is dismissed without confirming
            modalElement.addEventListener('hidden.bs.modal', function () {
                if (currentVerificationData) {
                    const dropdown = document.querySelector(`select[data-call-id="${currentVerificationData.callId}"]`);
                    if (dropdown) {
                        dropdown.selectedIndex = 0;
                    }
                    currentVerificationData = null;
                }
            }, { once: true });

            modal.show();
        }

        // Confirm quick verification from modal
        function confirmQuickVerify() {
            if (!currentVerificationData) return;

            const { callId, verificationType } = currentVerificationData;

            // Close modal
            const modalElement = document.getElementById('quickVerifyModal');
            const modal = bootstrap.Modal.getInstance(modalElement);
            modal.hide();

            // Create form and submit
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=QuickVerify';

            // Add anti-forgery token
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
            form.appendChild(tokenInput);

            // Add verification type
            const typeInput = document.createElement('input');
            typeInput.type = 'hidden';
            typeInput.name = 'verificationType';
            typeInput.value = verificationType;
            form.appendChild(typeInput);

            // Add call ID
            const idInput = document.createElement('input');
            idInput.type = 'hidden';
            idInput.name = 'selectedIds';
            idInput.value = callId;
            form.appendChild(idInput);

            document.body.appendChild(form);
            form.submit();
        }

        // Store selected IDs for confirmation
        let pendingVerificationIds = [];
        let pendingVerificationType = '';

        function quickVerifySelected(verificationType) {
            // Only get unverified, non-expired calls
            const selectedCheckboxes = Array.from(document.querySelectorAll('.call-checkbox:checked'));
            const expiredCount = selectedCheckboxes.filter(cb => cb.getAttribute('data-expired') === 'true').length;
            const selectedIds = selectedCheckboxes
                .filter(cb => cb.getAttribute('data-verified') === 'false' && cb.getAttribute('data-expired') === 'false')
                .map(cb => cb.value);

            if (expiredCount > 0) {
                // Show warning in modal instead of alert
                showWarningModal(`Warning: ${expiredCount} expired call(s) cannot be verified. They will be automatically recovered.`);
            }

            if (selectedIds.length === 0) {
                showWarningModal('Please select at least one unverified, non-expired call.');
                return;
            }

            // Store the data for later submission
            pendingVerificationIds = selectedIds;
            pendingVerificationType = verificationType;

            // Show appropriate modal
            if (verificationType === 'Official') {
                document.getElementById('officialCallCount').textContent = `${selectedIds.length} call${selectedIds.length !== 1 ? 's' : ''}`;
                const modal = new bootstrap.Modal(document.getElementById('confirmOfficialModal'));
                modal.show();
            } else if (verificationType === 'Personal') {
                document.getElementById('personalCallCount').textContent = `${selectedIds.length} call${selectedIds.length !== 1 ? 's' : ''}`;
                const modal = new bootstrap.Modal(document.getElementById('confirmPersonalModal'));
                modal.show();
            }
        }

        function confirmQuickVerifyOfficial() {
            submitQuickVerification('Official');
        }

        function confirmQuickVerifyPersonal() {
            submitQuickVerification('Personal');
        }

        function submitQuickVerification(verificationType) {
            // Close the modal
            const modalId = verificationType === 'Official' ? 'confirmOfficialModal' : 'confirmPersonalModal';
            const modal = bootstrap.Modal.getInstance(document.getElementById(modalId));
            if (modal) {
                modal.hide();
            }

            // Create form and submit
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=QuickVerify';

            // Add anti-forgery token
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
            form.appendChild(tokenInput);

            // Add verification type
            const typeInput = document.createElement('input');
            typeInput.type = 'hidden';
            typeInput.name = 'verificationType';
            typeInput.value = verificationType;
            form.appendChild(typeInput);

            // Add selected IDs
            pendingVerificationIds.forEach(id => {
                const idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'selectedIds';
                idInput.value = id;
                form.appendChild(idInput);
            });

            document.body.appendChild(form);
            form.submit();
        }

        function showWarningModal(message) {
            // Create a simple alert-style modal for warnings
            const alertDiv = document.createElement('div');
            alertDiv.className = 'alert alert-warning alert-dismissible fade show position-fixed';
            alertDiv.style.cssText = 'top: 20px; right: 20px; z-index: 9999; max-width: 400px;';
            alertDiv.innerHTML = `
                <i class="bi bi-exclamation-triangle me-2"></i>${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            document.body.appendChild(alertDiv);

            // Auto-dismiss after 5 seconds
            setTimeout(() => {
                alertDiv.classList.remove('show');
                setTimeout(() => alertDiv.remove(), 300);
            }, 5000);
        }

        // Assignment Accept/Reject Functions
        let currentCallRecordId = null;

        function showAcceptModal(callRecordId, callNumber, amount, fromUser) {
            currentCallRecordId = callRecordId;
            document.getElementById('acceptCallNumber').textContent = callNumber;
            document.getElementById('acceptCallAmount').textContent = '$' + amount;
            document.getElementById('acceptFromUser').textContent = fromUser || 'Unknown';
            const modal = new bootstrap.Modal(document.getElementById('acceptAssignmentModal'));
            modal.show();
        }

        async function confirmAcceptAssignment() {
            try {
                const response = await fetch(`/Modules/EBillManagement/CallRecords/MyCallLogs?handler=AcceptAssignment&callRecordId=${currentCallRecordId}`, {
                    method: 'POST',
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();

                if (result.success) {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('acceptAssignmentModal'));
                    modal.hide();
                    alert('Assignment accepted successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                alert('Error accepting assignment: ' + error.message);
            }
        }

        function showRejectModal(callRecordId, callNumber, amount, fromUser) {
            currentCallRecordId = callRecordId;
            document.getElementById('rejectCallNumber').textContent = callNumber;
            document.getElementById('rejectCallAmount').textContent = '$' + amount;
            document.getElementById('rejectFromUser').textContent = fromUser || 'Unknown';
            document.getElementById('rejectionReason').value = '';
            document.getElementById('rejectionReason').classList.remove('is-invalid');
            const modal = new bootstrap.Modal(document.getElementById('rejectAssignmentModal'));
            modal.show();
        }

        async function confirmRejectAssignment() {
            const reason = document.getElementById('rejectionReason').value.trim();
            const reasonField = document.getElementById('rejectionReason');

            if (!reason) {
                reasonField.classList.add('is-invalid');
                return;
            }

            reasonField.classList.remove('is-invalid');

            try {
                const response = await fetch(`/Modules/EBillManagement/CallRecords/MyCallLogs?handler=RejectAssignment`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({
                        callRecordId: currentCallRecordId,
                        reason: reason
                    })
                });

                const result = await response.json();

                if (result.success) {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('rejectAssignmentModal'));
                    modal.hide();
                    alert('Assignment rejected successfully!');
                    location.reload();
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                alert('Error rejecting assignment: ' + error.message);
            }
        }

        // Initialize extension checkboxes on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Update all extension checkboxes to reflect their current state
            document.querySelectorAll('.extension-checkbox').forEach(extCheck => {
                const extensionId = extCheck.getAttribute('data-extension');
                updateExtensionCheckbox(extensionId);
            });

            // Initialize Bootstrap tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl, {
                    trigger: 'hover',
                    delay: { show: 300, hide: 100 }
                });
            });
        });
    </script>
}
