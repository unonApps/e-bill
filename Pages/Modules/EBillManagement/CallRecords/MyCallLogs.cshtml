        // Custom confirmation modal function
        function showConfirmation(title, message, confirmText, onConfirm, onCancel) {
            // Remove existing modal if any
            const existingModal = document.getElementById('customConfirmModal');
            if (existingModal) {
                existingModal.remove();
            }

            // Create modal HTML with your app's design style
            const modalHtml = `
                <div class="modal fade" id="customConfirmModal" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.15);">
                            <div class="modal-header bg-primary text-white" style="border-bottom: none; padding: 1.5rem; border-radius: 16px 16px 0 0;">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-white rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                                        <i class="bi bi-question-circle-fill text-primary" style="font-size: 1.5rem;"></i>
                                    </div>
                                    <div>
                                        <h5 class="modal-title fw-bold text-white mb-0">${title}</h5>
                                        <p class="text-white text-opacity-75 small mb-0">Please confirm your action</p>
                                    </div>
                                </div>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body" style="padding: 1.5rem;">
                                ${message}
                            </div>
                            <div class="modal-footer" style="border-top: 1px solid #e5e7eb; padding: 1rem 1.5rem;">
                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 8px;">
                                    <i class="bi bi-x-lg me-1"></i>Cancel
                                </button>
                                <button type="button" class="btn btn-primary" id="confirmModalBtn" style="border-radius: 8px;">
                                    <i class="bi bi-check-lg me-1"></i>${confirmText}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;

            // Add modal to page
            document.body.insertAdjacentHTML('beforeend', modalHtml);

            // Get modal element
            const modalElement = document.getElementById('customConfirmModal');
            const modal = new bootstrap.Modal(modalElement);

            // Handle confirm button
            document.getElementById('confirmModalBtn').addEventListener('click', () => {
                modal.hide();
                if (onConfirm) onConfirm();
            });

            // Handle modal hidden (cleanup)
            modalElement.addEventListener('hidden.bs.modal', () => {
                if (!modalElement.classList.contains('confirmed')) {
                    if (onCancel) onCancel();
                }
                modalElement.remove();
            });

            // Handle confirm button to mark as confirmed
            document.getElementById('confirmModalBtn').addEventListener('click', () => {
                modalElement.classList.add('confirmed');
            }, { once: true });

            // Show modal
            modal.show();
        }

        // Store selected IDs for confirmation
        let pendingVerificationIds = [];
        let pendingVerificationType = '';

        function quickVerifySelected(verificationType) {
            // Only get unverified, non-expired calls
            const selectedCheckboxes = Array.from(document.querySelectorAll('.call-checkbox:checked'));
            const expiredCount = selectedCheckboxes.filter(cb => cb.getAttribute('data-expired') === 'true').length;
            const selectedIds = selectedCheckboxes
                .filter(cb => cb.getAttribute('data-verified') === 'false' && cb.getAttribute('data-expired') === 'false')
                .map(cb => cb.value);

            if (expiredCount > 0) {
                // Show warning in modal instead of alert
                showWarningModal(`Warning: ${expiredCount} expired call(s) cannot be verified. They will be automatically recovered.`);
            }

            if (selectedIds.length === 0) {
                showWarningModal('Please select at least one unverified, non-expired call.');
                return;
            }

            // Store the data for later submission
            pendingVerificationIds = selectedIds;
            pendingVerificationType = verificationType;

            // Show appropriate modal
            if (verificationType === 'Official') {
                document.getElementById('officialCallCount').textContent = `${selectedIds.length} call${selectedIds.length !== 1 ? 's' : ''}`;
                const modal = new bootstrap.Modal(document.getElementById('confirmOfficialModal'));
                modal.show();
            } else if (verificationType === 'Personal') {
                document.getElementById('personalCallCount').textContent = `${selectedIds.length} call${selectedIds.length !== 1 ? 's' : ''}`;
                const modal = new bootstrap.Modal(document.getElementById('confirmPersonalModal'));
                modal.show();
            }
        }

