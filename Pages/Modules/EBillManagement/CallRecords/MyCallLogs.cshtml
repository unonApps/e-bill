@* Quick Verification Modal *@
<div class="modal fade" id="quickVerifyModal" tabindex="-1" aria-labelledby="quickVerifyModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.15);">
            <div class="modal-header" id="quickVerifyModalHeader" style="border-bottom: 2px solid #e5e7eb; padding: 1.5rem; border-radius: 16px 16px 0 0;">
                <h5 class="modal-title fw-bold" id="quickVerifyModalLabel">
                    <i class="bi bi-check-circle me-2" id="quickVerifyIcon"></i><span id="quickVerifyTitle">Mark Call</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <p class="mb-3" id="quickVerifyMessage" style="font-size: 1.05rem; color: #4b5563;"></p>

                <div class="card border-0" style="background: #f8f9fa; border-radius: 12px;">
                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-3" style="color: #1f2937;">
                            <i class="bi bi-info-circle me-2 text-primary"></i>Call Details
                        </h6>
                        <div class="row g-2">
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-telephone-fill text-primary"></i>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Number</small>
                                        <strong id="verifyCallNumber" style="font-size: 0.95rem;">-</strong>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-currency-dollar text-success"></i>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Cost</small>
                                        <strong id="verifyCallCost" style="font-size: 0.95rem;">-</strong>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-clock-fill text-warning"></i>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Duration</small>
                                        <strong id="verifyCallDuration" style="font-size: 0.95rem;">-</strong>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-calendar-fill text-info"></i>
                                    <div>
                                        <small class="text-muted d-block" style="font-size: 0.75rem;">Date</small>
                                        <strong id="verifyCallDate" style="font-size: 0.95rem;">-</strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="alert mt-3 mb-0" id="quickVerifyNote" style="border-radius: 10px; border: none;">
                    <i class="bi me-2" id="quickVerifyNoteIcon"></i>
                    <span id="quickVerifyNoteText"></span>
                </div>
            </div>
            <div class="modal-footer" style="border-top: 2px solid #e5e7eb; padding: 1rem 1.5rem;">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal" style="border-radius: 10px; padding: 0.6rem 1.5rem;">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </button>
                <button type="button" class="btn" id="confirmQuickVerifyBtn" onclick="confirmQuickVerify()" style="border-radius: 10px; padding: 0.6rem 1.5rem;">
                    <i class="bi bi-check-circle me-1"></i>
                    <span id="confirmVerifyBtnText">Confirm</span>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Submit to Supervisor Modal -->
<div class="modal fade" id="submitToSupervisorModal" tabindex="-1" aria-labelledby="submitToSupervisorModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content" style="border-radius: 12px; border: none;">
            <div class="modal-header bg-primary text-white" style="border-radius: 12px 12px 0 0; padding: 1rem 1.25rem;">
                <h5 class="modal-title" id="submitToSupervisorModalLabel">
                    <i class="bi bi-send me-2"></i>Submit to Supervisor
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.25rem; background-color: #f8f9fa;">
                <!-- Loading State -->
                <div id="submissionLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status" style="width: 2.5rem; height: 2.5rem;">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted mb-0">Loading submission preview...</p>
                </div>

                <!-- Error State -->
                <div id="submissionError" class="d-none">
                    <div class="alert alert-danger mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <span id="submissionErrorMessage"></span>
                    </div>
                </div>

                <!-- Content (hidden until loaded) -->
                <div id="submissionContent" class="d-none">
                    <!-- Summary Cards Row -->
                    <div class="row g-2 mb-3" id="summaryCards">
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm h-100" style="border-radius: 10px;">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <i class="bi bi-list-check text-primary"></i>
                                        <div class="text-end">
                                            <h5 class="mb-0 fw-bold" id="summaryTotalCalls">0</h5>
                                            <small class="text-muted" style="font-size: 0.75rem;">Calls</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm h-100" style="border-radius: 10px;">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <i class="bi bi-briefcase text-success"></i>
                                        <div class="text-end">
                                            <h5 class="mb-0 fw-bold" id="summaryOfficialCost">$0.00</h5>
                                            <small class="text-muted" style="font-size: 0.75rem;" id="summaryAllowanceLabel">Official</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm h-100" style="border-radius: 10px;">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <i class="bi bi-person text-warning"></i>
                                        <div class="text-end">
                                            <h5 class="mb-0 fw-bold" id="summaryPersonalCost">$0.00</h5>
                                            <small class="text-muted" style="font-size: 0.75rem;">Personal</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="card border-0 shadow-sm h-100" id="summaryOverageCard" style="border-radius: 10px;">
                                <div class="card-body py-2 px-3">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <span id="summaryOverageIcon"><i class="bi bi-exclamation-triangle text-danger"></i></span>
                                        <div class="text-end">
                                            <h5 class="mb-0 fw-bold" id="summaryOverageAmount">$0.00</h5>
                                            <small class="text-muted" style="font-size: 0.75rem;" id="summaryOverageLabel">Overage</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Overage Warning Banner (conditional) -->
                    <div id="overageWarningBanner" class="alert alert-warning d-none mb-3 py-2" style="border-radius: 8px;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <small id="overageWarningText"></small>
                        </div>
                    </div>

                    <!-- Phone Overage Justifications (conditional) -->
                    <div id="phoneOverageSection"></div>

                    <!-- Supervisor Info -->
                    <div id="supervisorInfo" class="card border-0 shadow-sm mb-0 py-2 px-3" style="border-radius: 10px;">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-person-badge me-2 text-primary"></i>
                            <small>
                                <strong>Supervisor:</strong> <span id="supervisorName"></span>
                                (<span id="supervisorEmail" class="text-muted"></span>)
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer" style="border-top: 2px solid #e5e7eb; padding: 1rem 1.5rem;">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">
                    Cancel
                </button>
                <button type="button" class="btn btn-primary btn-sm" id="btnConfirmSubmit" onclick="confirmSubmitToSupervisor()">
                    <i class="bi bi-send me-1"></i>Submit
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Notification Container for Alerts -->
    <div id="notificationContainer" style="position: fixed; top: 80px; right: 20px; z-index: 9999; max-width: 400px;"></div>

    <!-- Loading Overlay for Bulk Operations -->
    <div id="loadingOverlay" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 10000; justify-content: center; align-items: center;">
        <div class="text-center bg-white p-4 rounded-4 shadow-lg" style="min-width: 300px;">
            <div class="spinner-border text-primary mb-3" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Loading...</span>
            </div>
            <h5 class="mb-2" id="loadingTitle">Processing...</h5>
            <p class="text-muted mb-0" id="loadingMessage">Please wait while we process your request.</p>
            <div class="progress mt-3" style="height: 6px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" style="width: 100%"></div>
            </div>
        </div>
    </div>

    <script>
        // Loading overlay functions
        function showLoadingOverlay(title, message) {
            const overlay = document.getElementById('loadingOverlay');
            const titleEl = document.getElementById('loadingTitle');
            const messageEl = document.getElementById('loadingMessage');

            if (title) titleEl.textContent = title;
            if (message) messageEl.textContent = message;

            overlay.style.display = 'flex';
        }

        function hideLoadingOverlay() {
            document.getElementById('loadingOverlay').style.display = 'none';
        }

        // Custom notification function
        function showNotification(type, title, message) {
            const container = document.getElementById('notificationContainer');

            // Map type to Bootstrap alert class
            const alertClass = {
                'success': 'alert-success',
                'error': 'alert-danger',
                'warning': 'alert-warning',
                'info': 'alert-info'
            }[type] || 'alert-info';

            // Icon mapping
            const icon = {
                'success': 'bi-check-circle-fill',
                'error': 'bi-x-circle-fill',
                'warning': 'bi-exclamation-triangle-fill',
                'info': 'bi-info-circle-fill'
            }[type] || 'bi-info-circle-fill';

            // Create notification element
            const notification = document.createElement('div');
            notification.className = `alert ${alertClass} alert-dismissible fade show shadow-sm mb-3`;
            notification.style.borderRadius = '8px';
            notification.innerHTML = `
                <div class="d-flex align-items-start">
                    <i class="bi ${icon} me-2" style="font-size: 1.2rem;"></i>
                    <div class="flex-grow-1">
                        <strong>${title}</strong>
                        <div class="mt-1">${message}</div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;

            container.appendChild(notification);

            // Auto-remove after 5 seconds
            setTimeout(() => {
                notification.classList.remove('show');
                setTimeout(() => notification.remove(), 150);
            }, 5000);
        }

        // ========================
        // AJAX LOADING FOR 3-LEVEL PAGINATION
        // ========================

        // Level 1 → Level 2: Toggle dialed numbers for an extension group
        async function toggleCallDetails(groupId) {
            const container = document.getElementById('dialed-container-' + groupId);
            const content = document.getElementById('dialed-content-' + groupId);
            const toggle = document.getElementById('toggle-' + groupId);

            if (!container || !content) return;

            const isHidden = container.style.display === 'none';

            if (isHidden) {
                // Show container
                container.style.display = '';
                toggle.classList.remove('bi-plus-circle');
                toggle.classList.add('bi-dash-circle');

                // Load data if not already loaded
                if (content.dataset.loaded === 'false') {
                    await loadDialedNumbers(content, 1);
                }
            } else {
                // Hide container
                container.style.display = 'none';
                toggle.classList.remove('bi-dash-circle');
                toggle.classList.add('bi-plus-circle');
            }
        }

        // Load dialed numbers for an extension (Level 2) via AJAX
        async function loadDialedNumbers(contentDiv, page) {
            const extension = contentDiv.dataset.extension;
            const month = contentDiv.dataset.month;
            const year = contentDiv.dataset.year;
            const groupId = contentDiv.dataset.groupId;

            // Show loading
            contentDiv.innerHTML = `
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <span class="ms-2 text-muted">Loading dialed numbers...</span>
                </div>
            `;

            try {
                const response = await fetch(`?handler=DialedNumbers&extension=${encodeURIComponent(extension)}&month=${month}&year=${year}&page=${page}&pageSize=20`);
                const data = await response.json();

                if (data.error) {
                    contentDiv.innerHTML = `<div class="alert alert-danger m-2">${data.error}</div>`;
                    return;
                }

                contentDiv.dataset.loaded = 'true';
                renderDialedNumbers(contentDiv, data, groupId);
            } catch (error) {
                console.error('Error loading dialed numbers:', error);
                contentDiv.innerHTML = `<div class="alert alert-danger m-2">Error loading dialed numbers. Please try again.</div>`;
            }
        }

        // Render dialed numbers table (Level 2)
        function renderDialedNumbers(contentDiv, data, groupId) {
            if (!data.dialedNumbers || data.dialedNumbers.length === 0) {
                contentDiv.innerHTML = `<div class="text-center py-3 text-muted">No dialed numbers found.</div>`;
                return;
            }

            let html = `
                <table class="table table-sm mb-0" style="background: #f8fafc;">
                    <thead style="background: #e2e8f0;">
                        <tr>
                            <th style="width: 30px;"></th>
                            <th style="width: 40px;"></th>
                            <th>Dialed Number</th>
                            <th>Status</th>
                            <th class="text-center">Calls</th>
                            <th>Cost (KSH)</th>
                            <th>Cost (USD)</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            data.dialedNumbers.forEach(dn => {
                let statusBadge = '';
                let submissionBadge = '';

                // Verification type badge - default to Official
                if (dn.assignmentStatus === 'Mixed') {
                    statusBadge = '<span class="badge bg-secondary">Mixed</span>';
                } else if (dn.assignmentStatus === 'Personal') {
                    statusBadge = '<span class="badge bg-warning text-dark">Personal</span>';
                } else {
                    // Default to Official for unverified or Official status
                    statusBadge = '<span class="badge bg-success">Official</span>';
                }

                // Submission status badge
                if (dn.approvedCount > 0 && dn.approvedCount === dn.callCount) {
                    submissionBadge = '<span class="badge bg-secondary ms-1"><i class="bi bi-check-circle-fill"></i> Approved</span>';
                } else if (dn.pendingApprovalCount > 0) {
                    submissionBadge = `<span class="badge bg-info ms-1"><i class="bi bi-hourglass-split"></i> ${dn.pendingApprovalCount} Pending</span>`;
                } else if (dn.submittedCount > 0) {
                    submissionBadge = `<span class="badge bg-primary bg-opacity-75 ms-1"><i class="bi bi-send"></i> ${dn.submittedCount} Submitted</span>`;
                }

                // Incoming assignment badge (calls assigned TO current user)
                let assignmentBadge = '';
                if (dn.incomingAssignmentCount > 0) {
                    assignmentBadge = `<span class="badge bg-info ms-1" style="font-size: 0.65rem;"><i class="bi bi-arrow-left me-1"></i>${dn.incomingAssignmentCount} Assigned to you</span>`;
                }

                // Outgoing pending reassignment badge
                let outgoingBadge = '';
                if (dn.outgoingPendingCount > 0) {
                    const toUser = dn.assignedToUser || 'others';
                    outgoingBadge = `<span class="badge bg-warning text-dark ms-1" style="font-size: 0.65rem;"><i class="bi bi-hourglass-split me-1"></i>${dn.outgoingPendingCount} Pending with ${escapeHtml(toUser)}</span>`;
                }

                html += `
                    <tr class="dialed-number-row" data-dialed-group="${dn.dialedGroupId}">
                        <td class="text-center">
                            <input type="checkbox" class="form-check-input dialed-number-checkbox"
                                   id="dn-check-${dn.dialedGroupId}"
                                   data-dialed-group="${dn.dialedGroupId}"
                                   data-extension="${escapeHtmlAttr(data.extension)}"
                                   data-month="${data.month}"
                                   data-year="${data.year}"
                                   data-dialed-number="${escapeHtmlAttr(dn.dialedNumber)}"
                                   onchange="toggleDialedNumberCalls(this);" />
                        </td>
                        <td class="text-center" style="cursor: pointer;" onclick="toggleCallLogs('${dn.dialedGroupId}', '${data.extension}', ${data.month}, ${data.year}, '${dn.dialedNumber}')">
                            <i class="bi bi-plus-circle text-info toggle-icon-dialed" id="toggle-dialed-${dn.dialedGroupId}"></i>
                        </td>
                        <td style="cursor: pointer;" onclick="toggleCallLogs('${dn.dialedGroupId}', '${data.extension}', ${data.month}, ${data.year}, '${dn.dialedNumber}')">
                            <strong style="color: #0066cc;">${dn.dialedNumber}</strong>
                            ${dn.destination ? `<br><small class="text-muted">${dn.destination}</small>` : ''}
                        </td>
                        <td>${statusBadge}${submissionBadge}${assignmentBadge}${outgoingBadge}</td>
                        <td class="text-center"><span class="badge bg-info bg-opacity-10 text-info">${dn.callCount} calls</span></td>
                        <td><strong>KSh ${dn.totalCostKSH.toFixed(2)}</strong></td>
                        <td><strong>$${dn.totalCostUSD.toFixed(2)}</strong></td>
                        <td class="text-center">
                            <div class="d-flex gap-1 justify-content-center flex-wrap">
                                <button type="button" class="btn btn-success btn-sm" style="font-size: 0.7rem; padding: 0.15rem 0.4rem;"
                                        onclick="verifyAllDialedNumberAjax('${dn.dialedGroupId}', '${dn.dialedNumber}', '${data.extension}', ${data.month}, ${data.year}, 'Official')">
                                    <i class="bi bi-briefcase"></i> Official
                                </button>
                                <button type="button" class="btn btn-warning btn-sm" style="font-size: 0.7rem; padding: 0.15rem 0.4rem;"
                                        onclick="verifyAllDialedNumberAjax('${dn.dialedGroupId}', '${dn.dialedNumber}', '${data.extension}', ${data.month}, ${data.year}, 'Personal')">
                                    <i class="bi bi-person"></i> Personal
                                </button>
                                <button type="button" class="btn btn-outline-secondary btn-sm" style="font-size: 0.7rem; padding: 0.15rem 0.4rem;"
                                        onclick="openReassignDialogForDialedNumber('${dn.dialedNumber}', '${data.extension}', ${data.month}, ${data.year}, ${dn.callCount})"
                                        title="Reassign all calls to this number">
                                    <i class="bi bi-person-plus"></i>
                                </button>
                                ${dn.incomingAssignmentCount > 0 ? `
                                <div class="btn-group btn-group-sm">
                                    <button type="button" class="btn btn-success btn-sm"
                                            style="font-size: 0.7rem; padding: 0.15rem 0.4rem;"
                                            onclick="showAcceptBulkModal('dialedNumber', '${escapeHtmlAttr(data.extension)}', ${data.month}, ${data.year}, '${escapeHtmlAttr(dn.dialedNumber)}', ${dn.incomingAssignmentCount}, ${dn.totalCostUSD.toFixed(2)}, '${escapeHtmlAttr(dn.assignedFromUser || '')}')"
                                            title="Accept all ${dn.incomingAssignmentCount} assignments">
                                        <i class="bi bi-check-lg"></i> Accept
                                    </button>
                                    <button type="button" class="btn btn-danger btn-sm"
                                            style="font-size: 0.7rem; padding: 0.15rem 0.4rem;"
                                            onclick="showRejectBulkModal('dialedNumber', '${escapeHtmlAttr(data.extension)}', ${data.month}, ${data.year}, '${escapeHtmlAttr(dn.dialedNumber)}', ${dn.incomingAssignmentCount}, ${dn.totalCostUSD.toFixed(2)}, '${escapeHtmlAttr(dn.assignedFromUser || '')}')"
                                            title="Reject all ${dn.incomingAssignmentCount} assignments">
                                        <i class="bi bi-x-lg"></i> Reject
                                    </button>
                                </div>
                                ` : ''}
                                ${dn.outgoingPendingCount > 0 ? `
                                <button type="button" class="btn btn-outline-warning btn-sm"
                                        style="font-size: 0.7rem; padding: 0.15rem 0.4rem;"
                                        onclick="showRecallBulkModal('dialedNumber', '${escapeHtmlAttr(data.extension)}', ${data.month}, ${data.year}, '${escapeHtmlAttr(dn.dialedNumber)}', ${dn.outgoingPendingCount}, ${dn.totalCostUSD.toFixed(2)}, '${escapeHtmlAttr(dn.assignedToUser || '')}')"
                                        title="Recall all ${dn.outgoingPendingCount} pending reassignments">
                                    <i class="bi bi-arrow-return-left me-1"></i>Recall
                                </button>
                                ` : ''}
                            </div>
                        </td>
                    </tr>
                    <tr id="calllogs-container-${dn.dialedGroupId}" style="display: none;">
                        <td colspan="8" class="p-0">
                            <div class="calllogs-content" id="calllogs-content-${dn.dialedGroupId}"
                                 data-extension="${escapeHtmlAttr(data.extension)}" data-month="${data.month}" data-year="${data.year}"
                                 data-dialed-number="${escapeHtmlAttr(dn.dialedNumber)}" data-dialed-group-id="${escapeHtmlAttr(dn.dialedGroupId)}" data-loaded="false">
                                <div class="text-center py-2">
                                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                    <span class="ms-2 text-muted small">Loading call logs...</span>
                                </div>
                            </div>
                        </td>
                    </tr>
                `;
            });

            html += `</tbody></table>`;

            // Add pagination if needed
            if (data.totalPages > 1) {
                html += renderPagination(data, 'dialed', groupId);
            }

            contentDiv.innerHTML = html;

            // Apply selection state to newly loaded dialed number checkboxes
            applySelectionStateToDialedNumbers(data.extension, data.month, data.year);

            // Update extension checkbox state
            updateExtensionCheckbox(data.extension, data.month, data.year);
        }

        // Level 2 → Level 3: Toggle call logs for a dialed number
        async function toggleCallLogs(dialedGroupId, extension, month, year, dialedNumber) {
            const container = document.getElementById('calllogs-container-' + dialedGroupId);
            const content = document.getElementById('calllogs-content-' + dialedGroupId);
            const toggle = document.getElementById('toggle-dialed-' + dialedGroupId);

            if (!container || !content) return;

            const isHidden = container.style.display === 'none';

            if (isHidden) {
                container.style.display = '';
                if (toggle) {
                    toggle.classList.remove('bi-plus-circle');
                    toggle.classList.add('bi-dash-circle');
                }

                // Load data if not already loaded
                if (content.dataset.loaded === 'false') {
                    await loadCallLogs(content, extension, month, year, dialedNumber, dialedGroupId, 1);
                }
            } else {
                container.style.display = 'none';
                if (toggle) {
                    toggle.classList.remove('bi-dash-circle');
                    toggle.classList.add('bi-plus-circle');
                }
            }
        }

        // Load call logs for a dialed number (Level 3) via AJAX
        async function loadCallLogs(contentDiv, extension, month, year, dialedNumber, dialedGroupId, page, sortBy = 'CallDate', sortDesc = true) {
            const url = `?handler=CallLogs&extension=${encodeURIComponent(extension)}&month=${month}&year=${year}&dialedNumber=${encodeURIComponent(dialedNumber)}&callLogPage=${page}&callLogPageSize=10&sortBy=${sortBy}&sortDesc=${sortDesc}`;
            console.log('>>> FETCHING call logs - URL:', url);
            console.log('>>> Requested page:', page, 'sortBy:', sortBy, 'sortDesc:', sortDesc);

            contentDiv.innerHTML = `
                <div class="text-center py-2">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <span class="ms-2 text-muted small">Loading call logs...</span>
                </div>
            `;

            try {
                const response = await fetch(url);
                const data = await response.json();

                console.log('>>> Response received - currentPage:', data.currentPage, 'totalPages:', data.totalPages, 'totalCount:', data.totalCount);
                console.log('>>> Call logs count:', data.callLogs ? data.callLogs.length : 0);

                if (data.error) {
                    contentDiv.innerHTML = `<div class="alert alert-danger m-2">${data.error}</div>`;
                    return;
                }

                contentDiv.dataset.loaded = 'true';
                contentDiv.dataset.extension = extension;
                contentDiv.dataset.month = month;
                contentDiv.dataset.year = year;
                contentDiv.dataset.dialedNumber = dialedNumber;
                contentDiv.dataset.sortBy = data.sortBy || 'CallDate';
                contentDiv.dataset.sortDesc = data.sortDesc !== false ? 'true' : 'false';
                renderCallLogs(contentDiv, data, dialedGroupId);
            } catch (error) {
                console.error('Error loading call logs:', error);
                contentDiv.innerHTML = `<div class="alert alert-danger m-2">Error loading call logs. Please try again.</div>`;
            }
        }

        // Render call logs table (Level 3)
        function renderCallLogs(contentDiv, data, dialedGroupId) {
            if (!data.callLogs || data.callLogs.length === 0) {
                contentDiv.innerHTML = `<div class="text-center py-2 text-muted small">No call logs found.</div>`;
                return;
            }

            // Helper to render sort indicator
            const sortIcon = (column) => {
                if (data.sortBy?.toLowerCase() === column.toLowerCase()) {
                    return data.sortDesc
                        ? '<i class="bi bi-caret-down-fill ms-1"></i>'
                        : '<i class="bi bi-caret-up-fill ms-1"></i>';
                }
                return '<i class="bi bi-caret-down text-muted ms-1" style="opacity: 0.3;"></i>';
            };

            let html = `
                <table class="table table-sm table-hover mb-0" style="background: white; font-size: 0.85rem;">
                    <thead style="background: #f1f5f9;">
                        <tr>
                            <th style="width: 30px;"><input type="checkbox" class="form-check-input" onclick="toggleAllCallsInDialedNumber('${dialedGroupId}', this)"></th>
                            <th class="sortable-header" style="cursor: pointer;" data-sort="CallDate" data-dialed-group="${dialedGroupId}">
                                Date/Time ${sortIcon('CallDate')}
                            </th>
                            <th class="sortable-header" style="cursor: pointer;" data-sort="Duration" data-dialed-group="${dialedGroupId}">
                                Duration ${sortIcon('Duration')}
                            </th>
                            <th class="sortable-header" style="cursor: pointer;" data-sort="CostKSH" data-dialed-group="${dialedGroupId}">
                                Cost (KSH) ${sortIcon('CostKSH')}
                            </th>
                            <th class="sortable-header" style="cursor: pointer;" data-sort="CostUSD" data-dialed-group="${dialedGroupId}">
                                Cost (USD) ${sortIcon('CostUSD')}
                            </th>
                            <th class="sortable-header" style="cursor: pointer;" data-sort="Type" data-dialed-group="${dialedGroupId}">
                                Type ${sortIcon('Type')}
                            </th>
                            <th class="sortable-header" style="cursor: pointer;" data-sort="Status" data-dialed-group="${dialedGroupId}">
                                Status ${sortIcon('Status')}
                            </th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            data.callLogs.forEach(call => {
                const callDate = new Date(call.callDate);
                const dateStr = callDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
                const timeStr = callDate.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });

                // Check if this is a GPRS/data session (duration is in KB)
                const isDataSession = call.callType && (
                    call.callType.toLowerCase().includes('gprs') ||
                    call.callType.toLowerCase().includes('data')
                );

                let durationStr;
                if (isDataSession) {
                    // Format as data size (KB → MB → GB)
                    durationStr = formatDataSize(call.callDuration);
                } else {
                    // Format as time (minutes:seconds)
                    const minutes = Math.floor(call.callDuration);
                    const seconds = Math.round((call.callDuration - minutes) * 100);
                    durationStr = `${minutes}:${seconds.toString().padStart(2, '0')}`;
                }

                let statusBadge = '';
                // Build verification type badge - default to Official
                let verificationBadge = '';
                if (call.verificationType === 'Personal') {
                    verificationBadge = '<span class="badge bg-warning text-dark">Personal</span>';
                } else {
                    // Default to Official for unverified calls or calls marked as Official
                    verificationBadge = '<span class="badge bg-success">Official</span>';
                }

                // Build submission status badge
                let submissionStatusBadge = '';
                if (call.isLocked) {
                    submissionStatusBadge = '<br><span class="badge bg-secondary" style="font-size: 0.65rem;"><i class="bi bi-lock-fill me-1"></i>Locked</span>';
                } else if (call.isSubmittedToSupervisor) {
                    if (call.supervisorApprovalStatus === 'Pending') {
                        submissionStatusBadge = '<br><span class="badge bg-info" style="font-size: 0.65rem;"><i class="bi bi-hourglass-split me-1"></i>Pending Approval</span>';
                    } else if (call.supervisorApprovalStatus === 'Approved') {
                        submissionStatusBadge = '<br><span class="badge bg-secondary" style="font-size: 0.65rem;"><i class="bi bi-check-circle me-1"></i>Approved</span>';
                    } else if (call.supervisorApprovalStatus === 'PartiallyApproved') {
                        submissionStatusBadge = '<br><span class="badge bg-secondary" style="font-size: 0.65rem;"><i class="bi bi-check-circle me-1"></i>Partial Approved</span>';
                    } else if (call.supervisorApprovalStatus === 'Rejected') {
                        submissionStatusBadge = '<br><span class="badge bg-danger" style="font-size: 0.65rem;"><i class="bi bi-x-circle me-1"></i>Rejected</span>';
                    } else if (call.supervisorApprovalStatus === 'Reverted') {
                        submissionStatusBadge = '<br><span class="badge bg-warning text-dark" style="font-size: 0.65rem;"><i class="bi bi-arrow-return-left me-1"></i>Reverted</span>';
                    } else {
                        submissionStatusBadge = '<br><span class="badge bg-primary" style="font-size: 0.65rem;"><i class="bi bi-send-check me-1"></i>Submitted</span>';
                    }
                }

                // Assignment status badge - show if call is assigned to current user or pending reassignment
                let assignmentBadge = '';
                const isPendingOutgoingReassignment = call.assignmentStatus === 'assigned_out_pending';
                if (call.assignmentStatus === 'assigned') {
                    assignmentBadge = '<br><span class="badge bg-info" style="font-size: 0.65rem;"><i class="bi bi-arrow-left me-1"></i>Assigned to you</span>';
                } else if (isPendingOutgoingReassignment) {
                    const assignedToDisplay = call.assignedTo ? escapeHtml(call.assignedTo) : 'another user';
                    assignmentBadge = `<br><span class="badge bg-warning text-dark" style="font-size: 0.65rem;"><i class="bi bi-hourglass-split me-1"></i>Pending with ${assignedToDisplay}</span>`;
                }

                statusBadge = verificationBadge + submissionStatusBadge + assignmentBadge;

                // Disable checkbox if locked (approved) OR if submitted and pending approval OR if pending outgoing reassignment
                const isSubmittedPending = call.isSubmittedToSupervisor &&
                    (call.supervisorApprovalStatus === 'Pending' || call.supervisorApprovalStatus === 'Approved' || call.supervisorApprovalStatus === 'PartiallyApproved');
                const isSubmittedRejectedOrReverted = call.isSubmittedToSupervisor &&
                    (call.supervisorApprovalStatus === 'Rejected' || call.supervisorApprovalStatus === 'Reverted');
                const canModify = !call.isLocked && !isSubmittedPending && !isPendingOutgoingReassignment; // Can modify if not locked, not pending/approved, and not pending reassignment
                const isDisabled = (call.isLocked || isSubmittedPending || isPendingOutgoingReassignment) ? 'disabled' : '';
                const rowClass = call.isLocked ? 'table-secondary' : (isSubmittedPending ? 'table-info bg-opacity-25' : (isSubmittedRejectedOrReverted ? 'table-warning bg-opacity-25' : ''));

                // Get extension, month, year from contentDiv for checkbox data attributes
                const extension = contentDiv.dataset.extension || '';
                const month = contentDiv.dataset.month || '';
                const year = contentDiv.dataset.year || '';

                html += `
                    <tr class="${rowClass}">
                        <td><input type="checkbox" class="form-check-input call-checkbox-ajax"
                            value="${call.id}" data-dialed-group="${dialedGroupId}"
                            data-extension="${escapeHtmlAttr(extension)}"
                            data-month="${month}" data-year="${year}"
                            data-verified="${call.isVerified}" data-locked="${call.isLocked}"
                            data-expired="false"
                            data-submitted="${call.isSubmittedToSupervisor || false}"
                            data-approval-status="${call.supervisorApprovalStatus || ''}" ${isDisabled}></td>
                        <td>
                            <span>${dateStr}</span>
                            <br><small class="text-muted">${timeStr}</small>
                        </td>
                        <td>${durationStr}</td>
                        <td>KSh ${call.callCostKSH.toFixed(2)}</td>
                        <td>$${call.callCostUSD.toFixed(2)}</td>
                        <td><span class="badge bg-light text-dark">${call.callType || '-'}</span></td>
                        <td>${statusBadge}</td>
                        <td class="text-center">
                            <div class="d-flex align-items-center justify-content-center gap-1">
                            ${call.isLocked ? '<span class="text-muted small"><i class="bi bi-lock-fill"></i> Locked</span>' :
                              isPendingOutgoingReassignment ? `
                                <span class="text-muted small me-2"><i class="bi bi-hourglass-split"></i> Pending</span>
                                <button type="button" class="btn btn-outline-warning btn-sm"
                                        style="padding: 0.2rem 0.5rem; font-size: 0.7rem;"
                                        onclick="showRecallModal(${call.id}, '${escapeHtmlAttr(call.dialedNumber)}', ${call.callCostUSD.toFixed(2)}, '${escapeHtmlAttr(call.assignedTo || '')}')"
                                        title="Recall this reassignment">
                                    <i class="bi bi-arrow-return-left me-1"></i>Recall
                                </button>
                              ` :
                              !canModify ? '<span class="text-muted small"><i class="bi bi-hourglass-split"></i> Awaiting Approval</span>' :
                              call.callType === 'Corporate Value Pack Data 25GB' ? `
                                <span class="badge bg-dark" style="font-size: 0.7rem;" title="Auto-Official: Corporate Value Pack Data calls cannot be marked as Personal">
                                    <i class="bi bi-shield-lock-fill me-1"></i>Official (Auto)
                                </span>` : `
                                <select class="form-select form-select-sm" style="width: 90px; font-size: 0.75rem;"
                                        onchange="quickVerifyCallAjax(${call.id}, this.value)">
                                    <option value="Official" ${call.verificationType !== 'Personal' ? 'selected' : ''}>Official</option>
                                    <option value="Personal" ${call.verificationType === 'Personal' ? 'selected' : ''}>Personal</option>
                                </select>
                                ${!call.isSubmittedToSupervisor ? `
                                <button type="button" class="btn btn-outline-secondary btn-sm"
                                        style="padding: 0.2rem 0.4rem; font-size: 0.7rem;"
                                        onclick="openReassignDialog(${call.id}, '${escapeHtmlAttr(call.callNumber)}', '${escapeHtmlAttr(call.callDestination || '')}', event)"
                                        title="Reassign to another user">
                                    <i class="bi bi-person-plus"></i>
                                </button>
                                ` : ''}
                                ${call.assignmentStatus === 'assigned' ? `
                                <div class="btn-group btn-group-sm ms-1">
                                    <button type="button" class="btn btn-success btn-sm"
                                            style="padding: 0.2rem 0.4rem; font-size: 0.7rem;"
                                            onclick="showAcceptModal(${call.id}, '${escapeHtmlAttr(call.dialedNumber)}', ${call.callCostUSD.toFixed(2)}, '${escapeHtmlAttr(call.assignedFrom || '')}')"
                                            title="Accept this assignment">
                                        <i class="bi bi-check-lg"></i>
                                    </button>
                                    <button type="button" class="btn btn-danger btn-sm"
                                            style="padding: 0.2rem 0.4rem; font-size: 0.7rem;"
                                            onclick="showRejectModal(${call.id}, '${escapeHtmlAttr(call.dialedNumber)}', ${call.callCostUSD.toFixed(2)}, '${escapeHtmlAttr(call.assignedFrom || '')}')"
                                            title="Reject this assignment">
                                        <i class="bi bi-x-lg"></i>
                                    </button>
                                </div>
                                ` : ''}
                            `}
                            </div>
                        </td>
                    </tr>
                `;
            });

            html += `</tbody></table>`;

            // Add pagination if needed
            if (data.totalPages > 1) {
                html += renderCallLogsPagination(data, dialedGroupId);
            }

            contentDiv.innerHTML = html;

            // Apply selection state to newly loaded call checkboxes
            const extension = contentDiv.dataset.extension;
            const month = contentDiv.dataset.month;
            const year = contentDiv.dataset.year;
            applySelectionStateToCallLogs(extension, month, year, dialedGroupId);

            // Also update the dialed number checkbox state and quick verify buttons
            updateDialedNumberCheckbox(dialedGroupId);
            updateQuickVerifyButtons();
        }

        // Render pagination for Level 2 (dialed numbers)
        function renderPagination(data, type, groupId) {
            // Escape the groupId for safe use in HTML attributes
            const safeGroupId = escapeHtmlAttr(groupId);

            let html = `
                <div class="d-flex justify-content-between align-items-center p-2 border-top" style="background: #f8fafc;">
                    <small class="text-muted">Showing ${(data.currentPage - 1) * data.pageSize + 1} - ${Math.min(data.currentPage * data.pageSize, data.totalCount)} of ${data.totalCount} dialed numbers</small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0" data-group-id="${safeGroupId}">
            `;

            // Previous button
            if (data.currentPage > 1) {
                html += `<li class="page-item"><a class="page-link dialednumbers-page-link" href="#" data-page="${data.currentPage - 1}">«</a></li>`;
            }

            // Page numbers
            for (let i = Math.max(1, data.currentPage - 2); i <= Math.min(data.totalPages, data.currentPage + 2); i++) {
                html += `<li class="page-item ${i === data.currentPage ? 'active' : ''}">
                    <a class="page-link dialednumbers-page-link" href="#" data-page="${i}">${i}</a>
                </li>`;
            }

            // Next button
            if (data.currentPage < data.totalPages) {
                html += `<li class="page-item"><a class="page-link dialednumbers-page-link" href="#" data-page="${data.currentPage + 1}">»</a></li>`;
            }

            html += `</ul></nav></div>`;
            return html;
        }

        // Render pagination for Level 3 (call logs)
        function renderCallLogsPagination(data, dialedGroupId) {
            // Escape the dialedGroupId for safe use in HTML attributes
            const safeDialedGroupId = escapeHtmlAttr(dialedGroupId);

            let html = `
                <div class="d-flex justify-content-between align-items-center p-2 border-top" style="background: #f8fafc;">
                    <small class="text-muted">Showing ${(data.currentPage - 1) * data.pageSize + 1} - ${Math.min(data.currentPage * data.pageSize, data.totalCount)} of ${data.totalCount} calls</small>
                    <nav>
                        <ul class="pagination pagination-sm mb-0" data-dialed-group-id="${safeDialedGroupId}">
            `;

            if (data.currentPage > 1) {
                html += `<li class="page-item"><a class="page-link calllogs-page-link" href="#" data-page="${data.currentPage - 1}">«</a></li>`;
            }

            for (let i = Math.max(1, data.currentPage - 2); i <= Math.min(data.totalPages, data.currentPage + 2); i++) {
                html += `<li class="page-item ${i === data.currentPage ? 'active' : ''}">
                    <a class="page-link calllogs-page-link" href="#" data-page="${i}">${i}</a>
                </li>`;
            }

            if (data.currentPage < data.totalPages) {
                html += `<li class="page-item"><a class="page-link calllogs-page-link" href="#" data-page="${data.currentPage + 1}">»</a></li>`;
            }

            html += `</ul></nav></div>`;
            return html;
        }

        // Escape string for use in HTML attributes
        function escapeHtmlAttr(str) {
            if (!str) return '';
            return str.replace(/&/g, '&amp;')
                      .replace(/'/g, '&#39;')
                      .replace(/"/g, '&quot;')
                      .replace(/</g, '&lt;')
                      .replace(/>/g, '&gt;');
        }

        // Format data size from KB to appropriate unit (KB, MB, GB)
        function formatDataSize(kb) {
            if (kb === null || kb === undefined || isNaN(kb)) return '0 KB';

            if (kb < 1024) {
                return `${kb.toFixed(2)} KB`;
            } else if (kb < 1024 * 1024) {
                return `${(kb / 1024).toFixed(2)} MB`;
            } else {
                return `${(kb / (1024 * 1024)).toFixed(2)} GB`;
            }
        }

        // Load dialed numbers page (for pagination)
        async function loadDialedNumbersPage(groupId, page) {
            const content = document.getElementById('dialed-content-' + groupId);
            if (content) {
                await loadDialedNumbers(content, page);
            }
        }

