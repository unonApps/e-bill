            document.getElementById('reassignMonth').value = month;
            document.getElementById('reassignYear').value = year;
            document.getElementById('reassignCallId').value = '0'; // Not used for extension level
            document.getElementById('hiddenDialedNumber').value = ''; // Not used for extension level

            // Update modal display
            document.getElementById('reassignModalTitle').textContent = 'Reassign Extension Calls';
            document.getElementById('reassignModalSubtitle').textContent = `Reassign all unsubmitted calls from extension ${extension}`;

            // Hide dialed number info, show extension and call count info
            document.getElementById('reassignDialedNumber').parentElement.style.display = 'none';
            document.getElementById('reassignExtensionInfo').style.display = 'flex';
            document.getElementById('reassignExtensionNumber').textContent = extension;
            document.getElementById('reassignCallCountInfo').style.display = 'flex';
            document.getElementById('reassignCallCount').textContent = callCount + ' calls';

            const modal = new bootstrap.Modal(document.getElementById('reassignModal'));
            modal.show();
        }

        // Open reassign dialog for all calls to a dialed number (Level 2)
        function openReassignDialogForDialedNumber(dialedNumber, extension, month, year, callCount) {
            // Reset modal
            resetReassignModal();

            // Set dialed-number-level reassignment data
            document.getElementById('reassignLevel').value = 'dialed';
            document.getElementById('reassignExtension').value = extension;
            document.getElementById('reassignMonth').value = month;
            document.getElementById('reassignYear').value = year;
            document.getElementById('reassignCallId').value = '0'; // Not used for dialed level
            document.getElementById('hiddenDialedNumber').value = dialedNumber;

            // Update modal display
            document.getElementById('reassignModalTitle').textContent = 'Reassign Dialed Number Calls';
            document.getElementById('reassignModalSubtitle').textContent = `Reassign all unsubmitted calls to ${dialedNumber}`;

            // Show dialed number info, also show extension and call count
            document.getElementById('reassignDialedNumber').parentElement.style.display = 'flex';
            document.getElementById('reassignDialedNumber').textContent = dialedNumber;
            document.getElementById('reassignExtensionInfo').style.display = 'flex';
            document.getElementById('reassignExtensionNumber').textContent = extension;
            document.getElementById('reassignCallCountInfo').style.display = 'flex';
            document.getElementById('reassignCallCount').textContent = callCount + ' calls';

            const modal = new bootstrap.Modal(document.getElementById('reassignModal'));
            modal.show();
        }

        // Reset reassign modal to default state
        function resetReassignModal() {
            // Reset hidden fields
            document.getElementById('reassignCallId').value = '';
            document.getElementById('hiddenDialedNumber').value = '';
            document.getElementById('reassignLevel').value = 'call';
            document.getElementById('reassignExtension').value = '';
            document.getElementById('reassignMonth').value = '';
            document.getElementById('reassignYear').value = '';

            // Reset display elements
            document.getElementById('reassignDialedNumber').textContent = '';
            document.getElementById('reassignDialedNumber').parentElement.style.display = 'flex';
            document.getElementById('reassignExtensionInfo').style.display = 'none';
            document.getElementById('reassignCallCountInfo').style.display = 'none';

            // Clear selected user
            clearSelectedUser();
        }

        // Variables for reassignment
        let selectedUserForReassignment = null;

        // Search users for reassignment
        async function searchUsersForReassignment(searchTerm) {
            const resultsDiv = document.getElementById('reassignUserSearchResults');

            if (!searchTerm || searchTerm.length < 2) {
                resultsDiv.innerHTML = `
                    <div class="text-center py-3 text-muted">
                        <i class="bi bi-search" style="font-size: 2rem; opacity: 0.3;"></i>
                        <p class="mt-2 mb-0 small">Start typing to search users...</p>
                    </div>
                `;
                return;
            }

            // Show loading
            resultsDiv.innerHTML = `
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Searching...</span>
                    </div>
                    <p class="mt-2 mb-0 small">Searching for users...</p>
                </div>
            `;

            try {
                const response = await fetch(`/Modules/EBillManagement/CallRecords/MyCallLogs?handler=SearchUsers&searchTerm=${encodeURIComponent(searchTerm)}`);
                const data = await response.json();

                if (data.error) {
                    resultsDiv.innerHTML = `
                        <div class="alert alert-danger mb-0">
                            <i class="bi bi-x-circle me-2"></i>
                            ${data.error}
                        </div>
                    `;
                    return;
                }

                if (data.users && data.users.length > 0) {
                    // Display users
                    const usersHtml = data.users.map(user => `
                        <div class="border rounded-3 p-3 mb-2 user-select-card" style="cursor: pointer; transition: all 0.2s;"
                             onmouseover="this.style.background='#f9fafb'; this.style.borderColor='#9ca3af';"
                             onmouseout="this.style.background='white'; this.style.borderColor='#e5e7eb';"
                             onclick="selectUserForReassignment('${user.indexNumber}', '${user.firstName}', '${user.lastName}', '${user.email || 'N/A'}')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold" style="color: #1f2937;">
                                        ${user.firstName} ${user.lastName}
                                    </div>
                                    <div class="text-muted small mt-1">
                                        <i class="bi bi-person-badge me-1"></i>Index: ${user.indexNumber}
                                    </div>
                                    <div class="text-muted small">
                                        <i class="bi bi-envelope me-1"></i>${user.email || 'N/A'}
                                    </div>
                                </div>
                                <div class="text-end">
                                    <i class="bi bi-chevron-right" style="color: #9ca3af;"></i>
                                </div>
                            </div>
                        </div>
                    `).join('');

                    resultsDiv.innerHTML = usersHtml;
                } else if (data.isSearchingForSelf) {
                    // User is searching for themselves
                    resultsDiv.innerHTML = `
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Cannot assign to yourself</strong><br>
                            You are currently logged in as ${data.currentUserName}. You cannot reassign calls to yourself.
                        </div>
                    `;
                } else {
                    resultsDiv.innerHTML = `
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            No users found matching "${searchTerm}"
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error searching users:', error);
                resultsDiv.innerHTML = `
                    <div class="alert alert-danger mb-0">
                        <i class="bi bi-x-circle me-2"></i>
                        Error searching users. Please try again.
                    </div>
                `;
            }
        }

        // Select user for reassignment
        function selectUserForReassignment(indexNumber, firstName, lastName, email) {
            selectedUserForReassignment = { indexNumber, firstName, lastName, email };

            // Update hidden input
            document.getElementById('selectedUserIndexNumber').value = indexNumber;

            // Show preview
            const previewDiv = document.getElementById('selectedUserPreview');
            const detailsDiv = document.getElementById('selectedUserDetails');

            detailsDiv.innerHTML = `
                <div>
                    <strong style="color: #1f2937;">${firstName} ${lastName}</strong><br>
                    <span class="text-muted small">Index: ${indexNumber}</span><br>
                    <span class="text-muted small">Email: ${email}</span>
                </div>
            `;

            previewDiv.classList.remove('d-none');

            // Clear search
            document.getElementById('reassignUserSearchInput').value = '';
            document.getElementById('reassignUserSearchResults').innerHTML = '';
        }

        // Clear selected user
        function clearSelectedUser() {
            selectedUserForReassignment = null;
            document.getElementById('selectedUserIndexNumber').value = '';
            document.getElementById('selectedUserPreview').classList.add('d-none');
            document.getElementById('reassignUserSearchInput').value = '';
            document.getElementById('reassignUserSearchResults').innerHTML = `
                <div class="text-center py-3 text-muted">
                    <i class="bi bi-search" style="font-size: 2rem; opacity: 0.3;"></i>
                    <p class="mt-2 mb-0 small">Start typing to search users...</p>
                </div>
            `;
        }

        // Initialize extension checkboxes on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Update all extension checkboxes to reflect their current state
            document.querySelectorAll('.extension-checkbox').forEach(extCheck => {
                const extension = extCheck.getAttribute('data-extension');
                const month = extCheck.getAttribute('data-month');
                const year = extCheck.getAttribute('data-year');
                updateExtensionCheckbox(extension, month, year);
            });

            // Event delegation for Level 2 (dialed numbers) pagination
            document.addEventListener('click', function(e) {
                const pageLink = e.target.closest('.dialednumbers-page-link');
                if (pageLink) {
                    e.preventDefault();
                    const page = parseInt(pageLink.dataset.page);
                    const paginationContainer = pageLink.closest('ul.pagination');
                    if (paginationContainer) {
                        const groupId = paginationContainer.dataset.groupId;
                        if (groupId && page) {
                            loadDialedNumbersPage(groupId, page);
                        }
                    }
                }
            });

            // Event delegation for Level 3 (call logs) pagination
            document.addEventListener('click', function(e) {
                const pageLink = e.target.closest('.calllogs-page-link');
                if (pageLink) {
                    e.preventDefault();
                    e.stopPropagation();

                    console.log('=== LEVEL 3 PAGINATION CLICK ===');
                    console.log('Clicked element:', pageLink);
                    console.log('data-page attribute:', pageLink.dataset.page);

                    const page = parseInt(pageLink.dataset.page);
                    console.log('Parsed page number:', page);

                    const paginationContainer = pageLink.closest('ul.pagination');
                    console.log('Pagination container:', paginationContainer);

                    if (paginationContainer) {
                        const dialedGroupId = paginationContainer.dataset.dialedGroupId;
                        console.log('dialedGroupId from container:', dialedGroupId);

                        // Check if page is valid (could be 0 which is falsy)
                        if (dialedGroupId && !isNaN(page) && page >= 1) {
                            console.log('>>> Calling loadCallLogsPage with:', { dialedGroupId, page });
                            loadCallLogsPage(dialedGroupId, page);
                        } else {
                            console.error('Invalid pagination params!');
                            console.error('page:', page, 'isNaN:', isNaN(page));
                            console.error('dialedGroupId:', dialedGroupId);
                        }
                    } else {
                        console.error('Pagination container (ul.pagination) not found!');
                    }
                }
            });

            // Event delegation for Level 3 (call logs) sorting
            document.addEventListener('click', function(e) {
                const sortHeader = e.target.closest('.sortable-header');
                if (sortHeader) {
                    e.preventDefault();
                    e.stopPropagation();

                    const sortBy = sortHeader.dataset.sort;
                    const dialedGroupId = sortHeader.dataset.dialedGroup;

                    if (!sortBy || !dialedGroupId) return;

                    const contentDiv = document.getElementById('calllogs-content-' + dialedGroupId);
                    if (!contentDiv) return;

                    // Get current sort state
                    const currentSortBy = contentDiv.dataset.sortBy || 'CallDate';
                    const currentSortDesc = contentDiv.dataset.sortDesc !== 'false';

                    // Determine new sort direction
                    let newSortDesc;
                    if (currentSortBy.toLowerCase() === sortBy.toLowerCase()) {
                        // Toggle direction if same column
                        newSortDesc = !currentSortDesc;
                    } else {
                        // Default to descending for new column
                        newSortDesc = true;
                    }

                    // Get other data attributes
                    const extension = contentDiv.dataset.extension;
                    const month = contentDiv.dataset.month;
                    const year = contentDiv.dataset.year;
                    const dialedNumber = contentDiv.dataset.dialedNumber;

                    console.log('Sorting by:', sortBy, 'desc:', newSortDesc);

                    // Reload with new sort, starting at page 1
                    loadCallLogs(contentDiv, extension, month, year, dialedNumber, dialedGroupId, 1, sortBy, newSortDesc);
                }
            });

            // Event delegation for AJAX-loaded checkbox changes (Level 3)
            document.addEventListener('change', function(e) {
                if (e.target.classList.contains('call-checkbox-ajax')) {
                    const extension = e.target.getAttribute('data-extension');
                    const month = e.target.getAttribute('data-month');
                    const year = e.target.getAttribute('data-year');
                    const dialedGroup = e.target.getAttribute('data-dialed-group');
                    const isChecked = e.target.checked;

                    // If manually unchecking, clear parent selection states
                    // (since not all children are selected anymore)
                    if (!isChecked) {
                        if (dialedGroup) {
                            setDialedNumberSelected(dialedGroup, false);
                        }
                        if (extension && month && year) {
                            setExtensionSelected(extension, month, year, false);
                        }
                    }

                    // Update Level 2 (dialed number) checkbox
                    if (dialedGroup) {
                        updateDialedNumberCheckbox(dialedGroup);
                    }

                    // Update Level 1 (extension) checkbox
                    if (extension && month && year) {
                        updateExtensionCheckbox(extension, month, year);
                    }

                    updateQuickVerifyButtons();
                }
            });

            // Initialize Bootstrap tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl, {
                    trigger: 'hover',
                    delay: { show: 300, hide: 100 }
                });
            });

            // Initialize reassignment search input with debounce
            const searchInput = document.getElementById('reassignUserSearchInput');
            if (searchInput) {
                let searchTimeout;
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        searchUsersForReassignment(this.value);
                    }, 500);
                });
            }

            // Reset form when reassignment modal is closed
            const reassignModal = document.getElementById('reassignModal');
            if (reassignModal) {
                reassignModal.addEventListener('hidden.bs.modal', function () {
                    clearSelectedUser();
                });

                // Show initial message when modal opens
                reassignModal.addEventListener('shown.bs.modal', function () {
                    if (!selectedUserForReassignment) {
                        document.getElementById('reassignUserSearchResults').innerHTML = `
                            <div class="text-center py-3 text-muted">
                                <i class="bi bi-search" style="font-size: 2rem; opacity: 0.3;"></i>
                                <p class="mt-2 mb-0 small">Start typing to search users...</p>
                            </div>
                        `;
                    }
                });
            }
        });
    </script>
}
