        // Quick verify single call via AJAX
        async function quickVerifyCallAjax(callId, verificationType) {
            if (!verificationType) return;

            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=QuickVerify';

            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
            form.appendChild(tokenInput);

            const typeInput = document.createElement('input');
            typeInput.type = 'hidden';
            typeInput.name = 'verificationType';
            typeInput.value = verificationType;
            form.appendChild(typeInput);

            const idInput = document.createElement('input');
            idInput.type = 'hidden';
            idInput.name = 'selectedIds';
            idInput.value = callId;
            form.appendChild(idInput);

            // Show loading overlay
            showLoadingOverlay('Marking Call...', `Marking call as ${verificationType}.`);

            document.body.appendChild(form);
            form.submit();
        }

        // Verify all calls for a dialed number via AJAX
        function verifyAllDialedNumberAjax(dialedGroupId, dialedNumber, extension, month, year, verificationType) {
            const typeLabel = verificationType === 'Official' ? 'Official (work-related)' : 'Personal';
            const typeColor = verificationType === 'Official' ? 'success' : 'warning';

            showConfirmation(
                `Mark All Calls to ${dialedNumber}?`,
                `You are about to mark <strong>ALL calls</strong> to <strong>${dialedNumber}</strong> as <span class="badge bg-${typeColor}">${typeLabel}</span>.`,
                'Yes, Mark All',
                () => {
                    // Submit form to mark all by dialed number
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '?handler=VerifyAllByDialedNumber';

                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    form.appendChild(tokenInput);

                    [['extension', extension], ['month', month], ['year', year], ['dialedNumber', dialedNumber], ['verificationType', verificationType]].forEach(([name, value]) => {
                        const input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = name;
                        input.value = value;
                        form.appendChild(input);
                    });

                    // Show loading overlay before submit
                    showLoadingOverlay(
                        'Marking Calls...',
                        `Marking all calls to ${dialedNumber} as ${verificationType}. This may take a moment.`
                    );

                    document.body.appendChild(form);
                    form.submit();
                }
            );
        }

        // Toggle all checkboxes in a dialed number group
        function toggleAllCallsInDialedNumber(dialedGroupId, masterCheckbox) {
            const checkboxes = document.querySelectorAll(`.call-checkbox-ajax[data-dialed-group="${dialedGroupId}"]`);
            checkboxes.forEach(cb => {
                if (!cb.disabled) {
                    cb.checked = masterCheckbox.checked;
                }
            });
        }

        // Legacy toggleDialedNumberDetails function (keeping for compatibility)
        function toggleDialedNumberDetails(dialedGroupId) {
            const subRows = document.querySelectorAll(`tr.call-detail-row[data-group="${dialedGroupId}"]`);
            const toggle = document.getElementById('toggle-dialed-' + dialedGroupId);

            if (subRows.length > 0) {
                const isHidden = subRows[0].style.display === 'none';

                subRows.forEach(row => {
                    row.style.display = isHidden ? '' : 'none';
                });

                if (toggle) {
                    if (isHidden) {
                        toggle.classList.remove('bi-plus-circle');
                        toggle.classList.add('bi-dash-circle');
                    } else {
                        toggle.classList.remove('bi-dash-circle');
                        toggle.classList.add('bi-plus-circle');
                    }
                }
            }
        }

        // Legacy extension toggle (keeping for compatibility)
        function toggleExtension(extensionId) {
            const rows = document.querySelectorAll(`tr.extension-row[data-extension="${extensionId}"]`);
            const toggle = document.getElementById('toggle-' + extensionId);

            if (rows.length > 0) {
                const isHidden = rows[0].style.display === 'none';

                rows.forEach(row => {
                    row.style.display = isHidden ? '' : 'none';
                });

                if (isHidden) {
                    toggle.classList.remove('bi-chevron-right');
                    toggle.classList.add('bi-chevron-down');
                } else {
                    toggle.classList.remove('bi-chevron-down');
                    toggle.classList.add('bi-chevron-right');
                }
            }
        }

        function expandAllExtensions() {
            document.querySelectorAll('.extension-row').forEach(row => {
                row.style.display = '';
            });
            document.querySelectorAll('.extension-toggle').forEach(toggle => {
                toggle.classList.remove('bi-chevron-right');
                toggle.classList.add('bi-chevron-down');
            });
        }

        function collapseAllExtensions() {
            document.querySelectorAll('.extension-row').forEach(row => {
                row.style.display = 'none';
            });
            document.querySelectorAll('.extension-toggle').forEach(toggle => {
                toggle.classList.remove('bi-chevron-down');
                toggle.classList.add('bi-chevron-right');
            });
        }

        // =====================================================
        // Selection State Tracking
        // =====================================================
        // Track which extensions and dialed numbers are "fully selected"
        // so we can apply selection to content that loads later (AJAX/pagination)
        const selectionState = {
            extensions: new Map(), // key: "extension_month_year", value: true/false
            dialedNumbers: new Map() // key: "dialedGroupId", value: true/false
        };

        function getExtensionKey(extension, month, year) {
            return `${extension}_${month}_${year}`;
        }

        function setExtensionSelected(extension, month, year, selected) {
            const key = getExtensionKey(extension, month, year);
            if (selected) {
                selectionState.extensions.set(key, true);
            } else {
                selectionState.extensions.delete(key);
            }
        }

        function isExtensionSelected(extension, month, year) {
            return selectionState.extensions.get(getExtensionKey(extension, month, year)) === true;
        }

        function setDialedNumberSelected(dialedGroupId, selected) {
            if (selected) {
                selectionState.dialedNumbers.set(dialedGroupId, true);
            } else {
                selectionState.dialedNumbers.delete(dialedGroupId);
            }
        }

        function isDialedNumberSelected(dialedGroupId) {
            return selectionState.dialedNumbers.get(dialedGroupId) === true;
        }

        // Apply selection state to newly loaded content
        function applySelectionStateToDialedNumbers(extension, month, year) {
            if (isExtensionSelected(extension, month, year)) {
                // Parent extension is selected, select all dialed number checkboxes
                const dialedCheckboxes = document.querySelectorAll(
                    `.dialed-number-checkbox[data-extension="${extension}"][data-month="${month}"][data-year="${year}"]`
                );
                dialedCheckboxes.forEach(cb => {
                    cb.checked = true;
                    cb.indeterminate = false;
                    // Also mark this dialed number as selected
                    const dialedGroupId = cb.getAttribute('data-dialed-group');
                    if (dialedGroupId) {
                        setDialedNumberSelected(dialedGroupId, true);
                    }
                });
            }
        }

        function applySelectionStateToCallLogs(extension, month, year, dialedGroupId) {
            const isParentExtensionSelected = isExtensionSelected(extension, month, year);
            const isParentDialedSelected = isDialedNumberSelected(dialedGroupId);

            if (isParentExtensionSelected || isParentDialedSelected) {
                // Parent is selected, select all call checkboxes for this dialed group
                const callCheckboxes = document.querySelectorAll(
                    `.call-checkbox-ajax[data-dialed-group="${dialedGroupId}"]`
                );
                callCheckboxes.forEach(cb => {
                    if (cb.getAttribute('data-locked') === 'false') {
                        cb.checked = true;
                    }
                });
            }
        }

        // Extension-level checkbox functions (Level 1)
        function toggleExtensionCalls(extensionCheckbox) {
            const extension = extensionCheckbox.getAttribute('data-extension');
            const month = extensionCheckbox.getAttribute('data-month');
            const year = extensionCheckbox.getAttribute('data-year');
            const isChecked = extensionCheckbox.checked;

            // Store selection state for this extension
            setExtensionSelected(extension, month, year, isChecked);

            // Toggle Level 2 (dialed number) checkboxes that are currently loaded
            const dialedNumberCheckboxes = document.querySelectorAll(
                `.dialed-number-checkbox[data-extension="${extension}"][data-month="${month}"][data-year="${year}"]`
            );
            dialedNumberCheckboxes.forEach(cb => {
                cb.checked = isChecked;
                cb.indeterminate = false;
                // Also update dialed number selection state
                const dialedGroupId = cb.getAttribute('data-dialed-group');
                if (dialedGroupId) {
                    setDialedNumberSelected(dialedGroupId, isChecked);
                }
            });

            // Toggle Level 3 (call) checkboxes that are currently loaded
            const callCheckboxes = document.querySelectorAll(
                `.call-checkbox[data-extension="${extension}"][data-month="${month}"][data-year="${year}"], ` +
                `.call-checkbox-ajax[data-extension="${extension}"][data-month="${month}"][data-year="${year}"]`
            );

            callCheckboxes.forEach(cb => {
                // Only toggle unlocked checkboxes
                if (cb.getAttribute('data-locked') === 'false') {
                    cb.checked = isChecked;
                }
            });

            updateQuickVerifyButtons();
        }

        function updateExtensionCheckbox(extension, month, year) {
            // Find the extension checkbox by matching extension + month + year
            const extensionCheckbox = document.querySelector(
                `.extension-checkbox[data-extension="${extension}"][data-month="${month}"][data-year="${year}"]`
            );
            if (!extensionCheckbox) return;

            // Include both static and AJAX-loaded checkboxes matching extension + month + year
            const checkboxes = Array.from(document.querySelectorAll(
                `.call-checkbox[data-extension="${extension}"][data-month="${month}"][data-year="${year}"], ` +
                `.call-checkbox-ajax[data-extension="${extension}"][data-month="${month}"][data-year="${year}"]`
            )).filter(cb => cb.getAttribute('data-locked') === 'false');

            if (checkboxes.length === 0) return;

            const checkedCount = checkboxes.filter(cb => cb.checked).length;

            if (checkedCount === 0) {
                extensionCheckbox.checked = false;
                extensionCheckbox.indeterminate = false;
            } else if (checkedCount === checkboxes.length) {
                extensionCheckbox.checked = true;
                extensionCheckbox.indeterminate = false;
            } else {
                extensionCheckbox.checked = false;
                extensionCheckbox.indeterminate = true;
            }
        }

        // Level 2 (Dialed Number) checkbox functions
        function toggleDialedNumberCalls(dialedNumberCheckbox) {
            const dialedGroupId = dialedNumberCheckbox.getAttribute('data-dialed-group');
            const extension = dialedNumberCheckbox.getAttribute('data-extension');
            const month = dialedNumberCheckbox.getAttribute('data-month');
            const year = dialedNumberCheckbox.getAttribute('data-year');
            const isChecked = dialedNumberCheckbox.checked;

            // Store selection state for this dialed number
            setDialedNumberSelected(dialedGroupId, isChecked);

            // If unchecking, also clear the parent extension selection
            // (since not all children are selected anymore)
            if (!isChecked) {
                setExtensionSelected(extension, month, year, false);
            }

            // Select all Level 3 call checkboxes under this dialed number (currently loaded)
            const checkboxes = document.querySelectorAll(
                `.call-checkbox-ajax[data-dialed-group="${dialedGroupId}"]`
            );

            checkboxes.forEach(cb => {
                // Only toggle unlocked checkboxes
                if (cb.getAttribute('data-locked') === 'false') {
                    cb.checked = isChecked;
                }
            });

            // Update the parent extension checkbox
            updateExtensionCheckbox(extension, month, year);
            updateQuickVerifyButtons();
        }

        function updateDialedNumberCheckbox(dialedGroupId) {
            const dialedNumberCheckbox = document.getElementById('dn-check-' + dialedGroupId);
            if (!dialedNumberCheckbox) return;

            // Get all Level 3 call checkboxes under this dialed number
            const checkboxes = Array.from(document.querySelectorAll(
                `.call-checkbox-ajax[data-dialed-group="${dialedGroupId}"]`
            )).filter(cb => cb.getAttribute('data-locked') === 'false');

            if (checkboxes.length === 0) return;

            const checkedCount = checkboxes.filter(cb => cb.checked).length;

            if (checkedCount === 0) {
                dialedNumberCheckbox.checked = false;
                dialedNumberCheckbox.indeterminate = false;
            } else if (checkedCount === checkboxes.length) {
                dialedNumberCheckbox.checked = true;
                dialedNumberCheckbox.indeterminate = false;
            } else {
                dialedNumberCheckbox.checked = false;
                dialedNumberCheckbox.indeterminate = true;
            }
        }

        function toggleSelectAll(checkbox) {
            const isChecked = checkbox.checked;

            // Update selection state for all extensions
            document.querySelectorAll('.extension-checkbox').forEach(extCheck => {
                const extension = extCheck.getAttribute('data-extension');
                const month = extCheck.getAttribute('data-month');
                const year = extCheck.getAttribute('data-year');
                setExtensionSelected(extension, month, year, isChecked);
                extCheck.checked = isChecked;
                extCheck.indeterminate = false;
            });

            // Toggle Level 2 (dialed number) checkboxes and track state
            document.querySelectorAll('.dialed-number-checkbox').forEach(cb => {
                cb.checked = isChecked;
                cb.indeterminate = false;
                const dialedGroupId = cb.getAttribute('data-dialed-group');
                if (dialedGroupId) {
                    setDialedNumberSelected(dialedGroupId, isChecked);
                }
            });

            // Toggle Level 3 (call) checkboxes - both static and AJAX-loaded
            const callCheckboxes = document.querySelectorAll('.call-checkbox, .call-checkbox-ajax');
            callCheckboxes.forEach(cb => {
                // Select all unlocked calls (both verified and unverified)
                // Skip only locked calls (assigned out pending)
                if (cb.getAttribute('data-locked') === 'false') {
                    cb.checked = isChecked;
                }
            });

            updateQuickVerifyButtons();
        }

        function updateQuickVerifyButtons() {
            // Get both static and AJAX-loaded checkboxes
            const selectedCheckboxes = document.querySelectorAll('.call-checkbox:checked, .call-checkbox-ajax:checked');
            const selectedCount = selectedCheckboxes.length;

            // Count how many selected calls are unverified
            const unverifiedCount = Array.from(selectedCheckboxes)
                .filter(cb => cb.getAttribute('data-verified') === 'false')
                .length;

            const quickVerifyButtons = document.getElementById('quickVerifyButtons');
            const selectedCountElement = document.getElementById('selectedCount');
            const selectedCountNumber = document.getElementById('selectedCountNumber');

            // Show selection count if anything is selected
            if (selectedCount > 0) {
                selectedCountElement.style.display = 'inline';
                selectedCountNumber.textContent = selectedCount;
            } else {
                selectedCountElement.style.display = 'none';
            }

            // Only show Mark as Official/Personal buttons if unverified calls are selected
            if (unverifiedCount > 0) {
                quickVerifyButtons.style.display = 'inline-flex';
            } else {
                quickVerifyButtons.style.display = 'none';
            }
        }

        // Store submission data for the modal
        let submissionCallIds = [];
        let submissionData = null;

        async function submitToSupervisor() {
            // Get both static and AJAX-loaded checkboxes that are checked
            const selectedCheckboxes = Array.from(document.querySelectorAll('.call-checkbox:checked, .call-checkbox-ajax:checked'));

            // Also check for extension-level checkbox selections (content may not be expanded)
            const selectedExtensions = Array.from(document.querySelectorAll('.extension-checkbox:checked'));

            // Also check for dialed-number-level checkbox selections
            const selectedDialedNumbers = Array.from(document.querySelectorAll('.dialed-number-checkbox:checked'));

            // If we have no selections at any level, show error
            if (selectedCheckboxes.length === 0 && selectedExtensions.length === 0 && selectedDialedNumbers.length === 0) {
                showNotification('warning', 'No Selection', 'Please select at least one call to submit to supervisor.');
                return;
            }

            let allCallIds = [];
            let skippedSubmittedCount = 0;

            // Show loading indicator on button
            const submitBtn = document.querySelector('button[onclick="submitToSupervisor()"]');
            const originalText = submitBtn ? submitBtn.innerHTML : '';
            if (submitBtn) {
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Loading...';
                submitBtn.disabled = true;
            }

            try {
                // If extension checkboxes are selected, fetch call IDs for those extensions
                if (selectedExtensions.length > 0) {
                    for (const extCheckbox of selectedExtensions) {
                        const extension = extCheckbox.getAttribute('data-extension');
                        const month = extCheckbox.getAttribute('data-month');
                        const year = extCheckbox.getAttribute('data-year');

                        const response = await fetch(`?handler=CallIdsForExtension&extension=${encodeURIComponent(extension)}&month=${month}&year=${year}`);
                        if (response.ok) {
                            const data = await response.json();
                            if (data.callIds && data.callIds.length > 0) {
                                allCallIds = allCallIds.concat(data.callIds);
                            }
                            if (data.skippedCount > 0) {
                                skippedSubmittedCount += data.skippedCount;
                            }
                        }
                    }
                }

                // If dialed number checkboxes are selected, fetch call IDs for those dialed numbers
                if (selectedDialedNumbers.length > 0) {
                    for (const dnCheckbox of selectedDialedNumbers) {
                        const extension = dnCheckbox.getAttribute('data-extension');
                        const month = dnCheckbox.getAttribute('data-month');
                        const year = dnCheckbox.getAttribute('data-year');
                        const dialedNumber = dnCheckbox.getAttribute('data-dialed-number');

                        if (dialedNumber) {
                            const response = await fetch(`?handler=CallIdsForDialedNumber&extension=${encodeURIComponent(extension)}&month=${month}&year=${year}&dialedNumber=${encodeURIComponent(dialedNumber)}`);
                            if (response.ok) {
                                const data = await response.json();
                                if (data.callIds && data.callIds.length > 0) {
                                    data.callIds.forEach(id => {
                                        if (!allCallIds.includes(id)) {
                                            allCallIds.push(id);
                                        }
                                    });
                                }
                                if (data.skippedCount > 0) {
                                    skippedSubmittedCount += data.skippedCount;
                                }
                            }
                        }
                    }
                }

                // Also add any individually selected call checkboxes (excluding already submitted ones)
                selectedCheckboxes.forEach(cb => {
                    const callId = parseInt(cb.value);
                    const isSubmitted = cb.getAttribute('data-submitted') === 'true';
                    const approvalStatus = cb.getAttribute('data-approval-status') || '';

                    if (isSubmitted && (approvalStatus === 'Pending' || approvalStatus === 'Approved')) {
                        skippedSubmittedCount++;
                        return;
                    }

                    if (!allCallIds.includes(callId)) {
                        allCallIds.push(callId);
                    }
                });

                if (allCallIds.length === 0) {
                    if (skippedSubmittedCount > 0) {
                        showNotification('warning', 'Already Submitted', `All ${skippedSubmittedCount} selected call(s) have already been submitted to supervisor and are pending approval.`);
                    } else {
                        showNotification('warning', 'No Calls Found', 'No calls found to submit. Please try selecting calls directly or expand the rows first.');
                    }
                    return;
                }

                // Notify user if some calls were skipped
                if (skippedSubmittedCount > 0) {
                    const proceed = confirm(`${skippedSubmittedCount} call(s) are already submitted and pending approval - they will be skipped.\n\nProceed with submitting the remaining ${allCallIds.length} call(s)?`);
                    if (!proceed) return;
                }

                // Open the modal and load preview data
                await openSubmitToSupervisorModal(allCallIds);

            } catch (error) {
                console.error('Error in submitToSupervisor:', error);
                showNotification('error', 'Error', 'An error occurred while preparing submission. Please try again.');
            } finally {
                if (submitBtn) {
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            }
        }

        async function openSubmitToSupervisorModal(callIds) {
            submissionCallIds = callIds;

            // Show modal with loading state
            const modal = new bootstrap.Modal(document.getElementById('submitToSupervisorModal'));
            document.getElementById('submissionLoading').classList.remove('d-none');
            document.getElementById('submissionContent').classList.add('d-none');
            document.getElementById('submissionError').classList.add('d-none');
            modal.show();

            try {
                // Load preview data
                const response = await fetch(`?handler=SubmissionPreview&callIds=${callIds.join(',')}`);
                submissionData = await response.json();

                if (!submissionData.success) {
                    document.getElementById('submissionLoading').classList.add('d-none');
                    document.getElementById('submissionError').classList.remove('d-none');
                    document.getElementById('submissionErrorMessage').textContent = submissionData.message;
                    return;
                }

                // Populate modal content
                renderSubmissionPreview(submissionData);

                // Show content, hide loading
                document.getElementById('submissionLoading').classList.add('d-none');
                document.getElementById('submissionContent').classList.remove('d-none');

            } catch (error) {
                console.error('Error loading submission preview:', error);
                document.getElementById('submissionLoading').classList.add('d-none');
                document.getElementById('submissionError').classList.remove('d-none');
                document.getElementById('submissionErrorMessage').textContent = 'Failed to load submission preview. Please try again.';
            }
        }

        function renderSubmissionPreview(data) {
            // Determine currency display based on service provider
            // Safaricom, Airtel, PSTN = KSH; PrivateWire = USD
            const isPrivateWire = data.isPrivateWire;
            const currencySymbol = isPrivateWire ? '$' : 'KSh ';
            const officialCost = isPrivateWire ? data.officialCostUSD : data.officialCostKSH;
            const personalCost = isPrivateWire ? data.personalCostUSD : data.personalCostKSH;

            // Update summary cards
            document.getElementById('summaryTotalCalls').textContent = data.totalCalls;
            document.getElementById('summaryOfficialCost').textContent = `${currencySymbol}${officialCost.toFixed(2)}`;
            document.getElementById('summaryPersonalCost').textContent = `${currencySymbol}${personalCost.toFixed(2)}`;

            // Update allowance label (allowance is in USD)
            if (data.monthlyAllowance > 0) {
                document.getElementById('summaryAllowanceLabel').textContent = `Limit: $${data.monthlyAllowance.toFixed(2)}`;
            } else {
                document.getElementById('summaryAllowanceLabel').textContent = 'Official';
            }

            // Update overage card
            if (data.hasOverage) {
                document.getElementById('summaryOverageAmount').textContent = `$${data.overageAmountUSD.toFixed(2)}`;
                document.getElementById('summaryOverageAmount').classList.add('text-danger');
                document.getElementById('summaryOverageLabel').textContent = 'Overage';
                document.getElementById('summaryOverageIcon').innerHTML = '<i class="bi bi-exclamation-triangle text-danger"></i>';
                document.getElementById('overageWarningBanner').classList.remove('d-none');
                document.getElementById('overageWarningText').textContent =
                    `Calls exceeded allowance by $${data.overageAmountUSD.toFixed(2)}`;
            } else {
                document.getElementById('summaryOverageAmount').textContent = `${currencySymbol}${officialCost.toFixed(2)}`;
                document.getElementById('summaryOverageAmount').classList.remove('text-danger');
                document.getElementById('summaryOverageLabel').textContent = 'Total';
                document.getElementById('summaryOverageIcon').innerHTML = '<i class="bi bi-check-circle text-success"></i>';
                document.getElementById('overageWarningBanner').classList.add('d-none');
            }

            // Render phone overage justification forms if needed
            renderPhoneOverageSection(data.phoneOverages, data.callMonth, data.callYear);

            // Render supervisor info
            document.getElementById('supervisorName').textContent = data.supervisor.name;
            document.getElementById('supervisorEmail').textContent = data.supervisor.email;
        }

