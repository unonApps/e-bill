        // Variables for reassignment
        let selectedUserForReassignment = null;

        // Search users for reassignment
        async function searchUsersForReassignment(searchTerm) {
            const resultsDiv = document.getElementById('reassignUserSearchResults');

            if (!searchTerm || searchTerm.length < 2) {
                resultsDiv.innerHTML = `
                    <div class="text-center py-3 text-muted">
                        <i class="bi bi-search" style="font-size: 2rem; opacity: 0.3;"></i>
                        <p class="mt-2 mb-0 small">Start typing to search users...</p>
                    </div>
                `;
                return;
            }

            // Show loading
            resultsDiv.innerHTML = `
                <div class="text-center py-3">
                    <div class="spinner-border spinner-border-sm text-primary" role="status">
                        <span class="visually-hidden">Searching...</span>
                    </div>
                    <p class="mt-2 mb-0 small">Searching for users...</p>
                </div>
            `;

            try {
                const response = await fetch(`/Modules/EBillManagement/CallRecords/MyCallLogs?handler=SearchUsers&searchTerm=${encodeURIComponent(searchTerm)}`);
                const data = await response.json();

                if (data.error) {
                    resultsDiv.innerHTML = `
                        <div class="alert alert-danger mb-0">
                            <i class="bi bi-x-circle me-2"></i>
                            ${data.error}
                        </div>
                    `;
                    return;
                }

                if (data.users && data.users.length > 0) {
                    // Display users
                    const usersHtml = data.users.map(user => `
                        <div class="border rounded-3 p-3 mb-2 user-select-card" style="cursor: pointer; transition: all 0.2s;"
                             onmouseover="this.style.background='#f9fafb'; this.style.borderColor='#9ca3af';"
                             onmouseout="this.style.background='white'; this.style.borderColor='#e5e7eb';"
                             onclick="selectUserForReassignment('${user.indexNumber}', '${user.firstName}', '${user.lastName}', '${user.email || 'N/A'}')">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <div class="fw-semibold" style="color: #1f2937;">
                                        ${user.firstName} ${user.lastName}
                                    </div>
                                    <div class="text-muted small mt-1">
                                        <i class="bi bi-person-badge me-1"></i>Index: ${user.indexNumber}
                                    </div>
                                    <div class="text-muted small">
                                        <i class="bi bi-envelope me-1"></i>${user.email || 'N/A'}
                                    </div>
                                </div>
                                <div class="text-end">
                                    <i class="bi bi-chevron-right" style="color: #9ca3af;"></i>
                                </div>
                            </div>
                        </div>
                    `).join('');

                    resultsDiv.innerHTML = usersHtml;
                } else if (data.isSearchingForSelf) {
                    // User is searching for themselves
                    resultsDiv.innerHTML = `
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Cannot assign to yourself</strong><br>
                            You are currently logged in as ${data.currentUserName}. You cannot reassign calls to yourself.
                        </div>
                    `;
                } else {
                    resultsDiv.innerHTML = `
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            No users found matching "${searchTerm}"
                        </div>
                    `;
                }
            } catch (error) {
                console.error('Error searching users:', error);
                resultsDiv.innerHTML = `
                    <div class="alert alert-danger mb-0">
                        <i class="bi bi-x-circle me-2"></i>
                        Error searching users. Please try again.
                    </div>
                `;
            }
        }

        // Select user for reassignment
        function selectUserForReassignment(indexNumber, firstName, lastName, email) {
            selectedUserForReassignment = { indexNumber, firstName, lastName, email };

            // Update hidden input
            document.getElementById('selectedUserIndexNumber').value = indexNumber;

            // Show preview
            const previewDiv = document.getElementById('selectedUserPreview');
            const detailsDiv = document.getElementById('selectedUserDetails');

            detailsDiv.innerHTML = `
                <div>
                    <strong style="color: #1f2937;">${firstName} ${lastName}</strong><br>
                    <span class="text-muted small">Index: ${indexNumber}</span><br>
                    <span class="text-muted small">Email: ${email}</span>
                </div>
            `;

            previewDiv.classList.remove('d-none');

            // Clear search
            document.getElementById('reassignUserSearchInput').value = '';
            document.getElementById('reassignUserSearchResults').innerHTML = '';
        }

        // Clear selected user
        function clearSelectedUser() {
            selectedUserForReassignment = null;
            document.getElementById('selectedUserIndexNumber').value = '';
            document.getElementById('selectedUserPreview').classList.add('d-none');
            document.getElementById('reassignUserSearchInput').value = '';
            document.getElementById('reassignUserSearchResults').innerHTML = `
                <div class="text-center py-3 text-muted">
                    <i class="bi bi-search" style="font-size: 2rem; opacity: 0.3;"></i>
                    <p class="mt-2 mb-0 small">Start typing to search users...</p>
                </div>
            `;
        }

        // Initialize extension checkboxes on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Update all extension checkboxes to reflect their current state
            document.querySelectorAll('.extension-checkbox').forEach(extCheck => {
                const extensionId = extCheck.getAttribute('data-extension');
                updateExtensionCheckbox(extensionId);
            });

            // Initialize Bootstrap tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl, {
                    trigger: 'hover',
                    delay: { show: 300, hide: 100 }
                });
            });

            // Initialize reassignment search input with debounce
            const searchInput = document.getElementById('reassignUserSearchInput');
            if (searchInput) {
                let searchTimeout;
                searchInput.addEventListener('input', function() {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        searchUsersForReassignment(this.value);
                    }, 500);
                });
            }

            // Reset form when reassignment modal is closed
            const reassignModal = document.getElementById('reassignModal');
            if (reassignModal) {
                reassignModal.addEventListener('hidden.bs.modal', function () {
                    clearSelectedUser();
                });

                // Show initial message when modal opens
                reassignModal.addEventListener('shown.bs.modal', function () {
                    if (!selectedUserForReassignment) {
                        document.getElementById('reassignUserSearchResults').innerHTML = `
                            <div class="text-center py-3 text-muted">
                                <i class="bi bi-search" style="font-size: 2rem; opacity: 0.3;"></i>
                                <p class="mt-2 mb-0 small">Start typing to search users...</p>
                            </div>
                        `;
                    }
                });
            }
        });
    </script>
}
