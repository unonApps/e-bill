                                <strong>Justification submitted</strong> on ${phoneOverage.existingJustificationDate}
                                <span class="badge bg-${phoneOverage.existingJustificationStatus === 'Approved' ? 'success' : phoneOverage.existingJustificationStatus === 'Rejected' ? 'danger' : 'secondary'} ms-1" style="font-size: 0.65rem;">
                                    ${phoneOverage.existingJustificationStatus}
