        // Verify all calls in a group (extension + month + year)
        function verifyAllCallsInGroup(groupId, verificationType) {
            // Reset dropdown if no selection
            if (!verificationType) {
                return;
            }

            // Get all call checkboxes in this group that are not locked/expired
            // Note: groupId is extension-level, but calls have data-group like "groupId_dialed_number"
            // So we need to find all checkboxes whose data-group starts with groupId + "_dialed_"
            const groupCheckboxes = document.querySelectorAll(`.call-checkbox[data-group^="${groupId}_dialed_"]`);
            const verifiableCallIds = [];
            let lockedCount = 0;
            let expiredCount = 0;
            let submittedPendingCount = 0;

            groupCheckboxes.forEach(checkbox => {
                const isLocked = checkbox.getAttribute('data-locked') === 'true';
                const isExpired = checkbox.getAttribute('data-expired') === 'true';
                const isVerified = checkbox.getAttribute('data-verified') === 'true';
                const isSubmitted = checkbox.getAttribute('data-submitted') === 'true';
                const approvalStatus = checkbox.getAttribute('data-approval-status') || '';

                if (isLocked) {
                    // Locked means approved/partially approved by supervisor - cannot change
                    lockedCount++;
                } else if (isExpired) {
                    expiredCount++;
                } else if (isVerified && isSubmitted && approvalStatus === 'Pending') {
                    // Submitted but still pending - can still be changed, so it's verifiable
                    submittedPendingCount++;
                    verifiableCallIds.push(checkbox.value);
                } else if (isVerified && !isSubmitted) {
                    // Verified but not submitted yet - can still be changed
                    verifiableCallIds.push(checkbox.value);
                } else if (!isVerified) {
                    // Not verified at all
                    verifiableCallIds.push(checkbox.value);
                }
            });

            // Check if there are any calls to verify
            if (verifiableCallIds.length === 0) {
                const totalCalls = groupCheckboxes.length;

                // Build detailed message
                let details = [];
                if (lockedCount > 0) details.push(`${lockedCount} locked (approved by supervisor)`);
                if (expiredCount > 0) details.push(`${expiredCount} expired`);

                let message = '';
                if (totalCalls === 0) {
                    message = 'No calls found in this group.';
                } else if (details.length > 0) {
                    message = `All ${totalCalls} call(s) in this group are: ${details.join(', ')}.`;
                } else {
                    message = `All ${totalCalls} call(s) in this group cannot be verified at this time.`;
                }

                showNotification('info', 'No Calls to Verify', message);

                // Reset dropdown
                event.target.selectedIndex = 0;
                return;
            }

            // Prepare confirmation modal content
            const callWord = verifiableCallIds.length === 1 ? 'call' : 'calls';
            const typeLabel = verificationType === 'Official' ? 'Official (work-related)' : 'Personal';
            const typeColor = verificationType === 'Official' ? 'success' : 'warning';

            let noteHtml = '';
            if (lockedCount > 0 || expiredCount > 0 || submittedPendingCount > 0) {
                let notes = [];
                if (lockedCount > 0) notes.push(`<li>${lockedCount} locked (approved by supervisor) call(s) will be skipped</li>`);
                if (expiredCount > 0) notes.push(`<li>${expiredCount} expired call(s) will be skipped</li>`);
                if (submittedPendingCount > 0) notes.push(`<li>${submittedPendingCount} call(s) are submitted and pending approval - they will be updated</li>`);
                noteHtml = `<div class="alert alert-info mt-3"><strong>Note:</strong><ul class="mb-0 mt-2">${notes.join('')}</ul></div>`;
            }

            // Show custom confirmation modal
            showConfirmation(
                `Verify ${verifiableCallIds.length} ${callWord}?`,
                `You are about to verify <strong>${verifiableCallIds.length} ${callWord}</strong> as <span class="badge bg-${typeColor}">${typeLabel}</span>.${noteHtml}`,
                'Yes, Verify',
                () => {
                    // User confirmed - submit form
                    const form = document.createElement('form');
                    form.method = 'POST';
                    form.action = '?handler=QuickVerify';

                    // Add anti-forgery token
                    const tokenInput = document.createElement('input');
                    tokenInput.type = 'hidden';
                    tokenInput.name = '__RequestVerificationToken';
                    tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    form.appendChild(tokenInput);

                    // Add verification type
                    const typeInput = document.createElement('input');
                    typeInput.type = 'hidden';
                    typeInput.name = 'verificationType';
                    typeInput.value = verificationType;
                    form.appendChild(typeInput);

                    // Add all verifiable call IDs
                    verifiableCallIds.forEach(callId => {
                        const idInput = document.createElement('input');
                        idInput.type = 'hidden';
                        idInput.name = 'selectedIds';
                        idInput.value = callId;
                        form.appendChild(idInput);
                    });

                    document.body.appendChild(form);
                    form.submit();
                },
                () => {
                    // User cancelled - reset dropdown
                    event.target.selectedIndex = 0;
                }
            );
        }

