@* Recall Single Assignment Modal *@
<div class="modal fade" id="recallAssignmentModal" tabindex="-1" aria-labelledby="recallModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="recallModalLabel">
                    <i class="bi bi-arrow-return-left me-2"></i>Recall Reassignment
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="lead">Are you sure you want to recall this reassignment?</p>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>What this means:</strong>
                    <ul class="mb-0 mt-2">
                        <li>The payment responsibility will return to you</li>
                        <li>The other user will no longer see this call in their inbox</li>
                        <li>You can reassign to someone else or verify the call yourself</li>
                    </ul>
                </div>
                <div class="border-start border-4 border-warning ps-3 py-2 bg-light">
                    <p class="mb-1"><strong>Call Details:</strong></p>
                    <p class="mb-0">Phone Number: <strong id="recallCallNumber"></strong></p>
                    <p class="mb-0">Amount: <strong id="recallCallAmount"></strong></p>
                    <p class="mb-0">Assigned to: <strong id="recallToUser"></strong></p>
                </div>
                <input type="hidden" id="recallCallId" value="0">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-warning" onclick="confirmRecallAssignment()">
                    <i class="bi bi-arrow-return-left me-1"></i>Recall Assignment
                </button>
            </div>
        </div>
    </div>
</div>

@* Bulk Recall Assignment Modal *@
<div class="modal fade" id="recallBulkAssignmentModal" tabindex="-1" aria-labelledby="recallBulkModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="recallBulkModalLabel">
                    <i class="bi bi-arrow-return-left me-2"></i>Recall All Reassignments
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="lead">Are you sure you want to recall <strong id="recallBulkCount"></strong> reassignment(s)?</p>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>
                    <strong>What this means:</strong>
                    <ul class="mb-0 mt-2">
                        <li>All payment responsibilities will return to you</li>
                        <li>The other users will no longer see these calls in their inbox</li>
                        <li>You can reassign to someone else or verify the calls yourself</li>
                    </ul>
                </div>
                <div class="border-start border-4 border-warning ps-3 py-2 bg-light">
                    <p class="mb-1"><strong>Reassignment Details:</strong></p>
                    <p class="mb-0">Level: <strong id="recallBulkLevel"></strong></p>
                    <p class="mb-0" id="recallBulkDialedNumberRow">Dialed Number: <strong id="recallBulkDialedNumber"></strong></p>
                    <p class="mb-0">Total Amount: <strong id="recallBulkAmount"></strong></p>
                    <p class="mb-0">Assigned to: <strong id="recallBulkToUser"></strong></p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-warning" onclick="confirmRecallBulkAssignment()">
                    <i class="bi bi-arrow-return-left me-1"></i>Recall All
                </button>
            </div>
        </div>
    </div>
</div>

@* Reassign Payment Modal *@
<div class="modal fade" id="reassignModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 20px 60px rgba(0,0,0,0.2);">
            <div class="modal-header bg-primary" style="color: white; border-bottom: none; padding: 2rem; border-radius: 16px 16px 0 0;">
                <div class="w-100">
                    <h5 class="mb-1 fw-bold">
                        <i class="bi bi-arrow-left-right me-2"></i>
                        <span id="reassignModalTitle">Reassign Payment</span>
                    </h5>
                    <p class="mb-0 opacity-75 small" id="reassignModalSubtitle">Transfer payment responsibility to another user</p>
                    <div class="mt-3 d-flex align-items-center gap-2 flex-wrap" id="reassignModalInfo">
                        <div class="d-flex align-items-center bg-white rounded-3 px-3 py-2" style="border: 2px solid rgba(255,255,255,0.3);">
                            <i class="bi bi-telephone-fill me-2" style="color: #009EDB;"></i>
                            <span class="text-muted small me-1">Dialed:</span>
                            <strong id="reassignDialedNumber" style="color: #1f2937;"></strong>
                        </div>
                        <div class="d-flex align-items-center bg-white rounded-3 px-3 py-2" style="border: 2px solid rgba(255,255,255,0.3); display: none;" id="reassignExtensionInfo">
                            <i class="bi bi-hash me-2" style="color: #009EDB;"></i>
                            <span class="text-muted small me-1">Extension:</span>
                            <strong id="reassignExtensionNumber" style="color: #1f2937;"></strong>
                        </div>
                        <div class="d-flex align-items-center bg-white rounded-3 px-3 py-2" style="border: 2px solid rgba(255,255,255,0.3); display: none;" id="reassignCallCountInfo">
                            <i class="bi bi-collection me-2" style="color: #009EDB;"></i>
                            <span class="text-muted small me-1">Calls:</span>
                            <strong id="reassignCallCount" style="color: #1f2937;"></strong>
                        </div>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white position-absolute" data-bs-dismiss="modal" style="top: 1.5rem; right: 1.5rem;"></button>
            </div>
            <div class="modal-body" style="padding: 2rem;">
                <form method="post" asp-page-handler="ReassignCalls" id="reassignForm">
                    <input type="hidden" name="callId" id="reassignCallId" />
                    <input type="hidden" name="dialedNumber" id="hiddenDialedNumber" />
                    @* Hidden fields for bulk operations *@
                    <input type="hidden" name="reassignLevel" id="reassignLevel" value="call" />
                    <input type="hidden" name="reassignExtension" id="reassignExtension" />
                    <input type="hidden" name="reassignMonth" id="reassignMonth" />
                    <input type="hidden" name="reassignYear" id="reassignYear" />

                    <div class="mb-4">
                        <label class="form-label fw-semibold mb-3" style="color: #1f2937;">
                            <i class="bi bi-person-fill me-2" style="color: #8b5cf6;"></i>
                            Search for User
                        </label>
                        <div class="input-group mb-2">
                            <span class="input-group-text bg-light" style="border-radius: 12px 0 0 12px; border: 2px solid #e5e7eb; border-right: none;">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control" id="reassignUserSearchInput"
                                   placeholder="Enter name, index number, or email..."
                                   style="border: 2px solid #e5e7eb; border-left: none; border-radius: 0 12px 12px 0;">
                        </div>
                        <div class="d-flex align-items-center mb-3 p-2 bg-light rounded-3">
                            <i class="bi bi-info-circle me-2" style="color: #06b6d4;"></i>
                            <small class="text-muted">Type to search and select a user</small>
                        </div>

                        <!-- Search Results -->
                        <div id="reassignUserSearchResults" style="max-height: 300px; overflow-y: auto;">
                            <div class="text-center py-3 text-muted">
                                <i class="bi bi-search" style="font-size: 2rem; opacity: 0.3;"></i>
                                <p class="mt-2 mb-0 small">Start typing to search users...</p>
                            </div>
                        </div>

                        <!-- Selected User Preview -->
                        <div id="selectedUserPreview" class="d-none mt-3 p-3 rounded-3" style="border: 2px solid #10b981; background: #f0fdf4;">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="fw-semibold mb-1" style="color: #10b981;">
                                        <i class="bi bi-check-circle-fill me-2"></i>Selected User
                                    </h6>
                                    <div id="selectedUserDetails"></div>
                                </div>
                                <button type="button" class="btn btn-sm btn-light" onclick="clearSelectedUser()">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </div>
                        </div>

                        <!-- Hidden input for the selected user -->
                        <input type="hidden" name="assignToIndexNumber" id="selectedUserIndexNumber" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold mb-3" style="color: #1f2937;">
                            <i class="bi bi-chat-left-text-fill me-2" style="color: #f59e0b;"></i>
                            Assignment Reason
                        </label>
                        <textarea class="form-control" name="assignmentReason" rows="4"
                                  placeholder="Provide a clear explanation for this payment reassignment..."
                                  style="border: 2px solid #e5e7eb; border-radius: 12px;"
                                  required></textarea>
                        <div class="d-flex align-items-center mt-2 p-2 bg-light rounded-3">
                            <i class="bi bi-exclamation-triangle me-2" style="color: #f59e0b;"></i>
                            <small class="text-muted">This action will transfer payment responsibility and notify the assigned user</small>
                        </div>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="button" class="btn btn-light flex-grow-1" data-bs-dismiss="modal" style="border-radius: 12px; padding: 0.75rem; border: 2px solid #e5e7eb;">
                            <i class="bi bi-x-circle me-2" style="color: #6b7280;"></i>Cancel
                        </button>
                        <button type="submit" class="btn btn-success flex-grow-1" style="border-radius: 12px; padding: 0.75rem;">
                            <i class="bi bi-check-circle-fill me-2"></i>Confirm Reassignment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* Quick Verify Confirmation Modal - Official *@
<div class="modal fade" id="confirmOfficialModal" tabindex="-1" aria-labelledby="confirmOfficialLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.15);">
            <div class="modal-header bg-success" style="border-bottom: none; padding: 1.5rem; border-radius: 16px 16px 0 0;">
                <div class="d-flex align-items-center gap-3">
                    <div class="bg-white rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <i class="bi bi-briefcase-fill text-success" style="font-size: 1.5rem;"></i>
                    </div>
                    <div>
                        <h5 class="modal-title fw-bold text-white mb-0" id="confirmOfficialLabel">Mark as Official</h5>
                        <p class="text-white text-opacity-75 small mb-0">Work-related call</p>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" style="padding: 1.5rem;">
                <div class="alert alert-success border-0" style="background-color: #d1fae5;">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-info-circle-fill text-success me-2 mt-1"></i>
                        <div>
                            <strong>What this means:</strong>
                            <ul class="mb-0 mt-2">
                                <li>These calls will be marked as work-related</li>
                                <li>They will be approved and no recovery will be initiated</li>
                                <li>This action will be submitted to your supervisor for approval</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="border-start border-4 border-success ps-3 py-2 bg-light rounded">
                    <p class="mb-1"><strong><i class="bi bi-check-square me-2"></i>Selected Calls:</strong></p>
                    <p class="mb-0 fs-4 fw-bold text-success" id="officialCallCount">0 calls</p>
                </div>
            </div>
            <div class="modal-footer" style="border-top: 1px solid #e5e7eb; padding: 1rem 1.5rem;">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 8px;">
                    <i class="bi bi-x-lg me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-success" onclick="confirmQuickVerifyOfficial()" style="border-radius: 8px;">
                    <i class="bi bi-check-lg me-1"></i>Confirm & Mark as Official
                </button>
            </div>
        </div>
    </div>
</div>

