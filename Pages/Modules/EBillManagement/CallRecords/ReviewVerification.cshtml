@page
@model TAB.Web.Pages.Modules.EBillManagement.CallRecords.ReviewVerificationModel
@{
    ViewData["Title"] = "Review Verification";
    ViewData["PageIcon"] = "bi-clipboard-check";
    ViewData["PageTitle"] = "Review Verification";
    ViewData["Breadcrumb"] = "E-Bill / Call Records / Review";
}

<style>
    .modern-table {
        border-collapse: separate;
        border-spacing: 0;
    }

    .modern-table thead th {
        background-color: #009EDB;
        color: white;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 1rem 0.75rem;
        border: none;
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .modern-table thead th:first-child {
        border-radius: 12px 0 0 0;
    }

    .modern-table thead th:last-child {
        border-radius: 0 12px 0 0;
    }

    .modern-table tbody tr {
        transition: all 0.2s ease;
        border-bottom: 1px solid #f0f0f0;
    }

    .modern-table tbody tr:hover {
        background-color: #f8f9fa;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .modern-table tbody td {
        padding: 0.875rem 0.75rem;
        vertical-align: middle;
        font-size: 0.9rem;
    }

    .extension-badge {
        display: inline-block;
        padding: 0.35rem 0.75rem;
        border-radius: 8px;
        font-weight: 500;
        font-size: 0.85rem;
        background-color: #6366f1;
        color: white;
    }

    .dial-number {
        font-family: 'Courier New', monospace;
        font-weight: 600;
        color: #2d3748;
        font-size: 0.9rem;
    }

    .table-container {
        max-height: 600px;
        overflow-y: auto;
        border-radius: 12px;
    }
</style>

<!-- Status Message -->
@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-@(Model.StatusMessageClass ?? "info") alert-dismissible fade show" role="alert">
        <i class="bi bi-@(Model.StatusMessageClass == "success" ? "check-circle" : Model.StatusMessageClass == "danger" ? "exclamation-triangle" : "info-circle") me-2"></i>
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width: 50px; height: 50px;">
                        <i class="bi bi-list-check text-primary" style="font-size: 20px;"></i>
                    </div>
                    <div>
                        <div class="text-muted small mb-1">Total Calls</div>
                        <h4 class="mb-0">@Model.TotalCalls</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width: 50px; height: 50px;">
                        <i class="bi bi-currency-dollar text-info" style="font-size: 20px;"></i>
                    </div>
                    <div>
                        <div class="text-muted small mb-1">Total Cost</div>
                        <h4 class="mb-0">$@Model.TotalAmount.ToString("N2")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width: 50px; height: 50px;">
                        <i class="bi bi-exclamation-triangle text-warning" style="font-size: 20px;"></i>
                    </div>
                    <div>
                        <div class="text-muted small mb-1">Overages</div>
                        <h4 class="mb-0">@Model.OverageCount</h4>
                        @if (Model.TotalOverage > 0)
                        {
                            <small class="text-muted">$@Model.TotalOverage.ToString("N2")</small>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 20px;">
            <div class="card-body p-3">
                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                         style="width: 50px; height: 50px;">
                        <i class="bi bi-graph-up text-success" style="font-size: 20px;"></i>
                    </div>
                    <div>
                        <div class="text-muted small mb-1">Allowance Limit</div>
                        <h4 class="mb-0">$@Model.AllowanceLimit.ToString("N2")</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- User Info Card -->
<div class="card border-0 shadow-sm mb-4" style="border-radius: 20px;">
    <div class="card-body p-4">
        <div class="d-flex align-items-center">
            <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3"
                 style="width: 60px; height: 60px;">
                <i class="bi bi-person text-primary" style="font-size: 24px;"></i>
            </div>
            <div>
                <h6 class="mb-0">@Model.UserName</h6>
                <small class="text-muted">@Model.UserIndexNumber</small>
                <div class="mt-1">
                    <small class="text-muted">
                        <i class="bi bi-calendar me-1"></i>
                        Submitted: @Model.SubmittedDate?.ToString("MMMM dd, yyyy")
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Call Details Table -->
<div class="card border-0 shadow-sm mb-4" style="border-radius: 20px;">
    <div class="card-header bg-light border-0 py-3" style="border-radius: 20px 20px 0 0;">
        <h6 class="mb-0 text-muted fw-semibold">
            <i class="bi bi-list-ul me-2"></i>
            Call Verifications (@Model.Verifications.Count)
        </h6>
    </div>
    <div class="card-body p-0">
        @if (Model.Verifications.Any())
        {
            <div class="table-container">
                <table class="table modern-table mb-0">
                    <thead>
                        <tr>
                            <th>Date & Time</th>
                            <th>Extension</th>
                            <th>Dialed Number</th>
                            <th>Destination</th>
                            <th>Type</th>
                            <th>Class of Service</th>
                            <th>Duration</th>
                            <th>Cost</th>
                            <th>Verification</th>
                            <th>Status</th>
                            <th>Documents</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var verification in Model.Verifications)
                        {
                            <tr class="@(verification.IsOverage ? "table-warning" : "")">
                                <td>
                                    <div class="fw-semibold">@verification.CallRecord.CallDate.ToString("MMM dd, yyyy")</div>
                                    <small class="text-muted">@verification.CallRecord.CallDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <span class="extension-badge">
                                        <i class="bi bi-telephone-fill me-1"></i>@verification.CallRecord.ExtensionNumber
                                    </span>
                                </td>
                                <td>
                                    <div class="dial-number">@verification.CallRecord.CallNumber</div>
                                </td>
                                <td>
                                    <div class="fw-semibold">@verification.CallRecord.CallDestination</div>
                                    <small class="text-muted">@verification.CallRecord.CallDestinationType</small>
                                </td>
                                <td>
                                    <span class="badge bg-primary bg-opacity-10 text-primary">
                                        @verification.CallRecord.CallType
                                    </span>
                                </td>
                                <td>
                                    @if (verification.CallRecord.UserPhone?.ClassOfService != null)
                                    {
                                        <div>
                                            <span class="badge bg-info bg-opacity-10 text-info">
                                                @verification.CallRecord.UserPhone.ClassOfService.Class
                                            </span>
                                            @if (verification.CallRecord.UserPhone.ClassOfService.AirtimeAllowanceAmount.HasValue && verification.CallRecord.UserPhone.ClassOfService.AirtimeAllowanceAmount.Value > 0)
                                            {
                                                <br />
                                                <small class="text-muted">Limit: $@verification.CallRecord.UserPhone.ClassOfService.AirtimeAllowanceAmount.Value.ToString("N2")</small>
                                            }
                                            else
                                            {
                                                <br />
                                                <small class="text-muted">Unlimited</small>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="fw-semibold">@verification.CallRecord.GetDurationFormatted()</span>
                                </td>
                                <td class="fw-semibold">
                                    $@verification.ActualAmount.ToString("N2")
                                    @if (verification.IsOverage)
                                    {
                                        <br />
                                        <small class="text-warning">
                                            <i class="bi bi-exclamation-triangle me-1"></i>
                                            +$@verification.OverageAmount.ToString("N2")
                                        </small>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info">
                                        @verification.VerificationType
                                    </span>
                                    @if (verification.PaymentAssignment != null)
                                    {
                                        <br />
                                        <small class="text-muted">
                                            <i class="bi bi-arrow-left-right me-1"></i>Assigned
                                        </small>
                                    }
                                </td>
                                <td>
                                    @if (verification.IsOverage)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-exclamation-triangle me-1"></i>Overage
                                        </span>
                                        @if (verification.OverageJustified)
                                        {
                                            <br />
                                            <small class="text-success">
                                                <i class="bi bi-check-circle me-1"></i>Justified
                                            </small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Within Allowance
                                        </span>
                                    }
                                </td>
                                <td>
                                    @if (verification.Documents.Any())
                                    {
                                        <span class="badge bg-info">
                                            <i class="bi bi-paperclip me-1"></i>@verification.Documents.Count
                                        </span>
                                        @foreach (var doc in verification.Documents)
                                        {
                                            <br />
                                            <small class="text-muted">@doc.DocumentType</small>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<!-- Supervisor Actions -->
<div class="row g-3">
    <!-- Approve All -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 20px;">
            <div class="card-header bg-success bg-opacity-10 border-0 py-3">
                <h6 class="mb-0 text-success fw-semibold">
                    <i class="bi bi-check-circle me-2"></i>Approve All
                </h6>
            </div>
            <form method="post" asp-page-handler="ApproveAll" asp-route-indexNumber="@Model.UserIndexNumber"
                  asp-route-date="@Model.SubmittedDate?.ToString("yyyy-MM-dd")">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Supervisor Comments (Optional)</label>
                        <textarea name="SupervisorComments" class="form-control border-0 bg-light" rows="3"
                                  style="border-radius: 12px;" placeholder="Add comments..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-success w-100" style="border-radius: 12px;"
                            onclick="return confirm('Approve all @Model.TotalCalls call verifications totaling $@Model.TotalAmount.ToString("N2")?')">
                        <i class="bi bi-check-circle me-1"></i>Approve All ($@Model.TotalAmount.ToString("N2"))
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Reject -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 20px;">
            <div class="card-header bg-danger bg-opacity-10 border-0 py-3">
                <h6 class="mb-0 text-danger fw-semibold">
                    <i class="bi bi-x-circle me-2"></i>Reject
                </h6>
            </div>
            <form method="post" asp-page-handler="Reject" asp-route-indexNumber="@Model.UserIndexNumber"
                  asp-route-date="@Model.SubmittedDate?.ToString("yyyy-MM-dd")">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Rejection Reason <span class="text-danger">*</span></label>
                        <textarea name="ActionReason" class="form-control border-0 bg-light" rows="3"
                                  style="border-radius: 12px;" placeholder="Please explain why..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-danger w-100" style="border-radius: 12px;"
                            onclick="return confirm('Reject all @Model.TotalCalls call verifications?')">
                        <i class="bi bi-x-circle me-1"></i>Reject All
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Revert to User -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 20px;">
            <div class="card-header bg-warning bg-opacity-10 border-0 py-3">
                <h6 class="mb-0 text-warning fw-semibold">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>Revert to User
                </h6>
            </div>
            <form method="post" asp-page-handler="Revert" asp-route-indexNumber="@Model.UserIndexNumber"
                  asp-route-date="@Model.SubmittedDate?.ToString("yyyy-MM-dd")">
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Revert Reason <span class="text-danger">*</span></label>
                        <textarea name="ActionReason" class="form-control border-0 bg-light" rows="3"
                                  style="border-radius: 12px;" placeholder="What needs to be corrected..." required></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning w-100" style="border-radius: 12px;"
                            onclick="return confirm('Revert all @Model.TotalCalls call verifications back to user?')">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Revert to User
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Back Button -->
    <div class="col-md-6">
        <div class="card border-0 shadow-sm" style="border-radius: 20px;">
            <div class="card-body d-flex align-items-center justify-content-center" style="min-height: 200px;">
                <a asp-page="/Modules/EBillManagement/CallRecords/SupervisorApprovals" class="btn btn-outline-secondary" style="border-radius: 12px;">
                    <i class="bi bi-arrow-left me-1"></i>Back to Approvals
                </a>
            </div>
        </div>
    </div>
</div>
