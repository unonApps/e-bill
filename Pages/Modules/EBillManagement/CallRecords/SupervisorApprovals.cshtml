            <div class="modal-footer border-0 pt-0 px-4 pb-4">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="border-radius: 12px; min-width: 120px;">
                    <i class="bi bi-x-circle me-1"></i>Cancel
                </button>
                <button type="button" class="btn btn-primary" onclick="submitPartialApprovalModal()" style="border-radius: 12px; min-width: 120px;">
                    <i class="bi bi-check2-square me-1"></i>Approve Now
                </button>
            </div>
        </div>
    </div>
</div>

