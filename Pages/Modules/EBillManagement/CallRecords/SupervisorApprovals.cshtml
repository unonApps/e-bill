@section Scripts {
    <script>
        // Toggle all calls in an extension
        function toggleExtensionCalls(extensionId) {
            const extensionCheckbox = document.getElementById(extensionId);
            const isChecked = extensionCheckbox.checked;

            // Find all call checkboxes for this extension
            const callCheckboxes = document.querySelectorAll(`input.call-checkbox[data-extension="${extensionId}"]`);
            callCheckboxes.forEach(checkbox => {
                checkbox.checked = isChecked;
            });

            // Also update dialed number checkboxes for this extension
            const dialedCheckboxes = document.querySelectorAll(`input.dialed-checkbox[data-extension="${extensionId}"]`);
            dialedCheckboxes.forEach(checkbox => {
                checkbox.checked = isChecked;
                checkbox.indeterminate = false;
            });

            updateSelectionSummary();
        }

        // Toggle all calls for a specific dialed number
        function toggleDialedCalls(dialedId) {
            const dialedCheckbox = document.getElementById(dialedId);
            const isChecked = dialedCheckbox.checked;

            // Find all call checkboxes for this dialed number
            const callCheckboxes = document.querySelectorAll(`input.call-checkbox[data-dialed="${dialedId}"]`);
            callCheckboxes.forEach(checkbox => {
                checkbox.checked = isChecked;
            });

            updateSelectionSummary();
        }

        // Update selection summary for all submissions
        function updateSelectionSummary() {
            // Get all accordion items
            const accordions = document.querySelectorAll('.accordion-item');

            accordions.forEach(accordion => {
                const summaryDiv = accordion.querySelector('[id^="selection-summary-"]');
                const approveBtn = accordion.querySelector('[id^="approve-selected-"]');

                if (!summaryDiv || !approveBtn) return;

                // Get all checked call checkboxes in this accordion
                const checkedBoxes = accordion.querySelectorAll('input.call-checkbox:checked');
                const count = checkedBoxes.length;

                if (count > 0) {
                    // Calculate total amount
                    let totalAmount = 0;
                    checkedBoxes.forEach(checkbox => {
                        totalAmount += parseFloat(checkbox.dataset.amount || 0);
                    });

                    summaryDiv.innerHTML = `
                        <span class="fw-semibold text-success">
                            <i class="bi bi-check-circle me-1"></i>
                            ${count} call(s) selected
                        </span>
                        <span class="text-muted ms-2">Total: $${totalAmount.toFixed(2)}</span>
                    `;
                    approveBtn.disabled = false;

                    // Enable all action buttons
                    const partialApproveBtn = accordion.querySelector(`[id^="partial-approve-selected-"]`);
                    const rejectBtn = accordion.querySelector(`[id^="reject-selected-"]`);
                    const revertBtn = accordion.querySelector(`[id^="revert-selected-"]`);
                    const reviewBtn = accordion.querySelector(`[id^="review-selected-"]`);

                    if (partialApproveBtn) partialApproveBtn.disabled = false;
                    if (rejectBtn) rejectBtn.disabled = false;
                    if (revertBtn) revertBtn.disabled = false;
                    if (reviewBtn) reviewBtn.disabled = false;
                } else {
                    summaryDiv.innerHTML = '<span class="fw-semibold">No calls selected</span>';
                    approveBtn.disabled = true;

                    // Disable all action buttons
                    const partialApproveBtn = accordion.querySelector(`[id^="partial-approve-selected-"]`);
                    const rejectBtn = accordion.querySelector(`[id^="reject-selected-"]`);
                    const revertBtn = accordion.querySelector(`[id^="revert-selected-"]`);
                    const reviewBtn = accordion.querySelector(`[id^="review-selected-"]`);

                    if (partialApproveBtn) partialApproveBtn.disabled = true;
                    if (rejectBtn) rejectBtn.disabled = true;
                    if (revertBtn) revertBtn.disabled = true;
                    if (reviewBtn) reviewBtn.disabled = true;
                }

                // Update extension checkboxes state
                updateExtensionCheckboxStates(accordion);
            });
        }

        // Update extension and dialed number checkbox states based on their calls
        function updateExtensionCheckboxStates(accordion) {
            // Update dialed number checkboxes first
            const dialedCheckboxes = accordion.querySelectorAll('input.dialed-checkbox');
            dialedCheckboxes.forEach(dialedCheckbox => {
                const dialedId = dialedCheckbox.id;
                const callCheckboxes = accordion.querySelectorAll(`input.call-checkbox[data-dialed="${dialedId}"]`);

                if (callCheckboxes.length === 0) return;

                const checkedCount = Array.from(callCheckboxes).filter(cb => cb.checked).length;

                if (checkedCount === callCheckboxes.length) {
                    dialedCheckbox.checked = true;
                    dialedCheckbox.indeterminate = false;
                } else if (checkedCount > 0) {
                    dialedCheckbox.checked = false;
                    dialedCheckbox.indeterminate = true;
                } else {
                    dialedCheckbox.checked = false;
                    dialedCheckbox.indeterminate = false;
                }
            });

            // Update extension checkboxes
            const extensionCheckboxes = accordion.querySelectorAll('input.extension-checkbox');
            extensionCheckboxes.forEach(extCheckbox => {
                const extensionId = extCheckbox.id;
                const callCheckboxes = accordion.querySelectorAll(`input.call-checkbox[data-extension="${extensionId}"]`);

                if (callCheckboxes.length === 0) return;

                const checkedCount = Array.from(callCheckboxes).filter(cb => cb.checked).length;

                if (checkedCount === callCheckboxes.length) {
                    extCheckbox.checked = true;
                    extCheckbox.indeterminate = false;
                } else if (checkedCount > 0) {
                    extCheckbox.checked = false;
                    extCheckbox.indeterminate = true;
                } else {
                    extCheckbox.checked = false;
                    extCheckbox.indeterminate = false;
                }
            });
        }

        // Global variable to store current approval data
        let currentApprovalData = null;

        // Approve selected calls
        function approveSelected(userIndexNumber) {
            // Find the accordion for this user
            const accordion = document.querySelector(`[id*="${userIndexNumber}"]`).closest('.accordion-item');
            const checkedBoxes = accordion.querySelectorAll('input.call-checkbox:checked');

            if (checkedBoxes.length === 0) {
                alert('Please select at least one call to approve.');
                return;
            }

            // Get verification IDs and call details
            const verificationIds = [];
            const callDetails = [];
            let totalAmount = 0;

            checkedBoxes.forEach(checkbox => {
                verificationIds.push(checkbox.dataset.verificationId);
                totalAmount += parseFloat(checkbox.dataset.amount || 0);

                // Get call details from the row
                const row = checkbox.closest('tr');
                const dateCell = row.querySelector('td:nth-child(2)');
                const destinationCell = row.querySelector('td:nth-child(3)');
                const amountCell = row.querySelector('td:nth-child(7)');

                callDetails.push({
                    date: dateCell ? dateCell.textContent.trim().split('\n')[0].trim() : 'N/A',
                    dialedNumber: checkbox.dataset.callNumber || 'N/A',
                    destination: destinationCell ? destinationCell.textContent.trim().split('\n')[0].trim() : 'N/A',
                    amount: checkbox.dataset.amount
                });
            });

            // Store data for confirmation
            currentApprovalData = {
                verificationIds: verificationIds,
                totalAmount: totalAmount
            };

            // Populate modal
            document.getElementById('modal-call-count').textContent = checkedBoxes.length;
            document.getElementById('modal-total-amount').textContent = `$${totalAmount.toFixed(2)}`;

            // Build call list
            const callListHtml = callDetails.map(call => `
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                    <div>
                        <div class="fw-semibold">${call.dialedNumber}</div>
                        <div class="text-muted" style="font-size: 0.85rem;">${call.destination} • ${call.date}</div>
                    </div>
                    <div class="fw-bold text-success">$${parseFloat(call.amount).toFixed(2)}</div>
                </div>
            `).join('');

            document.getElementById('modal-call-list').innerHTML = callListHtml || '<p class="text-muted mb-0">No calls selected</p>';

            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('approvalConfirmationModal'));
            modal.show();
        }

        // Review selected calls
        function reviewSelected(userIndexNumber, submittedDate) {
            // Find the accordion for this user
            const accordion = document.querySelector(`[id*="${userIndexNumber}"]`).closest('.accordion-item');
            const checkedBoxes = accordion.querySelectorAll('input.call-checkbox:checked');

            if (checkedBoxes.length === 0) {
                alert('Please select at least one call to review.');
                return;
            }

            // Get verification IDs
            const verificationIds = [];
            checkedBoxes.forEach(checkbox => {
                verificationIds.push(checkbox.dataset.verificationId);
            });

            // Navigate to ReviewVerification with selected IDs
            const idsParam = verificationIds.join(',');
            window.location.href = `/Modules/EBillManagement/CallRecords/ReviewVerification?indexNumber=${userIndexNumber}&date=${submittedDate}&ids=${idsParam}`;
        }

        // Confirm approval from modal
        document.getElementById('confirm-approve-btn').addEventListener('click', function() {
            if (!currentApprovalData) return;

            // Submit to server
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=ApproveSelected';

            // Add anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;
            form.appendChild(tokenInput);

            // Add verification IDs
            currentApprovalData.verificationIds.forEach(id => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'verificationIds';
                input.value = id;
                form.appendChild(input);
            });

            document.body.appendChild(form);
            form.submit();
        });

        // Global variables for current action context
        let currentActionUser = null;
        let currentActionData = null;
        let partialApprovalCalls = [];

        // Partial Approve Selected
        function partialApproveSelected(userIndexNumber) {
            currentActionUser = userIndexNumber;
            const accordion = document.querySelector(`[id*="${userIndexNumber}"]`).closest('.accordion-item');
            const checkedBoxes = accordion.querySelectorAll('input.call-checkbox:checked');

            if (checkedBoxes.length === 0) {
                alert('Please select at least one call to approve.');
                return;
            }

            // Build list of calls (read-only display)
            let callsListHTML = '<div class="list-group list-group-flush">';
            let totalActual = 0;
            partialApprovalCalls = [];

            checkedBoxes.forEach((checkbox, index) => {
                const verificationId = checkbox.dataset.verificationId;
                const amount = parseFloat(checkbox.dataset.amount);
                const callNumber = checkbox.dataset.callNumber || 'N/A';
                const destination = checkbox.dataset.destination || 'N/A';

                totalActual += amount;

                // Store call data for later submission
                partialApprovalCalls.push({
                    verificationId: verificationId,
                    amount: amount,
                    callNumber: callNumber,
                    destination: destination
                });

                callsListHTML += `
                    <div class="list-group-item px-2 py-2">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="flex-grow-1">
                                <strong>${callNumber}</strong> → ${destination}
                            </div>
                            <div class="text-end">
                                <strong class="text-primary">$${amount.toFixed(2)}</strong>
                            </div>
                        </div>
                    </div>
                `;
            });
            callsListHTML += '</div>';

            document.getElementById('partialApprovalCallsList').innerHTML = callsListHTML;
            document.getElementById('partialModalSelectedCount').textContent = checkedBoxes.length;
            document.getElementById('partialModalTotalAmount').textContent = '$' + totalActual.toFixed(2);

            // Set initial approved amount to total amount
            document.getElementById('partialApprovedAmountInput').value = totalActual.toFixed(2);
            document.getElementById('partialApprovedAmountInput').max = totalActual;
            document.getElementById('partialModalRecoveryTotal').textContent = '$0.00';

            const modal = new bootstrap.Modal(document.getElementById('partialApprovalModal'));
            modal.show();
        }

        // Update partial modal summary
        function updatePartialModalSummary() {
            const approvedInput = document.getElementById('partialApprovedAmountInput');
            const totalAmount = partialApprovalCalls.reduce((sum, call) => sum + call.amount, 0);
            const approvedAmount = parseFloat(approvedInput.value) || 0;
            const recovery = Math.max(0, totalAmount - approvedAmount);

            document.getElementById('partialModalRecoveryTotal').textContent = '$' + recovery.toFixed(2);
        }

        // Submit partial approval
        function submitPartialApprovalModal() {
            const approvedInput = document.getElementById('partialApprovedAmountInput');
            const totalApprovedAmount = parseFloat(approvedInput.value);

            if (!totalApprovedAmount || totalApprovedAmount <= 0) {
                alert('Please enter a valid approved amount.');
                return;
            }

            const totalAmount = partialApprovalCalls.reduce((sum, call) => sum + call.amount, 0);

            if (totalApprovedAmount > totalAmount) {
                alert('Approved amount cannot exceed the total amount.');
                return;
            }

            // Distribute approved amount proportionally across all calls
            const partialApprovals = [];
            let remainingApproved = totalApprovedAmount;

            partialApprovalCalls.forEach((call, index) => {
                let approvedForCall;

                if (index === partialApprovalCalls.length - 1) {
                    // Last call gets the remaining amount to avoid rounding issues
                    approvedForCall = remainingApproved;
                } else {
                    // Proportional distribution
                    approvedForCall = (call.amount / totalAmount) * totalApprovedAmount;
                    remainingApproved -= approvedForCall;
                }

                partialApprovals.push({
                    VerificationId: parseInt(call.verificationId),
                    ApprovedAmount: Math.max(0, approvedForCall),
                    Reason: ''
                });
            });

            const comments = document.getElementById('partialApprovalComments').value;

            // Submit to server
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=ApprovePartially';

            // Add anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;
            form.appendChild(tokenInput);

            // Add partial approvals as JSON
            const dataInput = document.createElement('input');
            dataInput.type = 'hidden';
            dataInput.name = 'PartialApprovalsJson';
            dataInput.value = JSON.stringify(partialApprovals);
            form.appendChild(dataInput);

            // Add comments
            const commentsInput = document.createElement('input');
            commentsInput.type = 'hidden';
            commentsInput.name = 'SupervisorComments';
            commentsInput.value = comments;
            form.appendChild(commentsInput);

            document.body.appendChild(form);
            form.submit();
        }

        // Reject Selected
        function rejectSelected(userIndexNumber) {
            currentActionUser = userIndexNumber;
            const accordion = document.querySelector(`[id*="${userIndexNumber}"]`).closest('.accordion-item');
            const checkedBoxes = accordion.querySelectorAll('input.call-checkbox:checked');

            if (checkedBoxes.length === 0) {
                alert('Please select at least one call to reject.');
                return;
            }

            document.getElementById('rejectModalCount').textContent = checkedBoxes.length;
            document.getElementById('rejectReason').value = '';

            const modal = new bootstrap.Modal(document.getElementById('rejectModal'));
            modal.show();
        }

        // Submit reject
        function submitRejectModal() {
            const reason = document.getElementById('rejectReason').value.trim();
            
            if (!reason) {
                alert('Please provide a rejection reason.');
                return;
            }

            const accordion = document.querySelector(`[id*="${currentActionUser}"]`).closest('.accordion-item');
            const checkedBoxes = accordion.querySelectorAll('input.call-checkbox:checked');
            const verificationIds = [];

            checkedBoxes.forEach(checkbox => {
                verificationIds.push(checkbox.dataset.verificationId);
            });

            // Submit to server
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=Reject';

            // Add anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;
            form.appendChild(tokenInput);

            // Add verification IDs
            verificationIds.forEach(id => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'verificationIds';
                input.value = id;
                form.appendChild(input);
            });

            // Add reason
            const reasonInput = document.createElement('input');
            reasonInput.type = 'hidden';
            reasonInput.name = 'rejectionReason';
            reasonInput.value = reason;
            form.appendChild(reasonInput);

            document.body.appendChild(form);
            form.submit();
        }

        // Revert Selected
        function revertSelected(userIndexNumber) {
            currentActionUser = userIndexNumber;
            const accordion = document.querySelector(`[id*="${userIndexNumber}"]`).closest('.accordion-item');
            const checkedBoxes = accordion.querySelectorAll('input.call-checkbox:checked');

            if (checkedBoxes.length === 0) {
                alert('Please select at least one call to revert.');
                return;
            }

            document.getElementById('revertModalCount').textContent = checkedBoxes.length;
            document.getElementById('revertReason').value = '';

            const modal = new bootstrap.Modal(document.getElementById('revertModal'));
            modal.show();
        }

        // Submit revert
        function submitRevertModal() {
            const reason = document.getElementById('revertReason').value.trim();
            
            if (!reason) {
                alert('Please provide a revert reason.');
                return;
            }

            const accordion = document.querySelector(`[id*="${currentActionUser}"]`).closest('.accordion-item');
            const checkedBoxes = accordion.querySelectorAll('input.call-checkbox:checked');
            const verificationIds = [];

            checkedBoxes.forEach(checkbox => {
                verificationIds.push(checkbox.dataset.verificationId);
            });

            // Submit to server
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '?handler=Revert';

            // Add anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const tokenInput = document.createElement('input');
            tokenInput.type = 'hidden';
            tokenInput.name = '__RequestVerificationToken';
            tokenInput.value = token;
            form.appendChild(tokenInput);

            // Add verification IDs
            verificationIds.forEach(id => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'verificationIds';
                input.value = id;
                form.appendChild(input);
            });

            // Add reason
            const reasonInput = document.createElement('input');
            reasonInput.type = 'hidden';
            reasonInput.name = 'revertReason';
            reasonInput.value = reason;
            form.appendChild(reasonInput);

            document.body.appendChild(form);
            form.submit();
        }

        // Initialize on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateSelectionSummary();

            // Handle filter collapse icon rotation
            const filtersCollapse = document.getElementById('filtersCollapse');
            const chevronIcon = document.querySelector('[data-bs-target="#filtersCollapse"] .bi-chevron-down');

            if (filtersCollapse && chevronIcon) {
                filtersCollapse.addEventListener('show.bs.collapse', function() {
                    chevronIcon.style.transform = 'rotate(180deg)';
                    chevronIcon.style.transition = 'transform 0.3s ease';
                });

                filtersCollapse.addEventListener('hide.bs.collapse', function() {
                    chevronIcon.style.transform = 'rotate(0deg)';
                    chevronIcon.style.transition = 'transform 0.3s ease';
                });
            }

            // Handle dialed number collapse chevron rotation
            document.querySelectorAll('.dialed-number-header').forEach(header => {
                const targetId = header.getAttribute('data-bs-target');
                if (targetId) {
                    const collapseEl = document.querySelector(targetId);
                    const chevron = header.querySelector('.dialed-chevron');
                    if (collapseEl && chevron) {
                        collapseEl.addEventListener('show.bs.collapse', function() {
                            chevron.style.transform = 'rotate(90deg)';
                        });
                        collapseEl.addEventListener('hide.bs.collapse', function() {
                            chevron.style.transform = 'rotate(0deg)';
                        });
                    }
                }
            });
        });
    </script>
}

