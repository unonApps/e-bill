@model string

@* Detail Header Row (Level 2) - Hidden by default *@
<tr class="call-detail-row call-detail-header" data-group="@Model" style="display: none; background-color: #e9ecef; font-weight: 600;">
    <th class="px-2 py-2 text-center" style="font-size: 11px;"><i class="bi bi-check-square"></i></th>
    <th class="px-2 py-2" style="font-size: 11px;"></th>
    <th class="px-2 py-2" style="font-size: 11px;">DIALLED NUMBER</th>
    <th class="px-2 py-2" style="font-size: 11px;">ASSIGNMENT</th>
    <th class="px-2 py-2" style="font-size: 11px;">DURATION</th>
    <th class="px-2 py-2" style="font-size: 11px;">KSH</th>
    <th class="px-2 py-2" style="font-size: 11px;">USD</th>
    <th class="px-2 py-2" style="font-size: 11px;">DESTINATION</th>
    <th class="px-2 py-2 text-center" style="font-size: 11px;">STATUS</th>
    <th class="px-2 py-2 text-center" style="font-size: 11px;">ACTION</th>
</tr>
