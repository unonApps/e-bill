@model (string GroupId, string DialedGroupId, string DialedNumber, string Destination, int CallCount, decimal TotalCostUSD, decimal TotalCostKSH, decimal TotalDuration, string AssignmentStatus, string MonthName, int Year)

@* Dialed Number Summary Row (Level 2) - Hidden by default, shown when extension is expanded *@
<tr class="call-detail-row dialed-number-summary-row" data-group="@Model.GroupId" data-dialed-group="@Model.DialedGroupId" style="display: none; background-color: #f0f8ff; font-weight: 500;">
    <td class="px-2 py-2 text-center"></td>
    <td class="text-center px-2 py-2" onclick="toggleDialedNumberDetails('@Model.DialedGroupId')" style="cursor: pointer;">
        <i class="bi bi-plus-circle text-info toggle-icon-dialed" id="toggle-dialed-@Model.DialedGroupId"></i>
    </td>
    <td class="px-3 py-2" onclick="toggleDialedNumberDetails('@Model.DialedGroupId')" style="cursor: pointer;">
        <div class="d-flex flex-column">
            <strong style="color: #0066cc;">@Model.DialedNumber</strong>
            @if (!string.IsNullOrEmpty(Model.Destination))
            {
                <small class="text-muted">@Model.Destination</small>
            }
        </div>
    </td>
    <td class="px-3 py-2" onclick="toggleDialedNumberDetails('@Model.DialedGroupId')" style="cursor: pointer;">
        @if (Model.AssignmentStatus == "Mixed")
        {
            <span class="badge bg-secondary bg-opacity-10 text-secondary" style="font-size: 0.75rem;">
                <i class="bi bi-dash-circle me-1"></i>Mixed
            </span>
        }
        else if (Model.AssignmentStatus == "Official")
        {
            <span class="badge bg-success bg-opacity-10 text-success" style="font-size: 0.75rem;">
                <i class="bi bi-briefcase me-1"></i>Official
            </span>
        }
        else if (Model.AssignmentStatus == "Personal")
        {
            <span class="badge bg-warning bg-opacity-10 text-warning" style="font-size: 0.75rem;">
                <i class="bi bi-person me-1"></i>Personal
            </span>
        }
        else
        {
            <span class="badge bg-light text-muted" style="font-size: 0.75rem;">
                <i class="bi bi-circle me-1"></i>Unverified
            </span>
        }
    </td>
    <td class="px-3 py-2 text-center" onclick="toggleDialedNumberDetails('@Model.DialedGroupId')" style="cursor: pointer;">
        <span class="badge bg-info bg-opacity-10 text-info">@Model.CallCount calls</span>
    </td>
    <td class="px-3 py-2" onclick="toggleDialedNumberDetails('@Model.DialedGroupId')" style="cursor: pointer;">
        <strong style="color: #666;">KSh @Model.TotalCostKSH.ToString("N2")</strong>
    </td>
    <td class="px-3 py-2" onclick="toggleDialedNumberDetails('@Model.DialedGroupId')" style="cursor: pointer;">
        <strong style="color: #666;">$@Model.TotalCostUSD.ToString("N2")</strong>
    </td>
    <td class="px-3 py-2" onclick="toggleDialedNumberDetails('@Model.DialedGroupId')" style="cursor: pointer;">
        @{
            var hours = (int)(Model.TotalDuration / 60);
            var minutes = (int)(Model.TotalDuration % 60);
            var display = hours > 0 ? $"{hours}h {minutes}m" : $"{minutes}m";
        }
        <span class="text-muted">@display</span>
    </td>
    <td class="px-3 py-2 text-center">
        <div class="d-flex justify-content-center align-items-center gap-2">
            <small class="text-info" style="font-size: 0.75rem; cursor: pointer;" onclick="toggleDialedNumberDetails('@Model.DialedGroupId')">
                <i class="bi bi-chevron-down me-1"></i>Click to view calls
            </small>
            <a href="/Modules/EBillManagement/CallRecords/Verify?dialedNumber=@Uri.EscapeDataString(Model.DialedNumber)&month=@Model.MonthName&year=@Model.Year"
               class="btn btn-sm btn-outline-primary"
               style="font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 6px;"
               title="View and verify all calls to this number for @Model.MonthName @Model.Year">
                <i class="bi bi-eye me-1"></i>View Details
            </a>
        </div>
    </td>
    <td class="px-3 py-2 text-end">
        <div class="d-flex gap-2 align-items-center justify-content-end">
            <button type="button"
                    class="btn btn-success btn-sm"
                    style="font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 6px;"
                    onclick="verifyAllDialedNumber('@Model.DialedGroupId', 'Official')"
                    title="Mark all calls to this number as Official">
                <i class="bi bi-briefcase me-1"></i>All Official
            </button>
            <button type="button"
                    class="btn btn-warning btn-sm"
                    style="font-size: 0.7rem; padding: 0.2rem 0.5rem; border-radius: 6px;"
                    onclick="verifyAllDialedNumber('@Model.DialedGroupId', 'Personal')"
                    title="Mark all calls to this number as Personal">
                <i class="bi bi-person me-1"></i>All Personal
            </button>
        </div>
    </td>
</tr>
